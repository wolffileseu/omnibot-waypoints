		textalign		ITEM_ALIGN_LEFT
		text			"^2 4. Debug Goal Availability"
		decoration
	}
	execKey "4" { exec "bot dbg_goalavailability";	exec "echo ^4Debug Map Availability ^2On^7/^1Off ^5-Check Console-" }

	itemDef {
		name			"window"
		visible			1
		rect			10 104 128 16
		origin			ORIGIN_QUICKMESSAGE
		forecolor		1 1 1 1
		backcolor		0 0 0 0
		textfont	UI_FONT_NORMAL
		textscale	.22
		textalign		ITEM_ALIGN_LEFT
		text			"^2 5. Draw Paththrough On"
		decoration
	}
	execKey "5" { exec "bot draw_paththrough 1";	exec "echo ^4Draw Paththrough ^2On" }

	itemDef {
		name			"window"
		visible			1
		rect			10 120 128 16
		origin			ORIGIN_QUICKMESSAGE
		forecolor		1 1 1 1
		backcolor		0 0 0 0
		textfont	UI_FONT_NORMAL
		textscale	.22
		textalign		ITEM_ALIGN_LEFT
		text			"^2 6. Draw Paththrough Off"
		decoration
		group			ingamebox
	}
	execKey "6" { exec "bot draw_paththrough 0";	exec "echo ^4Draw Paththrough ^1Off" }
	
	itemDef {
		name			"window"
		visible			1
		rect			10 136 128 16
		origin			ORIGIN_QUICKMESSAGE
		forecolor		1 1 1 1
		backcolor		0 0 0 0
		textfont	UI_FONT_NORMAL
		textscale	.22
		textalign		ITEM_ALIGN_LEFT
		text			"^2 7. StopMovers On (^7Req Cheats On^2)"
		decoration
		group			ingamebox
	}
	execKey "7" { exec "g_stopmovers 1";		exec "echo ^4StopMovers ^2On" }
	
	itemDef {
		name			"window"
		visible			1
		rect			10 152 128 16
		origin			ORIGIN_QUICKMESSAGE
		forecolor		1 1 1 1
		backcolor		0 0 0 0
		textfont	UI_FONT_NORMAL
		textscale	.22
		textalign		ITEM_ALIGN_LEFT
		text			"^2 8. StopMovers Off (^7Req Cheats On^2)"
		decoration
		group			ingamebox
	}
	execKey "8" { exec "g_stopmovers 1";		exec "echo ^4StopMovers ^2On" }
	
	itemDef {
		name			"window"
		visible			1
		rect			10 166 128 16
		origin			ORIGIN_QUICKMESSAGE
		forecolor		1 1 1 1
		backcolor		0 0 0 0
		textfont	UI_FONT_NORMAL
		textscale	.22
		textalign		ITEM_ALIGN_LEFT
		text			"^2 9. View MaxInUse/Progress"
		decoration
		group			ingamebox
	}
	execKey "9" { exec "bot sag 0 0 1";	exec "echo ^4Showing MaxInUse/Progres ^5-Check Console-" }

	itemDef {
		name			"window"
		visible			1
		rect			10 262 128 16
		origin			ORIGIN_QUICKMESSAGE
		forecolor		1 1 1 1
		backcolor		0 0 0 0
		textfont	UI_FONT_NORMAL
		textscale	.22
		textalign		ITEM_ALIGN_LEFT
		text			"^7 V. Back Z. Close"
		decoration
		group			ingamebox
	}
	execKey "v" { close wm_debug_alt; open wm_quickmessageAlt }
	execKey "z" { close wm_debug_alt }
}


