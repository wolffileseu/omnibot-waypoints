global Map =
{
	Debug = 1, // please set to zero before distributing your script

	Sea_Wall_breach_Destroyed = function( trigger )
	{
		Util.MapDebugPrint( "Sea_Wall_breach_Destroyed" );
	},

	Sea_Wall_door_Destroyed = function( trigger )
	{
		Util.MapDebugPrint( "Sea_Wall_door_Destroyed" );
	},

	submarine_Destroyed = function( trigger )
	{
		Util.MapDebugPrint( "submarine_Destroyed" );
	},

	submarine_comm_Destroyed = function( trigger )
	{
		Util.MapDebugPrint( "submarine_comm_Destroyed" );
	},

	War_Documents_Taken = function( trigger )
	{
		Util.MapDebugPrint( "War_Documents_Taken" );
	},

	beach_flag_Axis_Captured = function( trigger )
	{
		Util.MapDebugPrint( "beach_flag_Axis_Captured" );
	},

	beach_flag_Allies_Captured = function( trigger )
	{
		Util.MapDebugPrint( "beach_flag_Allies_Captured" );
	},

};

global OnMapLoad = function()
{
	// Register callback functions
	OnTrigger( "MISSING_STRING", Map.Sea_Wall_breach_Destroyed );
	OnTrigger( "MISSING_STRING", Map.Sea_Wall_door_Destroyed );
	OnTrigger( "MISSING_STRING", Map.submarine_Destroyed );
	OnTrigger( "MISSING_STRING", Map.submarine_comm_Destroyed );
	OnTrigger( "MISSING_STRING", Map.War_Documents_Taken );
	OnTrigger( "MISSING_STRING", Map.beach_flag_Axis_Captured );
	OnTrigger( "MISSING_STRING", Map.beach_flag_Allies_Captured );

	//~Util.DisableGoal( ".*", true ); // all but routes
	//~SetAvailableMapGoals( TEAM.AXIS, true, "ATTACK_.*" );
	//~SetAvailableMapGoals( TEAM.ALLIES, true, "ATTACK_.*" );


	Util.MapDebugPrint( "Omni-bot map script for " + GetMapName() + " executed." );
};

