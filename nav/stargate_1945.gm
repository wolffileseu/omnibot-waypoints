	Allies_Win = function()
	{
		Util.MapDebugPrint("Allies_Win");
		
		ETUtil.WinningChat( TEAM.ALLIES );
		ETUtil.LosingChat( TEAM.AXIS );
	},

	SouthBaseMG_Fixed = function( trigger )
	{
		Map.South_Base_MG_Fixed = true;
        
        Util.MapDebugPrint( "SouthBaseMG_Fixed" );
	},
	
	Wall_Destroyed = function( trigger )
	{
		Map.WallDestroyed = true;

		Util.MapDebugPrint( "Wall_Destroyed" );
	},
	
	Waypoint_Biconnect = function ( guid1, guid2 )
	{
		Wp.Connect(guid1,guid2);
		Wp.Connect(guid2,guid1);
	},
	
	Waypoint_Bi_Disconnect = function (guid1, guid2)
	{
		Wp.Disconnect(guid1,guid2);
		Wp.Disconnect(guid2,guid1);
	},
	
	Waypoint_Connect = function()
	{
		Map.Waypoint_Biconnect(395, 316);
		Map.Waypoint_Biconnect(395, 319);
		Map.Waypoint_Biconnect(395, 320);
		Map.Waypoint_Biconnect(396, 321);
		Map.Waypoint_Biconnect(396, 322);
		Map.Waypoint_Biconnect(396, 317);
		Map.Waypoint_Biconnect(396, 316);
		Map.Waypoint_Biconnect(396, 319);
		Map.Waypoint_Biconnect(396, 320);
		Map.Waypoint_Biconnect(397, 321);
		Map.Waypoint_Biconnect(397, 322);
	},
	
	Waypoint_Disconnect = function()
	{
		Map.Waypoint_Bi_Disconnect(395, 316);
		Map.Waypoint_Bi_Disconnect(395, 319);
		Map.Waypoint_Bi_Disconnect(395, 320);
		Map.Waypoint_Bi_Disconnect(396, 321);
		Map.Waypoint_Bi_Disconnect(396, 322);
		Map.Waypoint_Bi_Disconnect(396, 317);
		Map.Waypoint_Bi_Disconnect(396, 316);
		Map.Waypoint_Bi_Disconnect(396, 319);
		Map.Waypoint_Bi_Disconnect(396, 320);
		Map.Waypoint_Bi_Disconnect(397, 321);
		Map.Waypoint_Bi_Disconnect(397, 322);
	},
};

