global Map =
{
	Debug = 0,
	South_Base_MG_Fixed = false,
	Allied_CP = false,
	Axis_CP = false,
	TankStolen = false,
	Depogate = true,
	South_base_MG = false,
	Tank = false,
	Tank_Barrier_1 = false,
	Truck = true,
	TruckStolen = false,
	TruckInTunnel = false,
	Truck_Barrier_1 = false,
	Elevator_Wall = true,
	Taken_Naquada = 0,
	Secured_Naquada = 0,
	WallDestroyed = false,
	TruckPastBarrier = false,
	TruckAtBarrier = false,
	TruckPastDepoGate = false,
	TankAtBarrier = false,
	TankPastBarrier = false,
	LeftSecurityDoorOpened = false,
	RightSecurityDoorOpened = false,
	LeftSecurityDoorClosing = false,
	RightSecurityDoorClosing = false,
	
	Roles =
	{
		AXIS =
		{
			AllBots = true, // each bot is considered for a role

			DEFENDER =
			{
				numbots = 5,
				crucialClass = CLASS.ENGINEER,
			},
			DEFENDER1 =
			{
				numbots = 5,
				crucialClass = CLASS.ENGINEER,
			},
			DEFENDER2 =
			{
				numbots = 5,
				crucialClass = CLASS.SOLDIER,
			},
			DEFENDER3 =
			{
				numbots = 5,
				crucialClass = CLASS.FIELDOPS,
			},
		},

		ALLIES =
		{
			AllBots = true, // each bot is considered for a role

			ATTACKER =
			{
				numbots = 5,
				crucialClass = CLASS.ENGINEER,
			},
			ATTACKER1 =
			{
				numbots = 5,
				crucialClass = CLASS.ENGINEER,
			},
			ATTACKER2 =
			{
				numbots = 5,
				crucialClass = CLASS.SOLDIER,
			},
			ATTACKER3 =
			{
				numbots = 5,
				crucialClass = CLASS.FIELDOPS,
			},
		},
	},
	
	Navigation =
	{
		//	/bot waypoint_setproperty paththrough Navigation_PT:jump
		jump =
		{
			navigate = function(_this)
			{
				_this.Bot.HoldButton(BTN.JUMP, 0.55);
				sleep(0.55);
			},
		},
		
		//	/bot waypoint_setproperty paththrough Navigation_PT:jump_wait
		jump_wait =
		{
			navigate = function(_this)
			{
				sleep(0.25);
				_this.Bot.HoldButton(BTN.JUMP, 0.55);
				sleep(0.55);
			},
		},
		
		//	/bot waypoint_setproperty paththrough Navigation_PT:wall_1
		wall_1 =
		{
			EvalFunc = function() // if this function returns false, navigation will not run
			{
				return !Map.WallDestroyed;
			},
			
			navigate = function(_this)
			{
				if ( Map.WallDestroyed )
				{
					yield();
					return;
				}
				
				_this.AddWeaponRequest(Priority.High, WEAPON.KNIFE);
				_this.AddAimRequest(Priority.High, "facing", Vector3(-0.985, -0.127, 0.119));
				
				while( !Map.WallDestroyed )
				{
					_this.Bot.HoldButton(BTN.ATTACK1, 1);
					yield();
				}
				
				_this.ReleaseAimRequest();
				_this.ReleaseWeaponRequest();
			},
		},
		
		//	/bot waypoint_setproperty paththrough Navigation_PT:wall_2
		wall_2 =
		{
			EvalFunc = function() // if this function returns false, navigation will not run
			{
				return !Map.WallDestroyed;
			},
			
			navigate = function(_this)
			{
				if ( Map.WallDestroyed )
				{
					yield();
					return;
				}
				
				_this.AddWeaponRequest(Priority.High, WEAPON.KNIFE);
				_this.AddAimRequest(Priority.High, "facing", Vector3(0.857, 0.175, -0.485));
				
				while( !Map.WallDestroyed )
				{
					_this.Bot.HoldButton(BTN.ATTACK1, 1);
					yield();
				}
				
				_this.ReleaseAimRequest();
				_this.ReleaseWeaponRequest();
			},
		},
		
		//	/bot waypoint_setproperty paththrough Navigation_PT:wall_3
		wall_3 =
		{
			EvalFunc = function() // if this function returns false, navigation will not run
			{
				return !Map.WallDestroyed;
			},
			
			navigate = function(_this)
			{
				if ( Map.WallDestroyed )
				{
					yield();
					return;
				}
				
				_this.AddWeaponRequest(Priority.High, WEAPON.KNIFE);
				_this.AddAimRequest(Priority.High, "facing", Vector3(0.796, -0.485, -0.362));
				
				while( !Map.WallDestroyed )
				{
					_this.Bot.HoldButton(BTN.ATTACK1, 1);
					yield();
				}
				
				_this.ReleaseAimRequest();
				_this.ReleaseWeaponRequest();
			},
		},
	},

	Allied_CP_Built = function()
	{
		Map.Allied_CP = true;
		
		Util.MapDebugPrint("Allied_CP_Built");
		
		SetAvailableMapGoals( 0, false, "BUILD_Command_Post");
		
		if ( !Map.Elevator_Wall )
		{
			SetGoalRole( "PLANT_Command_Post", { ROLE.INFILTRATOR, ROLE.ATTACKER, ROLE.ATTACKER1, ROLE.ATTACKER2,  ROLE.ATTACKER3 });
		}
		
		SetAvailableMapGoals( TEAM.AXIS, true, "PLANT_Command_Post");
	},
	
	Allied_CP_Destroyed = function()
	{
		Map.Allied_CP = false;
		
		Util.MapDebugPrint("Allied_CP_Destroyed");
		
		SetAvailableMapGoals( TEAM.AXIS, false, "PLANT_Command_Post");
		
		ClearGoalRole( "PLANT_Command_Post", ROLE.INFILTRATOR );
		
		if ( !Map.TankStolen )
		{
			SetAvailableMapGoals( 0, true, "BUILD_Command_Post");
		}
		else
		{
			SetAvailableMapGoals( TEAM.ALLIES, true, "BUILD_Command_Post");
		}
	},

	Axis_CP_Built = function()
	{
		Map.Axis_CP = true;
		
		Util.MapDebugPrint("Axis_CP_Built");
		
		SetAvailableMapGoals( 0, false, "BUILD_Command_Post");
		
		SetAvailableMapGoals( TEAM.ALLIES, true, "PLANT_Command_Post");
	},

	Axis_CP_Destroyed = function()
	{
		Map.Axis_CP = false;
		
		Util.MapDebugPrint("Axis_CP_Destroyed");
		
		SetAvailableMapGoals( TEAM.ALLIES, false, "PLANT_Command_Post");
		
		if ( !Map.TankStolen )
		{
			SetAvailableMapGoals( 0, true, "BUILD_Command_Post");
		}
		else
		{
			SetAvailableMapGoals( TEAM.ALLIES, true, "BUILD_Command_Post");
		}
	},
	
	CP_Planted = function()
	{
		if ( Map.Allied_CP )
		{
			Util.MapDebugPrint("Allied_CP_Planted");
		}
		else
		{
			Util.MapDebugPrint("Axis_CP_Planted");
		}
	},
	
	Depogate_Planted = function()
	{
		Util.MapDebugPrint("Depogate_Planted");
		
		foreach( goal in Util.GoalTable("DEFUSE_Depogate.*") )
		{
			if ( !Map.TankStolen or Map.TruckPastBarrier )
			{
				pos1 = goal.GetPosition();
				if ( pos1.x > 796 )
				{
					goal.SetAvailable(TEAM.AXIS, false);
					Util.MapDebugPrint( "^5goal " + goal.GetName() + " is disabled" );
				}
				
				if ( Map.South_base_MG )
				{
					SetAvailableMapGoals( TEAM.AXIS, true, ".*MG42_South_base_MG" );
				}
				
				SetAvailableMapGoals( TEAM.ALLIES, true, "SMOKEBOMB_Allies_DepoGateDestr_.*" );
			}
			else
			{
				goal.SetAvailable(TEAM.AXIS, false);
				Util.MapDebugPrint( "^5goal " + goal.GetName() + " is disabled" );
			}
		}
	},

	Depogate_Defused = function()
	{
		Util.MapDebugPrint("Depogate_Defused");
		
		if ( !Map.TankStolen and tableCount(Util.GoalTable("DEFUSE_Depogate.*")) == 1 and Map.Depogate )
		{
			SetAvailableMapGoals( TEAM.AXIS, false, ".*MG42_South_base_MG" );
		}
	},
	
	Depogate_Destroyed = function()
	{
		Map.Depogate = false;
		
		Wp.SetWaypointFlag( "Left_Sentry_Box", "closed", true );
		
		Util.MapDebugPrint("Depogate_Destroyed");
		
		ClearGoalRole({ "PLANT_Command_Post", "BUILD_Command_Post", ".*MG42_South_base_MG" },
			{ ROLE.DEFENDER, ROLE.DEFENDER1, ROLE.DEFENDER2, ROLE.DEFENDER3, ROLE.OFFENSECAPTAIN });
		ClearGoalRole({ ".*_Allies_DepoGateDestr_.*", "BUILD_Tank", "ESCORT_Tank", "MOUNT_Tank", "PLANT_Tank_Barrier_1" }, ROLE.OFFENSECAPTAIN );
		
		DynamicPathsUpdated( TEAM.AXIS, TEAM.ALLIES );
		Wp.CheckBlockable();
		
		foreach( goal in Util.GoalTable("DEFUSE_Depogate.*") )
		{
			goal.SetAvailable(TEAM.AXIS, false);
		}
		
		SetAvailableMapGoals( TEAM.ALLIES, false, "PLANT_Depogate" );
		
		SetAvailableMapGoals( TEAM.AXIS, false, {
			".*MG42_t1",
			".*MG42_t1_1",
			".*_Axis_DepoGate_.*",
		});
		
		if ( !Map.TruckPastBarrier )
		{
			if ( !Map.TankStolen )
			{
				SetAvailableMapGoals( TEAM.AXIS, true, {
					"BUILD_Depogate",
					".*_Axis_DepoGateDestr_.*",
				});
				
				SetAvailableMapGoals( TEAM.ALLIES, false, {
					".*_Allies_DepoGate_.*",
					"GRENADE_Axis_MG42_.*",
				});
				
				SetAvailableMapGoals( TEAM.ALLIES, true, ".*_Allies_DepoGateDestr_.*" );
				
				if ( Map.South_base_MG )
				{
					SetAvailableMapGoals( TEAM.ALLIES, true, ".*MG42_South_base_MG" );
				}
				
				if ( !Map.Tank )
				{
					SetAvailableMapGoals( TEAM.ALLIES, true, "BUILD_Tank" );
				}
				else
				{
					SetAvailableMapGoals( TEAM.ALLIES, true, {
						"ESCORT_Tank",
						"MOUNT_Tank",
					});
				}
				
				if ( Map.Axis_CP )
				{
					SetAvailableMapGoals( TEAM.ALLIES, true, "PLANT_Command_Post" );
				}
				else
				{
					if ( !Map.Allied_CP )
					{
						SetAvailableMapGoals( TEAM.ALLIES, true, "BUILD_Command_Post" );
					}
				}
			}
		}
		else
		{
			if ( !Map.TruckPastDepoGate )
			{
				SetAvailableMapGoals( TEAM.AXIS, true, "BUILD_Depogate" );
			}
		}
		
		while ( !Map.Depogate and !Map.TankStolen )
		{
			if(GetEntFlags(GetGoal("MOUNTMG42_South_base_MG").GetEntity(), ENTFLAG.DEAD))
			{
				GetGoal("MOBILEMORTAR_Allies_DepoGateDestr_30").MortarAim = {Vec3(-0.790, 0.527, 0.313)};
				GetGoal("MOBILEMORTAR_Allies_DepoGateDestr_31").MortarAim = {Vec3(-0.927, 0.145, 0.347)};
			}
			else
			{
				GetGoal("MOBILEMORTAR_Allies_DepoGateDestr_30").MortarAim = {Vec3(-0.790, 0.527, 0.313), Vec3(-0.932, 0.258, 0.255)};
				GetGoal("MOBILEMORTAR_Allies_DepoGateDestr_31").MortarAim = {Vec3(-0.927, 0.145, 0.347), Vec3(-0.964, -0.056, 0.260)};
			}
			
			sleep(1);
		}
	},
	
	Depogate_Built = function()
	{
		Map.Depogate = true;
		
		Util.MapDebugPrint("Depogate_Built");
		
		DynamicPathsUpdated( TEAM.AXIS, TEAM.ALLIES );
		Wp.CheckBlockable();
		
		SetAvailableMapGoals( TEAM.AXIS, false, "BUILD_Depogate" );
		
		SetAvailableMapGoals( TEAM.ALLIES, true, "PLANT_Depogate" );
		
		if ( !Map.TruckStolen )
		{
			if ( !Map.TankStolen )
			{
				SetGoalRole({ "PLANT_Command_Post", "BUILD_Command_Post", ".*MG42_South_base_MG" },
					{ ROLE.DEFENDER, ROLE.DEFENDER1, ROLE.DEFENDER2, ROLE.DEFENDER3, ROLE.OFFENSECAPTAIN });
				SetGoalRole({ "ATTACK_Allies_DepoGateDestr_.*", "BUILD_Tank", "ESCORT_Tank", "MOUNT_Tank", "PLANT_Tank_Barrier_1" }, ROLE.OFFENSECAPTAIN );
				
				SetAvailableMapGoals( TEAM.ALLIES, false, {
					"MOBILEMORTAR_Allies_DepoGateDestr_.*",
					"SMOKEBOMB_Allies_DepoGateDestr_.*",
				});
				
				SetAvailableMapGoals( TEAM.ALLIES, true, {
					".*_Allies_DepoGate_.*",
					"GRENADE_Axis_MG42_.*",
				});
				
				SetAvailableMapGoals( TEAM.AXIS, false, {
					".*_Axis_DepoGateDestr_.*",
					".*MG42_South_base_MG",
				});
				
				SetAvailableMapGoals( TEAM.AXIS, true, {
					".*MG42_t1",
					".*MG42_t1_1",
					".*_Axis_DepoGate_.*",
				});
				
				SetAvailableMapGoals( TEAM.AXIS, false, "GRENADE_Axis_MG42_.*" );
			}
			else
			{
				Wp.SetWaypointFlag( "Left_Sentry_Box", "closed", false );
			}
		}
	},
	
	Behind_DepoGate =
	{
		Name = "Behind_DepoGate",
		TriggerOnClass = CLASS.ANYPLAYER,
		OnEnter = function(ent)
		{
			if ( GetEntTeam(ent) == TEAM.ALLIES )
			{
				bot = Util.IsBot(ent);
				if(bot){ bot.SetRoles(ROLE.OFFENSECAPTAIN); }
			}
		},
		OnExit = function(ent)
		{
			bot = Util.IsBot(ent);
			if(bot){ bot.ClearRoles(ROLE.OFFENSECAPTAIN); }
		},
	},
	
	South_base_MG_Built = function()
	{
		Map.South_base_MG = true;
		
		Util.MapDebugPrint("South_base_MG_Built");
		
		SetAvailableMapGoals( TEAM.AXIS, false, "BUILD_South_base_MG" );
		
		if ( !Map.TankStolen )
		{
			SetAvailableMapGoals( 0, true, ".*MG42_South_base_MG" );
		}
		
		if ( Map.TruckInTunnel )
		{
			SetAvailableMapGoals( TEAM.AXIS, true, ".*MG42_South_base_MG" );
		}
		
		if ( !Map.Depogate )
		{
			Util.MapDebugPrint("South_base_MG built & Depogate destroyed");
			
			GetGoal("MOBILEMORTAR_Allies_DepoGateDestr_30").MortarAim = {Vec3(-0.790, 0.527, 0.313), Vec3(-0.932, 0.258, 0.255)};
			GetGoal("MOBILEMORTAR_Allies_DepoGateDestr_31").MortarAim = {Vec3(-0.927, 0.145, 0.347), Vec3(-0.964, -0.056, 0.260)};
		}
	},

	South_base_MG_Destroyed = function()
	{
		Map.South_base_MG = false;
		
		Util.MapDebugPrint("South_base_MG_Destroyed");
		
		SetAvailableMapGoals( 0, false, ".*MG42_South_base_MG" );
		
		if ( !Map.Depogate )
		{
			Util.MapDebugPrint("South_base_MG Destroyed & Depogate destroyed");
			
			GetGoal("MOBILEMORTAR_Allies_DepoGateDestr_30").MortarAim = {Vec3(-0.790, 0.527, 0.313)};
			GetGoal("MOBILEMORTAR_Allies_DepoGateDestr_31").MortarAim = {Vec3(-0.927, 0.145, 0.347)};
		}
		
		if ( !Map.TankStolen or Map.TruckInTunnel )
		{
			SetAvailableMapGoals( TEAM.AXIS, true, "BUILD_South_base_MG" );
		}
	},

	Tank_Built = function()
	{
		Map.Tank = true;
		
		Util.MapDebugPrint("Tank_Built");
		
		SetAvailableMapGoals( TEAM.ALLIES, false, "BUILD_Tank" );
		
		if ( Map.Elevator_Wall )
		{
			SetAvailableMapGoals( TEAM.ALLIES, true, {
				"ESCORT_Tank",
				"MOUNT_Tank",
			});
		}
	},

	Tank_Stolen = function()
	{
		Util.MapDebugPrint("Tank_Stolen");
		
		Map.TankStolen = true;
		
		ClearGoalRole({ "PLANT_Command_Post", "BUILD_Command_Post", ".*MG42_South_base_MG" },
			{ ROLE.DEFENDER, ROLE.DEFENDER1, ROLE.DEFENDER2, ROLE.DEFENDER3, ROLE.OFFENSECAPTAIN });
		ClearGoalRole({ ".*_Allies_DepoGateDestr_.*", "BUILD_Tank", "ESCORT_Tank", "MOUNT_Tank", "PLANT_Tank_Barrier_1" }, ROLE.OFFENSECAPTAIN );
		
		foreach ( id and bot in BotTable )
		{
			bot.ClearRoles(ROLE.OFFENSECAPTAIN);
		}
		
		DeleteTriggerRegion("Behind_DepoGate");
		
		SetGoalPriority( ".*T_Tank", 0.79, TEAM.ALLIES, 0 );	//return to default priority
		
		if ( Map.Depogate )
		{
			Wp.SetWaypointFlag( "Left_Sentry_Box", "closed", false );
		}
		
		SetAvailableMapGoals( 0, false, {
			".*_DepoGate_.*",
			".*_DepoGateDestr_.*",
			".*MG42_South_base_MG",
		});
		
		SetAvailableMapGoals( TEAM.AXIS, false, {
			"BUILD_Depogate",
			"BUILD_South_base_MG",
			"BUILD_Command_Post",
			".*MG42_t.*",
		});
		
		SetAvailableMapGoals( TEAM.ALLIES, false, "GRENADE_Axis_MG42_.*" );
		
		SetAvailableMapGoals( TEAM.AXIS, true, {
			".*_Axis_TankStolen_.*",
			".*MG42_Elevators_.*",
			"DEFEND_Axis_TankPastBarrier_.*",
		});
		
		SetAvailableMapGoals( TEAM.ALLIES, true, "ATTACK_Allies_TankStolen_.*" );
		
		if ( Map.Tank_Barrier_1 )
		{
			SetAvailableMapGoals( TEAM.ALLIES, true, "PLANT_Tank_Barrier_1" );
		}
	},

	Tank_Destroyed = function()
	{
		Map.Tank = false;
		
		Util.MapDebugPrint("Tank_Destroyed");
		
		SetAvailableMapGoals( TEAM.ALLIES, false, {
			"ESCORT_Tank",
			"MOUNT_Tank",
		});
		
		if ( Map.Elevator_Wall and !Map.TankAtBarrier )
		{
			SetAvailableMapGoals( TEAM.ALLIES, true, "BUILD_Tank" );
		}
	},
	
	Tank_At_Barrier =
	{
		Name = "Tank_At_Barrier",
		TriggerOnEntity = GetGoal("MOVER_tank").GetEntity(),
		OnEnter = function(ent)
		{
			Util.MapDebugPrint( "Tank_At_Barrier" );
			
			Map.TankAtBarrier = true;
			
			SetAvailableMapGoals( TEAM.AXIS, true, "PLANTMINE_Axis_TankPastBarrier_.*" );
		},
		OnExit = function(ent)
		{
			
		},
	},
	
	Tank_Barrier_1_Built = function()
	{
		Map.Tank_Barrier_1 = true;
		
		Util.MapDebugPrint("Tank_Barrier_1_Built");
		
		SetAvailableMapGoals( TEAM.AXIS, false, "BUILD_Tank_Barrier_1" );
		
		SetAvailableMapGoals( TEAM.ALLIES, true, "PLANT_Tank_Barrier_1" );
		
		if ( !Map.Tank and Map.TankAtBarrier )
		{
			SetAvailableMapGoals( TEAM.ALLIES, false, "BUILD_Tank" );
		}
	},

	Tank_Barrier_1_Planted = function()
	{
		Util.MapDebugPrint("Tank_Barrier_1_Planted");
	},

	Tank_Barrier_1_Defused = function()
	{
		Util.MapDebugPrint("Tank_Barrier_1_Defused");
	},

	Tank_Barrier_1_Destroyed = function()
	{
		Map.Tank_Barrier_1 = false;
		
		Util.MapDebugPrint("Tank_Barrier_1_Destroyed");
		
		foreach( goal in Util.GoalTable("DEFUSE_Tank_Barrier_1_.*") )
		{
			goal.SetAvailable(TEAM.AXIS, false);
		}
		
		SetAvailableMapGoals( TEAM.ALLIES, false, "PLANT_Tank_Barrier_1" );
		
		if ( !Map.TankPastBarrier )
		{
			SetAvailableMapGoals( TEAM.AXIS, true, "BUILD_Tank_Barrier_1" );
		}
		
		if ( !Map.Tank and Map.TankAtBarrier )
		{
			SetAvailableMapGoals( TEAM.ALLIES, true, "BUILD_Tank" );
		}
	},
	
	Tank_Past_Barrier =
	{
		Name = "Tank_Past_Barrier",
		TriggerOnEntity = GetGoal("MOVER_tank").GetEntity(),
		OnEnter = function(ent)
		{
			Util.MapDebugPrint( "Tank_Past_Barrier" );
			
			Map.TankAtBarrier = false;
			Map.TankPastBarrier = true;
			
			SetGoalPriority( "PLANTMINE_Axis_TankPastBarrier_.*", 0.79, TEAM.AXIS, 0 );	//return to default value
			
			SetAvailableMapGoals( 0, false, ".*_TankStolen_.*" );
			
			SetAvailableMapGoals( TEAM.AXIS, false, "BUILD_Tank_Barrier_1" );
			
			SetAvailableMapGoals( TEAM.AXIS, true, ".*_Axis_TankPastBarrier_.*" );

			SetAvailableMapGoals( TEAM.ALLIES, true, ".*_Allies_TankPastBarrier_.*" );
			
			if ( !Map.Truck_Barrier_1 and !Map.TruckPastBarrier )
			{
				SetAvailableMapGoals( TEAM.AXIS, true, "BUILD_Truck_Barrier_1" );
			}
		},
		OnExit = function(ent)
		{
			
		},
	},
	
	Tank_Near_Wall =
	{
		Name = "Tank_Near_Wall",
		TriggerOnEntity = GetGoal("MOVER_tank").GetEntity(),
		OnEnter = function(ent)
		{
			Wp.SetWaypointFlag( "Near_Wall", "closed", true );
			
			Util.MapDebugPrint( "Tank_Near_Wall" );
		},
		OnExit = function(ent)
		{
			
		},
	},
	
	Tank_Past_Wall =
	{
		Name = "Tank_Past_Wall",
		TriggerOnEntity = GetGoal("MOVER_tank").GetEntity(),
		OnEnter = function(ent)
		{
			Wp.SetWaypointFlag( "Near_Wall", "closed", false );
			
			Util.MapDebugPrint( "Tank_Past_Wall" );
		},
		OnExit = function(ent)
		{
			
		},
	},
	
	Elevator_Wall_Destroyed = function()
	{
		Map.Elevator_Wall = false;
		
		Wp.SetWaypointFlag( "Elevator_Ladder_1", "closed", false );
		Wp.SetWaypointFlag( "Elevator_Ladder_2", "closed", false );
		
		Util.MapDebugPrint("Elevator_Wall_Destroyed");
		
		DynamicPathsUpdated( TEAM.AXIS, TEAM.ALLIES );
		Wp.CheckBlockable();
		
		Util.ChangeCrucialClassForRole( TEAM.AXIS, ROLE.DEFENDER3, CLASS.SOLDIER );
		
		SetAvailableMapGoals( 0, false, ".*_TankPastBarrier_.*" );
		
		SetAvailableMapGoals( TEAM.AXIS, false, ".*MG42_Elevators_.*" );
		
		SetAvailableMapGoals( TEAM.ALLIES, false, ".*_Tank" );
		
		foreach ( id and bot in BotTable )
		{
			bot.IgnoreTarget( "MOVER_tank", 9999 );
		}
		
		if ( Map.Allied_CP )
		{
			SetGoalRole( "PLANT_Command_Post", { ROLE.INFILTRATOR, ROLE.ATTACKER, ROLE.ATTACKER1, ROLE.ATTACKER2,  ROLE.ATTACKER3 });
		}
		
		if ( !Map.Truck and ( !Map.Truck_Barrier_1 or !Map.TruckAtBarrier ))
		{
			SetAvailableMapGoals( TEAM.ALLIES, true, "BUILD_Truck" );
		}
		
		if ( Map.Truck_Barrier_1 )
		{
			SetAvailableMapGoals( TEAM.ALLIES, true, "PLANT_Truck_Barrier_1" );
		}
		
		if ( Map.Taken_Naquada < 2 )
		{
			Map.Naquada_Room_goals();
		}
	},
	
	Left_Security_Door_Opened = function( trigger )
	{
		if ( !Map.LeftSecurityDoorOpened )	//for reduce multiple announcement (3x)
		{
			Map.LeftSecurityDoorOpened = true;
			
			Util.MapDebugPrint( "Left_Security_Door_Opened" );
			
			Wp.CheckBlockable();
			
			DeleteTriggerRegion("Stargate_room");
			foreach ( id and bot in BotTable )
			{
				if(bot){ bot.ClearRoles(ROLE.ROAMER); }
			}
			
			SetAvailableMapGoals( 0, false, {
				"CAMP_Inside_NaquadaRoom_.*",
				"CAPPOINT_Fake_.*",
			});
			
			SetAvailableMapGoals( TEAM.AXIS, false, "DEFEND_Axis_Bottom_SwitchRoom_.*" );
			
			if ( Map.RightSecurityDoorOpened )
			{
				SetAvailableMapGoals( TEAM.ALLIES, false, "SWITCH_.*_Door" );
			}
			else
			{
				SetAvailableMapGoals( TEAM.ALLIES, false, "SWITCH_Left_Door" );
				
				Util.SetMaxUsers( 2, "SWITCH_.*" );
			}
			
			if ( Map.Taken_Naquada < 2 )
			{
				SetAvailableMapGoals( TEAM.AXIS, false, "MOBILEMG42_Axis_Bottom_LeftSide_.*" );
				
				SetAvailableMapGoals( TEAM.AXIS, true, {
					"DEFEND_Axis_Bottom_LeftSide_.*",
					".*_Axis_Bottom_RightSide_.*",
					".*_Axis_Bottom_LeftSideOpened_.*",
					".*_Axis_NaquadaRoom_.*",
				});
				
				SetAvailableMapGoals( TEAM.ALLIES, true, "FLAG_Naquada" );
			}
			
			sleep(190);	//door is open for 200 sec
			
			Map.LeftSecurityDoorClosing = true;
			Util.MapDebugPrint( "Left security door will be closed" );
			
			if ( Map.RightSecurityDoorClosing or !Map.RightSecurityDoorOpened )
			{
				SetAvailableMapGoals( TEAM.AXIS, false, {
					".*_Axis_Bottom_LeftSideOpened_.*",
					".*_Axis_NaquadaRoom_.*",
				});
				
				SetAvailableMapGoals( TEAM.ALLIES, false, "FLAG_Naquada" );
				
				if ( Map.Taken_Naquada < 2 )
				{
					SetAvailableMapGoals( TEAM.AXIS, true, {
						"DEFEND_Axis_Bottom_SwitchRoom_.*",
						".*_Axis_Bottom_LeftSide_.*",
						".*_Axis_Bottom_RightSide_.*",
					});
				}
			}
		}
	},
	
	Left_Security_Door_Closed = function( trigger )
	{
		if ( Map.LeftSecurityDoorOpened )	//for reduce multiple announcement (3x)
		{
			Map.LeftSecurityDoorOpened = false;
			Map.LeftSecurityDoorClosing = false;
			
			Wp.CheckBlockable();
			
			Util.MapDebugPrint( "Left_Security_Door_Closed" );
			
			if ( !Map.RightSecurityDoorOpened )
			{
				OnTriggerRegion(AABB(-2208.875,3615.125,1.125,-1503.125,4508.875,327.883), Map.Stargate_room);
				
				Util.SetMaxUsers( 4, "SWITCH_.*" );
				
				SetAvailableMapGoals( TEAM.AXIS, false, {
					".*_Axis_Bottom_LeftSideOpened_.*",
					".*_Axis_NaquadaRoom_.*",
				});
				
				SetAvailableMapGoals( TEAM.ALLIES, false, "FLAG_Naquada" );
				
				yield();
				
				if ( !Map.LeftSecurityDoorOpened and !Map.RightSecurityDoorOpened )
				{
					SetAvailableMapGoals( 0, true, {
						"CAMP_Inside_NaquadaRoom_.*",
						"CAPPOINT_Fake_.*",
					});
				}
			}
			
			if ( Map.Taken_Naquada < 2 )
			{
				SetAvailableMapGoals( TEAM.ALLIES, true, {
					"SWITCH_Left_Door",
					"ATTACK_Allies_Bottom_SwitchRoom_.*",
				});
			}
		}
	},
	
	Right_Security_Door_Opened = function( trigger )
	{
		if ( !Map.RightSecurityDoorOpened )	//for reduce multiple announcement (3x)
		{
			Map.RightSecurityDoorOpened = true;
			
			Util.MapDebugPrint( "Right_Security_Door_Opened" );
			
			Wp.CheckBlockable();
			
			DeleteTriggerRegion("Stargate_room");
			foreach ( id and bot in BotTable )
			{
				if(bot){ bot.ClearRoles(ROLE.ROAMER); }
			}
			
			SetAvailableMapGoals( 0, false, {
				"CAMP_Inside_NaquadaRoom_.*",
				"CAPPOINT_Fake_.*",
			});
			
			SetAvailableMapGoals( TEAM.AXIS, false, "DEFEND_Axis_Bottom_SwitchRoom_.*" );
			
			if ( Map.LeftSecurityDoorOpened )
			{
				SetAvailableMapGoals( TEAM.ALLIES, false, "SWITCH_.*_Door" );
			}
			else
			{
				SetAvailableMapGoals( TEAM.ALLIES, false, "SWITCH_Right_Door" );
				
				Util.SetMaxUsers( 2, "SWITCH_.*" );
			}
			
			if ( Map.Taken_Naquada < 2 )
			{
				SetAvailableMapGoals( TEAM.AXIS, false, "MOBILEMG42_Axis_Bottom_RightSide_.*" );
				
				SetAvailableMapGoals( TEAM.AXIS, true, {
					".*_Axis_Bottom_LeftSide_.*",
					"DEFEND_Axis_Bottom_RightSide_.*",
					".*_Axis_Bottom_RightSideOpened_.*",
					".*_Axis_NaquadaRoom_.*",
				});
				
				SetAvailableMapGoals( TEAM.ALLIES, true, "FLAG_Naquada" );
			}
			
			sleep(190);	//door is open for 200 sec
			
			Map.RightSecurityDoorClosing = true;
			Util.MapDebugPrint( "Right security door will be closed" );
			
			if ( Map.LeftSecurityDoorClosing or !Map.LeftSecurityDoorOpened )
			{
				SetAvailableMapGoals( TEAM.AXIS, false, {
					".*_Axis_Bottom_RightSideOpened_.*",
					".*_Axis_NaquadaRoom_.*",
				});
				
				SetAvailableMapGoals( TEAM.ALLIES, false, "FLAG_Naquada" );
				
				if  ( Map.Taken_Naquada < 2 )
				{
					SetAvailableMapGoals( TEAM.AXIS, true, {
						"DEFEND_Axis_Bottom_SwitchRoom_.*",
						".*_Axis_Bottom_LeftSide_.*",
						".*_Axis_Bottom_RightSide_.*",
					});
				}
			}
		}
	},
	
	Right_Security_Door_Closed = function( trigger )
	{
		if ( Map.RightSecurityDoorOpened )	//for reduce multiple announcement (3x)
		{
			Map.RightSecurityDoorOpened = false;
			Map.RightSecurityDoorClosing = false;
			
			Wp.CheckBlockable();
			
			Util.MapDebugPrint( "Right_Security_Door_Closed" );
			
			if ( !Map.LeftSecurityDoorOpened )
			{
				OnTriggerRegion(AABB(-2208.875,3615.125,1.125,-1503.125,4508.875,327.883), Map.Stargate_room);
				
				Util.SetMaxUsers( 4, "SWITCH_.*" );
				
				SetAvailableMapGoals( TEAM.AXIS, false, {
					".*_Axis_Bottom_RightSideOpened_.*",
					".*_Axis_NaquadaRoom_.*",
				});
				
				SetAvailableMapGoals( TEAM.ALLIES, false, "FLAG_Naquada" );
				
				yield();
				
				if ( !Map.LeftSecurityDoorOpened and !Map.RightSecurityDoorOpened )
				{
					SetAvailableMapGoals( 0, true, {
						"CAMP_Inside_NaquadaRoom_.*",
						"CAPPOINT_Fake_.*",
					});
				}
			}
			
			if ( Map.Taken_Naquada < 2 )
			{
				SetAvailableMapGoals( TEAM.ALLIES, true, {
					"SWITCH_Right_Door",
					"ATTACK_Allies_Bottom_SwitchRoom_.*",
				});
			}
		}
	},
	
	Naquada_Room_goals = function()
	{
		if ( !Map.LeftSecurityDoorOpened and !Map.RightSecurityDoorOpened )
		{
			SetAvailableMapGoals( TEAM.AXIS, true, {
				"DEFEND_Axis_Bottom_SwitchRoom_.*",
				".*_Axis_Bottom_LeftSide_.*",
				".*_Axis_Bottom_RightSide_.*",
			});
			
			SetAvailableMapGoals( TEAM.ALLIES, true, {
				"SWITCH_.*_Door",
				"ATTACK_Allies_Bottom_SwitchRoom_.*",
			});

			if ( !Map.RightSecurityDoorOpened )
			{
				SetAvailableMapGoals( TEAM.ALLIES, true, {
					"SWITCH_Right_Door",
					"ATTACK_Allies_Bottom_SwitchRoom_.*",
				});
			}
			
			Util.MapDebugPrint("Security doors closed");
		}
		else
		{
			SetAvailableMapGoals( TEAM.AXIS, false, "DEFEND_Axis_Bottom_SwitchRoom_.*" );
			
			SetAvailableMapGoals( TEAM.AXIS, true, ".*_Axis_NaquadaRoom_.*" );
			
			SetAvailableMapGoals( TEAM.ALLIES, true, "FLAG_Naquada" );
			
			if ( Map.LeftSecurityDoorOpened and !Map.LeftSecurityDoorClosing and !Map.RightSecurityDoorOpened )
			{
				SetAvailableMapGoals( TEAM.AXIS, true, {
					"DEFEND_Axis_Bottom_LeftSide_.*",
					".*_Axis_Bottom_RightSide_.*",
					".*_Axis_Bottom_LeftSideOpened_.*",
				});
				
				SetAvailableMapGoals( TEAM.ALLIES, true, {
					"SWITCH_Right_Door",
					"ATTACK_Allies_Bottom_SwitchRoom_.*",
				});
				
				Util.MapDebugPrint("LeftSecurityDoorOpened and !LeftSecurityDoorClosing and !RightSecurityDoorOpened");
			}
			else if ( Map.RightSecurityDoorOpened and !Map.RightSecurityDoorClosing and !Map.LeftSecurityDoorOpened )
			{
				SetAvailableMapGoals( TEAM.AXIS, true, {
					".*_Axis_Bottom_LeftSide_.*",
					"DEFEND_Axis_Bottom_RightSide_.*",
					".*_Axis_Bottom_RightSideOpened_.*",
				});
				
				SetAvailableMapGoals( TEAM.ALLIES, true, {
					"SWITCH_Left_Door",
					"ATTACK_Allies_Bottom_SwitchRoom_.*",
				});
				
				Util.MapDebugPrint("RightSecurityDoorOpened and !RightSecurityDoorClosing and !LeftSecurityDoorOpened");
			}
			else if ( Map.LeftSecurityDoorOpened and !Map.LeftSecurityDoorClosing and Map.RightSecurityDoorOpened and !Map.RightSecurityDoorClosing )
			{
				SetAvailableMapGoals( TEAM.AXIS, true, {
					"DEFEND_Axis_Bottom_LeftSide_.*",
					"DEFEND_Axis_Bottom_RightSide_.*",
					".*_Axis_Bottom_.*SideOpened_.*",
				});
				
				Util.MapDebugPrint("LeftSecurityDoorOpened and !LeftSecurityDoorClosing and RightSecurityDoorOpened and !RightSecurityDoorClosing");
			}
		}
	},
	
	Stargate_room =
	{
		Name = "Stargate_room",
		TriggerOnClass = CLASS.ANYPLAYER,
		OnEnter = function(ent)
		{
			bot = Util.IsBot(ent);
			if(bot){ bot.SetRoles(ROLE.ROAMER); }
			
			sleep(60);
			
			if ( !Map.LeftSecurityDoorOpened and !Map.RightSecurityDoorOpened )
			{
				foreach ( id and bot in BotTable )
				{
					if ( bot.HasRole(ROLE.ROAMER) )
					{
					  bot.ExecCommand( "kill" );
					  Util.MapDebugPrint( "selfkill: " + GetEntName(ent) );
					}
				}
			}
		},
		OnExit = function(ent)
		{
			bot = Util.IsBot(ent);
			if(bot){ bot.ClearRoles(ROLE.ROAMER); }
		},
	},
	
	Naquada_Taken = function()
	{
		Map.Taken_Naquada += 1;
		
		Util.MapDebugPrint("Naquada_Taken");
		
		if ( !Map.Elevator_Wall )
		{
			if ( Map.Taken_Naquada == 2 )
			{
				SetAvailableMapGoals( TEAM.AXIS, false, {
					".*_Axis_Bottom_.*",
					".*_Axis_NaquadaRoom_.*",
				});
				
				SetAvailableMapGoals( TEAM.ALLIES, false, {
					"FLAG_Naquada",
					".*_Allies_Bottom_.*",
				});
			}
			
			SetAvailableMapGoals( TEAM.ALLIES, true, {
				"CAPPOINT_Truck",
				"DEFEND_Allies_Truck_.*",
				"ATTACK_Allies_NaquadaTaken_.*",
			});
			
			SetAvailableMapGoals( TEAM.AXIS, true, {
				"ATTACK_Axis_Truck_.*",
				".*MG42_Elevators_.*",
			});
		}
	},

	Naquada_Dropped = function()
	{
		Map.Taken_Naquada -= 1;
		
		Util.MapDebugPrint("Naquada_Dropped");
	},

	Naquada_Returned = function()
	{
		Util.MapDebugPrint("Naquada_Returned");
		
		if ( Map.Taken_Naquada == 0 or Map.Secured_Naquada == 1 )
		{
			SetAvailableMapGoals( TEAM.ALLIES, false, {
				"CAPPOINT_Truck",
				"DEFEND_Allies_Truck_.*",
				"ATTACK_Allies_NaquadaTaken_.*",
			});
			
			SetAvailableMapGoals( TEAM.AXIS, false, {
				"ATTACK_Axis_Truck_.*",
				".*MG42_Elevators_.*",
			});
		}
		
		if ( !Map.Elevator_Wall )
		{
			Map.Naquada_Room_goals();
		}
	},

	Naquada_Secured = function()
	{
		Map.Secured_Naquada += 1;
		
		Util.MapDebugPrint("Naquada_Secured");
		
		if ( Map.Secured_Naquada == 2 )
		{
			SetAvailableMapGoals( TEAM.ALLIES, false, {
				"CAPPOINT_Truck",
				"ATTACK_Allies_NaquadaTaken_.*",
				"SWITCH_.*_Door",
			});
		}
	},
	
	Truck_Built = function()
	{
		Map.Truck = true;
		
		Util.MapDebugPrint("Truck_Built");
		
		SetAvailableMapGoals( TEAM.ALLIES, false, "BUILD_Truck" );
		
		if ( Map.Secured_Naquada == 2 )
		{
			SetAvailableMapGoals( TEAM.ALLIES, true, "ESCORT_Truck" );
		}
	},

	Truck_Destroyed = function()
	{
		Map.Truck = false;
		
		Util.MapDebugPrint("Truck_Destroyed");
		
		SetAvailableMapGoals( TEAM.ALLIES, false, "ESCORT_Truck" );
		
		if ( !Map.Elevator_Wall and ( !Map.Truck_Barrier_1 or !Map.TruckAtBarrier ))
		{
			SetAvailableMapGoals( TEAM.ALLIES, true, "BUILD_Truck" );
		}
	},
	
	Truck_Stolen = function()
	{
		Util.MapDebugPrint("Truck_Stolen");
		
		Map.TruckStolen = true;
		
		SetAvailableMapGoals( TEAM.AXIS, true, ".*_Axis_TruckAtBarrier_.*" );

		SetAvailableMapGoals( TEAM.ALLIES, true, "DEFEND_Allies_TruckAtBarrier_.*" );
	},
	
	Truck_Barrier_1_Built = function()
	{
		Map.Truck_Barrier_1 = true;
		
		Util.MapDebugPrint("Truck_Barrier_1_Built");
		
		SetAvailableMapGoals( TEAM.AXIS, false, "BUILD_Truck_Barrier_1" );
		
		if ( !Map.Truck and Map.TruckAtBarrier )
		{
			SetAvailableMapGoals( TEAM.ALLIES, false, "BUILD_Truck" );
		}
		
		if ( !Map.Elevator_Wall and !Map.TruckPastBarrier )
		{
			SetAvailableMapGoals( TEAM.ALLIES, true, "PLANT_Truck_Barrier_1" );
		}
	},
	
	Truck_At_Barrier =
	{
		Name = "Truck_At_Barrier",
		TriggerOnEntity = GetGoal("MOVER_truck").GetEntity(),
		OnEnter = function(ent)
		{
			Util.MapDebugPrint( "Truck_At_Barrier" );
			
			Map.TruckAtBarrier = true;
			
			SetAvailableMapGoals( 0, false, ".*s_Truck_.*" );
		},
		OnExit = function(ent)
		{
			
		},
	},
	
	Truck_Barrier_1_Planted = function()
	{
		Util.MapDebugPrint("Truck_Barrier_1_Planted");
		
		if ( !Map.Elevator_Wall  )
		{
			SetAvailableMapGoals( TEAM.AXIS, false, "DEFUSE_Truck_Barrier_1_.*" );
		}
		else
		{
			if ( Map.Secured_Naquada < 2 )
			{
				Util.SetMaxUsers( 1, "DEFUSE_Truck_Barrier_1_.*" );
			}
			else
			{
				Util.SetMaxUsers( 4, "DEFUSE_Truck_Barrier_1_.*" );
			}
		}
	},

	Truck_Barrier_1_Defused = function()
	{
		Util.MapDebugPrint("Truck_Barrier_1_Defused");
	},

	Truck_Barrier_1_Destroyed = function()
	{
		Map.Truck_Barrier_1 = false;
		
		Util.MapDebugPrint("Truck_Barrier_1_Destroyed");
		
		foreach( goal in Util.GoalTable("DEFUSE_Truck_Barrier_1_.*") )
		{
			goal.SetAvailable(TEAM.AXIS, false);
		}
		
		SetAvailableMapGoals( TEAM.ALLIES, false, "PLANT_Truck_Barrier_1" );
		
		if ( !Map.Elevator_Wall and !Map.TruckPastBarrier )
		{
			SetAvailableMapGoals( TEAM.AXIS, true, "BUILD_Truck_Barrier_1" );
		}
		
		if ( !Map.Truck and Map.TruckAtBarrier )
		{
			SetAvailableMapGoals( TEAM.ALLIES, true, "BUILD_Truck" );
		}
	},
	
	Truck_Past_Barrier =
	{
		Name = "Truck_Past_Barrier",
		TriggerOnEntity = GetGoal("MOVER_truck").GetEntity(),
		OnEnter = function(ent)
		{
			Util.MapDebugPrint( "Truck_Past_Barrier" );
			
			Map.TruckAtBarrier = false;
			Map.TruckPastBarrier = true;
			
			Util.ChangeCrucialClassForRole( TEAM.AXIS, ROLE.DEFENDER2, CLASS.ENGINEER );
			Util.ChangeCrucialClassForRole( TEAM.AXIS, ROLE.DEFENDER3, CLASS.ENGINEER );
			
			SetAvailableMapGoals( 0, false, ".*_TruckAtBarrier_.*" );
			
			SetAvailableMapGoals( TEAM.AXIS, true, ".*_Axis_TruckPastBarrier_.*" );
			
			if ( !Map.Depogate )
			{
				SetAvailableMapGoals( TEAM.AXIS, true, "BUILD_Depogate" );
			}
			
			SetAvailableMapGoals( TEAM.ALLIES, true, "DEFEND_Allies_TruckPastBarrier_.*" );
		},
		OnExit = function(ent)
		{
			
		},
	},
	
