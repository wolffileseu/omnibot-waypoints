	},

	Trainstation_Entrance_Door_Destroyed = function( trigger )
	{
		ClearGoalRole( "BUILD.*", ROLE.DEFENDER ); //Remove limit for axis building
		SetAvailableMapGoals( TEAM.AXIS, false, "DEFEND_Flag.*" );
		SetAvailableMapGoals( TEAM.AXIS, true, {
			"CAMP_South_Gun.*",
			"CAMP_North_Gun.*",
			"MOUNTMG42_Garrison_MG_Nest.*",
			"REPAIRMG42_Garrison_MG_Nest.*",
		});

		SetAvailableMapGoals( TEAM.ALLIES, false, "ATTACK_Main_Door.*" );
		SetAvailableMapGoals( TEAM.ALLIES, true, {
			"PLANT_Flaggun_door.*",
			"PLANT_North_PAK_75mm_Gun",
			"PLANT_South_PAK_75mm_Gun",
			"CAMP_South_Gun.*",
			"CAMP_North_Gun.*",
			"PLANT_Axis_Command_Post",
		});

		Util.MapDebugPrint( "Trainstation_Entrance_Door_Destroyed" );
	},

