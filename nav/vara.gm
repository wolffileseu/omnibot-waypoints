	Spawn_Roles_Axis_var1 = function()
	{
		Map.Roles.AXIS.DEFENDER.spawnpt = 3;
		Map.Roles.AXIS.DEFENDER1.spawnpt = 7;
		Map.Roles.AXIS.DEFENDER2.spawnpt = 7;
		Map.Roles.AXIS.DEFENDER3.spawnpt = 1;
	},
	
	Test_of_version = function()
	{
		Util.MapDebugPrint( "Modified version" );
		
		Map.Modified = true;
		
		SetAvailableMapGoals( TEAM.AXIS, true, "BUILD_Radarcontrol" );
		
		Map.Roles.AXIS.DEFENSECAPTAIN.spawnpt = 4;
		
		Map.SetSpawn();
	},
	
	GoldTrigger =
	{
		Name = "GoldTrigger",
		TriggerOnClass = CLASS.ANYPLAYER,
		OnEnter = function(ent)
		{
			if ( Map.Gold_Secured < 3 )
			{
				if ( GetEntTeam(ent) == TEAM.ALLIES )
				{
					if (Map.count_AlliesGoldTrigger[ent])
					{
						Map.count_AlliesGoldTrigger[ent] += 1;
					}
					else
					{
						Map.count_AlliesGoldTrigger[ent] = 1;
					}
					
					ClearGoalRole( "PLANT_Command_Post", ROLE.DEFENDER3 );
					
					SetAvailableMapGoals( TEAM.AXIS, false, {
						".*MG42_East_Bunker",
						".*_Axis_SideEntrDest_.*",
						".*_Command_Post",
						".*_Axis_MainBunker_.*",
					});
					
					if ( Map.Garage_Door == "Opened" )
					{
						SetAvailableMapGoals( TEAM.AXIS, true, "SWITCH_Garage_Gate" );
					}
					
					SetAvailableMapGoals( TEAM.AXIS, true, ".*_Axis_Gold_.*" );
					SetAvailableMapGoals( TEAM.AXIS, true, ".*_Axis_Truck_.*" );
					
					if ( !Map.Truck_Barrier_1 )
					{
						SetAvailableMapGoals( TEAM.AXIS, true, "BUILD_Truck_Barrier_1" );
					}
					
					if ( Map.West_Bunker == TEAM.ALLIES or ( !Map.Modified and !Map.Gun_Controls ))
					{
						if ( !Map.Axis_Depot_MG_Nest )
						{
							SetAvailableMapGoals( TEAM.AXIS, true, "BUILD_Axis_North_West_MG_nest_1" );
						}
						else
						{
							SetAvailableMapGoals( TEAM.AXIS, true, "MOUNTMG42_Axis_North_West_MG_nest_1" );
						}
					}
					
					if ( Map.Modified )
					{
						Map.Roles.AXIS.DEFENDER3.spawnpt = 4;
					}
					
					Map.SetSpawn();
				}
			}
		},
		OnExit = function(ent)
		{
			if (Map.count_AlliesGoldTrigger[ent])
			{
				if (Map.count_AlliesGoldTrigger[ent] > 1)
				{
					Map.count_AlliesGoldTrigger[ent] -= 1;
				}
				else
				{
					Map.count_AlliesGoldTrigger[ent] = null;
				}
                
                if ( tableCount(Map.count_AlliesGoldTrigger) < 1 )
                {
					if ( Map.Gold_Secured < 3 )
					{
						SetGoalRole( "PLANT_Command_Post", ROLE.DEFENDER3 );
						
						SetAvailableMapGoals( TEAM.AXIS, false, {
							"SWITCH_Garage_Gate",
							".*_Axis_Gold_.*",
							".*_Axis_Truck_.*",
						});
						
						if ( !Map.Allied_CP )
						{
							SetAvailableMapGoals( TEAM.AXIS, false, "BUILD_Truck_Barrier_1" );
							
							if ( !Map.Axis_CP )
							{
								SetAvailableMapGoals( TEAM.AXIS, true, "BUILD_Command_Post" );
							}
							
							if ( Map.Side_Entrance )
							{
								SetAvailableMapGoals( TEAM.AXIS, true, ".*_Axis_SideEntrance_.*" );
							}
							else
							{
								SetAvailableMapGoals( TEAM.AXIS, true, {
									".*MG42_East_Bunker",
									".*_Axis_SideEntrDest_.*",
								});
							}
						}
						else
						{
							SetAvailableMapGoals( TEAM.AXIS, true, {
								"PLANT_Command_Post",
								".*_Axis_MainBunker_.*",
							});
						}
						
						Map.Roles.AXIS.DEFENDER3.spawnpt = 1;
						
						Map.SetSpawn();
					}
                }
			}
		},
	},
	
	Ignore_Target =
	{
		Name = "Ignore_Target",
		TriggerOnClass = CLASS.ANYPLAYER,
		OnEnter = function(ent)
		{
			b = Util.IsBot(ent);
			if ( b )
			{
				for ( q = 0; q < 64; q += 1 )
				{
					if ( EntityIsValid(q) and !GetEntFlags(q,ENTFLAG.CARRYINGGOAL) )
					{
						b.IgnoreTarget(q, 999);
					}
				}
			}
		},
		OnExit = function(ent)
		{
			b = Util.IsBot(ent);
			if ( b )
			{
				for ( q = 0; q < 64; q += 1 )
				{
					if ( EntityIsValid(q) )
					{
						b.IgnoreTarget(q, 0.1);
					}
				}
			}
		},
	},
	
	Ignore_Breakable =
	{
		Name = "Ignore_Breakable",
		TriggerOnClass = CLASS.ANYPLAYER,
		OnEnter = function(ent)
		{
			b = Util.IsBot(ent);
			if ( b )
			{
				b.TargetBreakableDist = 0;
			}
		},
		OnExit = function(ent)
		{
			b = Util.IsBot(ent);
			if ( b )
			{
				b.TargetBreakableDist = 130;
			}
		},
	},
};

