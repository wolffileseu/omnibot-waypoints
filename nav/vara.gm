	Allied_West_Beach_MG_Nest_Built = function( trigger )
	{
		Map.Allied_West_Beach_MG_Nest = true;
		
		Wp.SetWaypointFlag( "Allied_West_Beach_MG_Nest_2", "closed", false );
		Wp.SetWaypointFlag( "Allied_West_Beach_MG_Nest_3", "closed", false );
		
		Util.MapDebugPrint( "Allied_West_Beach_MG_Nest_Built" );
	},

	Allied_West_Beach_MG_Nest_Destroyed = function( trigger )
	{
		Map.Allied_West_Beach_MG_Nest = false;
		
		Wp.SetWaypointFlag( "Allied_West_Beach_MG_Nest_2", "closed", true );
		Wp.SetWaypointFlag( "Allied_West_Beach_MG_Nest_3", "closed", true );
		
		Util.MapDebugPrint( "Allied_West_Beach_MG_Nest_Destroyed" );
	},
	
	Axis_MG_Nest_Planted = function( trigger )
	{
		foreach( goal in Util.GoalTable("DEFUSE_Axis_North_West_MG_nest_.*") )
		{
			pos1 = goal.GetPosition();
			name = goal.GetName();
			
			if( pos1.y < 0 )
			{
				Util.MapDebugPrint( "Axis_North_West_MG_Nest_Planted" );
				
				goal.SetAvailable(TEAM.AXIS, false);
			}
			else
			{
				Util.MapDebugPrint( "Axis_Depot_MG_Nest_Planted" );
				
				Util.SetGoalRange( name, 1000);
				goal.SetGoalPriority( TEAM.AXIS, 0 , 0.9 );
				goal.SetRoles(ROLE.DEFENDER, ROLE.DEFENDER3);
				
				if ( !Map.Modified and !Map.Gun_Controls )
				{
					goal.SetRoles(ROLE.DEFENDER1, ROLE.DEFENDER2);
				}
				
				if ( Map.TruckPastBarrier_1 )
				{
					goal.SetAvailable(TEAM.AXIS, false);
				}
			}
		}
	},
	
	Axis_North_West_MG_Nest_Built = function( trigger )
	{
		Map.Axis_North_West_MG_Nest = true;
		
		Util.MapDebugPrint( "Axis_North_West_MG_Nest_Built" );
		
		SetAvailableMapGoals( TEAM.AXIS, false, "BUILD_Axis_North_West_MG_nest" );
		
		if ( Map.Modified or Map.Gun_Controls )
		{
			SetAvailableMapGoals( TEAM.ALLIES, true, "PLANT_Axis_North_West_MG_nest" );
			
			SetAvailableMapGoals( TEAM.AXIS, true, ".*_Axis_North_West_MG_nest" );
		}
	},

	Axis_North_West_MG_Nest_Destroyed = function( trigger )
	{
		Map.Axis_North_West_MG_Nest = false;
		
		Util.MapDebugPrint( "Axis_North_West_MG_Nest_Destroyed" );
		
		SetAvailableMapGoals( TEAM.ALLIES, false, "PLANT_Axis_North_West_MG_nest" );
	},

	Axis_Depot_MG_Nest_Built = function( trigger )
	{
		Map.Axis_Depot_MG_Nest = true;
		
		Wp.SetWaypointFlag( "Axis_Depot_MG_Nest_1", "closed", false );
		
		Util.MapDebugPrint( "Axis_Depot_MG_Nest_Built" );
		
		SetAvailableMapGoals( TEAM.AXIS, false, "BUILD_Axis_North_West_MG_nest_1" );
		
		if ( !Map.TruckPastBarrier_1 )
		{
			if ( !Map.TruckLeftGarage )
			{
				if ( tableCount(Map.count_AlliesGoldTrigger) > 0 and Map.West_Bunker == TEAM.ALLIES )
				{
					SetAvailableMapGoals( TEAM.AXIS, true, ".*MG42_Axis_North_West_MG_nest_1" );
				}
			}
			else
			{
				SetAvailableMapGoals( TEAM.AXIS, true, ".*MG42_Axis_North_West_MG_nest_1" );
			}
			
			if ( Map.Gold_Secured == 3 )
			{
				SetAvailableMapGoals( TEAM.ALLIES, true, "PLANT_Axis_North_West_MG_nest_1" );
			}
		}
	},
	
	Axis_Depot_MG_Nest_Destroyed = function( trigger )
	{
		Map.Axis_Depot_MG_Nest = false;
		
		Wp.SetWaypointFlag( "Axis_Depot_MG_Nest_1", "closed", true );
		
		Util.MapDebugPrint( "Axis_Depot_MG_Nest_Destroyed" );
		
		SetAvailableMapGoals( TEAM.AXIS, false, ".*MG42_Axis_North_West_MG_nest_1" );
		
		SetAvailableMapGoals( TEAM.ALLIES, false, "PLANT_Axis_North_West_MG_nest_1" );
		
		if ( !Map.TruckPastBarrier_1 )
		{
			if ( !Map.Modified and !Map.Gun_Controls )
			{
				SetGoalRole( "BUILD_Axis_North_West_MG_nest_1", { ROLE.DEFENDER1, ROLE.DEFENDER2 });
			}
			
			if ( !Map.TruckLeftGarage )
			{
				if ( tableCount(Map.count_AlliesGoldTrigger) > 0 or Map.Gold_Secured == 3 )
				{
					SetAvailableMapGoals( TEAM.AXIS, true, "BUILD_Axis_North_West_MG_nest_1" );
				}
			}
			else
			{
				SetAvailableMapGoals( TEAM.AXIS, true, "BUILD_Axis_North_West_MG_nest_1" );
			}
		}
	},

	Allied_CP_Built = function( trigger )
	{
		Map.Allied_CP = true;
		
		Util.MapDebugPrint( "Allied_CP_Built" );
		
		Util.DisableGoal( "BUILD_Command_Post" );
		
		SetAvailableMapGoals( TEAM.AXIS, false, {
			".*_Axis_SideEntrance_.*",
			".*_Axis_SideEntrDest_.*",
		});
		
		SetAvailableMapGoals( TEAM.ALLIES, false, ".*_Allies_CP_.*" );
		
		if ( tableCount(Map.count_AlliesGoldTrigger) < 1 and Map.Gold_Secured < 3 )
		{
			SetAvailableMapGoals( TEAM.AXIS, true, {
				"PLANT_Command_Post",
				".*_Axis_MainBunker_.*",
			});
		}
		
		SetGoalRole( "FLAG_gold_crate", ROLE.ATTACKER3 );
		SetGoalRole( "BUILD_Truck", ROLE.ATTACKER3 );
		SetGoalRole( "ESCORT_Truck", ROLE.ATTACKER3 );
		
		if ( Map.Fence )
		{
			SetGoalRole( "PLANT_Fence", ROLE.ATTACKER3 );
		}
		
		if ( Map.West_Bunker == TEAM.ALLIES )
		{
			Map.Spawn_Roles_Allies_var1();
		}
		else
		{
			Map.Spawn_Roles_Allies_var2();
		}
		
		Map.SetSpawn();
	},

	Axis_CP_Built = function( trigger )
	{
		Map.Axis_CP = true;
		
		Util.MapDebugPrint( "Axis_CP_Built" );
		
		Util.DisableGoal( "BUILD_Command_Post" );
		
		if ( !Map.Side_Entrance )
		{
			SetAvailableMapGoals( TEAM.ALLIES, true, "PLANT_Command_Post" );
		}
		
		Map.SetSpawn();
	},

	CP_Planted = function( trigger )
	{
		if ( Map.Allied_CP )
		{
			Util.MapDebugPrint( "Allied_CP_Planted" );
			
			foreach( goal in Util.GoalTable("DEFUSE_Command_Post_.*") )
			{
				goal.SetGoalPriority( TEAM.ALLIES, 0 , 0.85 );
				goal.SetRoles(ROLE.ATTACKER3);
			}
		}
		else
		{
			Util.MapDebugPrint( "Axis_CP_Planted" );
			
			foreach( goal in Util.GoalTable("DEFUSE_Command_Post_.*") )
			{
				goal.SetGoalPriority( TEAM.AXIS, 0 , 0.85 );
				goal.SetRoles(ROLE.DEFENDER3);
			}
		}
	},
	
	Allied_CP_Destroyed = function( trigger )
	{
		Map.Allied_CP = false;
		
		Util.MapDebugPrint( "Allied_CP_Destroyed" );
		
		SetAvailableMapGoals( TEAM.AXIS, false, ".*_Axis_MainBunker_.*" );
		
		if ( tableCount(Map.count_AlliesGoldTrigger) < 1 and Map.Gold_Secured < 3 )
		{
			SetAvailableMapGoals( TEAM.AXIS, true, "BUILD_Command_Post" );
			
			if ( Map.Side_Entrance )
			{
				SetAvailableMapGoals( TEAM.AXIS, true, ".*_Axis_SideEntrance_.*" );
			}
			else
			{
				SetAvailableMapGoals( TEAM.AXIS, true, {
					".*MG42_East_Bunker",
					".*_Axis_SideEntrDest_.*",
				});
			}
		}
		
		ClearGoalRole( "FLAG_gold_crate", ROLE.ATTACKER3 );
		ClearGoalRole( ".*_Truck", ROLE.ATTACKER3 );
		
		if ( Map.Fence )
		{
			ClearGoalRole( "PLANT_Fence", ROLE.ATTACKER3 );
		}
		
		if ( !Map.Side_Entrance )
		{
			SetAvailableMapGoals( TEAM.ALLIES, true, "BUILD_Command_Post" );
			
			if ( Map.Gold_Secured < 3 )
			{
				SetAvailableMapGoals( TEAM.ALLIES, true, ".*_Allies_CP_.*" );
			}
		}
		
		if ( Map.West_Bunker == TEAM.ALLIES )
		{
			Map.Spawn_Roles_Allies_var3();
		}
		else
		{
			Map.Spawn_Roles_Allies_var4();
		}
		
		Map.SetSpawn();
	},

	Axis_CP_Destroyed = function( trigger )
	{
		Map.Axis_CP = false;
		
		Util.MapDebugPrint( "Axis_CP_Destroyed" );
		
		if ( tableCount(Map.count_AlliesGoldTrigger) < 1 and !Map.TruckLeftGarage )
		{
			SetAvailableMapGoals( TEAM.AXIS, true, "BUILD_Command_Post" );
		}
		
		if ( !Map.Side_Entrance )
		{
			SetAvailableMapGoals( TEAM.ALLIES, true, "BUILD_Command_Post" );
		}
		
		Map.SetSpawn();
	},

