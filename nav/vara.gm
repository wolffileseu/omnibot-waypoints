	{
		Map.TruckAtBarrier2 = true;
		
		Util.MapDebugPrint( "Truck_At_Barrier_2" );
		
		if ( !Map.Truck )
		{
			SetAvailableMapGoals( TEAM.ALLIES, false, "BUILD_Truck" );
