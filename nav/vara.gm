	Gun_Controls_Destroyed = function( trigger )
	{
		Map.Gun_Controls = false;
		
		Util.MapDebugPrint( "Gun_Controls_Destroyed" );
		
		foreach( goal in Util.GoalTable("DEFUSE_Gun_Controls_.*") )
		{
			goal.SetAvailable(TEAM.AXIS, false);
		}
		
		SetAvailableMapGoals( TEAM.AXIS, false, ".*_Axis_GunIn_.*" );
		
		SetAvailableMapGoals( TEAM.ALLIES, false, ".*_Allies_GunIn_.*" );
		
		if ( Map.West_Bunker == TEAM.ALLIES )
		{
			SetAvailableMapGoals( TEAM.AXIS, false, "CHECKPOINT_westbunker_flag" );	//permanently allied
			
			Map.Roles.AXIS.DEFENDER.spawnpt = 1;
			Map.Roles.AXIS.DEFENDER1.spawnpt = 1;
			Map.Roles.AXIS.DEFENDER2.spawnpt = 1;
			Map.Roles.AXIS.DEFENDER3.spawnpt = 1;
		}
		
		Util.SetMaxUsers( 2, "CHECKPOINT_westbunker_flag" );
		
		if ( !Map.Modified )
		{
			SetGoalRole( "CHECKPOINT_westbunker_flag", ROLE.ATTACKER1 );
			SetGoalRole( "FLAG_gold_crate", {ROLE.ATTACKER1, ROLE.ATTACKER2} );
			SetGoalRole( "BUILD_Truck", {ROLE.ATTACKER1, ROLE.ATTACKER2} );
			SetGoalRole( "ESCORT_Truck", {ROLE.ATTACKER1, ROLE.ATTACKER2} );
			SetGoalRole( "MOBILEMG42_Axis_Gold_1.*", { ROLE.DEFENDER1, ROLE.DEFENDER2 });
			
			SetAvailableMapGoals( TEAM.AXIS, false, {
				".*_Axis_GunOut_.*",
				".*_Axis_GunIn_.*",
				".*_Axis_RadarIn_.*",
			});
			
			SetAvailableMapGoals( TEAM.ALLIES, false, {
				".*_Allies_RadarIn_.*",
				".*_Allies_GunOut_.*",
				".*_Allies_GunIn_.*",
			});
			
			if ( Map.West_Bunker == TEAM.AXIS)
			{
				Map.Roles.AXIS.DEFENDER.spawnpt = 3;
				Map.Roles.AXIS.DEFENDER1.spawnpt = 1;
				Map.Roles.AXIS.DEFENDER2.spawnpt = 1;
				Map.Roles.AXIS.DEFENDER3.spawnpt = 1;
			}
			else
			{
				SetAvailableMapGoals( TEAM.AXIS, false,".*_Axis_WestBunker_.*" );
			}
		}
		else
		{
			if ( Map.West_Bunker == TEAM.AXIS)
			{
				Map.Spawn_Roles_Axis_var1();
			}
		}
		
		Map.SetSpawn();
	},

