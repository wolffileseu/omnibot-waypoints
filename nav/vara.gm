	Radar_Bunker_Wall_Test = function()
	{
		start = Vector3(-77, 2671, 858);
		end = Vector3(-77, 2767, 858);
		while ( Map.Radar_Bunker_Wall )
		{
			tr = TraceLine( start, end, null, TRACE.SOLID, 0, false );
			if ( tr.fraction == 1 )
			{
				Map.Radar_Bunker_Wall_Destroyed();
			}
			sleep(0.25);
		}
	},
	
	Fence_Test = function()
	{
		start = Vector3(2250, 4184, 999);
		end = Vector3(2250, 4234, 999);
		while ( Map.Fence )
		{
			tr = TraceLine( start, end, null, TRACE.SOLID, 0, false );
			if ( tr.fraction == 1 )
			{
				Map.Fence_Destroyed();
			}
			sleep(0.25);
		}
	},
	
	SetSpawn = function()
	{
		foreach ( id and bot in BotTable )
		{
			Map.SetSpawn1(bot);
		}
	},
	
	SetSpawn1 = function(bot)
	{
		if ( bot.GetTeam() == TEAM.ALLIES )
        {
			if ( Map.West_Bunker == TEAM.ALLIES )
			{
				if ( Map.Allied_CP )
				{
					if ( bot.HasRole(ROLE.ATTACKER2) or bot.HasRole(ROLE.ATTACKER3) )
					{
						bot.ChangeSpawnPoint(5);	//East bunker
					}
					else
					{
						bot.ChangeSpawnPoint(3);	//West bunker
					}
				}
				else
				{
					bot.ChangeSpawnPoint(3);	//West bunker
				}
			}
			else
			{
				if ( Map.Allied_CP )
				{
					if ( bot.HasRole(ROLE.ATTACKER2) or bot.HasRole(ROLE.ATTACKER3) )
					{
						bot.ChangeSpawnPoint(5);	//East bunker
					}
					else
					{
						bot.ChangeSpawnPoint(2);	//West beach
					}
				}
				else
				{
					bot.ChangeSpawnPoint(2);	//West beach
				}
			}
		}
		else
		{
			if ( Map.West_Bunker == TEAM.ALLIES )
			{
				if ( Map.Modified )
				{
					if ( bot.HasRole(ROLE.DEFENDER) )
					{
						bot.ChangeSpawnPoint(4);	//Garage
					}
					
					if ( bot.HasRole(ROLE.DEFENSECAPTAIN) )
					{
						if ( !Map.TruckEnd )
						{
							bot.ChangeSpawnPoint(4);	//Garage
						}
						else
						{
							bot.ChangeSpawnPoint(1);	//Main bunker
						}
					}
					
					if ( bot.HasRole(ROLE.DEFENDER3) )
					{
						if ( tableCount(Map.count_AlliesGoldTrigger) > 0 or Map.Gold_Secured == 3 )
						{
							bot.ChangeSpawnPoint(4);	//Garage
						}
						else
						{
							bot.ChangeSpawnPoint(1);	//Main bunker
						}
					}
					
					if ( bot.HasRole(ROLE.DEFENDER1) or bot.HasRole(ROLE.DEFENDER2) )
					{
						bot.ChangeSpawnPoint(1);	//Main bunker
					}
				}
				else
				{
					bot.ChangeSpawnPoint(1);	//Main bunker
				}
			}
			else
			{
				if ( bot.HasRole(ROLE.DEFENDER) )
				{
					bot.ChangeSpawnPoint(3);	//West bunker
				}
				else
				{
					if ( bot.HasRole(ROLE.DEFENDER3) or bot.HasRole(ROLE.DEFENSECAPTAIN) )
					{
						if ( !Map.TruckEnd )
						{
							if ( bot.HasRole(ROLE.DEFENDER3) )
							{
								if ( Map.Modified and ( tableCount(Map.count_AlliesGoldTrigger) > 0 or Map.Gold_Secured == 3 ))
								{
									bot.ChangeSpawnPoint(4);	//Garage
								}
								else
								{
									bot.ChangeSpawnPoint(1);	//Main bunker
								}
							}
							else
							{
								if ( Map.Modified )
								{
									bot.ChangeSpawnPoint(4);	//Garage
								}
								else
								{
									bot.ChangeSpawnPoint(1);	//Main bunker
								}
							}
						}
						else
						{
							bot.ChangeSpawnPoint(7);	//Gun control
						}
					}
					else
					{
						if (( bot.HasRole(ROLE.DEFENDER1) or bot.HasRole(ROLE.DEFENDER2) ) and ( Map.Gun_Controls or Map.Modified ))
						{
							bot.ChangeSpawnPoint(7);	//Gun control
						}
						else
						{
							bot.ChangeSpawnPoint(1);	//Main bunker
						}
					}
				}
			}
		}
	},
	
	Spawn_Roles_Allies_var1 = function()
	{
		Map.Roles.ALLIES.ATTACKER.spawnpt = 3;
		Map.Roles.ALLIES.ATTACKER1.spawnpt = 3;
		Map.Roles.ALLIES.ATTACKER2.spawnpt = 5;
		Map.Roles.ALLIES.ATTACKER3.spawnpt = 5;
	},
	
	Spawn_Roles_Allies_var2 = function()
	{
		Map.Roles.ALLIES.ATTACKER.spawnpt = 2;
		Map.Roles.ALLIES.ATTACKER1.spawnpt = 2;
		Map.Roles.ALLIES.ATTACKER2.spawnpt = 5;
		Map.Roles.ALLIES.ATTACKER3.spawnpt = 5;
	},
	
	Spawn_Roles_Allies_var3 = function()
	{
		Map.Roles.ALLIES.ATTACKER.spawnpt = 3;
		Map.Roles.ALLIES.ATTACKER1.spawnpt = 3;
		Map.Roles.ALLIES.ATTACKER2.spawnpt = 3;
		Map.Roles.ALLIES.ATTACKER3.spawnpt = 3;
	},
	
	Spawn_Roles_Allies_var4 = function()
	{
		Map.Roles.ALLIES.ATTACKER.spawnpt = 2;
		Map.Roles.ALLIES.ATTACKER1.spawnpt = 2;
		Map.Roles.ALLIES.ATTACKER2.spawnpt = 2;
		Map.Roles.ALLIES.ATTACKER3.spawnpt = 2;
