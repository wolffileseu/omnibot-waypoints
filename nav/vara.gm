	Truck_Past_Barrier_2 = function( trigger )
	{
		Map.TruckPastBarrier_2 = true;
		Map.TruckAtBarrier2 = false;
		
		Util.MapDebugPrint( "Truck_Past_Barrier_2" );
		
		Util.ChangeCrucialClassForRole(TEAM.AXIS, ROLE.DEFENDER3, {CLASS.ENGINEER, CLASS.FIELDOPS, CLASS.COVERTOPS});
		
		SetAvailableMapGoals( TEAM.AXIS, false, {
			"BUILD_Truck_Barrier_2",
			".*_Axis_Barrier2_.*",
		});
		
		SetAvailableMapGoals( TEAM.ALLIES, false, ".*_Allies_Barrier2_.*" );
		
		SetAvailableMapGoals( TEAM.ALLIES, true, ".*_Allies_Between_.*" );
		
		SetAvailableMapGoals( TEAM.AXIS, true, ".*_Axis_Between_.*" );
	},
	
	Truck_Approaching_Barn = function( trigger )
	{
		Util.MapDebugPrint( "Truck_Approaching_Barn" );
		
		SetAvailableMapGoals( TEAM.AXIS, false, ".*_Axis_Between_.*" );
		
		SetAvailableMapGoals( TEAM.ALLIES, false, ".*_Allies_Between_.*" );
		
		SetAvailableMapGoals( TEAM.ALLIES, true, ".*_Allies_End_.*" );
		
		SetAvailableMapGoals( TEAM.AXIS, true, ".*_Axis_End_.*" );
	},
	
	Truck_End = function( trigger )
	{
		Map.TruckEnd = true;
		
		Util.MapDebugPrint( "Truck_End" );
		
		SetGoalRole( ".*_Axis_North_West_MG_nest", { ROLE.DEFENDER, ROLE.DEFENDER3 });
		SetGoalRole( "BUILD_Radarcontrol", { ROLE.DEFENDER, ROLE.DEFENDER3 });
		SetGoalRole( ".*_Axis_GunIn_.*", { ROLE.DEFENDER, ROLE.DEFENDER3 });
		SetGoalRole( ".*_Axis_RadarIn_.*", { ROLE.DEFENDER, ROLE.DEFENDER3 });
		
		if ( Map.Gun_Controls or Map.Modified )
		{
			Map.Roles.AXIS.DEFENDER3.spawnpt = 7;
		}
		
		if ( Map.Gun_Controls )
		{
			SetGoalRole( "PLANT_Gun_Controls", { ROLE.ATTACKER, ROLE.ATTACKER3 });
		}
		
		if ( Map.Radar_Control )
		{
			SetGoalRole( "PLANT_Radarcontrol", { ROLE.ATTACKER, ROLE.ATTACKER3 });
		}
		
		SetAvailableMapGoals( TEAM.AXIS, false, ".*_Axis_End_.*" );
		
		SetAvailableMapGoals( TEAM.ALLIES, false, {
			".*_Allies_End_.*",
			".*_Truck",
		});
		
		SetAvailableMapGoals( TEAM.ALLIES, true, ".*_Allies_GunSec_.*" );
		
		SetAvailableMapGoals( TEAM.AXIS, true, ".*_Axis_GunSec_.*" );
		
		Map.SetSpawn();
	},
	
	Fence_Planted = function( trigger )
	{
		Util.MapDebugPrint( "Fence_Planted" );
		
		foreach( goal in Util.GoalTable("DEFUSE_Fence_.*") )
		{
			name = goal.GetName();
			Util.SetGoalRange( name, 900);
			goal.MaxUsers_InProgress( 1 );
			goal.SetGoalPriority( TEAM.AXIS, 0 , 0.82 );
			goal.SetRoles(ROLE.DEFENDER, ROLE.DEFENDER3);
			
			if ( !Map.Modified and !Map.Gun_Controls )
			{
				goal.SetRoles(ROLE.DEFENDER1, ROLE.DEFENDER2);
			}
		}
	},
	
	Fence_Destroyed = function( trigger )
	{
		Map.Fence = false;
		
		Util.MapDebugPrint( "Fence_Destroyed" );
		
		foreach( goal in Util.GoalTable("DEFUSE_Fence_.*") )
		{
			goal.SetAvailable(TEAM.AXIS, false);
		}
	},

	Lager_Grate_Door = function()
	{
		sleep(2);
		
		if ( GetModName() == "nitmod" )
		{
			lager_a_door = GetGameEntityFromId(705);
			lager_b_door = GetGameEntityFromId(710);
			lager_c_door = GetGameEntityFromId(711);
		}
		else if ( GetModName() == "noquarter" )
		{
			lager_a_door = GetGameEntityFromId(690);
			lager_b_door = GetGameEntityFromId(695);
			lager_c_door = GetGameEntityFromId(696);
		}
		else
		{
			lager_a_door = GetGameEntityFromId(610);
			lager_b_door = GetGameEntityFromId(615);
			lager_c_door = GetGameEntityFromId(616);
		}
		
		while ( 1 )
		{
			lager_a_door_pos = Round(GetEntPosition(lager_a_door).x);
			lager_b_door_pos = Round(GetEntPosition(lager_b_door).x);
			lager_c_door_pos = Round(GetEntPosition(lager_c_door).x);
			
			if ( lager_a_door_pos == 1534 or lager_a_door_pos == 1471 )
			{
				Map.Lager_A_Door_Opened = true;
			}
			else
			{
				Map.Lager_A_Door_Opened = false;
			}
			
			if ( lager_b_door_pos == 1534 or lager_b_door_pos == 1471 )
			{
				Map.Lager_B_Door_Opened = true;
			}
			else
			{
				Map.Lager_B_Door_Opened = false;
			}
			
			if ( lager_c_door_pos == 1255 or lager_c_door_pos == 1318 )
			{
				Map.Lager_C_Door_Opened = true;
			}
			else
			{
				Map.Lager_C_Door_Opened = false;
			}
			sleep(0.2);
		}
	},
	
	Gun_Controls_Planted = function( trigger )
	{
		Util.MapDebugPrint( "Gun_Controls_Planted" );
		
		foreach( goal in Util.GoalTable("DEFUSE_Gun_Controls_.*") )
		{
