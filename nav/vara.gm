				numbots = 5,
				crucialClass = {CLASS.ENGINEER, CLASS.SOLDIER, CLASS.COVERTOPS},
			},
			DEFENDER2 =	
			{
				spawnpt = 7,
				numbots = 4,
				crucialClass = {CLASS.ENGINEER, CLASS.FIELDOPS, CLASS.MEDIC},
			},
			DEFENDER3 =	
			{
				spawnpt = 1,
				numbots = 4,
				crucialClass = {CLASS.ENGINEER, CLASS.SOLDIER, CLASS.COVERTOPS},
			},
			DEFENSECAPTAIN =	
			{
				spawnpt = 1,
				numbots = 2,
				crucialClass = {CLASS.FIELDOPS, CLASS.MEDIC},
			},
		},
		ALLIES =
		{
			AllBots = true,
			ATTACKER =	
			{
				numbots = 5,
				crucialClass = {CLASS.ENGINEER, CLASS.MEDIC},
			},
			ATTACKER1 =	
			{
				numbots = 5,
				crucialClass = {CLASS.ENGINEER, CLASS.COVERTOPS},
			},
			ATTACKER2 =	
			{
				numbots = 5,
				crucialClass = {CLASS.ENGINEER, CLASS.COVERTOPS},
			},
			ATTACKER3 =	
			{
