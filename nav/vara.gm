	Side_Entrance_Destroyed = function( trigger )
	{
		Map.Side_Entrance = false;
		
		Util.MapDebugPrint( "Side_Entrance_Destroyed" );
		
		foreach( goal in Util.GoalTable("DEFUSE_Side_Entrance_.*") )
		{
			goal.SetAvailable(TEAM.AXIS, false);
		}
		
		SetAvailableMapGoals( TEAM.AXIS, false, ".*_Axis_SideEntrance_.*" );
		
		SetAvailableMapGoals( TEAM.ALLIES, false, "PLANT_Side_Entrance" );
		
		if ( !Map.Allied_CP and Map.Gold_Secured < 3 and tableCount(Map.count_AlliesGoldTrigger) < 1 )
		{
			SetAvailableMapGoals( TEAM.AXIS, true, {
				".*MG42_East_Bunker",
				".*_Axis_SideEntrDest_.*",
			});
		}
		
		sleep(1);
		
		SetAvailableMapGoals( TEAM.ALLIES, false, ".*_Allies_SideEntrance_.*" );
		
		if ( !Map.Axis_CP and !Map.Allied_CP )
		{
			SetAvailableMapGoals( TEAM.ALLIES, true, "BUILD_Command_Post" );
		}
		else
		{
			if ( Map.Axis_CP )
			{
				SetAvailableMapGoals( TEAM.ALLIES, true, "PLANT_Command_Post" );
			}
		}
		
		if ( Map.Gold_Secured < 3 )
		{
			SetAvailableMapGoals( TEAM.ALLIES, true, ".*_Allies_CP_.*" );
		}
	},
	
	West_Bunker_Axis_Captured = function( trigger )
	{
		Map.West_Bunker = TEAM.AXIS;
		
		Util.MapDebugPrint( "West_Bunker_Axis_Captured" );
		
		Util.SetMaxUsers( 5, "CHECKPOINT_westbunker_flag" );
		
		ClearGoalRole( "FLAG_gold_crate", ROLE.ATTACKER );
		ClearGoalRole( ".*_Truck", ROLE.ATTACKER );
		
		if ( Map.Fence )
		{
			ClearGoalRole( "PLANT_Fence", ROLE.ATTACKER );
		}
		
		SetAvailableMapGoals( TEAM.AXIS, false, "CHECKPOINT_westbunker_flag" );
		
		SetAvailableMapGoals( TEAM.AXIS, true, ".*_Axis_WestBunker_.*" );
		
		SetAvailableMapGoals( TEAM.ALLIES, true, "CHECKPOINT_westbunker_flag" );
		
		if ( tableCount(Map.count_AlliesGoldTrigger) < 1 and Map.Gold_Secured < 3 )
		{
			SetAvailableMapGoals( TEAM.AXIS, false, {
				"SWITCH_Garage_Gate",
				".*_Axis_Gold_.*",
				".*_Axis_Truck_.*",
			});
			
			if ( !Map.Allied_CP )
			{
				SetAvailableMapGoals( TEAM.AXIS, false, "BUILD_Truck_Barrier_1" );
				
				if ( !Map.Axis_CP )
				{
					SetAvailableMapGoals( TEAM.AXIS, true, "BUILD_Command_Post" );
				}
				
				if ( Map.Side_Entrance )
				{
					SetAvailableMapGoals( TEAM.AXIS, true, ".*_Axis_SideEntrance_.*" );
				}
				else
				{
					SetAvailableMapGoals( TEAM.AXIS, true, {
						".*MG42_East_Bunker",
						".*_Axis_SideEntrDest_.*",
					});
				}
			}
			else
			{
				SetAvailableMapGoals( TEAM.AXIS, true, {
					"PLANT_Command_Post",
					".*_Axis_MainBunker_.*",
				});
			}
		}
		
		if ( Map.Allied_CP )
		{
			Map.Spawn_Roles_Allies_var2();
		}
		else
		{
			Map.Spawn_Roles_Allies_var4();
		}
		
		Map.Spawn_Roles_Axis_var1();
		
		Map.SetSpawn();
	},

	West_Bunker_Allies_Captured = function( trigger )
	{
		Map.West_Bunker = TEAM.ALLIES;
		
		Util.MapDebugPrint( "West_Bunker_Allies_Captured" );
		
		Util.SetMaxUsers( 3, "CHECKPOINT_westbunker_flag" );
		
		SetGoalRole( "FLAG_gold_crate", ROLE.ATTACKER );
		SetGoalRole( "BUILD_Truck", ROLE.ATTACKER );
		SetGoalRole( "ESCORT_Truck", ROLE.ATTACKER );
		
		if ( Map.Fence )
		{
			SetGoalRole( "PLANT_Fence", ROLE.ATTACKER );
		}
		
		SetAvailableMapGoals( TEAM.AXIS, false, ".*_Axis_WestBunker_.*" );
		
		SetAvailableMapGoals( TEAM.ALLIES, false, "CHECKPOINT_westbunker_flag" );
		
		if ( Map.Gun_Controls )
		{
			SetAvailableMapGoals( TEAM.AXIS, true, "CHECKPOINT_westbunker_flag" );
		}
		
		if ( Map.Gold_Secured < 3 )
		{
			SetAvailableMapGoals( TEAM.AXIS, false, {
				".*MG42_East_Bunker",
				".*_Axis_SideEntrDest_.*",
				".*_Command_Post",
				".*_Axis_MainBunker_.*",
			});
			
			if ( Map.Garage_Door == "Opened" )
			{
				SetAvailableMapGoals( TEAM.AXIS, true, "SWITCH_Garage_Gate" );
			}
			
			SetAvailableMapGoals( TEAM.AXIS, true, ".*_Axis_Gold_.*" );
			SetAvailableMapGoals( TEAM.AXIS, true, ".*_Axis_Truck_.*" );
			
			if ( !Map.Truck_Barrier_1 )
			{
				SetAvailableMapGoals( TEAM.AXIS, true, "BUILD_Truck_Barrier_1" );
			}
		}
		
		if ( Map.Modified )
		{
			Map.Roles.AXIS.DEFENDER.spawnpt = 4;
		}
		else
		{
			Map.Roles.AXIS.DEFENDER.spawnpt = 1;
		}
		Map.Roles.AXIS.DEFENDER1.spawnpt = 1;
		Map.Roles.AXIS.DEFENDER2.spawnpt = 1;
		Map.Roles.AXIS.DEFENDER3.spawnpt = 1;
		
		if ( Map.Allied_CP )
		{
			Map.Spawn_Roles_Allies_var1();
		}
		else
		{
			Map.Spawn_Roles_Allies_var3();
		}
		
		Map.SetSpawn();
	},
	
	Garage_Door_Moving = function( trigger )
	{
		if ( ToVector( trigger.Action ).z > 0 )
		{
			Util.MapDebugPrint( "Garage_Door_Opening" );
			Map.Garage_Door = "Opened";
			
			Util.EnableGoal( "ROUTE_GarageDoor" );
			
			SetAvailableMapGoals( TEAM.ALLIES, false, "SWITCH_Garage_Gate");
			
			dowhile ( x_pos != 1536 or z_pos != 636 )
			{
				pos = Util.GetMapGoalPosition("MOVER_tbdoor1_9");
				x_pos = Round(pos.x);
				z_pos = Round(pos.z);
				yield();
			}
			
			Util.MapDebugPrint( "Garage_Door_Opened" );
			
			if ( !Map.TruckLeftGarage )
			{
				SetAvailableMapGoals( TEAM.AXIS, true, "SWITCH_Garage_Gate");
			}
		}
		else
		{
			Util.MapDebugPrint( "Garage_Door_Closing" );
			Map.Garage_Door = "Closed";
			
			Util.DisableGoal( "ROUTE_GarageDoor" );
			
			SetAvailableMapGoals( TEAM.AXIS, false, "SWITCH_Garage_Gate");
			
			ClearGoalRole( "SWITCH_.*", ROLE.DEFENSECAPTAIN );
			
			dowhile ( x_pos != 1732 or z_pos != 588 )
			{
				pos = Util.GetMapGoalPosition("MOVER_tbdoor1_9");
				x_pos = Round(pos.x);
				z_pos = Round(pos.z);
				yield();
			}
			
			Util.MapDebugPrint( "Garage_Door_Closed" );
			
			if ( !Map.TruckLeftGarage )
			{
				SetAvailableMapGoals( TEAM.ALLIES, true, "SWITCH_Garage_Gate");
			}
		}
	},
	
	Door_Moving = function( trigger )
	{
		if ( ToVector( trigger.Action ).y > 0 )
		{
			if ( trigger.Entity == 234 or trigger.Entity == 248 or trigger.Entity == 329 )
			{
				Map.Door_1 = "Opened";
				
				Util.MapDebugPrint( "Door_1_Opened" );
			}
			else if ( trigger.Entity == 249 or trigger.Entity == 263 or trigger.Entity == 344 )
			{
				Map.Door_2 = "Opened";
				
				Util.EnableGoal( "ROUTE_Lager2Floor" );
				
				Util.MapDebugPrint( "Door_2_Opened" );
				
				SetAvailableMapGoals( TEAM.ALLIES, false, "SWITCH_Door_2" );
				
				if ( Map.Gold_Secured < 3 )
				{
					SetAvailableMapGoals( TEAM.AXIS, true, "SWITCH_Door_2" );
				}
			}
			else if ( trigger.Entity == 252 or trigger.Entity == 266 or trigger.Entity == 347 )
			{
				Map.Door_3 = "Opened";
				
				Util.MapDebugPrint( "Door_3_Opened" );
			}
		}
		else
		{
			if ( trigger.Entity == 234 or trigger.Entity == 248 or trigger.Entity == 329 )
			{
				Map.Door_1 = "Closed";
				
				Util.MapDebugPrint( "Door_1_Closed" );
			}
			else if ( trigger.Entity == 249 or trigger.Entity == 263 or trigger.Entity == 344 )
			{
				Map.Door_2 = "Closed";
				
				Util.DisableGoal( "ROUTE_Lager2Floor" );
				
				Util.MapDebugPrint( "Door_2_Closed" );
				
				SetAvailableMapGoals( TEAM.AXIS, false, "SWITCH_Door_2" );
				
				if ( Map.Gold_Secured < 3 )
				{
					SetAvailableMapGoals( TEAM.ALLIES, true, "SWITCH_Door_2" );
				}
			}
			else if ( trigger.Entity == 252 or trigger.Entity == 266 or trigger.Entity == 347 )
			{
				Map.Door_3 = "Closed";
				
				Util.MapDebugPrint( "Door_3_Closed" );
			}
		}
	},
	
