				crucialClass = {CLASS.ENGINEER, CLASS.FIELDOPS, CLASS.COVERTOPS, CLASS.MEDIC},
			},
		},
	},
	
	Movers =
	{
		"MOVER_tbdoor1_9"
	},
	
	Positions =
	{
		Vector3( 1661, 4933, 521 ),		//Truck_Left_Garage
		Vector3( 2489, 4925, 522 ),		//Truck_At_Barrier_1
		Vector3( 2727, 4923, 526 ),		//Truck_Past_Barrier_1
		Vector3( 3458, 3253, 505 ),		//Truck_At_Barrier_2
		Vector3( 3456, 3091, 515 ),		//Truck_Past_Barrier_2
		Vector3( 3366, 1136, 545 ),		//Truck_Approaching_Barn
		Vector3( 3684, -1533, 531 ),	//Truck_End
		Vector3( 1480, 4615, 380 ),		//Lager_A
		Vector3( 1480, 4765, 380 ),		//Lager_B
		Vector3( 1304, 4799, 380 ),		//Lager_C
	},
	
	Strings =
	{
		"Truck_Left_Garage",
		"Truck_At_Barrier_1",
		"Truck_Past_Barrier_1",
		"Truck_At_Barrier_2",
		"Truck_Past_Barrier_2",
