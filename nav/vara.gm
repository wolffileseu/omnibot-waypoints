	Radar_Bunker_Wall_Planted = function( trigger )
	{
		Util.MapDebugPrint( "Radar_Bunker_Wall_Planted" );
		
		if ( Map.Modified )
		{
			foreach( goal in Util.GoalTable("DEFUSE_Blow_up_the_Radarbunker_to_get_in_.*") )
			{
				goal.SetGoalPriority( TEAM.AXIS, 0 , 0.87 );
				goal.SetRoles(ROLE.DEFENDER1, ROLE.DEFENDER2);
				
				if ( Map.TruckEnd )
				{
					goal.SetRoles(ROLE.DEFENDER, ROLE.DEFENDER3);
				}
			}
		}
	},
	
	Radar_Bunker_Wall_Destroyed = function( trigger )
	{
		Map.Radar_Bunker_Wall = false;
		
		Util.MapDebugPrint( "Radar_Bunker_Wall_Destroyed" );
		
		SetAvailableMapGoals( TEAM.ALLIES, true, "PLANT_Radarcontrol" );
		
		if ( Map.Modified )
		{
			SetAvailableMapGoals( TEAM.AXIS, true, ".*_Axis_RadarIn_.*" );
			
			SetAvailableMapGoals( TEAM.ALLIES, true, ".*_Allies_RadarIn_.*" );
		}
	},
	
	Radar_Control_Planted = function( trigger )
	{
		Util.MapDebugPrint( "Radar_Control_Planted" );
		
		foreach( goal in Util.GoalTable("DEFUSE_Radarcontrol_.*") )
		{
			if ( Map.Modified )
			{
				goal.SetGoalPriority( TEAM.AXIS, 0 , 0.9 );
				goal.SetRoles(ROLE.DEFENDER1, ROLE.DEFENDER2);
				
				if ( Map.TruckEnd )
				{
					goal.SetRoles(ROLE.DEFENDER, ROLE.DEFENDER3);
				}
			}
			else
			{
				goal.SetAvailable(TEAM.AXIS, false);
			}
		}
	},
	
	Radar_Control_Built = function( trigger )
	{
		Map.Radar_Control = true;
		
		Wp.SetWaypointFlag( "Radar_Control_1", "closed", false );
		
		Util.MapDebugPrint( "Radar_Control_Built" );
		
		if ( Map.Modified and !Map.Radar_Bunker_Wall )
		{
			SetAvailableMapGoals( TEAM.ALLIES, true, {
				"PLANT_Radarcontrol",
				".*_Allies_RadarIn_.*",
				".*_Allies_GunOut_.*",
			});
		}
		
		Util.SetMaxUsers( 3, "BUILD_Radarcontrol" );
	},

	Radar_Control_Destroyed = function( trigger )
	{
		Map.Radar_Control = false;
		
		Wp.SetWaypointFlag( "Radar_Control_1", "closed", true );
		
		Util.MapDebugPrint( "Radar_Control_Destroyed" );
		
		foreach( goal in Util.GoalTable("DEFUSE_Radarcontrol_.*") )
		{
			goal.SetAvailable(TEAM.AXIS, false);
		}
		
		SetAvailableMapGoals( TEAM.ALLIES, false, "PLANT_Radarcontrol" );
		
		if ( Map.Modified )
		{
			SetAvailableMapGoals( TEAM.AXIS, true, "BUILD_Radarcontrol" );
		}
		else
		{
			SetAvailableMapGoals( TEAM.AXIS, false, ".*_Axis_RadarIn_.*" );
			
			SetAvailableMapGoals( TEAM.ALLIES, false, ".*_Allies_RadarIn_.*" );
		}
	},
	
	Truck_Built = function( trigger )
	{
		Map.Truck = true;
		
		Util.MapDebugPrint( "Truck_Built" );
		
		SetAvailableMapGoals( TEAM.ALLIES, false, "BUILD_Truck" );
		
		if ( Map.Gold_Secured == 3 )
		{
			SetAvailableMapGoals( TEAM.ALLIES, true, "ESCORT_Truck" );
		}
	},

	Truck_Destroyed = function( trigger )
	{
		Map.Truck = false;
		
		Util.MapDebugPrint( "Truck_Destroyed" );
		
		SetAvailableMapGoals( TEAM.ALLIES, false, "ESCORT_Truck" );
		
		if ( Map.Gold_Secured == 3 and ( !Map.TruckAtBarrier1 or !Map.Truck_Barrier_1 ) and ( !Map.TruckAtBarrier2 or !Map.Truck_Barrier_2 ) and !Map.TruckEnd )
		{
			SetAvailableMapGoals( TEAM.ALLIES, true, "BUILD_Truck" );
		}
	},
	
	Gold_Crate_Taken = function( trigger )
	{
		Map.Gold_Taken += 1;
		
		Util.MapDebugPrint( "Gold_Crate_Taken" );
		
		if ( Map.Gold_Taken == 2 )
		{
			SetAvailableMapGoals( TEAM.AXIS, false, {
				".*_Axis_Gold_.*",
				"DEFEND_Axis_Lager_.*",
			});
			
			SetAvailableMapGoals( TEAM.ALLIES, false, "FLAG_gold_crate" );
			
			SetAvailableMapGoals( TEAM.ALLIES, true, ".*_Allies_Barrier1_.*" );
		}
		
		SetAvailableMapGoals( TEAM.AXIS, true, ".*_Axis_Truck_.*" );
		
		SetAvailableMapGoals( TEAM.ALLIES, true, {
			"CAPPOINT_Truck",
			".*_Allies_Truck_.*",
		});
	},
	
	Gold_Crate_Returned = function( trigger )
	{
		Map.Gold_Taken -= 1;
		
		Util.MapDebugPrint( "Gold_Crate_Returned" );
		
		if ( tableCount(Map.count_AlliesGoldTrigger) < 1 )
		{
			SetAvailableMapGoals( TEAM.AXIS, false, ".*_Axis_Gold_.*" );
		}
		else
		{
			SetAvailableMapGoals( TEAM.AXIS, true, ".*_Axis_Gold_.*" );
		}
		
		SetAvailableMapGoals( TEAM.AXIS, true, "DEFEND_Axis_Lager_.*" );
		
		SetAvailableMapGoals( TEAM.ALLIES, true, "FLAG_gold_crate" );
		
		if ( Map.Gold_Taken == 0 )
		{
			SetAvailableMapGoals( TEAM.AXIS, false, ".*_Axis_Truck_.*" );
			
			SetAvailableMapGoals( TEAM.ALLIES, false, {
				"CAPPOINT_Truck",
				".*_Allies_Truck_.*",
				".*_Allies_Barrier1_.*",
			});
		}
	},
	
	Gold_Crate_Secured = function( trigger )
	{
		Map.Gold_Secured += 1;
		
		Util.MapDebugPrint( "Gold_Crate_Secured" );
		
		if ( Map.Gold_Secured == 3 )
		{
			SetGoalRole( "SWITCH_.*", ROLE.DEFENSECAPTAIN );
			
			SetAvailableMapGoals( TEAM.AXIS, false, {
				".*MG42_East_Bunker",
				".*_Axis_SideEntrance_.*",
				".*_Axis_SideEntrDest_.*",
				".*_Command_Post",
				".*_Axis_MainBunker_.*",
				".*_Axis_Gold_.*",
			});
			
			SetAvailableMapGoals( TEAM.ALLIES, false, "CAPPOINT_Truck" );
			
			SetAvailableMapGoals( TEAM.AXIS, true, ".*_Axis_Barrier1_.*" );
			
			if ( Map.Truck )
			{
				if ( Map.Garage_Door == "Opened" )
				{
					SetAvailableMapGoals( TEAM.ALLIES, true, "ESCORT_Truck" );
				}
			}
			else
			{
				SetAvailableMapGoals( TEAM.ALLIES, true, "BUILD_Truck" );
			}
			
			if ( !Map.Axis_Depot_MG_Nest )
			{
				SetAvailableMapGoals( TEAM.AXIS, true, "BUILD_Axis_North_West_MG_nest_1" );
			}
			else
			{
				SetAvailableMapGoals( TEAM.AXIS, true, "MOUNTMG42_Axis_North_West_MG_nest_1" );
				
				SetAvailableMapGoals( TEAM.ALLIES, true, "PLANT_Axis_North_West_MG_nest_1" );
			}
			
			if ( Map.Garage_Door == "Opened" )
			{
				SetAvailableMapGoals( TEAM.AXIS, true, "SWITCH_Garage_Gate" );
			}
			else
			{
				SetAvailableMapGoals( TEAM.ALLIES, true, "SWITCH_Garage_Gate" );
			}
			
			if ( !Map.Truck_Barrier_1 )
			{
				SetAvailableMapGoals( TEAM.AXIS, true, "BUILD_Truck_Barrier_1" );
			}
			else
			{
				SetAvailableMapGoals( TEAM.ALLIES, true, "PLANT_Truck_Barrier_1" );
			}
			
			if ( Map.Gun_Controls )
			{
				SetGoalRole( "CHECKPOINT_westbunker_flag", {ROLE.DEFENDER3, ROLE.ATTACKER3} );
			}
			else
			{
				SetGoalRole( "CHECKPOINT_westbunker_flag", ROLE.ATTACKER3 );
			}
			
			if ( Map.Modified )
			{
				Map.Roles.AXIS.DEFENDER3.spawnpt = 4;
			}
			
			Map.SetSpawn();
		}
	},
	
	Truck_Left_Garage = function( trigger )
	{
		Util.MapDebugPrint( "Truck_Left_Garage" );
		
		Map.TruckLeftGarage = true;
		
		SetAvailableMapGoals( TEAM.AXIS, false, {
			"SWITCH_Garage_Gate",
			".*_Axis_Truck_.*",
		});
		
		SetAvailableMapGoals( TEAM.ALLIES, false, {
			".*_Allies_Truck_.*",
			"SWITCH_Garage_Gate",
		});
		
		if ( !Map.Truck_Barrier_2 )
		{
			SetAvailableMapGoals( TEAM.AXIS, true, "BUILD_Truck_Barrier_2" );
		}
		else
		{
			SetAvailableMapGoals( TEAM.ALLIES, true, "PLANT_Truck_Barrier_2" );
		}
	},
	
	Truck_At_Barrier_1 = function( trigger )
	{
		Map.TruckAtBarrier1 = true;
		
		Util.MapDebugPrint( "Truck_At_Barrier_1" );
		
		if ( !Map.Truck )
		{
			SetAvailableMapGoals( TEAM.ALLIES, false, "BUILD_Truck" );
		}
	},
	
	Truck_Barrier_1_Built = function( trigger )
	{
		Map.Truck_Barrier_1 = true;
		
		Wp.SetWaypointFlag( "Truck_Barrier_1_1", "closed", false );
		
		Util.MapDebugPrint( "Truck_Barrier_1_Built" );
		
		SetAvailableMapGoals( TEAM.AXIS, false, "BUILD_Truck_Barrier_1" );
		
		if ( Map.TruckAtBarrier1 )
		{
			SetAvailableMapGoals( TEAM.ALLIES, false, "BUILD_Truck" );
		}
		
		if ( Map.Gold_Secured == 3 )
		{
			SetAvailableMapGoals( TEAM.ALLIES, true, "PLANT_Truck_Barrier_1" );
		}
	},

	Truck_Barrier_1_Planted = function( trigger )
	{
		Util.MapDebugPrint( "Truck_Barrier_1_Planted" );
		
		foreach( goal in Util.GoalTable("DEFUSE_Truck_Barrier_1_.*") )
		{
			name = goal.GetName();
			Util.SetGoalRange( name, 1000);
			goal.SetGoalPriority( TEAM.AXIS, 0 , 0.9 );
			goal.SetRoles(ROLE.DEFENDER, ROLE.DEFENDER3);
			
			if ( !Map.Modified and !Map.Gun_Controls )
			{
				goal.SetRoles(ROLE.DEFENDER1, ROLE.DEFENDER2);
			}
		}
	},
	
	Truck_Barrier_1_Destroyed = function( trigger )
	{
		Map.Truck_Barrier_1 = false;
		
		Wp.SetWaypointFlag( "Truck_Barrier_1_1", "closed", true );
		
		Util.MapDebugPrint( "Truck_Barrier_1_Destroyed" );
		
		foreach( goal in Util.GoalTable("DEFUSE_Truck_Barrier_1_.*") )
		{
			goal.SetAvailable(TEAM.AXIS, false);
		}
		
		SetAvailableMapGoals( TEAM.ALLIES, false, "PLANT_Truck_Barrier_1" );
		
		if (( Map.Gold_Secured > 0 or tableCount(Map.count_AlliesGoldTrigger) > 0 ) and !Map.TruckPastBarrier_1 )
		{
			SetAvailableMapGoals( TEAM.AXIS, true, "BUILD_Truck_Barrier_1" );
		}
		
		if ( Map.TruckAtBarrier1 )
		{
			SetAvailableMapGoals( TEAM.ALLIES, true, "BUILD_Truck" );
		}
	},
	
	Truck_Past_Barrier_1 = function( trigger )
	{
		Util.MapDebugPrint( "Truck_Past_Barrier_1" );
		
		Map.TruckAtBarrier1 = false;
		Map.TruckPastBarrier_1 = true;
		
		SetAvailableMapGoals( TEAM.AXIS, false, {
			"BUILD_Truck_Barrier_1",
			".*_Axis_North_West_MG_nest_1",
			".*_Axis_Barrier1_.*",
		});
		
		SetAvailableMapGoals( TEAM.ALLIES, false, {
			".*_Allies_Barrier1_.*",
			".*_Axis_North_West_MG_nest_1",
		});
		
		SetAvailableMapGoals( TEAM.ALLIES, true, ".*_Allies_Barrier2_.*" );
		
		SetAvailableMapGoals( TEAM.AXIS, true, ".*_Axis_Barrier2_.*" );
	},
	
