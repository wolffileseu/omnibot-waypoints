	RegionTrigger.Create(AABB(689.197,-1049.060,421.883,1041.937,-753.057,582.648), "DisableBotPush", "Barbwire");
	RegionTrigger.Create(AABB(1539.615,-941.679,453.167,1767.954,-657.505,664.905), "DisableBotPush", "Barbwire");
	RegionTrigger.Create(AABB(-3202.584,1857.446,440.102,-2969.198,2101.899,660.359), "DisableBotPush", "Side_Entrance");
	RegionTrigger.Create(AABB(-180.678,2651.536,820.012,-32.983,2770.915,910.189), "DisableCombatMovement", "Radar_Control_Wall");
	RegionTrigger.Create(AABB(2698.592,4519.538,585.125,2795.060,5630.718,709.119), "DisableCombatMovement", "Barrier1_Wall");
	RegionTrigger.Create(AABB(1168.125,4459.135,441.125,1298.979,4606.053,515.125), "DisableCombatMovement", "Switches");
	OnTriggerRegion(Vector3(-2.269, 1051.055, 450.939),600, RegionTrigger.DisableCombatMovement);	//around gun
	
	OnTriggerRegion(AABB(127.125,2695,825.358,192.875,2704.875,899.358), Map.Ignore_Target );
	OnTriggerRegion(AABB(-210.710,2900.215,839.447,-128.981,2961.655,900.264), Map.Ignore_Breakable );
	
	foreach( goal in Util.GoalTable("AMMOCAB_.*") )
	{
		name = goal.GetName();
		Util.SetGoalRange( name, 2000);
	}
	
	foreach( goal in Util.GoalTable("HEALTHCAB_.*") )
	{
		name = goal.GetName();
		Util.SetGoalRange( name, 2000);
	}
	
	foreach( goal in Util.GoalTable("SWITCH_.*") )
	{
		name = goal.GetName();
		Util.SetGoalRange( name, 800);
	}
	
	foreach( goal in Util.GoalTable(".*MG42_Axis_North_West_MG_nest_1") )
	{
		name = goal.GetName();
		Util.SetGoalRange( name, 900);
	}
	
	foreach( goal in Util.GoalTable("BUILD_Truck_Barrier_.*") )
	{
		name = goal.GetName();
		Util.SetGoalRange( name, 1000);
	}
	
	foreach( goal in Util.GoalTable("PLANTMINE_Axis_Barrier.*") )
	{
		name = goal.GetName();
		Util.SetGoalRange( name, 1100);
	}
	
	foreach( goal in Util.GoalTable("PLANTMINE_Axis_End_.*") )
	{
		name = goal.GetName();
		Util.SetGoalRange( name, 900);
	}
	
	WeaponTable.SetWeaponAvailability( CLASS.SOLDIER, WEAPON.MP40, true );
	WeaponTable.SetWeaponAvailability( CLASS.SOLDIER, WEAPON.THOMPSON, true );
	WeaponTable.SetWeaponAvailability( CLASS.SOLDIER, WEAPON.PANZERFAUST, false );
	WeaponTable.SetWeaponAvailability( CLASS.SOLDIER, WEAPON.FLAMETHROWER, false );
	
	if ( GetGameState() == "Playing" )
	{
		sleep(5);
		EchoToScreen(0,"^3Omni-bot map script ^3by ^1Q^2i^3k^4i ^3and ^1n^2a^4t^8i^3v^5e12 ^3");
		Util.BotChat( 0, "say", "^3Omni-bot map script ^3by ^1Q^2i^3k^4i ^3and ^1n^2a^4t^8i^3v^5e12^7" , 1 );
	}
	
	if ( Map.Debug )
	{
		Util.DebugColorString = "^3";
		
		while ( 1 )
		{
			for ( i = 0; i <= tableCount(Map.Positions) - 1; i += 1 )
			{
				if ( i < 7 )
				{
					DrawRadius( Map.Positions[i], 75, COLOR.BLUE, 1 );
					DrawDebugLine( Map.Positions[i] + Vec3(0,0,25), Map.Positions[i] - Vec3(0,0,25), COLOR.MAGENTA, 1 );
					DrawText3d( Map.Positions[i] + Vec3(0,0,25), Map.Strings[i], COLOR.AQUAMARINE, 1 );
				}
				else
				{
					DrawText3d( Map.Positions[i], Map.Strings[i], COLOR.AQUAMARINE, 1 );
				}
			}
			sleep(1);
		}
	}
};

global OnBotJoin = function( bot )
{
	bot.TargetBreakableDist = 130;
};

global InitializeRoutes = function()
{
	routeGarage =
    {
        ROUTE_GarageFloor = {Weight = 2,},
        ROUTE_Lager2Floor = {},
        ROUTE_Stairs = {},
    };
	
	MapRoutes =
	{
		FLAG_gold_crate =
		{
			ROUTE_WestBunkerSpawn =
			{
				ROUTE_TruckWay =
				{
					ROUTE_GarageDoor = routeGarage,
					ROUTE_UpperDoor =
					{
						ROUTE_UpperDoorOut =
						{
							ROUTE_UpperDoorIns = routeGarage,
						},
					},
				},
			},
			ROUTE_UpperDoorIns = routeGarage,
		},
	};
	
	MapRoutes[".*_Axis_GunOut_.*"] =
	{
		ROUTE_GunControl_Spawn_1 =
		{
			ROUTE_SideTunnelToGun_1 =
			{
				Weight = 2,
				ROUTE_SideTunnelToGun_2 = {},
			},
			ROUTE_UnderGun_1 =
			{
				ROUTE_LadderOut = {},
			},
		},
	};
	
	MapRoutes[".*_Axis_GunIn_.*"] =
	{
		ROUTE_GunControl_Spawn_1 =
		{
			ROUTE_SideTunnelToGun_1 =
			{
				ROUTE_SideTunnelToGun_2 = {},
			},
			ROUTE_UnderGun_1 =
			{
				ROUTE_LadderBelowGun =
				{
					ROUTE_InsideGun = {},
				},
			},
		},
	};
	
	MapRoutes[".*_Axis_RadarIn_.*"] =
	{
		ROUTE_GunControl_Spawn_1 =
		{
			ROUTE_SideTunnelToGun_1 =
			{
				ROUTE_SideTunnelToGun_2 = {},
			},
		},
	};
	
	MapRoutes[".*_Allies_Barrier.*"] =
	{
		ROUTE_CP_Spawn =
		{
			ROUTE_Main_Bunker =
			{
				ROUTE_Gold_Way = {},
			},
		},
	};
	
	MapRoutes[".*_Axis_GunOut_.*"].ROUTE_GunControl_Spawn_2 = MapRoutes[".*_Axis_GunOut_.*"].ROUTE_GunControl_Spawn_1;
	MapRoutes[".*_Axis_GunOut_.*"].ROUTE_GunControl_Spawn_3 = MapRoutes[".*_Axis_GunOut_.*"].ROUTE_GunControl_Spawn_1;
	MapRoutes[".*_Axis_GunOut_.*"].ROUTE_GunControl_Spawn_4 = MapRoutes[".*_Axis_GunOut_.*"].ROUTE_GunControl_Spawn_1;
	MapRoutes[".*_Axis_GunOut_.*"].ROUTE_MainBunkerSpawn = MapRoutes[".*_Axis_GunOut_.*"].ROUTE_GunControl_Spawn_1;
	MapRoutes[".*_Axis_GunIn_.*"].ROUTE_GunControl_Spawn_2 = MapRoutes[".*_Axis_GunIn_.*"].ROUTE_GunControl_Spawn_1;
	MapRoutes[".*_Axis_GunIn_.*"].ROUTE_GunControl_Spawn_3 = MapRoutes[".*_Axis_GunIn_.*"].ROUTE_GunControl_Spawn_1;
	MapRoutes[".*_Axis_GunIn_.*"].ROUTE_GunControl_Spawn_4 = MapRoutes[".*_Axis_GunIn_.*"].ROUTE_GunControl_Spawn_1;
	MapRoutes[".*_Axis_GunIn_.*"].ROUTE_MainBunkerSpawn = MapRoutes[".*_Axis_GunIn_.*"].ROUTE_GunControl_Spawn_1;
	MapRoutes[".*_Axis_RadarIn_.*"].ROUTE_GunControl_Spawn_2 = MapRoutes[".*_Axis_RadarIn_.*"].ROUTE_GunControl_Spawn_1;
	MapRoutes[".*_Axis_RadarIn_.*"].ROUTE_GunControl_Spawn_3 = MapRoutes[".*_Axis_RadarIn_.*"].ROUTE_GunControl_Spawn_1;
	MapRoutes[".*_Axis_RadarIn_.*"].ROUTE_GunControl_Spawn_4 = MapRoutes[".*_Axis_RadarIn_.*"].ROUTE_GunControl_Spawn_1;
	MapRoutes[".*_Axis_RadarIn_.*"].ROUTE_MainBunkerSpawn = MapRoutes[".*_Axis_RadarIn_.*"].ROUTE_GunControl_Spawn_1;
	MapRoutes["PLANT_Truck_Barrier.*"] = MapRoutes[".*_Allies_Barrier.*"];
	
	Util.Routes(MapRoutes);
};