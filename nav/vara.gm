//==========================================================================================
//	We've made a modification for standart version of this map (vara_radarcontrol.pk3).
//	In modified version allies must also destroy the radar control in order to win
//	and axis must keep it built to prevent allies from winning.
//	Axis have additional spawn at garage.
//	If you want this modification, download and move this pk3 file (link below) into ETMAIN folder:
//	https://app.assembla.com/spaces/omnibot/tickets/207-vara/details#
//
//	Keep your omni-bot scripts up to date!
//	Bugs and suggestions: PM on https://fearless-assassins.com/

global Map =
{
	Debug = 0,
	Allied_West_Beach_MG_Nest = false,
	Axis_North_West_MG_Nest = false,
	Axis_Depot_MG_Nest = false,
	Allied_CP = false,
	Axis_CP = false,
	East_Beach_Barrier = false,
	Radar_Control = false,
	Truck = true,
	Truck_Barrier_1 = false,
	Truck_Barrier_2 = false,
	West_Beach_Barrier = false,
	Radar_Bunker_Wall = true,
	Fence = true,
	Gun_Controls = true,
	Side_Entrance = true,
	West_Bunker = TEAM.AXIS,
	Garage_Door = "Opened",
	Door_1 = "Closed",
	Door_2 = "Closed",
	Door_3 = "Closed",
	Gold_Taken = 0,
	Gold_Secured = 0,
	Modified = false,
	count_AlliesGoldTrigger = {},
	TruckLeftGarage = false,
	TruckPastBarrier_1 = false,
	TruckAtBarrier1 = false,
	TruckAtBarrier2 = false,
	TruckEnd = false,
	TruckPastBarrier_2 = false,
	Lager_2_Floor = true,
	Garage_Floor = true,
	Lager_A_Door_Opened = false,
	Lager_B_Door_Opened = false,
	Lager_C_Door_Opened = false,
	
	DontDispenseAmmo = true,
	
	Navigation =
	{
		//	/bot waypoint_setproperty paththrough Navigation_PT:jump
		jump =
		{
			navigate = function(_this)
			{
				_this.Bot.HoldButton(BTN.JUMP, 0.55);
				sleep(0.55);
			},
		},
		
		//	/bot waypoint_setproperty paththrough Navigation_PT:gold_take
		gold_take =
		{
			EvalFunc = function(_this)
			{
				goal = _this.Bot.GetMapGoalName();
				
				if ( goal == "FLAG_gold_crate" )
				{
					return true;
				}
				else
				{
					return false;
				}
			},
			navigate = function(_this)
			{
				_this.Goto(_this.Bot.GetPosition());
				_this.AddAimRequest(Priority.VeryHigh, "position", Vec3( 1693.784, 4527.276, 264.125 ));
				sleep(0.3);
				_this.Bot.PressButton(BTN.USE);
				sleep(0.1);
				_this.Bot.PressButton(BTN.USE);
				sleep(0.1);
				_this.Bot.PressButton(BTN.USE);
			},
		},
		
		//	/bot waypoint_setproperty paththrough Navigation_PT:jump_wait
		jump_wait =
		{
			navigate = function(_this)
			{
				sleep(0.5);
				_this.Bot.HoldButton(BTN.JUMP, 0.55);
				sleep(0.55);
			},
		},
		
		//	/bot waypoint_setproperty paththrough Navigation_PT:garage_floor_up
		garage_floor_up =
		{
			EvalFunc = function(_this)
			{
				return Map.Garage_Floor;
			},
			navigate = function(_this)
			{
				_this.Goto(_this.Bot.GetPosition());
				_this.AddAimRequest(Priority.VeryHigh, "facing", Vec3( 0, -0.316, -0.949 ));
				_this.AddWeaponRequest(Priority.VeryHigh, WEAPON.KNIFE );
				sleep(0.5);
				_this.timer = 0;
				
				while ( Map.Garage_Floor )
				{
					_this.timer += 1;
					_this.Bot.PressButton(BTN.ATTACK1);
					_this.Bot.PressButton(BTN.CROUCH);
					sleep(0.1);
					
					if ( _this.timer > 100 )
					{
						return;
					}
				}
			},
		},
		
		//	/bot waypoint_setproperty paththrough Navigation_PT:garage_floor_down
		garage_floor_down =
		{
			EvalFunc = function(_this)
			{
				if ( !Map.Garage_Floor )
				{
					sleep(0.5);
					_this.Bot.HoldButton(BTN.JUMP, 0.55);
					sleep(0.55);
				}
				return Map.Garage_Floor;
			},
			navigate = function(_this)
			{
				_this.Goto(_this.Bot.GetPosition());
				_this.AddAimRequest(Priority.VeryHigh, "facing", Vec3( 0, 0.411, 0.912 ));
				_this.AddWeaponRequest(Priority.VeryHigh, WEAPON.KNIFE );
				sleep(0.5);
				_this.timer = 0;
				
				while ( Map.Garage_Floor )
				{
					_this.timer += 1;
					_this.Bot.PressButton(BTN.ATTACK1);
					sleep(0.1);
					
					if ( _this.timer > 100 )
					{
						return;
					}
				}
			},
		},
		
		//	/bot waypoint_setproperty paththrough Navigation_PT:lager_2_up
		lager_2_up =
		{
			EvalFunc = function(_this)
			{
				return Map.Lager_2_Floor;
			},
			navigate = function(_this)
			{
				_this.Goto(_this.Bot.GetPosition());
				_this.AddAimRequest(Priority.VeryHigh, "facing", Vec3( 0, 0.321, -0.947 ));
				_this.AddWeaponRequest(Priority.VeryHigh, WEAPON.KNIFE );
				sleep(0.5);
				_this.timer = 0;
				
				while ( Map.Lager_2_Floor )
				{
					_this.timer += 1;
					_this.Bot.PressButton(BTN.ATTACK1);
					_this.Bot.PressButton(BTN.CROUCH);
					sleep(0.1);
					
					if ( _this.timer > 100 )
					{
						_this.Bot.MoveTowards(Vec3(1609, 4420, 505), 10);
						return;
					}
				}
			},
		},
		
		//	/bot waypoint_setproperty paththrough Navigation_PT:lager_2_down
		lager_2_down =
		{
			EvalFunc = function(_this)
			{
				if ( !Map.Lager_2_Floor )
				{
					sleep(0.5);
					_this.Bot.HoldButton(BTN.JUMP, 0.55);
					sleep(0.55);
				}
				
				return Map.Lager_2_Floor;
			},
			navigate = function(_this)
			{
				_this.Goto(_this.Bot.GetPosition());
				_this.AddAimRequest(Priority.VeryHigh, "facing", Vec3( 0, 0, 1 ));
				_this.AddWeaponRequest(Priority.VeryHigh, WEAPON.KNIFE );
				sleep(0.5);
				_this.timer = 0;
				
				while ( Map.Lager_2_Floor )
				{
					_this.timer += 1;
					_this.Bot.PressButton(BTN.ATTACK1);
					sleep(0.1);
					
					if ( _this.timer > 100 )
					{
						return;
					}
				}
			},
		},
			
		//	/bot waypoint_setproperty paththrough Navigation_PT:lager_a_door
		lager_a_door =
		{
			EvalFunc = function(_this)
			{
				if ( Map.Lager_A_Door_Opened )
				{
					return false;
				}
				else
				{
					return true;
				}
			},
			navigate = function(_this)
			{
				_this.Goto(_this.Bot.GetPosition());
				
				if ( _this.Bot.GetPosition().x > 1503 )	//Inside
				{
					_this.AddAimRequest(Priority.VeryHigh, "position", Vec3( 1446.367, 4552.803, 264.125 ));
					
					for ( timer = 0; timer < 50 and !Map.Lager_A_Door_Opened; timer += 1 )
					{
						_this.Bot.PressButton(BTN.USE);
						sleep(0.1);
					}
					
					if ( !Map.Lager_A_Door_Opened )
					{
						_this.ReleaseAimRequest();
						
						for ( timer = 0; timer < 50 and !_this.Bot.MoveTowards(Vec3(1555, 4529, 288), 25); timer += 1 )
						{
							sleep(0.1);
						}
						return;
					}
					
					_this.ReleaseAimRequest();
					
					for ( timer = 0; timer < 50 and !_this.Bot.MoveTowards(Vec3(1405, 4616, 288), 10); timer += 1 )
					{
						sleep(0.1);
					}
				}
				else	//Outside
				{
					_this.AddAimRequest(Priority.VeryHigh, "position", Vec3( 1559.963, 4554.548, 264.125 ));
					
					for ( timer = 0; timer < 50 and !Map.Lager_A_Door_Opened; timer += 1 )
					{
						_this.Bot.PressButton(BTN.USE);
						sleep(0.1);
					}
					
					if ( !Map.Lager_A_Door_Opened )
					{
						_this.ReleaseAimRequest();
						
						for ( timer = 0; timer < 50 and !_this.Bot.MoveTowards(Vec3(1457, 4696, 288), 25); timer += 1 )
						{
							sleep(0.1);
						}
						return;
					}
					
					_this.ReleaseAimRequest();
					
					for ( timer = 0; timer < 50 and !_this.Bot.MoveTowards(Vec3(1561, 4616, 288), 10); timer += 1 )
					{
						sleep(0.1);
					}
				}
			},
		},
		
		//	/bot waypoint_setproperty paththrough Navigation_PT:lager_b_door
		lager_b_door =
		{
			EvalFunc = function(_this)
			{
				if ( Map.Lager_B_Door_Opened )
				{
					return false;
				}
				else
				{
					return true;
				}
			},
			navigate = function(_this)
			{
				_this.Goto(_this.Bot.GetPosition());
				
				if ( _this.Bot.GetPosition().x > 1503 )	//Inside
				{
					_this.AddAimRequest(Priority.VeryHigh, "position", Vec3( 1455.521, 4826.750, 264.125 ));
					
					for ( timer = 0; timer < 50 and !Map.Lager_B_Door_Opened; timer += 1 )
					{
						_this.Bot.PressButton(BTN.USE);
						sleep(0.1);
					}
					
					if ( !Map.Lager_B_Door_Opened )
					{
						_this.ReleaseAimRequest();
						
						for ( timer = 0; timer < 50 and !_this.Bot.MoveTowards(Vec3(1610, 4769, 288), 25); timer += 1 )
						{
							sleep(0.1);
						}
						return;
					}
					
					_this.ReleaseAimRequest();
					
					for ( timer = 0; timer < 50 and !_this.Bot.MoveTowards(Vec3(1398, 4767, 288), 10); timer += 1 )
					{
						sleep(0.1);
					}
				}
				else	//Outside
				{
					_this.AddAimRequest(Priority.VeryHigh, "position", Vec3( 1553.020, 4830.665, 264.125 ));
					
					for ( timer = 0; timer < 50 and !Map.Lager_B_Door_Opened; timer += 1 )
					{
						_this.Bot.PressButton(BTN.USE);
						sleep(0.1);
					}
					
					if ( !Map.Lager_B_Door_Opened )
					{
						_this.ReleaseAimRequest();
						
						for ( timer = 0; timer < 50 and !_this.Bot.MoveTowards(Vec3(1397, 4801, 288), 25); timer += 1 )
						{
							sleep(0.1);
						}
						return;
					}
					
					_this.ReleaseAimRequest();
					
					for ( timer = 0; timer < 50 and !_this.Bot.MoveTowards(Vec3(1545, 4768, 288), 10); timer += 1 )
					{
						sleep(0.1);
					}
				}
			},
		},
		
		
		//	/bot waypoint_setproperty paththrough Navigation_PT:lager_c_door
		lager_c_door =
		{
			EvalFunc = function(_this)
			{
				if ( Map.Lager_C_Door_Opened )
				{
					return false;
				}
				else
				{
					return true;
				}
			},
			navigate = function(_this)
			{
				_this.Goto(_this.Bot.GetPosition());
				
				if ( _this.Bot.GetPosition().x < 1285 )	//Inside
				{
					_this.AddAimRequest(Priority.VeryHigh, "position", Vec3( 1333.305, 4859.105, 264.125 ));
					
					for ( timer = 0; timer < 50 and !Map.Lager_C_Door_Opened; timer += 1 )
					{
						_this.Bot.PressButton(BTN.USE);
						sleep(0.1);
					}
					
					if ( !Map.Lager_C_Door_Opened )
					{
						_this.ReleaseAimRequest();
						
						for ( timer = 0; timer < 50 and !_this.Bot.MoveTowards(Vec3(1218, 4876, 288), 25); timer += 1 )
						{
							sleep(0.1);
						}
						return;
					}
					
					_this.ReleaseAimRequest();
					
					for ( timer = 0; timer < 50 and !_this.Bot.MoveTowards(Vec3(1398, 4800, 288), 10); timer += 1 )
					{
						sleep(0.1);
					}
				}
				else	//Outside
				{
					_this.AddAimRequest(Priority.VeryHigh, "position", Vec3( 1216.514, 4861.291, 264.125 ));
					
					for ( timer = 0; timer < 50 and !Map.Lager_C_Door_Opened; timer += 1 )
					{
						_this.Bot.PressButton(BTN.USE);
						sleep(0.1);
					}
					
					if ( !Map.Lager_C_Door_Opened )
					{
						_this.ReleaseAimRequest();
						
						for ( timer = 0; timer < 50 and !_this.Bot.MoveTowards(Vec3(1397, 4801, 288), 25); timer += 1 )
						{
							sleep(0.1);
						}
						return;
					}
					
					_this.ReleaseAimRequest();
					
					for ( timer = 0; timer < 50 and !_this.Bot.MoveTowards(Vec3(1217, 4801, 288), 10); timer += 1 )
					{
						sleep(0.1);
					}
				}
			},
		},
	},
		
	Roles =
	{
		AXIS =
		{
			AllBots = true,
			DEFENDER =	
			{
				spawnpt = 3,
				numbots = 5,
				crucialClass = {CLASS.SOLDIER, CLASS.FIELDOPS, CLASS.MEDIC},
			},
			DEFENDER1 =	
			{
