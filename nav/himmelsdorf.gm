global Map =
{
	Debug = 0,
	Allied_Command_Post = false,
	Axis_Command_Post = false,
	Tank = false,
	Truck = true,
	Truck_Barrier_1 = false,
	Truck_Barrier_2 = false,
	Tunnel_Door = true,
	Brickwall = true,
	Depot_Side_Door = true,
	Gold_Depository_Door = true,
	Main_Gate = true,
	Gold_Taken = 0,
	Gold_Secured = 0,
	Tank_Fuel = "Returned",
	Lift = "Down",
	Lift_botId = {-1, -1, -1, -1, -1, -1, -1, -1},
	Bot_Ready = {false, false, false, false, false, false, false, false},
	boarding = false,
	Bookcase = "Closed",
	First_corner = false,
	Second_corner = false,
	TruckAtBarrier_1 = false,
	TruckPastBarrier_1 = false,
	TruckAtBarrier_2 = false,
	TruckPastBarrier_2 = false,
	SpawnChange = false,
	Version = null,
	MG_Mount_Team = 0,
	
	Lift_Positions =
	{
		Vec3(-42.125, -1573.875, -351.875),		//ride pos 0
		Vec3(-42.125, -1474.125, -351.875),		//ride pos 1
		Vec3(-221.875, -1573.875, -351.875),	//ride pos 2
		Vec3(-221.875, -1474.125, -351.875),	//ride pos 3
		Vec3(-107.739, -1573.875, -351.875),	//ride pos 4
		Vec3(-42.125, -1522.628, -351.875),		//ride pos 5
		Vec3(-221.875, -1522.786, -351.875),	//ride pos 6
		Vec3(-160.704, -1573.875, -351.875),	//ride pos 7
		Vec3(-129.022, -1521.078, -351.875),	//board pos
	},
	
	Strings =
	{
		"Ride_Pos_0",
		"Ride_Pos_1",
		"Ride_Pos_2",
		"Ride_Pos_3",
		"Ride_Pos_4",
		"Ride_Pos_5",
		"Ride_Pos_6",
		"Ride_Pos_7",
		"Board_Pos",
	},
	
	Navigation =
	{
		//	/bot waypoint_setproperty paththrough Navigation_PT:jump
		jump =
		{
			navigate = function(_this)
			{
				_this.Bot.HoldButton(BTN.JUMP, 0.55);
				sleep(0.55);
			},
		},
		
		//	/bot waypoint_setproperty paththrough Navigation_PT:lift
		lift =
		{
			OnExit = function()
			{
				for ( i = 0; i <= 7; i+=1 )
				{
					if ( Map.Lift_botId[i] == this.Bot.GetGameId() )
					{
						Map.Lift_botId[i] = -1;
						Map.Bot_Ready[i] = false;
					}
				}
				Map.boarding = false;
				this.Bot.DisableCombatMovement = false;
			},

			navigate = function()
			{
				this.Goto(this.Bot.GetPosition());
				this.Bot.DisableCombatMovement = true;

				for ( i = 0; ; i+= 1 )
				{
					if ( i == 8 )
					{
						sleep(0.5);
						return;
					}
					
					if ( Map.Lift_botId[i] == -1 )
					{
						Map.Lift_botId[i] = this.Bot.GetGameId();
						slot = i;
						break;
					}
				}

				while ( Map.Lift != "Down" or Map.boarding )
				{
					yield();
				}
				
				if ( Map.Lift != "Down" )
				{
					return;
				}
				
				timer = 0;
				while ( !this.Bot.MoveTowards(Map.Lift_Positions[8], 35) )
				{
					Map.boarding = true;
					sleep(0.1);
					timer += 1;
					if ( timer == 100 )
					{
						return;
					}
				}
				Map.boarding = false;
				timer = 0;
				while ( !this.Bot.MoveTowards(Map.Lift_Positions[slot], 20) )
				{
					sleep(0.1);
					timer += 1;
					
					if ( Map.Lift == "Up" or timer == 50 )
					{
						return;
					}
				}

				Map.Bot_Ready[i] = true;
				
				for ( i = 0; i <= 7; i+= 1 )
				{
					if ( Map.Lift_botId[i] != -1 )
					{
						while ( !Map.Bot_Ready[i] and Map.Lift_botId[i] != -1 )
						{
							yield();
							
							if ( Map.Lift == "Up" )
							{
								return;
							}
						}
					}
				}
				
				while ( Map.Lift != "Moving" )
				{
					this.AddAimRequest(Priority.VeryHigh, "facing", Vec3(0, 0, -1));
					sleep(0.1);
					this.Bot.PressButton(BTN.USE);
					
					if ( Map.Lift == "Up" )
					{
						return;
					}
				}
				this.ReleaseAimRequest();
				
				while ( Map.Lift != "Up" )
				{
					this.Bot.MoveTowards(this.Bot.GetPosition());
					yield();
				}
			},
		},
		
		//	/bot waypoint_setproperty paththrough Navigation_PT:bookcase
		bookcase =
		{
			EvalFunc = function()
			{
				return Map.Bookcase != "Opened";
			},
			navigate = function()
			{
				this.Goto(this.Bot.GetPosition());
				
				while ( Map.Bookcase == "Moving" )
				{
					yield();
				}
				
				if ( Map.Bookcase == "Closed" )
				{
					if ( this.Bot.GetPosition().x < 716 )	//Outside
					{
						this.AddAimRequest(Priority.VeryHigh, "facing", Vec3( 1, 0, 0 ));
					}
					else
					{
						this.AddAimRequest(Priority.VeryHigh, "facing", Vec3( -1, 0, 0 ));
					}
					sleep(0.5);
					timer = 0;
					
					while ( Map.Bookcase != "Moving" )
					{
						sleep(0.1);
						timer += 1;
						this.Bot.HoldButton(BTN.USE, 0.1);
						
						if ( timer == 50 )
						{
							return;
						}
					}
					this.ReleaseAimRequest();
				}
				
				while ( Map.Bookcase == "Moving" )
				{
					yield();
				}
			},
		},
	},
	
	Allied_Command_Post_Built = function()
	{
		Map.Allied_Command_Post = true;
		
		Util.MapDebugPrint( "Allied_Command_Post_Built" );
		
		SetAvailableMapGoals( TEAM.ALLIES, false, "BUILD_Allied_Command_Post");
		
		if ( !Map.TruckPastBarrier_1 )
		{
			SetAvailableMapGoals( TEAM.AXIS, true, "PLANT_Allied_Command_Post");
		}
	},
	
	Allied_Command_Post_Destroyed = function()
	{
		Map.Allied_Command_Post = false;
		
		Util.MapDebugPrint( "Allied_Command_Post_Destroyed" );
		
		SetAvailableMapGoals( TEAM.AXIS, false, "PLANT_Allied_Command_Post");
		
		SetAvailableMapGoals( TEAM.ALLIES, true, "BUILD_Allied_Command_Post");
	},
	
	Tunnel_Door_Planted = function()
	{
		Wp.SetWaypointFlag( "Old_City_Spawn_Exit", "closed", false );
		
		Util.MapDebugPrint( "Tunnel_Door_Planted" );
	},
	
	Tunnel_Door_Defused = function()
	{
		if ( tableCount(Util.GoalTable("DEFUSE_Tunnel_Door_.*")) == 1 )
		{
			Wp.SetWaypointFlag( "Old_City_Spawn_Exit", "closed", true );
			
			Util.MapDebugPrint( "WP closed" );
		}
		
		Util.MapDebugPrint( "Tunnel_Door_Defused" );
	},
	
	Tunnel_Door_Destroyed = function()
	{
		Map.Tunnel_Door = false;
		
		Util.MapDebugPrint( "Tunnel_Door_Destroyed" );
		
		Wp.SetWaypointFlag( "Old_City_Spawn_Exit", "closed", true );
		
		foreach( goal in Util.GoalTable("DEFUSE_Tunnel_Door_.*") )
		{
			goal.SetAvailable(TEAM.AXIS, false);
		}
		
		SetAvailableMapGoals( TEAM.ALLIES, false, "PLANT_Tunnel_Door" );
		
		sleep(2.5);
		
		Util.SetGoalPosition(-965.811, 1687.875, -382.875, "DEFEND_Axis_Fuel_04");
		Util.SetGoalPosition(-850.125, 1687.875, -372.875, "DEFEND_Axis_Fuel_06");
		GetGoal("DEFEND_Axis_Fuel_04").AimVectors = { Vec3(0.280, -0.960, 0.023) };
		GetGoal("DEFEND_Axis_Fuel_06").AimVectors = { Vec3(-0.315, -0.949, -0.013) };
		
		SetAvailableMapGoals( TEAM.ALLIES, false, ".*_Allies_Fuel_.*" );
		
		if ( Map.Tank_Fuel != "Taken" )
		{
			SetAvailableMapGoals( TEAM.ALLIES, true, {
				"FLAG_tank_fuel",
				"SMOKEBOMB_Allies_Fuel_.*"
			});
		}
	},
	
	Tank_Fuel_Taken = function()
	{
		Map.Tank_Fuel = "Taken";
		
		Util.MapDebugPrint( "Tank_Fuel_Taken" );
		
		Wp.SetWaypointFlag( "Old_City_Spawn_Exit", "closed", false );
		
		SetAvailableMapGoals( TEAM.ALLIES, false, "FLAG_tank_fuel" );
		
		SetAvailableMapGoals( TEAM.ALLIES, true, {
			"CAPPOINT_Tank",
			".*_Allies_Tank_.*",
			".*_Allies_CappointTankWay_.*"
		});
		
		sleep(2);
		
		if ( Map.Tank_Fuel == "Taken" )
		{
			SetAvailableMapGoals( TEAM.AXIS, false, ".*_Axis_Fuel_.*" );
			
			SetAvailableMapGoals( TEAM.AXIS, true, ".*_Axis_Tank_.*" );
			
			SetAvailableMapGoals( TEAM.ALLIES, false, "SMOKEBOMB_Allies_Fuel_.*" );
		}
	},

	Tank_Fuel_Dropped = function()
	{
		Map.Tank_Fuel = "Dropped";
		
		Util.MapDebugPrint( "Tank_Fuel_Dropped" );
	},

	Tank_Fuel_Returned = function()
	{
		Map.Tank_Fuel = "Returned";
		
		Util.MapDebugPrint( "Tank_Fuel_Returned" );
		
		Wp.SetWaypointFlag( "Old_City_Spawn_Exit", "closed", true );
		
		SetAvailableMapGoals( TEAM.AXIS, false, ".*_Axis_Tank_.*" );
		
		SetAvailableMapGoals( TEAM.ALLIES, false, {
			"CAPPOINT_Tank",
			".*_Allies_Tank_.*",
			".*_Allies_CappointTankWay_.*"
		});
		
		SetAvailableMapGoals( TEAM.AXIS, true, ".*_Axis_Fuel_.*" );
		
		SetAvailableMapGoals( TEAM.ALLIES, true, {
			"FLAG_tank_fuel",
			"SMOKEBOMB_Allies_Fuel_.*",
		});
	},

	Tank_Fuel_Secured = function()
	{
		Map.Tank_Fuel = "Secured";
		
		Util.MapDebugPrint( "Tank_Fuel_Secured" );
		
		Wp.SetWaypointFlag( "Old_City_Spawn_Exit", "closed", true );
		
		SetAvailableMapGoals( TEAM.ALLIES, false, "CAPPOINT_Tank" );
		
		SetAvailableMapGoals( TEAM.ALLIES, true, "BUILD_Tank" );
	},
	
	Tank_Built = function()
	{
		Map.Tank = true;
		
		Util.MapDebugPrint( "Tank_Built" );
		
		SetAvailableMapGoals( TEAM.ALLIES, false, {
			"CAPPOINT_Tank",
			"BUILD_Tank",
			".*_Allies_Tank_.*",
			".*_Allies_CappointTankWay_.*"
		});
		
		SetAvailableMapGoals( TEAM.AXIS, false, ".*_Axis_Tank_.*" );
		
		if ( Map.Main_Gate )
		{
			SetAvailableMapGoals( TEAM.ALLIES, true, {
				"ESCORT_Tank",
			});
			
			if ( !Map.First_corner )
			{
				SetAvailableMapGoals( TEAM.AXIS, true, ".*_Axis_FirstTankWay_.*" );
			}
			if ( !Map.Second_corner )
			{
				SetAvailableMapGoals( TEAM.AXIS, true, {
					".*_Axis_SecondTankWay_.*",
					".*MG42_Tank_Route",
				});
				
				SetAvailableMapGoals( TEAM.ALLIES, true, ".*_Allies_TankPathStart_.*" );
			}
		}
	},
	
	Tank_Destroyed = function()
	{
		Map.Tank = false;
		
		Util.MapDebugPrint( "Tank_Destroyed" );
		
		if ( Map.Main_Gate )
		{
			SetAvailableMapGoals( TEAM.ALLIES, true, "BUILD_Tank" );
		}
	},
	
	Tank_At_Corner_1 = function()
	{
		Util.MapDebugPrint( "Tank_At_Corner_1" );
		
		Map.First_corner = true;
		
		SetAvailableMapGoals( TEAM.AXIS, false, ".*_Axis_FirstTankWay_.*" );
		
		ETUtil.SetExcludeIndexes( "BUILD_Tank", { 1, 2, 3, 4 } );
		
		SetAvailableMapGoals( TEAM.ALLIES, true, ".*_Allies_TankPastCorn1_.*" );
	},
	
	Tank_At_Corner_2 = function()
	{
		Util.MapDebugPrint( "Tank_At_Corner_2" );
		
		Map.Second_corner = true;
		
		SetAvailableMapGoals( TEAM.AXIS, false, ".*_Axis_SecondTankWay_.*" );
		
		SetAvailableMapGoals( TEAM.AXIS, true, {
			".*_Axis_ThirdTankWay_.*",
			".*MG42_Watchtower",
			"PLANTMINE_Axis_DepotWay_.*"
		});
		
		SetAvailableMapGoals( TEAM.ALLIES, false, {
			".*_Allies_TankPathStart_.*",
			".*_Allies_TankPastCorn1_.*"
		});
		
		SetAvailableMapGoals( TEAM.ALLIES, true, ".*_Allies_TankPathEnd_.*" );
	},
	
	Tank_At_Barrier = function()
	{
		Util.MapDebugPrint( "Tank_At_Barrier" );
		
		SetAvailableMapGoals( TEAM.AXIS, true, "DEFEND_Axis_DepotSideDoor_.*" );
	},
	
	Main_Gate_Destroyed = function()
	{
		Map.Main_Gate = false;
		
		thread ( Map.MG_Facing );
		
		Wp.SetWaypointFlag( "Tank_Path_.*", "blockwall", false );
		Wp.SetWaypointFlag( "Truck_Path_.*", "blockwall", true );
		
		Util.MapDebugPrint( "Main_Gate_Destroyed" );
		
		SetAvailableMapGoals( TEAM.AXIS, false, {
			".*_Axis_ThirdTankWay_.*",
			".*MG42_Tank_Route",
			".*MG42_Watchtower",
			"PLANTMINE_Axis_DepotWay_.*"
		});
		
		SetAvailableMapGoals( TEAM.AXIS, true, {
			".*MG42_Gold_Depository",
			".*MG42_Truck_Barrier_1",
			".*MG42_Road_1",
			".*_Axis_GoldDeposDoor_.*",
			".*_Axis_GoldDeposWay_.*",
			".*_Axis_DepotSideDoor_.*"
		});
		
		if ( !Map.Truck_Barrier_1 )
		{
			SetAvailableMapGoals( TEAM.AXIS, true, "BUILD_Truck_Barrier_1" );
		}
		
		if ( !Map.Tank )
		{
			SetAvailableMapGoals( TEAM.ALLIES, false, "BUILD_Tank" );
		}
		
		sleep(2.5);
		
		SetAvailableMapGoals( TEAM.ALLIES, false, {
			"ESCORT_Tank",
			".*_Allies_TankPathEnd_.*"
		});
		
		SetAvailableMapGoals( TEAM.ALLIES, true, {
			"PLANT_Depot_Side_Door",
			"PLANT_GOLD_DEPOSITORY_DOOR",
			"MOUNTMG42_Gold_Depository",
			".*_Allies_GoldDeposDoor_.*",
			".*_Allies_GoldDeposWay_.*",
			".*_Allies_DepotSideDoor_.*",
			".*MG42_Factory_.*"
		});
		
		if ( Map.Version != "b6" )
		{
			SetAvailableMapGoals( TEAM.ALLIES, true, "PLANT_Brickwall" );
		}
		
		if ( Map.Brickwall )
		{
			SetAvailableMapGoals( TEAM.ALLIES, false, "SMOKEBOMB_Allies_GoldDeposWay_30" );
		}
	},
	
	Truck_Barrier_1_Built = function()
	{
		Map.Truck_Barrier_1 = true;
		
		Wp.SetWaypointFlag( "Truck_Barrier_1_1", "closed", false );
		
		Util.MapDebugPrint( "Truck_Barrier_1_Built" );
		
		SetAvailableMapGoals( TEAM.AXIS, false, "BUILD_Truck_Barrier_1" );
		
		if ( Map.Version == "b6" )
		{
			if ( Map.Gold_Secured != 2 )
			{
				GetGoal("MOBILEMORTAR_Allies_Barrier1_31").MortarAim = {
				Vec3(0.493, 0.861, 0.126), Vec3(0.606, 0.777, 0.170), Vec3(0.415, 0.906, 0.087), Vec3(0.174, 0.968, 0.181),
				Vec3(0.335, 0.928, 0.162), Vec3(0.428, 0.893, 0.140), Vec3(0.517, 0.852, 0.081) };
			}
			else
			{
				GetGoal("MOBILEMORTAR_Allies_Barrier1_31").MortarAim = {
				Vec3(0.493, 0.861, 0.126), Vec3(0.415, 0.906, 0.087), Vec3(0.174, 0.968, 0.181),
				Vec3(0.335, 0.928, 0.162), Vec3(0.428, 0.893, 0.140), Vec3(0.517, 0.852, 0.081) };
			}
		}
		else
		{
			if ( Map.Gold_Secured != 2 )
			{
				GetGoal("MOBILEMORTAR_Allies_Barrier1_31").MortarAim = { Vec3(0.511, 0.852, 0.128), Vec3(0.615, 0.771, 0.166), Vec3(0.410, 0.907, 0.093),
				Vec3(0.202, 0.962, 0.182), Vec3(0.431, 0.892, 0.134), Vec3(0.349, 0.923, 0.166), Vec3(0.527, 0.846, 0.077) };
			}
			else
			{
				GetGoal("MOBILEMORTAR_Allies_Barrier1_31").MortarAim = { Vec3(0.511, 0.852, 0.128), Vec3(0.410, 0.907, 0.093),
				Vec3(0.202, 0.962, 0.182), Vec3(0.431, 0.892, 0.134), Vec3(0.349, 0.923, 0.166), Vec3(0.527, 0.846, 0.077) };
			}
		}
		
		if ( Map.Gold_Secured == 2 )
		{
			SetAvailableMapGoals( TEAM.ALLIES, true, "PLANT_Truck_Barrier_1" );
		}
		
		if ( Map.TruckAtBarrier_1 and !Map.Truck )
		{
			SetAvailableMapGoals( TEAM.ALLIES, false, "BUILD_Truck" );
		}
	},

	Truck_Barrier_1_Destroyed = function()
	{
		Map.Truck_Barrier_1 = false;
		
		Wp.SetWaypointFlag( "Truck_Barrier_1_1", "closed", true );
		
		Util.MapDebugPrint( "Truck_Barrier_1_Destroyed" );
		
		SetAvailableMapGoals( TEAM.ALLIES, false, "PLANT_Truck_Barrier_1" );
		
		foreach( goal in Util.GoalTable("DEFUSE_Truck_Barrier_1_.*") )
		{
			goal.SetAvailable(TEAM.AXIS, false);
		}
		
		if ( !Map.Main_Gate and !Map.TruckPastBarrier_1 )
		{
			SetAvailableMapGoals( TEAM.AXIS, true, "BUILD_Truck_Barrier_1" );
		}
		
		if ( Map.TruckAtBarrier_1 )
		{
			if ( Map.Version == "b6" )
			{
				GetGoal("MOBILEMORTAR_Allies_Barrier1_31").MortarAim = { Vec3(0.497, 0.852, 0.165) };
			}
			else
			{
				GetGoal("MOBILEMORTAR_Allies_Barrier1_31").MortarAim = { Vec3(0.500, 0.850, 0.164) };
			}
			
			if ( !Map.Truck )
			{
				SetAvailableMapGoals( TEAM.ALLIES, true, "BUILD_Truck" );
			}
			else
			{
				SetAvailableMapGoals( TEAM.ALLIES, true, "ESCORT_Truck" );
			}
		}
	},
	
	Brickwall_Planted = function()
	{
		Util.MapDebugPrint( "Brickwall_Planted" );
		
		foreach( goal in Util.GoalTable("DEFUSE_Brickwall_.*") )
		{
			goal.SetAvailable(TEAM.AXIS, false);
		}
	},
	
	Brickwall_Destroyed = function()
	{
		Map.Brickwall = false;
		
		Util.EnableGoal( "ROUTE_BrickWall_.*" );
		
		Util.MapDebugPrint( "Brickwall_Destroyed" );
		
		foreach( goal in Util.GoalTable("DEFUSE_Brickwall_.*") )
		{
			goal.SetAvailable(TEAM.AXIS, false);
		}
		
		if ( !Map.Main_Gate )
		{
			if ( Map.Gold_Secured < 2 )
			{
				SetAvailableMapGoals( TEAM.ALLIES, true, "SMOKEBOMB_Allies_GoldDeposWay_30" );
			}
			
			if ( !Map.SpawnChange and Map.Gold_Secured == 2 )
			{
				SetAvailableMapGoals( TEAM.ALLIES, true, "SMOKEBOMB_Allies_Barrier1_21" );
			}
		}
	},

	Depot_Side_Door_Planted = function()
	{
		Util.MapDebugPrint( "Depot_Side_Door_Planted" );
		
		foreach( goal in Util.GoalTable("DEFUSE_Depot_Side_Door_.*") )
		{
			pos1 = goal.GetPosition();
			if( pos1.y < 5095 )
			{
				goal.SetAvailable(TEAM.AXIS, false);
			}
		}
	},

	Depot_Side_Door_Destroyed = function()
	{
		Map.Depot_Side_Door = false;
		
		Util.EnableGoal( "ROUTE_SideDoor_.*" );
		
		Util.MapDebugPrint( "Depot_Side_Door_Destroyed" );
		
		foreach( goal in Util.GoalTable("DEFUSE_Depot_Side_Door_.*") )
		{
			goal.SetAvailable(TEAM.AXIS, false);
		}
		
		GetGoal("DEFEND_Axis_GoldDeposDoor_01").AimVectors = { Vec3(0.281, 0.955, 0.098), Vec3(0.961, 0.252, 0.117) };
		GetGoal("DEFEND_Axis_GoldDeposDoor_03").AimVectors = { Vec3(-0.927, -0.374, 0.026), Vec3(-0.320, -0.947, 0.026) };
		GetGoal("DEFEND_Axis_GoldDeposDoor_04").AimVectors = { Vec3(-0.992, -0.128, 0.010), Vec3(-0.534, -0.844, 0.052) };
		GetGoal("DEFEND_Axis_DepotSideDoor_00").AimVectors = { Vec3(-0.933, 0.273, 0.237), Vec3(-0.191, 0.962, 0.195) };
		GetGoal("DEFEND_Axis_DepotSideDoor_01").AimVectors = { Vec3(-0.204, -0.979, 0.027), Vec3(-0.222, 0.935, 0.278) };
		GetGoal("DEFEND_Axis_DepotSideDoor_02").AimVectors = { Vec3(0.339, -0.933, -0.123), Vec3(-0.086, 0.955, 0.284) };
		GetGoal("DEFEND_Axis_DepotSideDoor_03").AimVectors = { Vec3(0.067, -0.979, -0.191), Vec3(-0.152, 0.977, 0.150) };
		GetGoal("DEFEND_Axis_DepotSideDoor_04").AimVectors = { Vec3(0.220, -0.947, -0.236), Vec3(0.186, 0.982, 0.043) };
		GetGoal("DEFEND_Axis_DepotSideDoor_05").AimVectors = { Vec3(0.073, -0.972, -0.223), Vec3(-0.256, 0.966, -0.048) };
		
		SetAvailableMapGoals( TEAM.ALLIES, false, {
			"PLANT_Depot_Side_Door",
			".*_Allies_DepotSideDoor_.*"
		});
		
		if ( Map.Gold_Secured < 2 and !Map.Gold_Depository_Door )
		{
			SetAvailableMapGoals( TEAM.ALLIES, true, "SMOKEBOMB_Allies_Gold_00" );
		}
		
		if ( Map.Gold_Depository_Door )
		{
			SetAvailableMapGoals( TEAM.ALLIES, true, "CAMP_Allies_GoldMG42_.*" );
		}
	},

	Gold_Depository_Door_Destroyed = function()
	{
		Map.Gold_Depository_Door = false;
		
		Util.MapDebugPrint( "Gold_Depository_Door_Destroyed" );
		
		SetAvailableMapGoals( TEAM.ALLIES, false, "PLANT_GOLD_DEPOSITORY_DOOR" );
		
		foreach( goal in Util.GoalTable("DEFUSE_GOLD_DEPOSITORY_DOOR_.*") )
		{
			goal.SetAvailable(TEAM.AXIS, false);
		}
		
		if ( !Map.Depot_Side_Door )
		{
			SetAvailableMapGoals( TEAM.ALLIES, true, "SMOKEBOMB_Allies_Gold_00" );
		}
		
		sleep(2);
		
		SetAvailableMapGoals( TEAM.AXIS, true, "DEFEND_Axis_GoldCrates_.*" );
		
		SetAvailableMapGoals( TEAM.ALLIES, true, {
			"FLAG_gold_crate",
			".*MG42_Gold_Depository"
		});
	},

	Gold_Crate_Taken = function()
	{
		Map.Gold_Taken += 1;
		
		Util.MapDebugPrint( "Gold_Crate_Taken" );
		Util.MapDebugPrint( "^1Taken: ^3" + Map.Gold_Taken );
		Util.MapDebugPrint( "^1Secured: ^3" + Map.Gold_Secured );
		
		if ( Map.Gold_Taken == 2 )
		{
			SetAvailableMapGoals( TEAM.ALLIES, false, "FLAG_gold_crate" );
		}
		
		SetAvailableMapGoals( TEAM.ALLIES, true, "CAPPOINT_Truck" );
		
		sleep(3);
		
		if ( Map.Gold_Taken == 1 )
		{
			SetAvailableMapGoals( TEAM.AXIS, true, "ATTACK_Axis_Truck_0[13]" );
		}
		
		if ( Map.Gold_Taken == 2 )
		{
			SetAvailableMapGoals( TEAM.AXIS, false, {
				"DEFEND_Axis_GoldCrates_.*",
				".*_Axis_GoldDeposDoor_.*",
			});
			
			SetAvailableMapGoals( TEAM.ALLIES, false, {
				".*_Allies_GoldDeposDoor_.*",
				".*_Allies_Gold_.*"
			});
			
			if ( Map.Gold_Secured != 2 )
			{
				SetAvailableMapGoals( TEAM.AXIS, true, "ATTACK_Axis_Truck_.*" );
			}
		}
	},
	
	Gold_Crate_Dropped = function()
	{
		Map.Gold_Taken -= 1;
		
		Util.MapDebugPrint( "Gold_Crate_Dropped" );
		Util.MapDebugPrint( "^1Taken: ^3" + Map.Gold_Taken );
		Util.MapDebugPrint( "^1Secured: ^3" + Map.Gold_Secured );
	},
	
	Gold_Crate_Returned = function()
	{
		Util.MapDebugPrint( "Gold_Crate_Returned" );
		Util.MapDebugPrint( "^1Taken: ^3" + Map.Gold_Taken );
		Util.MapDebugPrint( "^1Secured: ^3" + Map.Gold_Secured );
		
		SetAvailableMapGoals( TEAM.AXIS, true, {
			"DEFEND_Axis_GoldCrates_.*",
			".*_Axis_GoldDeposDoor_.*",
		});
		
		SetAvailableMapGoals( TEAM.ALLIES, true, {
			"FLAG_gold_crate",
			".*_Allies_GoldDeposDoor_.*",
			".*_Allies_Gold_.*"
		});
		
		if ( Map.Gold_Taken > 0 and Map.Gold_Secured == 0 )
		{
			SetAvailableMapGoals( TEAM.AXIS, false, "ATTACK_Axis_Truck_0[024]" );
		}
		else
		{
			SetAvailableMapGoals( TEAM.AXIS, false, "ATTACK_Axis_Truck_.*" );
			
			SetAvailableMapGoals( TEAM.ALLIES, false, "CAPPOINT_Truck" );
		}
	},

	Gold_Crate_Secured = function()
	{
		Map.Gold_Secured += 1;
		
		Util.MapDebugPrint( "Gold_Crate_Secured" );
		Util.MapDebugPrint( "^1Taken: ^3" + Map.Gold_Taken );
		Util.MapDebugPrint( "^1Secured: ^3" + Map.Gold_Secured );
		
		if ( Map.Gold_Taken == 1 )
		{
			SetAvailableMapGoals( TEAM.AXIS, false, "ATTACK_Axis_Truck_.*" );
		}
		
		if ( Map.Gold_Secured == 2 )
		{
			SetGoalPriority( "REPAIRMG42_.*", 0.81, TEAM.ALLIES );
			
			SetAvailableMapGoals( TEAM.AXIS, false, {
				".*MG42_Gold_Depository",
				"ATTACK_Axis_Truck_.*",
				".*_Axis_GoldDeposWay_.*",
				".*_Axis_DepotSideDoor_.*"
			});
			
			SetAvailableMapGoals( TEAM.AXIS, true, ".*_Axis_Barrier1_.*" );
			
			SetAvailableMapGoals( TEAM.ALLIES, false, {
				"CAPPOINT_Truck",
				".*_Allies_GoldDeposWay_.*",
				".*_Allies_Gold_.*",
				".*_Allies_DepotSideDoor_.*",
				"CAMP_Allies_GoldMG42_.*.*",
				".*MG42_Factory_.*"
			});
			
			if ( Map.Version == "b6" )
			{
				GetGoal("MOBILEMORTAR_Allies_Barrier1_31").MortarAim = {
				Vec3(0.493, 0.861, 0.126), Vec3(0.415, 0.906, 0.087), Vec3(0.174, 0.968, 0.181),
				Vec3(0.335, 0.928, 0.162), Vec3(0.428, 0.893, 0.140), Vec3(0.517, 0.852, 0.081) };
			}
			else
			{
				GetGoal("MOBILEMORTAR_Allies_Barrier1_31").MortarAim = { Vec3(0.511, 0.852, 0.128), Vec3(0.410, 0.907, 0.093),
				Vec3(0.202, 0.962, 0.182), Vec3(0.431, 0.892, 0.134), Vec3(0.349, 0.923, 0.166), Vec3(0.527, 0.846, 0.077) };
			}
			
			if ( !Map.Truck )
			{
				SetAvailableMapGoals( TEAM.ALLIES, true, "BUILD_Truck" );
			}
			else
			{
				SetAvailableMapGoals( TEAM.ALLIES, true, "ESCORT_Truck" );
			}
			
			if ( Map.Truck_Barrier_1 )
			{
				SetAvailableMapGoals( TEAM.ALLIES, true, "PLANT_Truck_Barrier_1" );
			}
			
			SetAvailableMapGoals( TEAM.ALLIES, true, ".*_Allies_Barrier1_.*" );
			
			if ( Map.Brickwall )
			{
				SetAvailableMapGoals( TEAM.ALLIES, false, "SMOKEBOMB_Allies_Barrier1_21" );
			}
			
			sleep(5);
			
			ETUtil.SetExcludeIndexes( "BUILD_Truck", { 2, 3, 4 } );
		}
	},
	
	Truck_Built = function()
	{
		Map.Truck = true;
		
		Util.MapDebugPrint( "Truck_Built" );
		
		SetAvailableMapGoals( TEAM.ALLIES, false, "BUILD_Truck" );
		
		if ( !Map.Main_Gate and Map.Gold_Secured == 2 )
		{
			if ( Map.TruckAtBarrier_1 and !Map.Truck_Barrier_1 )
			{
				SetAvailableMapGoals( TEAM.ALLIES, true, "ESCORT_Truck" );
			}
			else if ( Map.TruckAtBarrier_2 and !Map.Truck_Barrier_2 )
			{
				SetAvailableMapGoals( TEAM.ALLIES, true, "ESCORT_Truck" );
			}
			else if ( !Map.TruckAtBarrier_1 and !Map.TruckAtBarrier_2 )
			{
				SetAvailableMapGoals( TEAM.ALLIES, true, "ESCORT_Truck" );
			}
		}
	},
	
	Truck_Destroyed = function()
	{
		Map.Truck = false;
		
		Util.MapDebugPrint( "Truck_Destroyed" );
		
		SetAvailableMapGoals( TEAM.ALLIES, false, "ESCORT_Truck" );
		
		if ( !Map.Main_Gate and Map.Gold_Secured == 2 )
		{
			if ( Map.TruckAtBarrier_1 and Map.Truck_Barrier_1 )
			{
				SetAvailableMapGoals( TEAM.ALLIES, false, "BUILD_Truck" );
			}
			else if ( Map.TruckAtBarrier_2 and Map.Truck_Barrier_2 )
			{
				SetAvailableMapGoals( TEAM.ALLIES, false, "BUILD_Truck" );
			}
			else
			{
				SetAvailableMapGoals( TEAM.ALLIES, true, "BUILD_Truck" );
			}
		}
	},
	
	Truck_At_Turn = function()
	{
		Util.MapDebugPrint( "Truck_At_Turn" );
		
		ETUtil.SetExcludeIndexes( "BUILD_Truck", { 1, 2, 3, 4 } );
	},
	
	Truck_At_Barrier_1 = function()
	{
		Util.MapDebugPrint( "Truck_At_Barrier_1" );
		
		Map.TruckAtBarrier_1 = true;
		
		ETUtil.SetExcludeIndexes( "BUILD_Truck", { 0, 1, 2 } );
		
		Util.SetGoalPosition(1523.697, 5278.244, 128.134, "PLANT_Truck_Barrier_1");
		
		if ( Map.Truck_Barrier_1 )
		{
			SetAvailableMapGoals( TEAM.ALLIES, false, "ESCORT_Truck" );
		}
		else
		{
			if ( !Map.Truck )
			{
				SetAvailableMapGoals( TEAM.ALLIES, true, "BUILD_Truck" );
			}
		}
		
