		GetGoal("PLANT_Truck_Barrier_1").CoverSpots[1].AimVectors = { Vec3(-0.985, 0.169, 0.017), Vec3(0.935, -0.274, 0.224) };
		GetGoal("PLANT_Truck_Barrier_1").CoverSpots[1].stance = "crouch";
		GetGoal("PLANT_Truck_Barrier_1").CoverSpots[2].position = Vec3(2370.125, 5435.815, 152.361);
		GetGoal("PLANT_Truck_Barrier_1").CoverSpots[2].AimVectors = { Vec3(-0.960, -0.266, -0.085) };
