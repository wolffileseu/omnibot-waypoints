	Brickwall_Test = function()
	{
		sleep(0.5);
		start = Vector3(1314, 4844, 181);
		end = Vector3(1314, 4692, 181);
		while ( Map.Brickwall )
		{
			tr = TraceLine( start, end, null, TRACE.SOLID, 0, false );
			if ( tr.fraction == 1 )
			{
				Map.Brickwall_Destroyed();
				
				if ( Map.Debug )
				{
					DrawDebugLine( start, end, COLOR.GREEN, 0.25 );
				}
			}
			else
			{
				if ( Map.Debug )
				{
					DrawDebugLine( start, end, COLOR.RED, 0.25 );
				}
			}
			sleep(0.25);
		}
	},
	
	MG_Facing = function()
	{
		ent = GetGoal("MOUNTMG42_Gold_Depository").GetEntity();
		
		while ( !Map.SpawnChange )
		{
			if ( GetEntFlags(GetGoal("MOUNTMG42_Gold_Depository").GetEntity(), ENTFLAG.MOUNTED) )
			{
				foreach ( bot in BotTable )
				{
					owner = bot.GetMountedPlayerOnMG42(ent);
				}
				
				if ( owner )
				{
					if ( GetEntTeam(owner) == TEAM.AXIS )
					{
						if ( Map.MG_Mount_Team != TEAM.AXIS )
						{
							Map.MG_Mount_Team = TEAM.AXIS;
							
							GetGoal("MOUNTMG42_Gold_Depository").AimVectors = { Vec3(-0.583, -0.812, 0.007), Vec3(-0.965, -0.259, -0.045) };
							
							Util.MapDebugPrint( "MOUNTMG42_Gold_Depository mounted by Axis" );
						}
					}
					else if ( GetEntTeam(owner) == TEAM.ALLIES )
					{
						if ( Map.MG_Mount_Team != TEAM.ALLIES )
						{
							Map.MG_Mount_Team = TEAM.ALLIES;
							
							GetGoal("MOUNTMG42_Gold_Depository").AimVectors = { Vec3(-0.739, 0.670, 0.072), Vec3(-0.949, 0.313, 0.046) };
							
							Util.MapDebugPrint( "MOUNTMG42_Gold_Depository mounted by Allies" );
						}
					}
				}
			}
			sleep(1);
		}
	},

	Lift_Position = function()
	{
		tr = TraceLine( Vec3(-120, -1448, -351), Vec3(-120, -1478, -383), null, TRACE.SOLID, 0, false );
		while ( tr.entity )
		{
			if ( Round(GetEntPosition(tr.entity).z ) == -264 )
			{
				if ( Map.Lift != "Down" )
				{
					Map.Lift = "Down";
					Util.MapDebugPrint( "Lift_Down" );
				}
			}
			else if ( Round(GetEntPosition(tr.entity).z ) == -30 )
			{
				if ( Map.Lift != "Up" )
				{
					Map.Lift = "Up";
					Util.MapDebugPrint( "Lift_Up" );
				}
			}
			else
			{
				if ( Map.Lift != "Moving" )
				{
					Map.Lift = "Moving";
					Util.MapDebugPrint( "Lift_Moving" );
				}
			}
			yield();
		}
	},
	
	Bookcase_Test = function()
	{
		tr = TraceLine( Vec3(670.963, -1363.427, -82.697), Vec3(803.450, -1365.773, -87.184), null, TRACE.SOLID, 0, false );
		
		while ( 1 )
		{
			if ( Round(GetEntPosition(tr.entity).y ) == -1376 )
			{
				if ( Map.Bookcase != "Closed" )
				{
					Map.Bookcase = "Closed";
					Util.MapDebugPrint( "Bookcase_Closed" );
				}
			}
			else if ( Round(GetEntPosition(tr.entity).y ) == -1434 )
			{
				if ( Map.Bookcase != "Opened" )
				{
					Map.Bookcase = "Opened";
					Util.MapDebugPrint( "Bookcase_Opened" );
				}
			}
			else
			{
				if ( Map.Bookcase != "Moving" )
				{
					Map.Bookcase = "Moving";
					Util.MapDebugPrint( "Bookcase_Moving" );
				}
			}
			sleep(0.2);
		}
	},
	
	Supply_Test = function()
    {
        traceData = {
            { start = Vec3(-40, -1293, -343), end = Vec3(-40, -1335, -343) },
            { start = Vec3(-40, -1293, -343), end = Vec3(-40, -1254, -343) },
            { start = Vec3(630, -1005, 195),  end = Vec3(630, -972, 195) },
            { start = Vec3(630, -1005, 195),  end = Vec3(630, -1041, 195) },
            { start = Vec3(653, -1006, 195),  end = Vec3(653, -972, 195) },
            { start = Vec3(653, -1006, 195),  end = Vec3(653, -1041, 195) },
            { start = Vec3(1239, -507, -365),  end = Vec3(1241, -461, -365) }
        };
        meal1 = GetGoal("HEALTHCAB_Hot_Meal_1");
        meal2 = GetGoal("HEALTHCAB_Hot_Meal_2");
        ammo1 = GetGoal("AMMOCAB_Allied_HQ");
        
        while ( 1 )
        {
            foreach (data in traceData)
            {
                data.result = TraceLine(data.start, data.end, null, TRACE.ALL, 0, false).fraction != 1;

                if ( Map.Debug )
                {
                    if ( data.result )
                    {
                        c = COLOR.RED;
                    }
                    else
                    {
                        c = COLOR.GREEN;
                    }
                    DrawDebugLine(data.start, data.end, c, 0.2);
                }
            }

            meal2.SetAvailable(0, traceData[2].result or traceData[3].result or traceData[4].result or traceData[5].result);
			
            if ( Map.Version == "b8" )
			{
				meal1.SetAvailable(0, traceData[0].result or traceData[1].result);
				ammo1.SetAvailable(0, traceData[6].result);
			}

            sleep(0.2);
        }
    },
	
	Lift_Position_Debug = function()
	{
		for(;;)
        {
            for ( i = 0; i <= 8; i += 1 )
            {
                pos = Map.Lift_Positions[i];
                DrawText3d( pos + Vec3(0,0,40), Map.Strings[i], COLOR.LIGHT_GREY, 0.2 );
                if ( i == 8 )
                {
                    c = COLOR.BLUE;
                }
                else if ( Map.Lift_botId[i] == -1 )
                {
                    c = COLOR.GREEN;
                }
                else if ( Map.Bot_Ready[i] )
                {
                    c = COLOR.RED;
                }
                else
                {
                    c = COLOR.YELLOW;
                }
                DrawDebugLine( pos + Vec3(0,0,40), pos - Vec3(0,0,25), c, 0.2 );
            }
            sleep(0.2);
        }
	},
	
	Ignore_Target =
	{
		Name = "Ignore_Target",
		TriggerOnClass = CLASS.ANYPLAYER,
		OnEnter = function(ent)
		{
			b = Util.IsBot(ent);
			if ( b )
			{
				for ( q = 0; q < 64; q += 1 )
				{
					if ( EntityIsValid(q) and q != b.GetGameId() and !GetEntFlags(q,ENTFLAG.CARRYINGGOAL) )
					{
						b.IgnoreTarget(q, 999);
					}
				}
			}
		},
		OnExit = function(ent)
		{
			b = Util.IsBot(ent);
			if ( b )
			{
				for ( q = 0; q < 64; q += 1 )
				{
					if ( EntityIsValid(q) and q != b.GetGameId() )
					{
						b.IgnoreTarget(q, 0.1);
					}
				}
			}
		},
	},
};

