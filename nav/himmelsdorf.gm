	Truck_Past_Barrier_1 = function()
	{
		Util.MapDebugPrint( "Truck_Past_Barrier_1" );
		
		Map.TruckAtBarrier_1 = false;
		Map.TruckPastBarrier_1 = true;
		
		if ( Map.Allied_Command_Post )
		{
			SetAvailableMapGoals( TEAM.AXIS, false, "PLANT_Allied_Command_Post");
		}
		
		if ( !Map.Truck_Barrier_1 )
		{
			SetAvailableMapGoals( TEAM.AXIS, false, "BUILD_Truck_Barrier_1" );
		}
		
		if ( Map.Version == "b6" )
		{
			GetGoal("MOBILEMORTAR_Allies_Barrier1_31").MortarAim = {
			Vec3(0.493, 0.861, 0.126), Vec3(0.415, 0.906, 0.087), Vec3(0.174, 0.968, 0.181),
			Vec3(0.335, 0.928, 0.162), Vec3(0.428, 0.893, 0.140), Vec3(0.517, 0.852, 0.081) };
		}
		else
		{
			GetGoal("MOBILEMORTAR_Allies_Barrier1_31").MortarAim = { Vec3(0.511, 0.852, 0.128), Vec3(0.410, 0.907, 0.093),
			Vec3(0.202, 0.962, 0.182), Vec3(0.431, 0.892, 0.134), Vec3(0.349, 0.923, 0.166), Vec3(0.527, 0.846, 0.077) };
		}
		GetGoal("SMOKEBOMB_Allies_Barrier1_20").AimVectors = { Vec3(-0.318, 0.389, 0.865) };
		Util.SetGoalPosition(1338.057, 4710.529, 81.125, "SMOKEBOMB_Allies_Barrier1_21");
		GetGoal("SMOKEBOMB_Allies_Barrier1_21").AimVectors = { Vec3(-0.205, 0.769, 0.605) };
	},
	
	Spawn_Change = function()
	{
		Util.MapDebugPrint( "Spawn_Change" );
		
		Map.SpawnChange = true;
		
		Map.SetSpawn();
		
		SetAvailableMapGoals( TEAM.AXIS, false, {
			".*MG42_Gold_Depository",
			".*MG42_Truck_Barrier_1",
			".*MG42_Road_1",
			".*_Axis_Barrier1_.*"
		});
		
		SetAvailableMapGoals( TEAM.ALLIES, false, {
			".*MG42_Gold_Depository",
			".*_Allies_Barrier1_.*",
			".*_Allies_DepotSideDoor_.*"
		});
		
		if ( Map.Version != "b6" and Map.Brickwall )
		{
			SetAvailableMapGoals( TEAM.ALLIES, false, "PLANT_Brickwall" );
		}
		
		if ( Map.Depot_Side_Door )
		{
			SetAvailableMapGoals( TEAM.ALLIES, false, "PLANT_Depot_Side_Door" );
		}
		
		if ( !Map.Truck_Barrier_2 )
		{
			SetAvailableMapGoals( TEAM.AXIS, true, "BUILD_Truck_Barrier_2" );
		}
		else
		{
			SetAvailableMapGoals( TEAM.ALLIES, true, "PLANT_Truck_Barrier_2" );
		}
		
		if ( !Map.Axis_Command_Post )
		{
			SetAvailableMapGoals( TEAM.AXIS, true, "BUILD_Axis_Command_Post" );
		}
		else
		{
			SetAvailableMapGoals( TEAM.ALLIES, true, "PLANT_Axis_Command_Post" );
		}
		
		SetAvailableMapGoals( TEAM.AXIS, true, ".*_Axis_Barrier2_.*" );
		
		SetAvailableMapGoals( TEAM.ALLIES, true, ".*_Allies_Barrier2_.*" );
		
		ETUtil.SetExcludeIndexes( "BUILD_Truck", {} );
	},
	
	SetSpawn = function()
	{
		foreach ( id and bot in BotTable )
		{
			Map.SetSpawn1(bot);
		}
	},
	
	SetSpawn1 = function(bot)
	{
		if ( bot.GetTeam() == TEAM.AXIS )
        {
			if ( !Map.TruckPastBarrier_2 )
			{
				bot.ChangeSpawnPoint(4);
			}
			else
			{
				if ( RandInt(0,1 ) < 1)
				{
					bot.ChangeSpawnPoint(4);
				}
				else
				{
					bot.ChangeSpawnPoint(6);
				}
			}
		}
	},
	
	Axis_Command_Post_Built = function()
	{
		Map.Axis_Command_Post = true;
		
		Util.MapDebugPrint( "Axis_Command_Post_Built" );
		
		SetAvailableMapGoals( TEAM.AXIS, false, "BUILD_Axis_Command_Post" );
		
		if ( Map.TruckPastBarrier_1 )
		{
			SetAvailableMapGoals( TEAM.ALLIES, true, "PLANT_Axis_Command_Post" );
		}
	},
	
	Axis_Command_Post_Destroyed = function()
	{
		Map.Axis_Command_Post = false;
		
		Util.MapDebugPrint( "Axis_Command_Post_Destroyed" );
		
		foreach( goal in Util.GoalTable("DEFUSE_Axis_Command_Post_.*") )
		{
			goal.SetAvailable(TEAM.AXIS, false);
		}
		
		SetAvailableMapGoals( TEAM.ALLIES, false, "PLANT_Axis_Command_Post" );
		
		if ( Map.TruckPastBarrier_1 )
		{
			SetAvailableMapGoals( TEAM.AXIS, true, "BUILD_Axis_Command_Post" );
		}
	},
	
	Truck_Barrier_2_Built = function()
	{
		Map.Truck_Barrier_2 = true;
		
		Wp.SetWaypointFlag( "Truck_Barrier_2_1", "closed", false );
		
		Util.MapDebugPrint( "Truck_Barrier_2_Built" );
		
		if ( Map.TruckAtBarrier_2 and !Map.Truck )
		{
			SetAvailableMapGoals( TEAM.ALLIES, false, "BUILD_Truck" );
		}
		
		SetAvailableMapGoals( TEAM.AXIS, false, "BUILD_Truck_Barrier_2" );
		
		if ( Map.TruckPastBarrier_1 )
		{
			SetAvailableMapGoals( TEAM.ALLIES, true, "PLANT_Truck_Barrier_2" );
		}
	},
	
	Truck_Barrier_2_Destroyed = function()
	{
		Map.Truck_Barrier_2 = false;
		
		Wp.SetWaypointFlag( "Truck_Barrier_2_1", "closed", true );
		
		Util.MapDebugPrint( "Truck_Barrier_2_Destroyed" );
		
		SetAvailableMapGoals( TEAM.ALLIES, false, "PLANT_Truck_Barrier_2" );
		
		foreach( goal in Util.GoalTable("DEFUSE_Truck_Barrier_2_.*") )
		{
			goal.SetAvailable(TEAM.AXIS, false);
		}
		
		if ( Map.TruckAtBarrier_2 )
		{
			if ( !Map.Truck )
			{
				SetAvailableMapGoals( TEAM.ALLIES, true, "BUILD_Truck" );
			}
			else
			{
				SetAvailableMapGoals( TEAM.ALLIES, true, "ESCORT_Truck" );
			}
		}
		
		if ( Map.TruckPastBarrier_1 and !Map.TruckPastBarrier_2 )
		{
			SetAvailableMapGoals( TEAM.AXIS, true, "BUILD_Truck_Barrier_2" );
		}
	},
	
