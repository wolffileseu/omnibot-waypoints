	Truck_At_Final_Turn = function()
	{
		Util.MapDebugPrint( "Truck_At_Final_Turn" );
		
		ETUtil.SetExcludeIndexes( "BUILD_Truck", { 0, 3, 4 } );
		
		SetGoalPriority( "ATTACK_Allies_Barrier2_.*", 0.51, TEAM.ALLIES );
		
