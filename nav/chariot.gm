			}
			else
			{
				Map.Crane_2_Facing = "West";

				Wp.SetWaypointFlag( "Crane_2_West_.*", "closed", false );
			}

			Map.Crane_2_Moving_Right = false;
		}
		else
		{
			if ( Map.Crane_2_Facing == "West" )
			{
				Map.Crane_2_Facing = "South";

				Wp.SetWaypointFlag( "Crane_2_South_.*", "closed", false );
			}
			else if ( Map.Crane_2_Facing == "South" )
			{
				Map.Crane_2_Facing = "East";

				Wp.SetWaypointFlag( "Crane_2_East_.*", "closed", false );
			}
			else if ( Map.Crane_2_Facing == "East" )
			{
				Map.Crane_2_Facing = "North";

				Wp.SetWaypointFlag( "Crane_2_North_.*", "closed", false );
			}
			else
			{
				Map.Crane_2_Facing = "West";

				Wp.SetWaypointFlag( "Crane_2_West_.*", "closed", false );
			}
		}

		Util.MapDebugPrint( "Crane_2_Facing_" + Map.Crane_2_Facing );

		Map.Crane_2_Path_Adjustment();

		DynamicPathsUpdated( TEAM.AXIS, TEAM.ALLIES );
	},

	Ship_Ladder_1 =
	{
		Name = "Ship_Ladder_1",
		TriggerOnClass = CLASS.ANYPLAYER,
		OnEnter = function(ent)
		{
			Map.Ladder_1_In_Use += 1;
		},
		OnExit = function(ent)
		{
			Map.Ladder_1_In_Use -= 1;
		},
	},

	Ship_Ladder_2 =
	{
		Name = "Ship_Ladder_2",
		TriggerOnClass = CLASS.ANYPLAYER,
		OnEnter = function(ent)
		{
			Map.Ladder_2_In_Use += 1;
		},
		OnExit = function(ent)
		{
			Map.Ladder_2_In_Use -= 1;
		},
	},

	AlliesAtLadder1 =
	{
		Name = "AlliesAtLadder1",
		TriggerOnClass = CLASS.ANYPLAYER,
		OnEnter = function(ent)
		{
			Map.Allies_At_Ladder_1 += 1;
		},
		OnExit = function(ent)
		{
			Map.Allies_At_Ladder_1 -= 1;
		},
	},

	AlliesAtLadder2 =
	{
		Name = "AlliesAtLadder2",
		TriggerOnClass = CLASS.ANYPLAYER,
		OnEnter = function(ent)
		{
			Map.Allies_At_Ladder_2 += 1;
		},
		OnExit = function(ent)
		{
			Map.Allies_At_Ladder_2 -= 1;
		},
	},

	Ignore_Target =
	{
		Name = "Ignore_Target",
		TriggerOnClass = CLASS.ANYPLAYER,
		OnEnter = function(ent)
		{
			b = Util.IsBot(ent);
			if ( b )
			{
				for ( q = 0; q < 64; q += 1 )
				{
					if ( EntityIsValid(q) )
					{
						b.IgnoreTarget(q, 999);
					}
				}
			}
		},
		OnExit = function(ent)
		{
			b = Util.IsBot(ent);
			if ( b )
			{
				for ( q = 0; q < 64; q += 1 )
				{
					if ( EntityIsValid(q) )
					{
						b.IgnoreTarget(q, 0.1);
					}
				}
			}
		},
	},

	SetSpawn = function()
	{
		foreach ( id and bot in BotTable )
		{
			Map.SetSpawn1(bot);
		}
	},

	SetSpawn1 = function(bot)
	{
		if ( bot.GetTeam() == TEAM.ALLIES )
		{
			if ( Map.Dockside_Allied and !bot.HasRole(ROLE.DEFENDER3) and ( Map.Old_Lock or Map.South_Winding_Gear or Map.Pump or Map.North_Gate or Map.North_Winding_Gear ) )
			{
				if ( RandInt(0,1) > 0 )
				{
					bot.ChangeSpawnPoint(2);
				}
				else
				{
					bot.ChangeSpawnPoint(3);
				}
			}
			else
			{
				bot.ChangeSpawnPoint(2);
			}
		}
	},

