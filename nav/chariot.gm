	explosives_TakenOrDropped = function( trigger )
	{
		Util.MapDebugPrint( "explosives_TakenOrDropped" );

		Map.g = null;
		Map.h = null;
		foreach ( bot in BotTable )
		{
			if ( bot.IsCarryingFlag() )
			{
				switch (bot.GetMapGoalName())
				{
					case "CAPPOINT_Fuel_Dump":
					{
						if (!Map.g)
						{
							Map.g = "FuelDump";
							Util.MapDebugPrint("first goal: " + Map.g);
						}
						else
						{
							Map.h = "FuelDump";
							Util.MapDebugPrint("second goal: " + Map.h);
						}
						if (!Map.owner_CFD)
						{
							Map.owner_CFD = true;
							thread(Map.CFD_check, bot);
						}
					}
					case "CAPPOINT_North_Gate":
					{
						if (!Map.g)
						{
							Map.g = "NorthGate";
							Util.MapDebugPrint("first goal: " + Map.g);
						}
						else
						{
							Map.h = "NorthGate";
							Util.MapDebugPrint("second goal: " + Map.h);
						}
						if (!Map.owner_CNG)
						{
							Map.owner_CNG = true;
							thread(Map.CNG_check, bot);
						}
					}
					case "CAPPOINT_North_Winding_Gear":
					{
						if (!Map.g)
						{
							Map.g = "NWH";
							Util.MapDebugPrint("first goal: " + Map.g);
						}
						else
						{
							Map.h = "NWH";
							Util.MapDebugPrint("second goal: " + Map.h);
						}
						if (!Map.owner_CNWG)
						{
							Map.owner_CNWG = true;
							thread(Map.CNWG_check, bot);
						}
					}
					case "CAPPOINT_Old_Lock":
					{
						if (!Map.g)
						{
							Map.g = "OldLock";
							Util.MapDebugPrint("first goal: " + Map.g);
						}
						else
						{
							Map.h = "OldLock";
							Util.MapDebugPrint("second goal: " + Map.h);
						}
						if (!Map.owner_COL)
						{
							Map.owner_COL = true;
							thread(Map.COL_check, bot);
						}
					}
					case "CAPPOINT_Pump":
					{
						if (!Map.g)
						{
							Map.g = "PumpHouse";
							Util.MapDebugPrint("first goal: " + Map.g);
						}
						else
						{
							Map.h = "PumpHouse";
							Util.MapDebugPrint("second goal: " + Map.h);
						}
						if (!Map.owner_CP)
						{
							Map.owner_CP = true;
							thread(Map.CP_check, bot);
						}
					}
					case "CAPPOINT_South_Winding_Gear":
					{
						if (!Map.g)
						{
							Map.g = "SWH";
							Util.MapDebugPrint("first goal: " + Map.g);
						}
						else
						{
							Map.h = "SWH";
							Util.MapDebugPrint("second goal: " + Map.h);
						}
						if (!Map.owner_CSWG)
						{
							Map.owner_CSWG = true;
							thread(Map.CSWG_check, bot);
						}
					}
					default:
					{
						Map.OtherGoal_check(bot);
					}
				}
			}
		}

		if(Map.g)
		{
			SetAvailableMapGoals( TEAM.ALLIES, true, {
				"ATTACK_Allies_" + Map.g + "_1",
				"ATTACK_Allies_" + Map.g + "_2",
				"ATTACK_Allies_" + Map.g + "_3",
			});

			SetAvailableMapGoals( TEAM.AXIS, true, {
				"DEFEND_Axis_" + Map.g + "_1",
				"DEFEND_Axis_" + Map.g + "_2",
				"DEFEND_Axis_" + Map.g + "_3",
			});
		}
		if(Map.h)
		{
			SetAvailableMapGoals( TEAM.ALLIES, true, {
				"ATTACK_Allies_" + Map.h + "_1",
				"ATTACK_Allies_" + Map.h + "_2",
				"ATTACK_Allies_" + Map.h + "_3",
			});

			SetAvailableMapGoals( TEAM.AXIS, true, {
				"DEFEND_Axis_" + Map.h + "_1",
				"DEFEND_Axis_" + Map.h + "_2",
				"DEFEND_Axis_" + Map.h + "_3",
			});
		}

		DeleteTriggerRegion("PumpHouseTrigger");
		Map.pht_ally[ent] = null;
		Map.pht_ally_CG[ent] = null;
		DeleteTriggerRegion("FuelDumpTrigger");
		Map.fdt_ally[ent] = null;
		Map.fdt_ally_CG[ent] = null;
		DeleteTriggerRegion("NorthGateTrigger");
		Map.ngt_ally[ent] = null;
		Map.ngt_ally_CG[ent] = null;
		DeleteTriggerRegion("NorthHutTrigger");
		Map.nht_ally[ent] = null;
		Map.nht_ally_CG[ent] = null;
		DeleteTriggerRegion("OldLockTrigger");
		Map.olt_ally[ent] = null;
		Map.olt_ally_CG[ent] = null;
		DeleteTriggerRegion("SouthHutTrigger");
		Map.sht_ally[ent] = null;
		Map.sht_ally_CG[ent] = null;

		yield();

		if ( Map.Pump )
		{
			OnTriggerRegion(AABB(4986.527,2871.125,1025.254,5168.875,3448.875,1199.406), Map.PumpHouseTrigger );    //right enrance room
			OnTriggerRegion(AABB(4103.125,2871.294,641.125,4330.208,3448.875,1195.921), Map.PumpHouseTrigger );    //left enrance room
			OnTriggerRegion(AABB(4271.125,2871.125,641.125,5000.875,3448.875,1345.157), Map.PumpHouseTrigger );    //hut
		}
		if ( !Map.Fuel_Dump_Primed )
		{
			OnTriggerRegion(AABB(4671.525,-512.609,241.264,5056.875,32.875,1181.357), Map.FuelDumpTrigger ); //stairs
			OnTriggerRegion(AABB(2303.125,-1088.875,639.735,3840.875,-271.125,1388.934), Map.FuelDumpTrigger ); //entrance room
			OnTriggerRegion(AABB(2312.480,-1024.875,193.125,4787.898,768.875,706.317), Map.FuelDumpTrigger ); //dynamite room
		}
		if ( !Map.North_Gate_Primed )
		{
			OnTriggerRegion(AABB(8108.015,544.724,1025.125,9712.874,2944.692,1261.779), Map.NorthGateTrigger );
		}
		if ( !Map.North_Winding_Gear_Primed )
		{
			OnTriggerRegion(AABB(8639.125,3599.125,337.125,9312.875,4336.875,1285.789), Map.NorthHutTrigger );  //hut
			OnTriggerRegion(AABB(8751.125,2575.125,337.125,9200.875,3741.869,638.086), Map.NorthHutTrigger );   //water
			OnTriggerRegion(AABB(9256.242,3783.125,1025.125,9448.875,4152.875,1131.125), Map.NorthHutTrigger );   //entrance room
		}
		if ( !Map.Old_Lock_Primed )
		{
			OnTriggerRegion(AABB(701.531,4597.645,641.125,2938.875,6650.875,1216.062), Map.OldLockTrigger );
		}
		if ( !Map.South_Winding_Gear_Primed )
		{
			OnTriggerRegion(AABB(2831.125,3599.125,337.125,3503.787,4336.875,1285.789), Map.SouthHutTrigger );  //hut
			OnTriggerRegion(AABB(2943.125,2575.125,337.125,3392.875,3741.869,638.086), Map.SouthHutTrigger );   //water
			OnTriggerRegion(AABB(3458.231,3783.125,1025.125,3640.875,4152.725,1144.064), Map.SouthHutTrigger ); //entrance room
		}

		thread(Map.Disable_Goals_after_Capture);

		if ( !Map.Pump_Primed and tableCount(Map.pht_ally_CG) < 1 and Map.g != "PumpHouse" and Map.h != "PumpHouse" )
		{
			Util.DisableGoal(".*s_PumpHouse_.*");
		}
		if ( !Map.Fuel_Dump_Primed and tableCount(Map.fdt_ally_CG) < 1 and Map.g != "FuelDump" and Map.h != "FuelDump" )
		{
			Util.DisableGoal(".*s_FuelDump_.*");
		}
		if ( !Map.North_Gate_Primed and tableCount(Map.ngt_ally_CG) < 1 and Map.g != "NorthGate" and Map.h != "NorthGate" )
		{
			Util.DisableGoal(".*s_NorthGate_.*");
		}
		if ( !Map.North_Winding_Gear_Primed and tableCount(Map.nht_ally_CG) < 1 and Map.g != "NWH" and Map.h != "NWH" )
		{
			Util.DisableGoal(".*s_NWH_.*");
		}
		if ( !Map.Old_Lock_Primed and tableCount(Map.olt_ally_CG) < 1 and Map.g != "OldLock" and Map.h != "OldLock" )
		{
			Util.DisableGoal(".*s_OldLock_.*");
		}
		if ( !Map.South_Winding_Gear_Primed and tableCount(Map.sht_ally_CG) < 1 and Map.g != "SWH" and Map.h != "SWH" )
		{
			Util.DisableGoal(".*s_SWH_.*");
		}

		thread(Map.Enable_Goals_after_Capture);
	},

	OtherGoal_check = function (bot)
	{
		goal = bot.GetMapGoalName();
		if(!goal)
		{
			goal=bot.GetHighLevelGoalName();
		}
		if ( goal and goal.Left(8) != "CAPPOINT" )
		{
			while ( bot.Name and goal and goal.Left(8) != "CAPPOINT" )
			{
				sleep(0.5);
				if (bot.Name)
				{
					goal = bot.GetMapGoalName();
					if(!goal)
					{
						goal=bot.GetHighLevelGoalName();
					}
				}
				else
				{
					Util.MapDebugPrint( "END of other goal => return" );
					return;
				}
			}
			Util.MapDebugPrint( "END of other goal" );
			thread( Map.explosives_TakenOrDropped );
		}
	},

	CFD_check = function (bot)
	{
		goal = bot.GetMapGoalName();
		while (goal == "CAPPOINT_Fuel_Dump" and bot.Name and bot.IsCarryingFlag())
		{
			yield();
			if (bot.Name)
			{
				goal = bot.GetMapGoalName();
			}
		}
		Util.MapDebugPrint( "CFD_check end" );
		if (!Map.Fuel_Dump_Primed)
		{
			SetGoalPriority( "CAPPOINT_Fuel_Dump", 1.02, TEAM.ALLIES, 0 );
		}
		Map.owner_CFD = false;
		Map.explosives_TakenOrDropped();
	},

