		SetGoalPriority( "ATTACK_Allies_SWH_" + i, j, TEAM.ALLIES, 0 );
		j = j + 0.01;
	}

	foreach( goal in Util.GoalTable("CALLARTILLERY_Axis_Ship_.*") )
	{
		goal.SetRange(700);
	}

