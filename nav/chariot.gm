	Explosives_Taken = function( trigger )
	{
		Util.MapDebugPrint( "Explosives_Taken" );

		Map.count_dyno += 1;

		SetAvailableMapGoals( TEAM.ALLIES, true, "CAPPOINT_.*" );

		foreach ( bot in BotTable )
		{
			if ( bot.IsCarryingFlag())
			{
				goal = bot.GetMapGoalName();
				if (!goal or goal.Left(8) != "CAPPOINT")
				{
					pos = bot.GetPosition();
					foreach ( goal in Util.GoalTable("CAPPOINT_.*") )
					{
						name = goal.GetName();
						goalpos = goal.GetPosition();
						if ( DistanceBetween(pos, goalpos) < 1600 )
						{
							if ( name == "CAPPOINT_Pump" )
							{
								if ( !Map.First_Pumphouse_Door or !Map.Second_Pumphouse_Door or tableCount(Map.pht_ally_CG) > 0 )
								{
									goal.SetGoalPriority( TEAM.ALLIES, 0 , 1.1 );
									Util.MapDebugPrint("^5change of priority: " + name );
								}
							}
							else
							{
								goal.SetGoalPriority( TEAM.ALLIES, 0 , 1.1 );
								Util.MapDebugPrint("^5change of priority: " + name );
							}
						}
					}
				}
			}
		}
	},

	Explosives_Dropped = function( trigger )
	{
		Util.MapDebugPrint( "Explosives_Dropped" );

		Map.count_dyno -= 1;

		if ( Map.count_dyno < 1 )
		{
			SetAvailableMapGoals( TEAM.ALLIES, false, "CAPPOINT_.*" );
			SetGoalPriority( "CAPPOINT_.*", 1.02, TEAM.ALLIES, 0 );
		}
		foreach( goal in Util.GoalTable(".*_dropped") )
		{
			goal.MaxUsers_InProgress( 2 );
			goal.SetRange(2500);
		}
		Map.explosives_TakenOrDropped();
	},

	Dockside_Axis_Captured = function( trigger )
	{
		Map.Dockside_Allied = false;
		Map.SetSpawn();

		Util.MapDebugPrint( "Dockside_Axis_Captured" );

		SetAvailableMapGoals( TEAM.AXIS, false, "CHECKPOINT_dockside_flag" );

		ClearGoalRole( "CHECKPOINT_dockside_flag", ROLE.INFILTRATOR );
		SetGoalPriority( "CHECKPOINT_dockside_flag", 0.74, TEAM.ALLIES, 0 );
		SetGoalPriority( "CHECKPOINT_dockside_flag", 0.70, TEAM.ALLIES, CLASS.ENGINEER );

		if ( Map.Old_Lock or Map.South_Winding_Gear or Map.Pump or Map.North_Gate or Map.North_Winding_Gear )
		{
			SetAvailableMapGoals( TEAM.ALLIES, true, "CHECKPOINT_dockside_flag" );
		}
	},

	Dockside_Allies_Captured = function( trigger )
	{
		Map.Dockside_Allied = true;
		Map.SetSpawn();

		Util.MapDebugPrint( "Dockside_Allies_Captured" );

		SetAvailableMapGoals( TEAM.ALLIES, false, "CHECKPOINT_dockside_flag" );

		SetGoalRole( "CHECKPOINT_dockside_flag", ROLE.INFILTRATOR );
		SetGoalPriority( "CHECKPOINT_dockside_flag", 0.64, TEAM.AXIS, 0 );

		if ( Map.Old_Lock or Map.South_Winding_Gear or Map.Pump or Map.North_Gate or Map.North_Winding_Gear )
		{
			SetAvailableMapGoals( TEAM.AXIS, true, "CHECKPOINT_dockside_flag" );
		}
	},

