	Lift_1 = function( trigger )
	{
		vel = ToVector( trigger.Action );
		ent1 = GetEntityByName("lift1");
		Map.Lift_1_Up = false;
		Map.Lift_1_Down = false;

		if ( vel[ 2 ] > 0 )
		{
			Util.MapDebugPrint( "Lift_1_Going_Up" );

			while ( 1 )
			{
				yield();
				z = GetEntPosition(ent1).z;

				if ( z == 1031 )
				{
					break;
				}
			}

			Map.Lift_1_Up = true;

			Util.MapDebugPrint( "Lift_1_Is_Up" );
		}
		else
		{
			Util.MapDebugPrint( "Lift_1_Going_Down" );

			while ( 1 )
			{
				yield();
				z = GetEntPosition(ent1).z;

				if ( z < 400 )
				{
					break;
				}
			}

			Map.Lift_1_Down = true;

			Util.MapDebugPrint( "Lift_1_Is_Down" );
		}
	},

	Lift_2 = function( trigger )
	{
		vel = ToVector( trigger.Action );
		ent2 = GetEntityByName("lift2");
		Map.Lift_2_Up = false;
