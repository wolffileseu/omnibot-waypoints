	Fuel_Dump_Random_Plant_Position = function()
	{
		position = RandInt(1,8);
		goal = GetGoal("PLANT_Fuel_Dump");
		cover0=goal.CoverSpots[0];
		cover1=goal.CoverSpots[1];

		switch (position)
		{
			case 1:
