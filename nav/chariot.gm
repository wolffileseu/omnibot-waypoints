			},
			navigate = function(_this)
			{
				_this.Goto(_this.Bot.GetPosition());

				for ( timer = 0; timer <= 100 and !Map.Wait_Ladder_2_5_Empty; timer += 1 )
				{
					sleep(0.1);
					if ( _this.timer == 100 )
					{
						_this.Bot.ExecCommand( "kill" );
					}
				}

				Map.Wait_Ladder_2_5_Empty = false;

				for ( timer = 0; timer <= 60 and Map.Ladder_2_In_Use != 0; timer += 1 )
				{
					sleep(0.1);
					if ( _this.timer == 60 )
					{
						_this.Bot.ExecCommand( "kill" );
					}
				}

				for (timer = 0; timer < 30 and !_this.Bot.MoveTowards(Vec3(1513.474, 1855.490, 976.125), 10); timer += 1)
				{
					_this.Bot.PressButton(BTN.WALK);
