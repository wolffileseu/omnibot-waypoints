	Util.AddUseWp( "PLANT_1st_Pumphouse_Door", { "1st_Pumphouse_Door_1", "1st_Pumphouse_Door_3" } );
	Util.AddUseWp( "BUILD_1st_Pumphouse_Door", "1st_Pumphouse_Door_5" );
	Util.AddUseWp( "BUILD_2nd_Pumphouse_Door", "2nd_Pumphouse_Door_5" );

	Wp.SetWaypointFlag( "2nd_Pumphouse_Door_1", "door", true );
	Wp.SetWaypointFlag( "2nd_Pumphouse_Door_4", "closed", false );
	Wp.SetWaypointFlag( "2nd_Pumphouse_Door_2", { "door", "axis", "infiltrator" }, true );

	Wp.SetWaypointFlag( "1st_Pumphouse_Door_1", "door", true );
	Wp.SetWaypointFlag( "1st_Pumphouse_Door_4", "closed", false );
	Wp.SetWaypointFlag( "1st_Pumphouse_Door_2", { "door", "axis", "infiltrator" }, true );

	Wp.SetWaypointFlag( "Ladder_[12]", "closed", false );

	Wp.SetWaypointFlag( "Old_Lock_.*", "closed", true );

	Wp.SetWaypointFlag( "North_Gate_[0123456]", "closed", false );
	Wp.SetWaypointFlag( "North_Gate_[78]", "closed", true);

	Wp.SetWaypointFlag( "Crane_1_West_.*", "closed", false );
	Wp.SetWaypointFlag( "Crane_1_South_.*", "closed", true );
	Wp.SetWaypointFlag( "Crane_1_East_.*", "closed", true );
	Wp.SetWaypointFlag( "Crane_1_North_.*", "closed", true );

	Wp.SetWaypointFlag( "Crane_2_West_.*", "closed", false );
	Wp.SetWaypointFlag( "Crane_2_South_.*", "closed", true );
	Wp.SetWaypointFlag( "Crane_2_East_.*", "closed", true );
	Wp.SetWaypointFlag( "Crane_2_North_.*", "closed", true );

	Wp.SetWaypointFlag( "Fuel_Dump_[12345]", "closed", true);
	Wp.SetWaypointFlag( "Fuel_Dump_[67]", "closed", false );

	for ( s = 0; s <= 45; s += 1 )
	{
		Wp.SetWaypointFlag( "SWG_" + s, "closed", false );
	}

	for ( k = 46; k <= 63; k += 1 )
	{
		Wp.SetWaypointFlag( "SWG_" + k, "closed", true );
	}

	for ( o = 0; o <= 45; o += 1 )
	{
		Wp.SetWaypointFlag( "NWG_" + o, "closed", false );
	}

	for ( d = 46; d <= 63; d += 1 )
	{
		Wp.SetWaypointFlag( "NWG_" + d, "closed", true );
	}

	Map.Crane_1_Path_Adjustment();
	Map.Crane_2_Path_Adjustment();
	Map.Fuel_Dump_Random_Plant_Position();

	WeaponTable.SetWeaponAvailability( CLASS.SOLDIER, WEAPON.MP40, true );
	WeaponTable.SetWeaponAvailability( CLASS.SOLDIER, WEAPON.THOMPSON, true );
	WeaponTable.SetWeaponAvailability( CLASS.SOLDIER, WEAPON.PANZERFAUST, false );
	WeaponTable.SetWeaponAvailability( CLASS.SOLDIER, WEAPON.FLAMETHROWER, false );

	sleep(8);

	SetAvailableMapGoals( TEAM.ALLIES, true, "FLAG_explosives_2" );

	if ( GetGameState() == "Playing" )
	{
		EchoToScreen(0,"^3Omni-bot map script ^3by ^1Q^2i^3k^4i ^3and ^1n^2a^4t^8i^3v^5e12 ^3");
		Util.BotChat( 0, "say", "^3Omni-bot map script ^3by ^1Q^2i^3k^4i ^3and ^1n^2a^4t^8i^3v^5e12^7" , 1 );
	}
};

global OnBotJoin = function( bot )
{
	Map.SetSpawn1(bot);
	bot.TargetBreakableDist = 100;
};

