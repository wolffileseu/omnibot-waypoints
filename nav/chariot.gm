		},

		//	/bot waypoint_setproperty paththrough Navigation_PT:wait_ship_ladder_1_1
		wait_ship_ladder_1_1 =
		{
			OnExit = function(_this)
			{
				Map.Wait_Ladder_1_1_Empty = true;
			},
			navigate = function(_this)
			{
				_this.Goto(_this.Bot.GetPosition());

				while ( !Map.Wait_Ladder_1_1_Empty )
				{
					yield();
				}

				Map.Wait_Ladder_1_1_Empty = false;
				while ( Map.Ladder_1_In_Use != 0 )
				{
					yield();
				}
				for (timer = 0; timer < 30 and !_this.Bot.MoveTowards(Vec3(2765.194, 1873.165, 976.305), 10); timer += 1)
				{
					_this.Bot.PressButton(BTN.WALK);
					sleep(0.1);
				}
			},
		},

