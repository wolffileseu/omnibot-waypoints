	ShipLadderInstructions = function(_this, pos, empty1, empty2)
	{
		_this.Goto(_this.Bot.GetPosition());

		while (!Map[empty1])
		{
			yield();
		}

		Map[empty1] = false;
		while (!Map[empty2])
		{
			yield();
		}
		for (timer = 0; timer <= 60 and !_this.Bot.MoveTowards(pos, 10); timer += 1)
		{
			_this.Bot.PressButton(BTN.WALK);
			sleep(0.1);
		}
		if ( !_this.Bot.MoveTowards(pos, 10) )
		{
			_this.Bot.ExecCommand( "kill" );
		}
	},

	First_Pumphouse_Door_Built = function( trigger )
	{
		Map.First_Pumphouse_Door = true;

		Wp.SetWaypointFlag( "1st_Pumphouse_Door_1", "door", true );
		Wp.SetWaypointFlag( "1st_Pumphouse_Door_4", "closed", false );
		Wp.SetWaypointFlag( "1st_Pumphouse_Door_2", { "door", "axis", "infiltrator" }, true );

		DynamicPathsUpdated( TEAM.AXIS, TEAM.ALLIES );

		if ( Map.Second_Pumphouse_Door )
		{
			if (!Map.Pump_Primed)
			{
				SetGoalRole( "CAPPOINT_Pump", ROLE.ROAMER );
			}
			SetGoalRole( "PLANT_Pump", ROLE.ROAMER );
			SetGoalRole( "ATTACK_Allies_PumpHouse_.*", ROLE.ROAMER );
		}

		Util.MapDebugPrint( "First_Pumphouse_Door_Built" );

		SetAvailableMapGoals( TEAM.AXIS, false, "BUILD_1st_Pumphouse_Door" );

		if ( Map.Pump )
		{
			SetAvailableMapGoals( TEAM.ALLIES, true, "PLANT_1st_Pumphouse_Door" );
		}
	},

	First_Pumphouse_Door_Planted = function( trigger )
	{
		Util.MapDebugPrint( "First_Pumphouse_Door_Planted" );

		foreach( goal in Util.GoalTable("DEFUSE_1st_Pumphouse_Door_.*") )
		{
			goal.SetRange(1100);
			goal.MaxUsers_InProgress( 2 );
			goal.SetGoalPriority( TEAM.AXIS, 0 , 0.8 );
			goal.SetRoles(ROLE.DEFENDER, ROLE.DEFENDER1);

			if ((!Map.North_Gate or !Map.North_Gate_Primed) and (!Map.North_Winding_Gear or !Map.North_Winding_Gear_Primed))
			{
				goal.SetRoles(ROLE.DEFENDER2);
			}
			if ( !Map.Fuel_Dump or (!Map.Fuel_Dump_Primed and tableCount(Map.fdt_ally) < 1 and Map.g != "FuelDump" and Map.h != "FuelDump" ))
			{
				goal.SetRoles(ROLE.DEFENDER3);
			}
		}
	},

	First_Pumphouse_Door_Destroyed = function( trigger )
	{
		Map.First_Pumphouse_Door = false;

		Wp.SetWaypointFlag( "1st_Pumphouse_Door_1", "door", false );
		Wp.SetWaypointFlag( "1st_Pumphouse_Door_4", "closed", true );
		Wp.SetWaypointFlag( "1st_Pumphouse_Door_2", { "door", "axis", "infiltrator" }, false );

		DynamicPathsUpdated( TEAM.AXIS, TEAM.ALLIES );

		if (!Map.Pump_Primed)
		{
			ClearGoalRole( "CAPPOINT_Pump", ROLE.ROAMER );
		}
		ClearGoalRole( "PLANT_Pump", ROLE.ROAMER );
		ClearGoalRole( "ATTACK_Allies_PumpHouse_.*", ROLE.ROAMER );

		Util.MapDebugPrint( "First_Pumphouse_Door_Destroyed" );

		SetAvailableMapGoals( TEAM.ALLIES, false, "PLANT_1st_Pumphouse_Door" );

		foreach( goal in Util.GoalTable("DEFUSE_1st_Pumphouse_Door_.*") )
		{
			goal.SetAvailable(TEAM.AXIS, false);
		}

		if ( Map.Pump )
		{
			SetAvailableMapGoals( TEAM.AXIS, true, "BUILD_1st_Pumphouse_Door" );
		}
	},

	Second_Pumphouse_Door_Built = function( trigger )
	{
		Map.Second_Pumphouse_Door = true;

		Wp.SetWaypointFlag( "2nd_Pumphouse_Door_1", "door", true );
		Wp.SetWaypointFlag( "2nd_Pumphouse_Door_4", "closed", false );
		Wp.SetWaypointFlag( "2nd_Pumphouse_Door_2", { "door", "axis", "infiltrator" }, true );

		DynamicPathsUpdated( TEAM.AXIS, TEAM.ALLIES );

		if ( Map.First_Pumphouse_Door )
		{
			if (!Map.Pump_Primed)
			{
				SetGoalRole( "CAPPOINT_Pump", ROLE.ROAMER );
			}
			SetGoalRole( "PLANT_Pump", ROLE.ROAMER );
			SetGoalRole( "ATTACK_Allies_PumpHouse_.*", ROLE.ROAMER );
		}

		Util.MapDebugPrint( "Second_Pumphouse_Door_Built" );

		SetAvailableMapGoals( TEAM.AXIS, false, "BUILD_2nd_Pumphouse_Door" );

		if ( Map.Pump )
		{
			SetAvailableMapGoals( TEAM.ALLIES, true, "PLANT_2nd_Pumphouse_Door" );
		}
	},

	Second_Pumphouse_Door_Planted = function( trigger )
	{
		Util.MapDebugPrint( "Second_Pumphouse_Door_Planted" );

		foreach( goal in Util.GoalTable("DEFUSE_2nd_Pumphouse_Door_.*") )
		{
			goal.SetRange(1100);
			goal.MaxUsers_InProgress( 2 );
			goal.SetGoalPriority( TEAM.AXIS, 0 , 0.8 );
			goal.SetRoles(ROLE.DEFENDER, ROLE.DEFENDER1);

			if ((!Map.North_Gate or !Map.North_Gate_Primed) and (!Map.North_Winding_Gear or !Map.North_Winding_Gear_Primed))
			{
				goal.SetRoles(ROLE.DEFENDER2);
			}
			if ( !Map.Fuel_Dump or (!Map.Fuel_Dump_Primed and tableCount(Map.fdt_ally) < 1 and Map.g != "FuelDump" and Map.h != "FuelDump" ))
			{
				goal.SetRoles(ROLE.DEFENDER3);
			}
		}
	},

	Second_Pumphouse_Door_Destroyed = function( trigger )
	{
		Map.Second_Pumphouse_Door = false;

		Wp.SetWaypointFlag( "2nd_Pumphouse_Door_1", "door", false );
		Wp.SetWaypointFlag( "2nd_Pumphouse_Door_4", "closed", true );
		Wp.SetWaypointFlag( "2nd_Pumphouse_Door_2", { "door", "axis", "infiltrator" }, false );

		DynamicPathsUpdated( TEAM.AXIS, TEAM.ALLIES );

		if (!Map.Pump_Primed)
		{
			ClearGoalRole( "CAPPOINT_Pump", ROLE.ROAMER );
		}
		ClearGoalRole( "PLANT_Pump", ROLE.ROAMER );
		ClearGoalRole( "ATTACK_Allies_PumpHouse_.*", ROLE.ROAMER );

		Util.MapDebugPrint( "Second_Pumphouse_Door_Destroyed" );

		SetAvailableMapGoals( TEAM.ALLIES, false, "PLANT_2nd_Pumphouse_Door" );

		foreach( goal in Util.GoalTable("DEFUSE_2nd_Pumphouse_Door_.*") )
		{
			goal.SetAvailable(TEAM.AXIS, false);
		}

		if ( Map.Pump )
		{
			SetAvailableMapGoals( TEAM.AXIS, true, "BUILD_2nd_Pumphouse_Door" );
		}
	},

	Disable_Goals_after_Capture = function ()
	{
		if ( Map.count_dyno < 1 )
		{
			SetAvailableMapGoals( TEAM.ALLIES, false, "CAPPOINT_.*" );
		}

		Util.DisableGoal( ".*Start_.*" );
		Util.DisableGoal( ".*Out_.*" );
		Util.DisableGoal(".*MG42_Garage");
	},

	Enable_Goals_after_Capture = function ()
	{
		if ( Map.Old_Lock )
		{
			SetAvailableMapGoals( TEAM.AXIS, true, ".*Axis_OldLockStart_.*" );
			SetAvailableMapGoals( TEAM.ALLIES, true, ".*Allies_OldLockStart_.*" );
		}
		if ( Map.South_Winding_Gear )
		{
			SetAvailableMapGoals( TEAM.AXIS, true, ".*Axis_SWHOut_.*" );
			SetAvailableMapGoals( TEAM.ALLIES, true, ".*Allies_SWHOut_.*" );
		}
		if ( Map.Pump )
		{
			SetAvailableMapGoals( TEAM.AXIS, true, ".*Axis_PumpHouseOut_.*" );
			SetAvailableMapGoals( TEAM.ALLIES, true, ".*Allies_PumpHouseOut_.*" );
		}
		if ( Map.North_Gate )
		{
			SetAvailableMapGoals( TEAM.AXIS, true, ".*Axis_NorthGateStart_.*" );
			SetAvailableMapGoals( TEAM.ALLIES, true, ".*Allies_NorthGateStart_.*" );
		}
		if ( Map.North_Winding_Gear )
		{
			SetAvailableMapGoals( TEAM.AXIS, true, ".*Axis_NWHOut_.*" );
			SetAvailableMapGoals( TEAM.ALLIES, true, ".*Allies_NWHOut_.*" );
		}
		if ( Map.Fuel_Dump )
		{
			SetAvailableMapGoals( TEAM.AXIS, true, {
				".*Axis_FuelDumpOut_.*",
				".*MG42_Garage",
			});
			SetAvailableMapGoals( TEAM.ALLIES, true, ".*Allies_FuelDumpOut_.*" );
		}
	},

	Manage_Defends_Attacks = function (goal_axis, goal_allied)
	{
		amount_ax = Server.Team[TEAM.AXIS].NumPlayers;
		if ( amount_ax > 0 )
		{
			if ( Map.destroyed_count == 5 ) //the last defend is available => all bots
			{
				for( i = 1; i <= amount_ax and i <= 20; i += 1 )
				{
					SetAvailableMapGoals( TEAM.AXIS, true, goal_axis + i );
				}
			}
			else    //two differend defend spots are available
			{
				if ( Map.primed_count == 2 )    //both dyna placed
				{
					for( j = 20; j > Round(amount_ax/2); j -= 1 )
					{
						SetAvailableMapGoals( TEAM.AXIS, false, goal_axis + j );
					}
					for( i = 1; i <= Round(amount_ax/2) and i <= 10; i += 1 )
					{
						SetAvailableMapGoals( TEAM.AXIS, true, goal_axis + i );
					}
				}
				else
				{
					if ( Map.count_dyno == 1 )  //one dyno is taken
					{
						for( j = 20; j > Round(amount_ax/2); j -= 1 )
						{
							SetAvailableMapGoals( TEAM.AXIS, false, goal_axis + j );
						}
						for( i = 1; i <= Round(amount_ax/2) and i <= 10; i += 1 )
						{
							SetAvailableMapGoals( TEAM.AXIS, true, goal_axis + i );
						}
					}
					else
					{
						for( i = 1; i <= amount_ax and i <= 20; i += 1 )
						{
							SetAvailableMapGoals( TEAM.AXIS, true, goal_axis + i );
						}
					}
				}
			}
		}
		else
		{
			SetAvailableMapGoals( TEAM.AXIS, false, goal_axis + ".*" );
		}

		amount_al = Server.Team[TEAM.ALLIES].NumPlayers;
		if ( amount_al > 0 )
		{
			if ( Map.destroyed_count == 5 ) //the last attack is available => all bots
			{
				for( k = 1; k <= amount_al and k <= 20; k += 1 )
				{
					SetAvailableMapGoals( TEAM.ALLIES, true, goal_allied + k );
				}
			}
			else    //two differend attack spots are available
			{
				if ( Map.primed_count == 2 )    //both dyna placed
				{
					for( m = 20; m > Round(amount_ax/2); m -= 1 )
					{
						SetAvailableMapGoals( TEAM.ALLIES, false, goal_allied + m );
					}
					for( k = 1; k <= Round(amount_al/2) and k <= 10; k += 1 )
					{
						SetAvailableMapGoals( TEAM.ALLIES, true, goal_allied + k );
					}
				}
				else
				{
					if ( Map.count_dyno == 1 )  //one dyno is taken
					{
						for( m = 20; m > Round(amount_ax/2); m -= 1 )
						{
							SetAvailableMapGoals( TEAM.ALLIES, false, goal_allied + m );
						}
						for( k = 1; k <= Round(amount_al/2) and k <= 10; k += 1 )
						{
							SetAvailableMapGoals( TEAM.ALLIES, true, goal_allied + k );
						}
					}
					else
					{
						for( k = 1; k <= amount_al and k <= 20; k += 1 )
						{
							SetAvailableMapGoals( TEAM.ALLIES, true, goal_allied + k );
						}
					}
				}
			}
		}
		else
		{
			SetAvailableMapGoals( TEAM.ALLIES, false, goal_allied + ".*" );
		}
	},

	PumpHouseTrigger =
	{
		Name = "PumpHouseTrigger",
		TriggerOnClass = CLASS.ANYPLAYER,
		OnEnter = function(ent)
		{
			if ( GetEntTeam(ent) == TEAM.ALLIES )
			{
				bot = Util.IsBot(ent);
				if(bot)
				{
					bot.SetRoles(ROLE.ROAMER);
					goal = bot.GetMapGoalName();
				}

				if (Map.pht_ally[ent])
				{
					Map.pht_ally[ent] += 1;
					if ( GetEntFlags(ent,ENTFLAG.CARRYINGGOAL) )
					{
						if(!bot)
						{
							Map.pht_ally_CG[ent] += 1;
						}
						else
						{
							if (goal == "CAPPOINT_Pump" and bot.Name and bot.IsCarryingFlag())
							{
								Map.pht_ally_CG[ent] += 1;
							}
						}
					}
				}
				else
				{
					Map.pht_ally[ent] = 1;
					if ( GetEntFlags(ent,ENTFLAG.CARRYINGGOAL) )
					{
						if(!bot)
						{
							Map.pht_ally_CG[ent] = 1;
						}
						else
						{
							if (goal == "CAPPOINT_Pump" and bot.Name and bot.IsCarryingFlag())
							{
								Map.pht_ally_CG[ent] = 1;
							}
						}
					}
				}

				if ( !Map.Pump_Primed and GetEntFlags(ent,ENTFLAG.CARRYINGGOAL) )
				{
					thread(Map.Disable_Goals_after_Capture);
					if ( !bot )
					{
						SetAvailableMapGoals( TEAM.AXIS, true, "DEFEND_Axis_PumpHouse_[123]");
					}
					else
					{
						if (goal == "CAPPOINT_Pump" and bot.Name and bot.IsCarryingFlag())
						{
							SetAvailableMapGoals( TEAM.AXIS, true, "DEFEND_Axis_PumpHouse_[123]");
						}
					}
					yield();
					thread(Map.Enable_Goals_after_Capture);
				}
			}
		},
		OnExit = function(ent)
		{
			if (Map.pht_ally[ent])
			{
				bot = Util.IsBot(ent);
				if(bot)
				{
					bot.ClearRoles(ROLE.ROAMER);
					goal = bot.GetMapGoalName();
				}

				if (Map.pht_ally[ent] > 1)
				{
					Map.pht_ally[ent] -= 1;
					if ( GetEntFlags(ent,ENTFLAG.CARRYINGGOAL) )
					{
						if(!bot)
						{
							Map.pht_ally_CG[ent] -= 1;
						}
						else
						{
							if (goal != "CAPPOINT_Pump" and bot.Name and bot.IsCarryingFlag())
							{
								Map.pht_ally_CG[ent] -= 1;
							}
						}
					}
				}
				else
				{
					Map.pht_ally[ent] = null;
					Map.pht_ally_CG[ent] = null;
				}

				if (( tableCount(Map.pht_ally) < 1 or tableCount(Map.pht_ally_CG) < 1) and Map.g != "PumpHouse" and Map.h != "PumpHouse" )
				{
					if ( !Map.Pump_Primed or !Map.Pump )
					{
						SetAvailableMapGoals( TEAM.AXIS, false, "DEFEND_Axis_PumpHouse_[123]");
						SetAvailableMapGoals( TEAM.ALLIES, false, "ATTACK_Allies_PumpHouse_[123]");
					}
				}
			}
		},
	},

	Pump_Captured = function ( trigger )
	{
		Map.Pump_Primed = true;
		Map.count_dyno -= 1;
		Map.primed_count += 1;
		Map.cappoint_count += 1;
		Map.pht_ally[ent] = null;
		Map.pht_ally_CG[ent] = null;

		Util.MapDebugPrint( "Pump_Captured" );

		SetAvailableMapGoals( TEAM.ALLIES, true, "PLANT_Pump" );

		if ( !Map.owner_CP )
		{
			thread( Map.explosives_TakenOrDropped );
		}

		Util.RemoveGoal( "CAPPOINT_Pump" );

		while ( Map.Pump )
		{
			goal_axis = "DEFEND_Axis_PumpHouse_";
			goal_allied = "ATTACK_Allies_PumpHouse_";
			Map.Manage_Defends_Attacks(goal_axis, goal_allied);

			sleep(1);
		}

		Util.DisableGoal(".*_PumpHouse.*");
	},

	Pump_Planted = function( trigger )
	{
		Util.MapDebugPrint( "Pump_Planted" );

		count = ETUtil.CountClass( TEAM.AXIS, CLASS.ENGINEER);

		foreach( goal in Util.GoalTable("DEFUSE_Pump_.*") )
		{
			goal.SetRange(2500);
			if ( Map.primed_count == 2 and count > 1 )
			{
				amount = Round(count/2);
				goal.MaxUsers_InProgress( ToInt(amount) );
			}
			goal.SetGoalPriority( TEAM.AXIS, 0 , 1.1 );
		}
	},

	Pump_Destroyed = function( trigger )
	{
		Map.Pump = false;
		Map.primed_count -= 1;
		Map.destroyed_count += 1;
		DeleteTriggerRegion("PumpHouseTrigger");	//not earlier because of role Roamer

		Util.MapDebugPrint( "Pump_Destroyed" );

		foreach( goal in Util.GoalTable("DEFUSE_Pump_.*") )
		{
			goal.SetAvailable(TEAM.AXIS, false);
		}

		if ( Map.First_Pumphouse_Door or Map.Second_Pumphouse_Door )
		{
			Util.DisableGoal( ".*_Pumphouse_Door.*" );
		}

		Map.SetSpawn();
	},

	Fuel_Dump_Gate_Planted = function( trigger )
	{
		Util.MapDebugPrint( "Fuel_Dump_Gate_Planted" );

		foreach( goal in Util.GoalTable("DEFUSE_Fuel_Dump_Gate_.*") )
		{
			goal.SetRange(2500);
			goal.MaxUsers_InProgress( 2 );
			goal.SetGoalPriority( TEAM.AXIS, 0 , 0.9 );
		}
	},

	Fuel_Dump_Gate_Destroyed = function( trigger )
	{
		Map.Fuel_Dump_Gate = false;

		Util.MapDebugPrint( "Fuel_Dump_Gate_Destroyed" );

		foreach( goal in Util.GoalTable("DEFUSE_Fuel_Dump_Gate_.*") )
		{
			goal.SetAvailable(TEAM.AXIS, false);
		}

		Util.EnableGoal( "ROUTE_Lift1Route" );
		Util.EnableGoal( "ROUTE_Lift2Route" );
	},

	FuelDumpTrigger =
	{
		Name = "FuelDumpTrigger",
		TriggerOnClass = CLASS.ANYPLAYER,
		OnEnter = function(ent)
		{
			if ( GetEntTeam(ent) == TEAM.ALLIES )
			{
				bot = Util.IsBot(ent);
				if(bot){goal = bot.GetMapGoalName();}
				if (Map.fdt_ally[ent])
				{
					Map.fdt_ally[ent] += 1;
					if ( GetEntFlags(ent,ENTFLAG.CARRYINGGOAL) )
					{
						if(!bot)
						{
							Map.fdt_ally_CG[ent] += 1;
						}
						else
						{
							if (goal == "CAPPOINT_Fuel_Dump" and bot.Name and bot.IsCarryingFlag())
							{
								Map.fdt_ally_CG[ent] += 1;
							}
						}
					}
				}
				else
				{
					Map.fdt_ally[ent] = 1;
					if ( GetEntFlags(ent,ENTFLAG.CARRYINGGOAL) )
					{
						if(!bot)
						{
							Map.fdt_ally_CG[ent] = 1;
						}
						else
						{
							if (goal == "CAPPOINT_Fuel_Dump" and bot.Name and bot.IsCarryingFlag())
							{
								Map.fdt_ally_CG[ent] = 1;
							}
						}
					}
				}

				if ( !Map.Fuel_Dump_Primed and GetEntFlags(ent,ENTFLAG.CARRYINGGOAL) )
				{
					thread(Map.Disable_Goals_after_Capture);
					if ( !bot )
					{
						SetAvailableMapGoals( TEAM.AXIS, true, "DEFEND_Axis_FuelDump_[123]");
					}
					else
					{
						if (goal == "CAPPOINT_Fuel_Dump" and bot.Name and bot.IsCarryingFlag())
						{
							SetAvailableMapGoals( TEAM.AXIS, true, "DEFEND_Axis_FuelDump_[123]");
						}
					}
					yield();
					thread(Map.Enable_Goals_after_Capture);
				}
			}
		},
		OnExit = function(ent)
		{
			if (Map.fdt_ally[ent])
			{
				bot = Util.IsBot(ent);
				if(bot){goal = bot.GetMapGoalName();}
				if (Map.fdt_ally[ent] > 1)
				{
					Map.fdt_ally[ent] -= 1;
					if ( GetEntFlags(ent,ENTFLAG.CARRYINGGOAL) )
					{
						if(!bot)
						{
							Map.fdt_ally_CG[ent] -= 1;
						}
						else
						{
							if (goal != "CAPPOINT_Fuel_Dump" and bot.Name and bot.IsCarryingFlag())
							{
								Map.fdt_ally_CG[ent] -= 1;
							}
						}
					}
				}
				else
				{
					Map.fdt_ally[ent] = null;
					Map.fdt_ally_CG[ent] = null;
				}

				if (( tableCount(Map.fdt_ally) < 1 or tableCount(Map.fdt_ally_CG) < 1) and Map.g != "FuelDump" and Map.h != "FuelDump" )
				{
					if ( !Map.Fuel_Dump_Primed or !Map.Fuel_Dump )
					{
						SetAvailableMapGoals( TEAM.AXIS, false, "DEFEND_Axis_FuelDump_[123]");
						SetAvailableMapGoals( TEAM.ALLIES, false, "ATTACK_Allies_FuelDump_[123]");
					}
				}
			}
		},
	},

	Fuel_Dump_Captured = function ( trigger )
	{
		Map.Fuel_Dump_Primed = true;
		Map.count_dyno -= 1;
		Map.primed_count += 1;
		Map.cappoint_count += 1;
		DeleteTriggerRegion("FuelDumpTrigger");
		Map.fdt_ally[ent] = null;
		Map.fdt_ally_CG[ent] = null;

		Util.MapDebugPrint( "Fuel_Dump_Captured" );

		SetAvailableMapGoals( TEAM.ALLIES, true, "PLANT_Fuel_Dump" );

		if ( !Map.owner_CFD )
		{
			thread( Map.explosives_TakenOrDropped );
		}

		Util.RemoveGoal( "CAPPOINT_Fuel_Dump" );

		while ( Map.Fuel_Dump )
		{
			goal_axis = "DEFEND_Axis_FuelDump_";
			goal_allied = "ATTACK_Allies_FuelDump_";
			Map.Manage_Defends_Attacks(goal_axis, goal_allied);

			sleep(1);
		}
		Util.DisableGoal(".*_FuelDump.*");
		Util.DisableGoal(".*MG42_Garage");
	},

	Fuel_Dump_Planted = function( trigger )
	{
		Util.MapDebugPrint( "Fuel_Dump_Planted" );

		goals = Util.GoalTable("DEFUSE_Fuel_Dump_.*");
		goal = goals[tableCount(goals) - 1];
		goal.SetRange(3000);
		count = ETUtil.CountClass( TEAM.AXIS, CLASS.ENGINEER);
		if ( Map.primed_count == 2 and count > 1 )
		{
			goal.MaxUsers_InProgress( ToInt(Round(count/2)) );
		}
		goal.SetGoalPriority( TEAM.AXIS, 0, 1.1 );

		for (i=1; i<=4; i+=1)
		{
			if (!Map.forceDefend[i] or !GetGoal(Map.forceDefend[i]))
			{
				Map.forceDefend[i] = goal.GetName();
				defend = GetGoal("DEFEND_Axis_FuelDump_" + i);
				defend.SetPosition(goal.GetPosition());
				defend.AimVectors = { Vec3(0.805, -0.585, 0.095), Vec3(-0.982, -0.191, -0.010) };
				break;
			}
		}

		Util.MapDebugPrint( "^5goal: "+Map.forceDefend[i] );
	},

	Fuel_Dump_Defused = function( trigger )
	{
		Util.MapDebugPrint( "Fuel_Dump_Defused" );

		if ( tableCount(Util.GoalTable("DEFUSE_Fuel_Dump_.*")) == 1 )
		{
			Map.Fuel_Dump_Random_Plant_Position();
		}

		yield();

		for (i=1; i<=4; i+=1)
		{
			if (Map.forceDefend[i] and !GetGoal(Map.forceDefend[i]))
			{
				Map.forceDefend[i] = null;
				defend = GetGoal("DEFEND_Axis_FuelDump_" + i);
				defend.SetPosition(Map.DefendFuelDumpPos[i-1]);
				defend.AimVectors = Map.DefendFuelDumpAim[i-1];
			}
		}
	},

	Fuel_Dump_Destroyed = function( trigger )
	{
		Map.Fuel_Dump = false;
		Map.primed_count -= 1;
		Map.destroyed_count += 1;

		Wp.SetWaypointFlag( "Fuel_Dump_[12345]", "closed", false );
		Wp.SetWaypointFlag( "Fuel_Dump_[67]", "closed", true );

		Util.MapDebugPrint( "Fuel_Dump_Destroyed" );

		foreach( goal in Util.GoalTable("DEFUSE_Fuel_Dump_.*") )
		{
			goal.SetAvailable(TEAM.AXIS, false);
		}

		Map.forceDefend = {};

		if ( Map.Fuel_Dump_Gate )
		{
			Util.DisableGoal( ".*Fuel_Dump_Gate.*" );
		}

		SetGoalRole( "BUILD_.*_Pumphouse_Door", ROLE.DEFENDER3 );
	},

	NorthGateTrigger =
	{
		Name = "NorthGateTrigger",
		TriggerOnClass = CLASS.ANYPLAYER,
		OnEnter = function(ent)
		{
			if ( GetEntTeam(ent) == TEAM.ALLIES )
			{
				bot = Util.IsBot(ent);
				if(bot){goal = bot.GetMapGoalName();}
				if (Map.ngt_ally[ent])
				{
					Map.ngt_ally[ent] += 1;
					if ( GetEntFlags(ent,ENTFLAG.CARRYINGGOAL) )
					{
						if(!bot)
						{
							Map.ngt_ally_CG[ent] += 1;
						}
						else
						{
							if (goal == "CAPPOINT_North_Gate" and bot.Name and bot.IsCarryingFlag())
							{
								Map.ngt_ally_CG[ent] += 1;
							}
						}
					}
				}
				else
				{
					Map.ngt_ally[ent] = 1;
					if ( GetEntFlags(ent,ENTFLAG.CARRYINGGOAL) )
					{
						if(!bot)
						{
							Map.ngt_ally_CG[ent] = 1;
						}
						else
						{
							if (goal == "CAPPOINT_North_Gate" and bot.Name and bot.IsCarryingFlag())
							{
								Map.ngt_ally_CG[ent] = 1;
							}
						}
					}
				}

				if ( !Map.North_Gate_Primed and GetEntFlags(ent,ENTFLAG.CARRYINGGOAL) )
				{
					thread(Map.Disable_Goals_after_Capture);
					if ( !bot )
					{
						SetAvailableMapGoals( TEAM.AXIS, true, "DEFEND_Axis_NorthGate_[123]");
					}
					else
					{
						if (goal == "CAPPOINT_North_Gate" and bot.Name and bot.IsCarryingFlag())
						{
							SetAvailableMapGoals( TEAM.AXIS, true, "DEFEND_Axis_NorthGate_[123]");
						}
					}
					yield();
					thread(Map.Enable_Goals_after_Capture);
				}
			}
		},
		OnExit = function(ent)
		{
			if (Map.ngt_ally[ent])
			{
				bot = Util.IsBot(ent);
				if(bot){goal = bot.GetMapGoalName();}
				if (Map.ngt_ally[ent] > 1)
				{
					Map.ngt_ally[ent] -= 1;
					if ( GetEntFlags(ent,ENTFLAG.CARRYINGGOAL) )
					{
						if(!bot)
						{
							Map.ngt_ally_CG[ent] -= 1;
						}
						else
						{
							if (goal != "CAPPOINT_North_Gate" and bot.Name and bot.IsCarryingFlag())
							{
								Map.ngt_ally_CG[ent] -= 1;
							}
						}
					}
				}
				else
				{
					Map.ngt_ally[ent] = null;
					Map.ngt_ally_CG[ent] = null;
				}

				if (( tableCount(Map.ngt_ally) < 1 or tableCount(Map.ngt_ally_CG) < 1) and Map.g != "NorthGate" and Map.h != "NorthGate" )
				{
					if ( !Map.North_Gate_Primed or !Map.North_Gate )
					{
						SetAvailableMapGoals( TEAM.AXIS, false, "DEFEND_Axis_NorthGate_[123]");
						SetAvailableMapGoals( TEAM.ALLIES, false, "ATTACK_Allies_NorthGate_[123]");
					}
				}
			}
		},
	},

	North_Gate_Captured = function ( trigger )
	{
		Map.North_Gate_Primed = true;
		Map.count_dyno -= 1;
		Map.primed_count += 1;
		Map.cappoint_count += 1;
		DeleteTriggerRegion("NorthGateTrigger");
		Map.ngt_ally[ent] = null;
		Map.ngt_ally_CG[ent] = null;

		Util.MapDebugPrint( "North_Gate_Captured" );

		SetAvailableMapGoals( TEAM.ALLIES, true, "PLANT_North_Gate" );

		if ( !Map.owner_CNG )
		{
			thread( Map.explosives_TakenOrDropped );
		}

		Util.RemoveGoal( "CAPPOINT_North_Gate" );

		ClearGoalRole( "BUILD_.*_Pumphouse_Door", ROLE.DEFENDER2 );

		while ( Map.North_Gate )
		{
			goal_axis = "DEFEND_Axis_NorthGate_";
			goal_allied = "ATTACK_Allies_NorthGate_";
			Map.Manage_Defends_Attacks(goal_axis, goal_allied);

			sleep(1);
		}

		Util.DisableGoal(".*_NorthGate.*");
	},

	North_Gate_Planted = function( trigger )
	{
		Util.MapDebugPrint( "North_Gate_Planted" );

		count = ETUtil.CountClass( TEAM.AXIS, CLASS.ENGINEER);

		foreach( goal in Util.GoalTable("DEFUSE_North_Gate_.*") )
		{
			goal.SetRange(3500);
			if ( Map.primed_count == 2 and count > 1 )
			{
				amount = Round(count/2);
				goal.MaxUsers_InProgress( ToInt(amount) );
			}
			goal.SetGoalPriority( TEAM.AXIS, 0 , 1.1 );
		}
	},

	North_Gate_Destroyed = function( trigger )
	{
		Map.North_Gate = false;
		Map.primed_count -= 1;
		Map.destroyed_count += 1;

		Wp.SetWaypointFlag( "North_Gate_[0123456]", "closed", true);
		Wp.SetWaypointFlag( "North_Gate_[78]", "closed", false);

		Util.MapDebugPrint( "North_Gate_Destroyed" );

		foreach( goal in Util.GoalTable("DEFUSE_North_Gate_.*") )
		{
			goal.SetAvailable(TEAM.AXIS, false);
		}

		if (!Map.North_Winding_Gear or !Map.North_Winding_Gear_Primed)
		{
			SetGoalRole( "BUILD_.*_Pumphouse_Door", ROLE.DEFENDER2 );
		}

		Map.SetSpawn();
	},

