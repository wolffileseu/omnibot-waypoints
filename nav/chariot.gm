			OnExit = function(_this)
			{
				Wp.SetWaypointFlag( "Ladder_2", "closed", false );
				DynamicPathsUpdated( TEAM.ALLIES );
			},
			navigate = function(_this)
			{
				Wp.SetWaypointFlag( "Ladder_2", "closed", true );
				DynamicPathsUpdated( TEAM.ALLIES );
				_this.Goto(_this.Bot.GetPosition());

				while ( Map.Allies_At_Ladder_2 != 0 )
				{
					yield();
				}

				for ( timer = 0; timer <= 30 and !_this.Bot.MoveTowards(Vec3(1483.806, 1834.144, 1112.125), 5); timer += 1 )
				{
					_this.Bot.PressButton(BTN.WALK);
					sleep(0.1);

					if ( timer == 30 )
					{
						return;
					}
				}
				sleep(0.5);

				for ( timer = 0; timer <= 30 and !_this.Bot.MoveTowards(Vec3(1482.369, 1869.875, 976.125), 5); timer += 1 )
				{
					_this.Bot.PressButton(BTN.CROUCH);
					sleep(0.1);

					if ( timer == 30 )
					{
						return;
					}
				}
			},
		},

		//	/bot waypoint_setproperty paththrough Navigation_PT:lift_1_up
		//	/bot waypoint_setproperty paththrough Navigation_PT:lift_2_up	=> for: Map.Navigation.lift_2_up
		//	/bot waypoint_setproperty paththrough Navigation_PT:lift_1_down	=> for: Map.Navigation.lift_1_down
		//	/bot waypoint_setproperty paththrough Navigation_PT:lift_2_down	=> for: Map.Navigation.lift_2_down
		lift_1_up =
		{
			OnExit = function(_this)
			{
				botIds = Map.Lifts[_this.CurrentNavigation].botIds;
				foreach (i and bot in botIds)
				{
					if (bot == _this.Bot.GetGameId())
					{
						botIds[i] = -1;
						break;
					}
				}
			},
			navigate = function(_this)
			{
				_this.Goto(_this.Bot.GetPosition());
				name = _this.CurrentNavigation;
				lift = Map.Lifts[name];
				count = tableCount(lift.botIds);

				for (i=0; lift.botIds[i] != -1; i+=1)
				{
					if (i >= count)
					{
						sleep(1);
						return;
					}
				}
				lift.botIds[i] = _this.Bot.GetGameId();

				if ( !Map[lift.StartPos] )
				{
					while ( !_this.Bot.MoveTowards(lift.WaitPositions[i], 10) )
					{
						_this.Bot.PressButton(BTN.WALK);
						yield();
					}
				}
				while ( !Map[lift.StartPos] )
				{
					yield();
				}
				if (name.Right(2) == "up")
				{
					while ( !_this.Bot.MoveTowards(lift.RidePositions[i], 10) )
					{
						_this.Bot.PressButton(BTN.WALK);
						yield();

						if ( _this.Bot.GetPosition().z < lift.z_pos and Map[lift.EndPos] )
						{
							break;
						}
					}
					while ( !Map[lift.EndPos] )
					{
						_this.Bot.MoveTowards(_this.Bot.GetPosition());
						yield();
					}
					while ( !_this.Bot.MoveTowards(lift.ExitPosition, 35) )
					{
						yield();
					}
				}
				else
				{
					while ( !_this.Bot.MoveTowards(lift.RidePositions[i], 10) )
					{
						_this.Bot.PressButton(BTN.WALK);
						yield();
					}
					while ( !Map[lift.EndPos] )
					{
						_this.Bot.MoveTowards(_this.Bot.GetPosition());
						yield();
					}
					if ( _this.Bot.GetPosition().z < lift.z_pos )
					{
						return;
					}
					else
					{
						while ( !_this.Bot.MoveTowards(lift.ExitPosition, 35) )
						{
							yield();
						}
					}
				}
			},
		},
	},

