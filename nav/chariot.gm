				}
			}

			Map.Lift_2_Down = true;

			Util.MapDebugPrint( "Lift_2_Is_Down" );
		}
	},

	Crane_1_Moving = function( trigger )
	{
		vel = ToVector( trigger.Action );

		Wp.SetWaypointFlag( "Crane_1_.*", "closed", true );

		DynamicPathsUpdated( TEAM.AXIS, TEAM.ALLIES );

		if ( vel[ 1 ] > 0 )
		{
			Util.MapDebugPrint( "Crane_1_Moving_Left" );
		}
		else
		{
			Map.Crane_1_Moving_Right = true;

			Util.MapDebugPrint( "Crane_1_Moving_Right" );
		}
	},

	Crane_1_Stop = function( trigger )
	{
		if ( Map.Crane_1_Moving_Right )
		{
			if ( Map.Crane_1_Facing == "West" )
			{
				Map.Crane_1_Facing = "North";

				Wp.SetWaypointFlag( "Crane_1_North_.*", "closed", false );
			}
			else if ( Map.Crane_1_Facing == "North" )
			{
				Map.Crane_1_Facing = "East";

				Wp.SetWaypointFlag( "Crane_1_East_.*", "closed", false );
			}
			else if ( Map.Crane_1_Facing == "East" )
			{
				Map.Crane_1_Facing = "South";

				Wp.SetWaypointFlag( "Crane_1_South_.*", "closed", false );
			}
			else
			{
				Map.Crane_1_Facing = "West";

				Wp.SetWaypointFlag( "Crane_1_West_.*", "closed", false );
			}

			Map.Crane_1_Moving_Right = false;
		}
		else
		{
			if ( Map.Crane_1_Facing == "West" )
			{
				Map.Crane_1_Facing = "South";

				Wp.SetWaypointFlag( "Crane_1_South_.*", "closed", false );
			}
			else if ( Map.Crane_1_Facing == "South" )
			{
				Map.Crane_1_Facing = "East";

				Wp.SetWaypointFlag( "Crane_1_East_.*", "closed", false );
			}
			else if ( Map.Crane_1_Facing == "East" )
			{
				Map.Crane_1_Facing = "North";

				Wp.SetWaypointFlag( "Crane_1_North_.*", "closed", false );
			}
			else
			{
				Map.Crane_1_Facing = "West";

				Wp.SetWaypointFlag( "Crane_1_West_.*", "closed", false );
			}
		}

		Util.MapDebugPrint( "Crane_1_Facing_" + Map.Crane_1_Facing );

		Map.Crane_1_Path_Adjustment();

		DynamicPathsUpdated( TEAM.AXIS, TEAM.ALLIES );
	},

	Crane_2_Moving = function( trigger )
	{
		vel = ToVector( trigger.Action );

