	{
		Map.Wooden_Plank_2 = false;
		Util.MapDebugPrint( "Wooden_Plank_2_Exploded" );
		sleep(1);
		
		if ( !Map.Wooden_Plank_1 and !Map.Wooden_Plank_3 and !Map.Wooden_Plank_4 and !Map.Wooden_Plank_5 )
		{
			Wp.SetWaypointFlag( "Planks_.*", "closed", false );
			
			Util.EnableGoal( "ROUTE_Planks_.*" );
			Util.EnableGoal( "ROUTE_Flag2Way_.*" );
			
			Util.DisableGoal( "GRENADE_Wooden_Planks_.*" );
		}
	},
	
