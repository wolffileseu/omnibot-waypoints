		ClearGoalRole( ".*MG42_Tower" , ROLE.DEFENDER1 );
		
		Util.MapDebugPrint( "Launch_Pad_Axis_Captured" );
	},

	Launch_Pad_Allies_Captured = function( trigger )
	{
