global Map =
{
	Debug = 0,
	Allied_CP = false,
	Axis_CP = false,
	CP_Fixed = false,
	Steam_Engine_Room = 0,
	Launch_Pad = 0,
	Abbey = 0,
	Prison_Building = 0,
	Headquarters_Building = 0,
	Water_Tunnel_Cover = true,
	Wooden_Plank_1 = true,
	Wooden_Plank_2 = true,
	Wooden_Plank_3 = true,
	Wooden_Plank_4 = true,
	Wooden_Plank_5 = true,
	Wooden_Barrier = true,
	
	Attackers = {ROLE.ATTACKER, ROLE.ATTACKER1, ROLE.ATTACKER2, ROLE.ATTACKER3, ROLE.OFFENSECAPTAIN},
	Defenders = {ROLE.DEFENDER, ROLE.DEFENDER1, ROLE.DEFENDER2, ROLE.DEFENDER3, ROLE.DEFENSECAPTAIN},
	
	Navigation =
	{
		//	/bot waypoint_setproperty paththrough Navigation_PT:jump_wait
		jump_wait =
		{
			navigate = function(_this)
			{
				sleep(0.25);
				_this.Bot.HoldButton(BTN.JUMP, 0.55);
				sleep(0.55);
			},
		},
		
		//	/bot waypoint_setproperty paththrough Navigation_PT:water_tunnel_cover
		water_tunnel_cover =
		{
			EvalFunc = function(_this)
			{
				return Map.Water_Tunnel_Cover;
			},
			navigate = function(_this)
			{
				weaps =
				{
					WEAPON.LUGER,
					WEAPON.LUGER_AKIMBO,
					WEAPON.LUGER_SILENCED,
					WEAPON.LUGER_AKIMBO_SILENCED,
					WEAPON.COLT,
					WEAPON.COLT_AKIMBO,
					WEAPON.COLT_SILENCED,
					WEAPON.COLT_AKIMBO_SILENCED
				};
				_this.Goto(_this.Bot.GetPosition());
				_this.AddAimRequest(Priority.High, "position", Vector3(-2854.011, 5.688, 97.619));
				
				foreach ( w in weaps )
				{
					if ( _this.Bot.HasWeapon(w) )
					{
						_this.AddWeaponRequest(w);
						break;
					}
				}
				sleep(0.5);
				
				while ( Map.Water_Tunnel_Cover )
				{
					_this.Bot.HoldButton(BTN.ATTACK1, 0.2);
					sleep(0.2);
				}
			},
		},
		
		//	/bot waypoint_setproperty paththrough Navigation_PT:wooden_barrier
		wooden_barrier =
		{
			EvalFunc = function(_this)
			{
				return Map.Wooden_Barrier;
			},
			navigate = function(_this)
			{
				_this.Goto(_this.Bot.GetPosition());
				_this.AddAimRequest(Priority.High, "position", Vector3(-1771.125, -1123.423, 147.482));
				_this.AddWeaponRequest(Priority.VeryHigh, WEAPON.KNIFE );
				_this.timer = 0;
				sleep(0.5);
				
				while ( Map.Wooden_Barrier )
				{
					_this.Bot.HoldButton(BTN.ATTACK1, 0.1);
					sleep(0.1);
					_this.timer += 1;
					
					if ( _this.timer == 150 )
					{
						_this.ReleaseWeaponRequest();
						_this.ReleaseAimRequest();
						
						while ( !_this.Bot.MoveTowards(Vec3(-2149.317, -1189.462, 43.445), 35) )
						{
							yield();
						}
					}
				}
			},
		},
	},
	
	Allied_CP_Built = function( trigger )
	{
		Map.Allied_CP = true;
		
		Util.MapDebugPrint( "Allied_CP_Built" );
	},

	Allied_CP_Destroyed = function( trigger )
	{
		Map.Allied_CP = false;
		
		Util.MapDebugPrint( "Allied_CP_Destroyed" );
		
		foreach( goal in Util.GoalTable("DEFUSE_Command_Post_.*") )
		{
			goal.SetAvailable(TEAM.ALLIES, false);
		}
	},

	Axis_CP_Built = function( trigger )
	{
		Map.Axis_CP = true;
		
		Util.MapDebugPrint( "Axis_CP_Built" );
	},

	Axis_CP_Destroyed = function( trigger )
	{
		Map.Axis_CP = false;
		
		Util.MapDebugPrint( "Axis_CP_Destroyed" );
		
		foreach( goal in Util.GoalTable("DEFUSE_Command_Post_.*") )
		{
			goal.SetAvailable(TEAM.AXIS, false);
		}
	},

	CP_Planted = function( trigger )
	{
		foreach( goal in Util.GoalTable("DEFUSE_Command_Post_.*") )
		{
			name = goal.GetName();
			Util.SetGoalRange( name, 1400);
			goal.MaxUsers_InProgress( 1 );
		}
	},

	Command_Post_Fixed = function( trigger )
	{
		Map.CP_Fixed = true;
		
		Util.EnableGoal( "BUILD_Command_Post" );
		
		Util.MapDebugPrint( "Command_Post_Fixed" );
	},

	Steam_Engine_Room_Axis_Captured = function( trigger )
	{
