		Util.MapDebugPrint( "Headquarters_Building_Allies_Captured" );
	},
	
	Sidewalk_Exploded = function( trigger )
	{
		Wp.SetWaypointFlag( "Sidewalk_1", "closed", true );
		Wp.SetWaypointFlag( "Sidewalk_[23]", "closed", false );
		Wp.SetWaypointFlag( "Sidewalk_4", "crouch", false );
		Wp.SetWaypointFlag( "Sidewalk_4", { "inwater", "underwater" }, true );
		
		Util.MapDebugPrint( "Sidewalk_Exploded" );
	},
	
	Water_Tunnel_Cover_Exploded = function( trigger )
	{
		Map.Water_Tunnel_Cover = false;
		
		Util.MapDebugPrint( "Water_Tunnel_Cover_Exploded" );
	},
	
	Wooden_Plank_1_Exploded = function( trigger )
	{
		Map.Wooden_Plank_1 = false;
		Util.MapDebugPrint( "Wooden_Plank_1_Exploded" );
		sleep(1);
		
		if ( !Map.Wooden_Plank_2 and !Map.Wooden_Plank_3 and !Map.Wooden_Plank_4 and !Map.Wooden_Plank_5 )
		{
			Wp.SetWaypointFlag( "Planks_.*", "closed", false );
			
			Util.EnableGoal( "ROUTE_Planks_.*" );
			Util.EnableGoal( "ROUTE_Flag2Way_.*" );
			
			Util.DisableGoal( "GRENADE_Wooden_Planks_.*" );
		}
	},
	
