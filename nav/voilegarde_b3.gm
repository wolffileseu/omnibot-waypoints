		SetAvailableMapGoals( TEAM.ALLIES, true, "DEFEND_Hotel.*" );
		SetAvailableMapGoals( TEAM.ALLIES, false, {
			"ATTACK_Bravo.*",
			"PLANT_Electric_Floor_Controls"
		});

		Util.MapDebugPrint( "radarpart_Taken" );
	},

