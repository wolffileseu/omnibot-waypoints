	Right_Lab_Door_Button_Moving = function( trigger )
	{
		if ( Map.RightLabDoorStatus == DoorStatus.CLOSED )
		{
			Map.RightLabDoorStatus = DoorStatus.OPENING;
		}
	},

	Right_Lab_Door_Moving = function( trigger )
	{
		vel = ToVector( trigger.Action );
		if ( vel.z > 0 )
		{
			sleep( 0.9 ); // Wait 0.9 seconds while the door is opening
			Map.RightLabDoorStatus = DoorStatus.OPENED;
			Map.Switches.right_lab_door.Enabled = false;
		}
		else
		{
			Map.RightLabDoorStatus = DoorStatus.CLOSED;
			Map.Switches.right_lab_door.Enabled = true;
		}
	},

	East_Auto_Door_Button_Moving = function( trigger )
	{
		if ( Map.EastAutoDoorStatus == DoorStatus.CLOSED )
		{
			Map.EastAutoDoorStatus = DoorStatus.OPENING;
		}
	},

	East_Auto_Door_Moving = function( trigger )
	{
		vel = ToVector( trigger.Action );
		if ( vel.y > 0 )
		{
			sleep( 0.9 ); // Wait 0.9 seconds while the door is opening
			Map.EastAutoDoorStatus = DoorStatus.OPENED;
			Map.Switches.east_auto_door.Enabled = false;
		}
		else
		{
			Map.EastAutoDoorStatus = DoorStatus.CLOSED;
			Map.Switches.east_auto_door.Enabled = true;
		}
	},

	South_Auto_Door_Button_Moving = function( trigger )
	{
		if ( Map.SouthAutoDoorStatus == DoorStatus.CLOSED )
		{
			Map.SouthAutoDoorStatus = DoorStatus.OPENING;
		}
	},

	South_Auto_Door_Moving = function( trigger )
	{
		vel = ToVector( trigger.Action );
		if ( vel.x < 0 )
		{
			sleep( 0.9 ); // Wait 0.9 seconds while the door is opening
			Map.SouthAutoDoorStatus = DoorStatus.OPENED;
			Map.Switches.south_auto_door.Enabled = false;
		}
		else
		{
			Map.SouthAutoDoorStatus = DoorStatus.CLOSED;
			Map.Switches.south_auto_door.Enabled = true;
		}
	},

	Elevator1Pos = "top",
	Elevator1 = function( trigger )
	{
		// Elevator doors can be closed at once on both floors, but not opened at once on both floors
		while ( Map.ElevatorDoorsFFStatus == Map.ElevatorDoorsSFStatus ) { yield(); }

		vel = ToVector( trigger.Action );
		if ( vel.z < 0 )
		{
			Map.Elevator1Pos = "bottom";
			Map.Switches.e1_top1.Enabled = true;
			Map.Switches.e1_bot2.Enabled = true;
			Util.MapDebugPrint( "Elevator at bottom", true );
		}
		else
		{
			Map.Elevator1Pos = "top";
			Map.Switches.e1_bot1.Enabled = true;
			Map.Switches.e1_top2.Enabled = true;
			Util.MapDebugPrint( "Elevator at top", true );
		}
	},

	ElevatorDoorsFFStatus = "closed",
	First_Floor_Left_Door_Moving = function( trigger )
	{
		vel = ToVector( trigger.Action );
		if ( vel.x < 0 )
		{
			Map.ElevatorDoorsFFStatus = "opened";
			Util.MapDebugPrint( "First floor elevator doors opening", true );
		}
		else
		{
			Map.ElevatorDoorsFFStatus = "closed";
			Util.MapDebugPrint( "First floor elevator doors closing", true );
			Map.Elevator_Moving();
		}
	},

	ElevatorDoorsSFStatus = "opened",
	Second_Floor_Left_Door_Moving = function( trigger )
	{
		vel = ToVector( trigger.Action );
		if ( vel.x < 0 )
		{
			Map.ElevatorDoorsSFStatus = "opened";
			Util.MapDebugPrint( "Second floor elevator doors opening", true );
		}
		else
		{
			Map.ElevatorDoorsSFStatus = "closed";
			Util.MapDebugPrint( "Second floor elevator doors closing", true );
			Map.Elevator_Moving();
		}
	},

	Elevator_Moving = function()
	{
		Map.Elevator1Pos = "moving";
		Util.MapDebugPrint( "Elevator moving", true );

		Map.Switches.e1_top1.Enabled = false;
		Map.Switches.e1_top2.Enabled = false;
		Map.Switches.e1_bot1.Enabled = false;
		Map.Switches.e1_bot2.Enabled = false;
	},

	// -------------------------------------------------------------------------

	// Avoid spawn exit bottleneck
	// Only care about bots...
	// Class/weapon not taken into account (aka heavy weaps slowing down first movements)
	lab_spawn =
	{
		Name = "lab_spawn",
		TriggerOnClass = CLASS.ANYPLAYER,
		closestBot,
		mutex = false,
		botList = {},
		OnEnter = function( ent )
		{
			if ( !Map.isRadarPartStolen ) { return; }

			bot = Util.IsBot( ent );
			if ( !bot ) { return; }

			bot.Enable( false ); // Don't move
			Map.lab_spawn.botList[ bot ] = 1;

			// Little sleep to let all spawning bots be listed
			sleep ( .1 );

			while ( bot && Map.lab_spawn.mutex )
			{
				// Don't move until it's your turn to enter the mutex
				yield();
			}

			Map.lab_spawn.mutex = true;

			// Determine the closest bot from the exit, remove it from the list, make it go, sleep a bit, free the mutex, exit
			// If the current bot isn't the one, free the mutex and loop until it's the case...
			Map.lab_spawn.closestBot = Map.DetermineClosestBot( Map.lab_spawn.botList );
			if ( bot && bot.Name != Map.lab_spawn.closestBot.Name )
			{
				Map.lab_spawn.mutex = false;
				while ( bot && bot.Name != Map.lab_spawn.closestBot.Name )
				{
					// Stay still until it's your turn to move out
					yield();
				}

				// Now the current bot is the closest bot, take back the mutex
				Map.lab_spawn.mutex = true;
			}

			if ( bot )
			{
				bot.Enable( true ); // Move
				Map.lab_spawn.botList[ bot ] = null;
			}

			// Only look for the next closest bot if the one we just cleared wasn't the last of the list...
			if ( Map.CountTriggerBots() > 0 )
			{
				// Let the bot move towards the exit before checking for the next one to move
				sleep( .5 );

				Map.lab_spawn.closestBot = Map.DetermineClosestBot( Map.lab_spawn.botList );
			}

			Util.MapDebugPrint( "Exiting mutex as it is " + bot.Name + Util.DebugColorString + "'s turn", true );

			Map.lab_spawn.mutex = false;
		},
		OnExit = function( ent )
		{
			// As we don't wait for the bot to surely exit the spawn
			// (we just leave a bit of time between each bot, so they follow each other in single line),
			// no need for OnExit (botList filled and cleared exclusively in OnEnter)
		}
	},

	CountTriggerBots = function()
	{
		botCount = 0;
		foreach ( bot and val in Map.lab_spawn.botList )
		{
			if ( !bot ) { Map.lab_spawn.botList[ bot ] = 0; continue; }
			if ( val == 1 ) { botCount += 1; }
		}

		return botCount;
	},

	DetermineClosestBot = function( list )
	{
		closestBot;
		dist = 500;

		wpTable = {};
		w = Wp.GetWaypointByName( "axis_spawn_double_doors", wpTable );
		wpos = wpTable.position;

		foreach ( bot and val in list )
		{
			if ( !bot ) { val = 0; continue; } // Disconnected meanwhile
			if ( val != 1 ) { continue; }

			currentDist = DistanceBetween( bot.GetPosition(), wpos );
			if ( currentDist < dist )
			{
				closestBot = bot;
				dist = currentDist;
			}
		}

		return closestBot;
	},

