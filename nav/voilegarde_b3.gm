global Spawn =
{
	GUEST_HOUSE	= 1,
	LABORATORY	= 2,
	COURTYARD	= 3,

	alliedSplit = false,

	Split_Allied_Spawn = function ( active )
	{
		if ( active )
		{
			Util.MapDebugPrint( "Enabling Allied spawn split", true );
		}
		else
		{
			Util.MapDebugPrint( "Disabling Allied spawn split", true );
		}

		Spawn.alliedSplit = active;
		foreach ( bot in BotTable )
		{
			Spawn.Move_Bot( bot );
		}
	},

	Move_Bot = function( bot )
	{
		if ( bot.GetTeam() != TEAM.ALLIES ) { return; }

		spawn;
		if ( Spawn.alliedSplit )
		{
			if ( RandInt( 0, 9 ) < 5 ) { spawn = Spawn.COURTYARD; } else { spawn = Spawn.GUEST_HOUSE; }
		}
		else
		{
			spawn = Spawn.COURTYARD;
		}

		//Util.MapDebugPrint( "Moving " + bot.Name + Util.DebugColorString + " to " + Spawn.Get_Name( spawn ) + "...", true );
		bot.ChangeSpawnPoint( spawn );
	},

	Get_Name = function( spawnId )
	{
		switch ( spawnId )
		{
			case Spawn.GUEST_HOUSE:	{ return "Guest House"; }
			case Spawn.LABORATORY:	{ return "Laboratory"; }
			case Spawn.COURTYARD:	{ return "Courtyard"; }
		}

		return "{Unknown spawn ID: " + spawnId + "}";
	}
};

global DoorStatus =
{
	CLOSED	= 0,
	OPENING	= 1,
	OPENED	= 2
};

global Map =
