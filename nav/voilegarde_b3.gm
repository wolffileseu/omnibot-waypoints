/** Make the bots follow the Truck all along its journey */
// TODO: Add CAMP_Vehicle goals + drawing system (currently commented-out and scattered)
global VehicleTrackingSystem =
{
	ENTITY,					/** Entity to track the position of */
	MAP_GOAL_NAME,			/** MapGoal name for prints */
	RADIUS,					/** Radius around the entity to enable the goals from */
	GOAL_LIST,				/** List of the goals to manage */
	CHECK_INTERVAL,			/** Check interval */
	TEAM,					/** Team for which handle the CAMP goals availability */
	DEFENCE_TEAM,			/** Team for which handle the defensive Vehicle goals availability */
	AVAILABLE_GOAL_COLOR,
	PAUSED_GOAL_COLOR,		/** Used while the managed Mortar goal has DontShootMortar on */

	MORTAR_GOAL,
	MORTAR_RADIUS,
	VEHICLE_ARTILLERY,
	VEHICLE_ARTILLERY_Y_OFFSET,
	VEHICLE_CALL_ARTILLERY,

	entityPreviousPosition,	/** Entity last position, to detect if it's either moving or not */
	mortarTargetPos,
	run,					/** Flag that indicates if the thread can run or not */

	// *************************************************************************

	Start = function( mapGoalName, mortarMapGoalName )
	{
		VehicleTrackingSystem.Init( mapGoalName, mortarMapGoalName );

		VehicleTrackingSystem.VEHICLE_ARTILLERY.SetAvailable( VehicleTrackingSystem.DEFENCE_TEAM, true );
		SetAvailableMapGoals( VehicleTrackingSystem.DEFENCE_TEAM, true, VehicleTrackingSystem.VEHICLE_CALL_ARTILLERY );

		VehicleTrackingSystem.MORTAR_GOAL.SetAvailable( VehicleTrackingSystem.DEFENCE_TEAM, true );

		thread( VehicleTrackingSystem.TrackMovement );
	},

	Init = function( mapGoalName, mortarMapGoalName )
	{
		VehicleTrackingSystem.ENTITY		= GetGoal( mapGoalName ).GetEntity();
		VehicleTrackingSystem.MAP_GOAL_NAME	= GetGoal( mapGoalName ).GetName();
		VehicleTrackingSystem.GOAL_LIST		= Util.GoalTable( "CAMP_Vehicle.*"  );

		VehicleTrackingSystem.RADIUS = 768;

		VehicleTrackingSystem.CHECK_INTERVAL = 0.1;

		VehicleTrackingSystem.TEAM			= TEAM.AXIS & TEAM.ALLIES; // Both teams
		VehicleTrackingSystem.DEFENCE_TEAM	= TEAM.AXIS;

		VehicleTrackingSystem.AVAILABLE_GOAL_COLOR	= COLOR.CYAN;
		VehicleTrackingSystem.PAUSED_GOAL_COLOR		= COLOR.ORANGE;

		// Note: No need to force DontShootMortar, as it is not saved in _goals.gm file
		VehicleTrackingSystem.MORTAR_GOAL = GetGoal( mortarMapGoalName );
		VehicleTrackingSystem.MORTAR_RADIUS = 400;
		VehicleTrackingSystem.VEHICLE_ARTILLERY = GetGoal( "ARTILLERY_S_Vehicle" );
		VehicleTrackingSystem.VEHICLE_ARTILLERY_Y_OFFSET = 250;
		VehicleTrackingSystem.VEHICLE_CALL_ARTILLERY = "CALLARTILLERY_Vehicle.*";

		// ---

		VehicleTrackingSystem.run = true;
	},

	TrackMovement = function()
	{
		Util.MapDebugPrint(
			format( "Starting %s defence management thread.", VehicleTrackingSystem.MAP_GOAL_NAME ),
			true );

		while ( VehicleTrackingSystem.run )
		{
			entityCurrentPosition = GetEntPosition( VehicleTrackingSystem.ENTITY );
			if ( entityCurrentPosition != VehicleTrackingSystem.entityPreviousPosition )
			{
				VehicleTrackingSystem.entityPreviousPosition = entityCurrentPosition;
				VehicleTrackingSystem.ManageGoals();
			}
			/*else
			{
				// For debug purposes
				foreach ( goal in VehicleTrackingSystem.GOAL_LIST )
				{
					VehicleTrackingSystem.DrawDebugGoal( goal );
				}
			}*/

			// ---

			// For debug purposes

			// Map goal radius
			/*DrawRadius(
				entityCurrentPosition,
				VehicleTrackingSystem.RADIUS,
				COLOR.BROWN,
				VehicleTrackingSystem.CHECK_INTERVAL );*/

			// Artillery
			color;
			if ( VehicleTrackingSystem.VEHICLE_ARTILLERY.IsAvailable( VehicleTrackingSystem.DEFENCE_TEAM ) )
			{
				color = VehicleTrackingSystem.AVAILABLE_GOAL_COLOR;
			}
			else
			{
				color = VehicleTrackingSystem.PAUSED_GOAL_COLOR;
			}

			DrawRadius(
				VehicleTrackingSystem.VEHICLE_ARTILLERY.GetPosition(),
				VehicleTrackingSystem.VEHICLE_ARTILLERY.GetRadius(),
				color,
				VehicleTrackingSystem.CHECK_INTERVAL );

			// Mortar
			VehicleTrackingSystem.DrawMortar();

			sleep( VehicleTrackingSystem.CHECK_INTERVAL );
		}

		Util.MapDebugPrint(
			format( "Stopping %s defence management thread...", VehicleTrackingSystem.MAP_GOAL_NAME ),
			true );

		VehicleTrackingSystem.VEHICLE_ARTILLERY.SetAvailable( VehicleTrackingSystem.DEFENCE_TEAM, false );
		SetAvailableMapGoals( VehicleTrackingSystem.DEFENCE_TEAM, false, VehicleTrackingSystem.VEHICLE_CALL_ARTILLERY );
		VehicleTrackingSystem.MORTAR_GOAL.SetAvailable( VehicleTrackingSystem.DEFENCE_TEAM, false );
		foreach ( goal in VehicleTrackingSystem.GOAL_LIST )
		{
			goal.SetAvailable( VehicleTrackingSystem.TEAM, false );
		}

		Util.MapDebugPrint(
			format( "%s defence management thread stopped.", VehicleTrackingSystem.MAP_GOAL_NAME ),
			true );
	},

	ManageGoals = function()
	{
		VehicleTrackingSystem.ManageArtilleryAndMortar();
		/*foreach ( goal in VehicleTrackingSystem.GOAL_LIST )
		{
			shouldGoalBeEnabled =
				DistanceBetween( goal, VehicleTrackingSystem.ENTITY ) <= VehicleTrackingSystem.RADIUS;
			goal.SetAvailable( VehicleTrackingSystem.TEAM, shouldGoalBeEnabled );

			// For debug purposes
			VehicleTrackingSystem.DrawDebugGoal( goal );
		}*/
	},

	ManageArtilleryAndMortar = function()
	{
		artilleryPos =
			GroundPoint(
				GetEntityWorldSpace( VehicleTrackingSystem.ENTITY, Vec3( 0, VehicleTrackingSystem.VEHICLE_ARTILLERY_Y_OFFSET, 0 ) ) );
		VehicleTrackingSystem.VEHICLE_ARTILLERY.SetPosition( artilleryPos );
		VehicleTrackingSystem.RunTraceLineFromSkyToArtyTargetPos();

		VehicleTrackingSystem.ManageMortar();
	},

	RunTraceLineFromSkyToArtyTargetPos = function()
	{
		artyTargetPos = VehicleTrackingSystem.VEHICLE_ARTILLERY.GetPosition(); // Shorter local var name
		artyTargetSkyPos = Vec3( artyTargetPos.x, artyTargetPos.y, 1024 );

		// Adapted from et_utilities.TraceArty
		tr = TraceLine( artyTargetSkyPos, artyTargetPos, null, TRACE.FLOODFILL, 0, false );

		// Affect trace line result to artillery availability
		currentArtyTargetAvailability	= VehicleTrackingSystem.VEHICLE_ARTILLERY.IsAvailable( VehicleTrackingSystem.DEFENCE_TEAM );
		newDontArtyTargetAvailability	= tr.fraction == 1;
		if ( newDontArtyTargetAvailability != currentArtyTargetAvailability )
		{
			VehicleTrackingSystem.VEHICLE_ARTILLERY.SetAvailable( VehicleTrackingSystem.DEFENCE_TEAM, newDontArtyTargetAvailability );

			if ( currentArtyTargetAvailability )
			{
				Util.MapDebugPrint( "Resuming " + VehicleTrackingSystem.VEHICLE_ARTILLERY.GetName(), true );
			}
			else
			{
				Util.MapDebugPrint( "Pausing "  + VehicleTrackingSystem.VEHICLE_ARTILLERY.GetName(), true );
			}
		}
	},

	ManageMortar = function()
	{
		VehicleTrackingSystem.mortarTargetPos =
			GroundPoint( GetEntityWorldSpace( VehicleTrackingSystem.ENTITY, Vec3( 0, 150, 0 ) ) );
		tbl =
			CalcTrajectory(
				VehicleTrackingSystem.MORTAR_GOAL.GetPosition() + Vector3( 0, 0, 32 ),
				VehicleTrackingSystem.mortarTargetPos,
				2350,
				1 );
		if ( tbl )
		{
			dir = tbl[ tableCount( tbl ) - 1 ];
			playerFace = Vec3FromSpherical( dir.GetYaw(), dir.GetPitch() - DegToRad( 60 ) );
			VehicleTrackingSystem.MORTAR_GOAL.MortarAim[ 0 ] = playerFace;
			//Util.MapDebugPrint( VehicleTrackingSystem.MORTAR_GOAL.GetName() + " aim set to " + ToString( playerFace ), true );
			VehicleTrackingSystem.MORTAR_GOAL.AdjustOrientation();
			VehicleTrackingSystem.RunTraceLineFromSkyToMortarTargetPos();
		}
		else
		{
			// Log warning
			Util.MapDebugPrint(
				format(
					"%s %s %s",
					"^8Mortar trajectory not found for target",
					VehicleTrackingSystem.MAP_GOAL_NAME,
					ToString( GetEntPosition( VehicleTrackingSystem.ENTITY ) ) ),
				2 );
		}
	},

	RunTraceLineFromSkyToMortarTargetPos = function()
	{
		mortarTargetPos = VehicleTrackingSystem.mortarTargetPos; // Shorter local var name
		mortarTargetSkyPos = Vec3( mortarTargetPos.x, mortarTargetPos.y, 1024 );

		// Adapted from et_utilities.TraceArty
		// TRACE.FLOODFILL to ignore entities (e. g. Tank barrel)
		tr = TraceLine( mortarTargetSkyPos, mortarTargetPos, null, TRACE.FLOODFILL, 0, false );
		/*if ( tr.fraction < 1 )
		{
			DrawDebugLine(
				mortarTargetSkyPos,
				tr.end,
				COLOR.PINK,
				VehicleTrackingSystem.CHECK_INTERVAL );
			DrawRadius(
				tr.end,
				35,
				VehicleTrackingSystem.AVAILABLE_GOAL_COLOR,
				VehicleTrackingSystem.CHECK_INTERVAL );
			DrawDebugLine(
				tr.end,
				mortarTargetPos,
				COLOR.RED,
				VehicleTrackingSystem.CHECK_INTERVAL );
		}
		else
		{
			DrawDebugLine(
				mortarTargetSkyPos,
				mortarTargetPos,
				COLOR.GREEN,
				VehicleTrackingSystem.CHECK_INTERVAL );
		}*/

		// Affect trace line result to mortar ability to shoot
		currentDontShootMortar	= VehicleTrackingSystem.MORTAR_GOAL.DontShootMortar;
		newDontShootMortar		= tr.fraction < 1;
		if ( newDontShootMortar != currentDontShootMortar )
		{
			VehicleTrackingSystem.MORTAR_GOAL.DontShootMortar = newDontShootMortar;

			if ( currentDontShootMortar )
			{
				Util.MapDebugPrint( "Resuming " + VehicleTrackingSystem.MORTAR_GOAL.GetName() + " shooting", true );
			}
			else
			{
				Util.MapDebugPrint( "Pausing "  + VehicleTrackingSystem.MORTAR_GOAL.GetName() + " shooting", true );
			}
		}
	},

	DrawDebugGoal = function( goal )
	{
		goalPosition = goal.GetPosition();
		goalEyePosition = Vector3( goalPosition.x, goalPosition.y, goalPosition.z + 64 );

		color;
		if ( goal.IsAvailable( TEAM.AXIS ) || goal.IsAvailable( TEAM.ALLIES ) )
		{
			color = VehicleTrackingSystem.AVAILABLE_GOAL_COLOR;
		}
		else
		{
			color = VehicleTrackingSystem.PAUSED_GOAL_COLOR;
		}

		DrawDebugLine( goalPosition, goalEyePosition, color, VehicleTrackingSystem.CHECK_INTERVAL );
	},

	// Adapted from mapgoal_mobilemortar.Render
	DrawMortar = function()
	{
		goalBasePos	= VehicleTrackingSystem.MORTAR_GOAL.GetPosition();
		goalPos		= goalBasePos + Vector3( 0, 0, 64 );
		firePos		= goalBasePos + Vector3( 0, 0, 32 );

		color;
		if ( VehicleTrackingSystem.MORTAR_GOAL.DontShootMortar )
		{
			color = VehicleTrackingSystem.PAUSED_GOAL_COLOR;
		}
		else
		{
			color = VehicleTrackingSystem.AVAILABLE_GOAL_COLOR;
		}

		DrawRadius(
			goalBasePos,
			VehicleTrackingSystem.MORTAR_GOAL.GetRadius(),
			color,
			VehicleTrackingSystem.CHECK_INTERVAL );

		DrawLine(
			goalPos,
			goalBasePos,
			color,
			VehicleTrackingSystem.CHECK_INTERVAL );

		dir			= VehicleTrackingSystem.MORTAR_GOAL.MortarAim[ 0 ];
		yaw			= dir.GetYaw();
		pitch		= dir.GetPitch() + DegToRad( 60 );
		mortarDir	= Vec3FromSpherical( yaw, pitch );

		trajectory = {};
		trajectory.Velocity =
			Vector3(
				mortarDir.x * 3000.0 * 1.1,
				mortarDir.y * 3000.0 * 1.1,
				mortarDir.z * 1500.0 * 1.1 );
		trajectory.Position = firePos;
		//trajectory.StopAtHit = true;
		trajectory.TraceBounce = false;
		trajectory.Duration = 30;
		trajectory.Interval = 0.25;

		DrawTrajectory(
			trajectory,
			color,
			VehicleTrackingSystem.CHECK_INTERVAL );
	},

	// ---

	ManageVehicleArtyAndMortarShootingOnBarrierPlanted = function()
	{
		// Allow only one execution at once
		if ( VehicleTrackingSystem.mutex )
		{
			Util.MapDebugPrint( "ManageVehicleArtyAndMortarShootingOnBarrierPlanted already running, exiting", true );
			return;
		}

		VehicleTrackingSystem.mutex = true;

		SetAvailableMapGoals( VehicleTrackingSystem.DEFENCE_TEAM, true, "SMOKEBOMB_Defuse_Vehicle_Barrier" );

		while ( Map.Is_Vehicle_Barrier_Built_And_Planted() )
		{
			// If no Axis Engi close enough, just keep shooting to keep the Truck damaged (RIP other teammates for now)
			if ( VehicleTrackingSystem.AnyDefendingEngiCloseToAnyVehicleBarrierDyno() )
			{
				VehicleTrackingSystem.MORTAR_GOAL.DontShootMortar = true;
			}
			// Else, if any dynamite is within mortar splash damage range, have mortar shooting off
			else if ( VehicleTrackingSystem.AnyDynamiteWithinVehicleMortarRadius() )
			{
				VehicleTrackingSystem.MORTAR_GOAL.DontShootMortar = true;
			}
			else
			{
				VehicleTrackingSystem.MORTAR_GOAL.DontShootMortar = false;
			}

			SetAvailableMapGoals(
				VehicleTrackingSystem.DEFENCE_TEAM,
				!VehicleTrackingSystem.MORTAR_GOAL.DontShootMortar,
				"ARTILLERY_S_Vehicle" );

			sleep ( 1 );
		}

		// If the Barrier got destroyed, or all dynamites got defused since the last loop, reset the flag
		VehicleTrackingSystem.MORTAR_GOAL.DontShootMortar = false;
		SetAvailableMapGoals( VehicleTrackingSystem.DEFENCE_TEAM, true, "ARTILLERY_S_Vehicle" );

		SetAvailableMapGoals( VehicleTrackingSystem.DEFENCE_TEAM, false, "SMOKEBOMB_Defuse_Vehicle_Barrier" );

		VehicleTrackingSystem.mutex = false;
	},

	AnyDefendingEngiCloseToAnyVehicleBarrierDyno = function()
	{
		t = Map.Get_Vehicle_Defuse_Goal_Table();
		foreach ( bot in BotTable )
		{
			if ( bot.GetTeam() != VehicleTrackingSystem.DEFENCE_TEAM || bot.GetClass() != CLASS.ENGINEER ) { continue; }
			foreach ( defuse in t )
			{
				if ( DistanceBetween( bot.GetPosition(), defuse.GetPosition() ) <= 1000 )
				{
					DrawDebugLine( bot.GetPosition(), defuse.GetPosition(), COLOR.RED, 1 );
					return true;
				}
			}
		}

		return false;
	},

	// No need to specify a particular DEFUSE goal name, only barriers are along Tank path
	AnyDynamiteWithinVehicleMortarRadius = function()
	{
		t = Map.Get_Vehicle_Defuse_Goal_Table();
		foreach ( defuse in t )
		{
			if ( DistanceBetween( VehicleTrackingSystem.MORTAR_GOAL, defuse ) <= VehicleTrackingSystem.MORTAR_RADIUS )
			{
				DrawDebugLine( VehicleTrackingSystem.MORTAR_GOAL.GetPosition(), defuse.GetPosition(), COLOR.RED, 1 );
				return true;
			}
		}

		return false;
	},

	// ---

	Stop = function()
	{
		VehicleTrackingSystem.run = false;
	}
};
