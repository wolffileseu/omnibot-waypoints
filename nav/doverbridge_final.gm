		},
	};
	
	MapRoutes.PLANT_allies_radio = MapRoutes.PLANT_Allied_door;
	MapRoutes.PLANT_axis_radio = MapRoutes.PLANT_Axis_door;
	MapRoutes["ATTACK_Axis_.*"] = MapRoutes.PLANT_Allied_door;
	MapRoutes["ATTACK_Allies_.*"] = MapRoutes.PLANT_Axis_door;
	
	Util.Routes(MapRoutes);
};