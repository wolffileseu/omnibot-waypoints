	Big_Doors_Destroyed = function()
	{
		Map.Big_Doors = false;
		
		Util.MapDebugPrint("Big_Doors_Destroyed");
		
		Util.EnableGoal("ROUTE_BigDoors.*");
		
		ETUtil.SetAimModeForMount("MOUNT_Tank", { Vec3(-1667.296, -1672.875, 2357.224) });
		Util.IgnoreTargetGoalAll("MOVER_tank");
		
		SetAvailableMapGoals( TEAM.ALLIES, false, ".*_Allies_OverSpawn_.*" );
		
		SetAvailableMapGoals( TEAM.AXIS, false, {
			".*_Tank",
			".*_Axis_DamDoors_.*",
		});
		
		if ( !Map.Ropes )
		{
			SetAvailableMapGoals( TEAM.AXIS, false, "BUILD_ropes" );
		}
		else
		{
			SetAvailableMapGoals( TEAM.ALLIES, false, "PLANT_ropes" );
		}
		
		SetGoalRole( "FLAG_docs_crate", ROLE.ATTACKER1 );
		SetGoalRole( "PLANT_Truck_Barrier_1", ROLE.ATTACKER1 );
		ClearGoalRole( "MOUNT_Tank", { ROLE.ATTACKER, ROLE.ATTACKER1, ROLE.ATTACKER2, ROLE.ATTACKER3 });
		
		if ( !Map.Pressure_Pipes and !Map.TruckEscaped )
		{
			Map.SetSpawn();
		}
		
		if ( !Map.Truck_Barrier_1 and !Map.TruckPastBarrier_1 )
		{
			SetAvailableMapGoals( TEAM.ALLIES, true, "BUILD_Truck_Barrier_1" );
		}
		else
		{
			if ( !Map.BothDocumentsSecured )
			{
				Util.SetMaxUsers(1, "PLANT_Truck_Barrier_1");
			}
			SetAvailableMapGoals( TEAM.AXIS, true, "PLANT_Truck_Barrier_1" );
		}
		
		if ( Map.Tank and ( tableCount(Map.count_axis_DocsRoom) < 1 and
		( Map.Documents_1 == "Returned" or Map.Documents_2 == "Returned" or Map.TruckEscaped ) or tableCount(Map.count_axis_GenRoom) < 1 ))
		{
			SetAvailableMapGoals( TEAM.ALLIES, true, "MOUNT_Tank" );
		}
		
		DeleteTriggerRegion("Docs_room");
		yield();
		OnTriggerRegion(AABB(-1915.875,1762.125,2313.125,-250.125,3688.875,2650.856), Map.Docs_room );
		OnTriggerRegion(AABB(-258.501,2303.125,2629.125,261.874,2862.875,2753.125), Map.Docs_room );
		OnTriggerRegion(AABB(-937.875,1281.043,2313.125,-556.125,1762.338,2459.238), Map.Docs_room );
	},
	
	Documents_Dropped = function()
	{
		Util.MapDebugPrint("Documents_Dropped");
		
		foreach( goal in Util.GoalTable("FLAGRETURN_docs_crate_.*") )
		{
			goal.SetRoles(ROLE.DEFENDER, ROLE.DEFENDER1);
			goal.SetGoalPriority( TEAM.ALLIES, 0 , 0.70 );	//return to default due to role
		}
		
		foreach( goal in Util.GoalTable("FLAG_docs_crate_dropped.*") )
		{
			goal.SetRoles(ROLE.ATTACKER, ROLE.ATTACKER1);
			goal.SetGoalPriority( TEAM.AXIS, 0 , 0.70 );	//return to default due to role
		}
	},

	Documents_1_Taken = function()
	{
		Map.Documents_1 = "Taken";
		
		Util.MapDebugPrint("Documents_1: " +Map.Documents_1 +" Documents_2: " +Map.Documents_2 );
		
		if ( Map.Documents_2 == "Taken" or Map.Documents_2 == "Secured" )
		{
			SetAvailableMapGoals( TEAM.AXIS, false, "FLAG_docs_crate" );
			
			SetAvailableMapGoals( TEAM.ALLIES, true, ".*_Allies_CappPlace_.*" );
			
			SetAvailableMapGoals( TEAM.AXIS, true, ".*_Axis_CappPlace_.*" );
		}
		else
		{
			SetAvailableMapGoals( TEAM.ALLIES, false, ".*_Allies_DocsRoom_0.*" );
			
			SetAvailableMapGoals( TEAM.ALLIES, true, {
				".*_Allies_CappPlace_0.*",
				".*_Allies_CappPlace_2.*",
			});
			
			SetAvailableMapGoals( TEAM.AXIS, true, ".*_Axis_CappPlace_0.*" );
		}
		
		SetAvailableMapGoals( TEAM.AXIS, true, "CAPPOINT_Truck" );
		
		sleep(2);
		
		if ( Map.Documents_1 == "Taken" and ( Map.Documents_2 == "Taken" or Map.Documents_2 == "Secured" ))
		{
			SetAvailableMapGoals( TEAM.ALLIES, false, ".*_Allies_DocsRoom_.*" );
		}
	},

	Documents_1_Returned = function()
	{
		if ( Map.Documents_1 == "Returned" )
		{
			Util.MapDebugPrint("Correction_Returned_2");
			
			Map.Documents_2_Returned();
			
			return;
		}
		else
		{
			Map.Documents_1 = "Returned";
		}
		
		Util.MapDebugPrint("Documents_1 " +Map.Documents_1 +" Documents_2: " +Map.Documents_2);
		
		if ( !Map.Big_Doors )
		{
			SetAvailableMapGoals( TEAM.ALLIES, true, "MOBILEMG42_Allies_DocsRoom_21" );
		}
		
		if ( Map.Documents_2 == "Returned" or Map.Documents_2 == "Secured" )
		{
			SetAvailableMapGoals( TEAM.ALLIES, false, ".*_Allies_CappPlace_.*" );
			
			SetAvailableMapGoals( TEAM.AXIS, false, {
				"CAPPOINT_Truck",
				".*_Axis_CappPlace_.*",
			});
			
			if ( tableCount(Map.count_axis_DocsRoom) > 0 )
			{
				SetAvailableMapGoals( TEAM.ALLIES, true, ".*_Allies_DocsRoom_.*" );
			}
		}
		else if ( Map.Documents_2 == "Taken" )
		{
			SetAvailableMapGoals( TEAM.ALLIES, false, ".*_Allies_CappPlace_0.*" );
			
			if ( tableCount(Map.count_axis_DocsRoom) > 0 )
			{
				SetAvailableMapGoals( TEAM.ALLIES, true, ".*_Allies_DocsRoom_0.*" );
			}
		}
		
		if ( Map.TankBetween_DamDoor_BigDoors )
		{
			SetAvailableMapGoals( TEAM.ALLIES, true, {
				"MOBILEMG42_Allies_DocsRoom_21",
				"DEFEND_Allies_DocsRoom_30",
			});
		}
		
		if ( Map.TankPastBarrier_2 )
		{
			SetAvailableMapGoals( TEAM.AXIS, true, "FLAG_docs_crate" );
		}
	},

	Documents_1_Secured = function()
	{
		if ( Map.Documents_1 == "Returned" )
		{
			Util.MapDebugPrint("Correction_Secured_2");
			
			Map.Documents_2_Secured();
			
			return;
		}
		else
		{
			Map.Documents_1 = "Secured";
		}
		
		Util.MapDebugPrint("Documents_1: " +Map.Documents_1 +" Documents_2: " +Map.Documents_2);
		
		if ( Map.Documents_2 == "Returned" )
		{
			SetAvailableMapGoals( TEAM.ALLIES, false, ".*_Allies_CappPlace_.*" );
			
			SetAvailableMapGoals( TEAM.AXIS, false, {
				"CAPPOINT_Truck",
				".*_Axis_CappPlace_.*",
			});
			
			if ( !Map.Big_Doors )
			{
				SetAvailableMapGoals( TEAM.ALLIES, true, "MOBILEMG42_Allies_DocsRoom_21" );
			}
			
			if ( tableCount(Map.count_axis_DocsRoom) > 0 )
			{
				SetAvailableMapGoals( TEAM.ALLIES, true, ".*_Allies_DocsRoom_.*" );
			}
		}
		
		if ( Map.Documents_2 == "Secured" )
		{
			Map.BothDocumentsSecured = true;
			
			Util.MapDebugPrint("Both_Documents_Secured");
			
			Util.SetMaxUsers(2, "PLANT_Truck_Barrier_1");
			Util.SetMaxUsers(2, "ATTACK_Axis_BarrierOne_.*");
			Util.SetMaxUsers(2, "ATTACK_Axis_BarrierTwo_.*");
			
			ClearGoalRole( ".*LLERY_.*Allies_PastBarr1_.*", { ROLE.DEFENDER, ROLE.DEFENDER1 } );
			ClearGoalRole( "AIRSTRIKE_Allies_PastBarr1_.*", { ROLE.DEFENDER, ROLE.DEFENDER1 } );
			
			SetAvailableMapGoals( TEAM.ALLIES, false, {
				".*_Allies_CappPlace_.*",
				".*_Allies_DocsRoom_.*",
			});
			
			SetAvailableMapGoals( TEAM.AXIS, false, {
				"FLAG_docs_crate",
				"CAPPOINT_Truck",
				".*_Axis_CappPlace_.*",
			});
			
			SetAvailableMapGoals( TEAM.ALLIES, true, ".*_Allies_BarrierOne_.*" );
			
			SetAvailableMapGoals( TEAM.AXIS, true, ".*_Axis_BarrierOne_.*" );
			
			if( !Map.Truck )
			{
				SetAvailableMapGoals( TEAM.AXIS, true, "BUILD_Truck" );
			}
			else
			{
				SetAvailableMapGoals( TEAM.AXIS, true, "ESCORT_Truck" );
			}
		}
	},

	Documents_2_Taken = function()
	{
		if ( Map.Documents_1 == "Returned" )
		{
			Util.MapDebugPrint("Correction_Taken_1");
			
			Map.Documents_1_Taken();
			
			return;
		}
		else
		{
			Map.Documents_2 = "Taken";
			
			Util.MapDebugPrint("Documents_2: " +Map.Documents_2 +" Documents_1: " +Map.Documents_1);
		}
		
		if ( Map.Documents_1 == "Taken" or Map.Documents_1 == "Secured" )
		{
			SetAvailableMapGoals( TEAM.AXIS, false, "FLAG_docs_crate" );
			
			SetAvailableMapGoals( TEAM.ALLIES, true, ".*_Allies_CappPlace_.*" );
			
			SetAvailableMapGoals( TEAM.AXIS, true, ".*_Axis_CappPlace_.*" );
		}
		else
		{
			SetAvailableMapGoals( TEAM.ALLIES, false, ".*_Allies_DocsRoom_1.*" );
			
			SetAvailableMapGoals( TEAM.ALLIES, true, {
				".*_Allies_CappPlace_1.*",
				".*_Allies_CappPlace_2.*",
			});
			
			SetAvailableMapGoals( TEAM.AXIS, true, ".*_Axis_CappPlace_1.*" );
		}
		
		SetAvailableMapGoals( TEAM.AXIS, true, "CAPPOINT_Truck" );
		
		sleep(2);
		
		if ( Map.Documents_2 == "Taken" and ( Map.Documents_1 == "Taken" or Map.Documents_1 == "Secured" ))
		{
			SetAvailableMapGoals( TEAM.ALLIES, false, ".*_Allies_DocsRoom_.*" );
		}
	},

	Documents_2_Returned = function()
	{
		if ( Map.Documents_1 == "Taken" )
		{
			Util.MapDebugPrint("Correction_Returned_1");
			
			Map.Documents_1_Returned();
			
			return;
		}
		else
		{
			Map.Documents_2 = "Returned";
			
			Util.MapDebugPrint("Documents_2: " +Map.Documents_2 +" and Documents_1: " +Map.Documents_1);
		}
		
		if ( !Map.Big_Doors )
		{
			SetAvailableMapGoals( TEAM.ALLIES, true, "MOBILEMG42_Allies_DocsRoom_21" );
		}
		
		if ( Map.Documents_1 == "Returned" or Map.Documents_1 == "Secured" )
		{
			SetAvailableMapGoals( TEAM.ALLIES, false, ".*_Allies_CappPlace_.*" );
			
			SetAvailableMapGoals( TEAM.AXIS, false, {
				"CAPPOINT_Truck",
				".*_Axis_CappPlace_.*",
			});
			
			if ( tableCount(Map.count_axis_DocsRoom) > 0 )
			{
				SetAvailableMapGoals( TEAM.ALLIES, true, ".*_Allies_DocsRoom_.*" );
			}
		}
		else if ( Map.Documents_1 == "Taken" )
		{
			SetAvailableMapGoals( TEAM.ALLIES, false, ".*_Allies_CappPlace_1.*" );
			
			if ( tableCount(Map.count_axis_DocsRoom) > 0 )
			{
				SetAvailableMapGoals( TEAM.ALLIES, true, ".*_Allies_DocsRoom_1.*" );
			}
		}
		
		if ( Map.TankBetween_DamDoor_BigDoors )
		{
			SetAvailableMapGoals( TEAM.ALLIES, true, {
				"MOBILEMG42_Allies_DocsRoom_21",
				"DEFEND_Allies_DocsRoom_30",
			});
		}
		
		if ( Map.TankPastBarrier_2 )
		{
			SetAvailableMapGoals( TEAM.AXIS, true, "FLAG_docs_crate" );
		}
	},

	Documents_2_Secured = function()
	{
		if ( Map.Documents_1 == "Taken" )
		{
			Util.MapDebugPrint("Correction_Secured_1");
			
			Map.Documents_1_Secured();
			
			return;
		}
		else
		{
			Map.Documents_2 = "Secured";
			
			Util.MapDebugPrint("Documents_2: " +Map.Documents_2 +" Documents_1: " +Map.Documents_1);
		}
		
		if ( Map.Documents_1 == "Returned" )
		{
			SetAvailableMapGoals( TEAM.ALLIES, false, {
				".*_Allies_CappPlace_.*",
				".*_Allies_DocsRoom_.*",
			});
			
			SetAvailableMapGoals( TEAM.AXIS, false, {
				"CAPPOINT_Truck",
				".*_Axis_CappPlace_.*",
			});
			
			if ( !Map.Big_Doors )
			{
				SetAvailableMapGoals( TEAM.ALLIES, true, "MOBILEMG42_Allies_DocsRoom_21" );
			}
			
			if ( tableCount(Map.count_axis_DocsRoom) > 0 )
			{
				SetAvailableMapGoals( TEAM.ALLIES, true, ".*_Allies_DocsRoom_.*" );
			}
		}
		
		if ( Map.Documents_1 == "Secured" )
		{
			Map.BothDocumentsSecured = true;
			
			Util.MapDebugPrint("Both_Documents_Secured");
			
			Util.SetMaxUsers(2, "PLANT_Truck_Barrier_1");
			Util.SetMaxUsers(2, "ATTACK_Axis_BarrierOne_.*");
			Util.SetMaxUsers(2, "ATTACK_Axis_BarrierTwo_.*");
			
			ClearGoalRole( ".*LLERY_.*Allies_PastBarr1_.*", { ROLE.DEFENDER, ROLE.DEFENDER1 } );
			ClearGoalRole( "AIRSTRIKE_Allies_PastBarr1_.*", { ROLE.DEFENDER, ROLE.DEFENDER1 } );
			
			SetAvailableMapGoals( TEAM.ALLIES, false, {
				".*_Allies_CappPlace_.*",
				".*_Allies_DocsRoom_.*",
			});
			
			SetAvailableMapGoals( TEAM.AXIS, false, {
				"FLAG_docs_crate",
				"CAPPOINT_Truck",
				".*_Axis_CappPlace_.*",
			});
			
			SetAvailableMapGoals( TEAM.ALLIES, true, ".*_Allies_BarrierOne_.*" );
			
			SetAvailableMapGoals( TEAM.AXIS, true, ".*_Axis_BarrierOne_.*" );
			
			if( !Map.Truck )
			{
				SetAvailableMapGoals( TEAM.AXIS, true, "BUILD_Truck" );
			}
			else
			{
				SetAvailableMapGoals( TEAM.AXIS, true, "ESCORT_Truck" );
			}
		}
	},
	
	Truck_Built = function()
	{
		Map.Truck = true;
		
		Util.MapDebugPrint("Truck_Built");
		
		SetAvailableMapGoals( TEAM.AXIS, false, "BUILD_Truck" );
		
		if (( !Map.TruckAtBarrier_1 or !Map.Truck_Barrier_1 ) and ( Map.Documents_1 == "Secured" and Map.Documents_2 == "Secured" ) and !Map.TruckEscaped )
		{
			SetAvailableMapGoals( TEAM.AXIS, true, "ESCORT_Truck" );
		}
	},

	Truck_Destroyed = function()
	{
		Map.Truck = false;
		
		Util.MapDebugPrint("Truck_Destroyed");
		
		SetAvailableMapGoals( TEAM.AXIS, false, "ESCORT_Truck" );
		
		if (( !Map.TruckAtBarrier_1 or !Map.Truck_Barrier_1 ) and ( Map.Documents_1 == "Secured" and Map.Documents_2 == "Secured" ) and !Map.TruckEscaped )
		{
			SetAvailableMapGoals( TEAM.AXIS, true, "BUILD_Truck" );
		}
	},

	Truck_Barrier_1_Built = function()
	{
		Map.Truck_Barrier_1 = true;
		
		Wp.SetWaypointFlag( "Truck_Barrier_1_3", "closed", false );
		
		Util.MapDebugPrint("Truck_Barrier_1_Built");
		
		SetAvailableMapGoals( TEAM.ALLIES, false, "BUILD_Truck_Barrier_1" );
		
		if ( Map.TankPastBarrier_2 )
		{
			SetAvailableMapGoals( TEAM.AXIS, true, "PLANT_Truck_Barrier_1" );
		}
		
		if ( Map.TruckAtBarrier_1 and !Map.Truck )
		{
			SetAvailableMapGoals( TEAM.AXIS, false, "BUILD_Truck" );
		}
	},
	
	Truck_Barrier_1_Planted = function( trigger )
	{
		Util.MapDebugPrint( "Truck_Barrier_1_Planted" );
		
		foreach( goal in Util.GoalTable("DEFUSE_Truck_Barrier_1_.*") )
		{
			goal.SetRoles(ROLE.DEFENDER, ROLE.DEFENDER1);
			goal.SetGoalPriority( TEAM.ALLIES, 0 , 0.90 );	//return to default due to role
		}
	},
	
	Truck_At_Barrier_1 = function( trigger )
	{
		Util.MapDebugPrint( "Truck_At_Barrier_1" );
		
		Map.TruckAtBarrier_1 = true;
		
		SetAvailableMapGoals( TEAM.ALLIES, false, "PLANTMINE_Allies_BarrierOne_.*" );
		
		SetAvailableMapGoals( TEAM.ALLIES, true, "PLANTMINE_Allies_PastBarrOne_.*" );
	},
	
	Truck_Barrier_1_Destroyed = function()
	{
		Map.Truck_Barrier_1 = false;
		
		Wp.SetWaypointFlag( "Truck_Barrier_1_3", "closed", true );
		
		Util.MapDebugPrint("Truck_Barrier_1_Destroyed");
		
		SetAvailableMapGoals( TEAM.AXIS, false, "PLANT_Truck_Barrier_1" );
		
		if ( !Map.Big_Doors and !Map.TruckPastBarrier_1 )
		{
			SetAvailableMapGoals( TEAM.ALLIES, true, "BUILD_Truck_Barrier_1" );
		}
		
		if ( Map.TruckAtBarrier_1 and !Map.Truck )
		{
			SetAvailableMapGoals( TEAM.AXIS, true, "BUILD_Truck" );
		}
	},
	
	Truck_Past_Barrier_1 = function( trigger )
	{
		Util.MapDebugPrint( "Truck_Past_Barrier_1" );
		
		Map.TruckAtBarrier_1 = false;
		Map.TruckPastBarrier_1 = true;
		
		SetAvailableMapGoals( 0, false, ".*_BarrierOne_.*" );
		
		SetAvailableMapGoals( TEAM.ALLIES, true, ".*_Allies_PastBarrOne_.*" );
		
		SetAvailableMapGoals( TEAM.AXIS, true, ".*_Axis_PastBarrOne_.*" );
		
		if ( Map.Truck_Barrier_2 == "Opened" )
		{
			SetAvailableMapGoals( TEAM.ALLIES, true, "SWITCH_Guard" );
		}
	},
	
	Truck_Half_Way = function( trigger )
	{
		Util.MapDebugPrint( "Truck_Half_Way" );
		
		Map.TruckHalfWay = true;
		
		SetAvailableMapGoals( 0, false, ".*_PastBarrOne_.*" );
		
		SetAvailableMapGoals( TEAM.ALLIES, true, ".*_Allies_BarrierTwo_.*" );
		
		SetAvailableMapGoals( TEAM.AXIS, true, ".*_Axis_BarrierTwo_.*" );
		
		if ( Map.Truck_Barrier_2 != "Opened" )
		{
			SetAvailableMapGoals( TEAM.AXIS, true, "SWITCH_Guard" );
		}
	},
	
	Truck_At_Barrier_2 = function( trigger )
	{
		Util.MapDebugPrint( "Truck_At_Barrier_2" );
	},
	
	Truck_Barrier_Position = function()
	{
		ent = GetEntityByName("barrier");
		
		while ( 1 )
		{
			pos = GetEntPosition(ent).z;
			
			if ( pos < 2352 )
			{
				if ( Map.Truck_Barrier_2 != "Closed" )
				{
					Map.Truck_Barrier_2 = "Closed";
					Util.MapDebugPrint( "Truck_Barrier_Closed" );
					
					SetAvailableMapGoals( TEAM.ALLIES, false, "SWITCH_Guard" );
					
					if ( Map.TruckHalfWay and !Map.TruckPastBarrier_2 )
					{
						SetAvailableMapGoals( TEAM.AXIS, true, "SWITCH_Guard" );
					}
				}
			}
			else if ( pos == 2455 )
			{
				if ( Map.Truck_Barrier_2 != "Opened" )
				{
					Map.Truck_Barrier_2 = "Opened";
					Util.MapDebugPrint( "Truck_Barrier_Opened" );
					
					SetAvailableMapGoals( TEAM.AXIS, false, "SWITCH_Guard" );
					
					if ( !Map.TruckPastBarrier_2 and Map.TruckPastBarrier_1 )
					{
						SetAvailableMapGoals( TEAM.ALLIES, true, "SWITCH_Guard" );
					}
				}
			}
			else
			{
				if ( Map.Truck_Barrier_2 != "Moving" )
				{
					SetAvailableMapGoals( 0, false, "SWITCH_Guard" );
					Map.Truck_Barrier_2 = "Moving";
					Util.MapDebugPrint( "Truck_Barrier_Moving" );
				}
			}
			yield();
		}
	},
	
	Truck_Past_Barrier_2 = function( trigger )
	{
		Map.TruckPastBarrier_2 = true;
		
		Util.MapDebugPrint( "Truck_Past_Barrier_2" );
		
		SetAvailableMapGoals( 0, false, "SWITCH_Guard" );
	},
	
	Truck_Escaped = function( trigger )
	{
		Util.MapDebugPrint( "Truck_Escaped" );
		
		Map.TruckEscaped = true;
		
		SetAvailableMapGoals( TEAM.ALLIES, true, ".*_Allies_PastBarr1_.*" );
		
		if ( Map.Pressure_Pipes )
		{
			SetGoalRole( "PLANT_Generator", ROLE.DEFENDER );
			SetGoalRole( "BUILD_Generator", ROLE.ATTACKER );
			SetGoalRole( "PLANT_Pressure_Pipes", ROLE.ATTACKER1 );
			
			SetAvailableMapGoals( TEAM.ALLIES, true, ".*_Allies_PipesDef1_.*" );
			
			SetAvailableMapGoals( TEAM.AXIS, true, ".*_Axis_PipesAtt1_.*" );
		}
		else
		{
			SetGoalRole( "PLANT_Generator", { ROLE.DEFENDER, ROLE.DEFENDER1 } );
			SetGoalRole( "BUILD_Generator", { ROLE.ATTACKER, ROLE.ATTACKER1 } );
		}
		
		SetAvailableMapGoals( 0, false, {
			".*_BarrierTwo_.*",
			".*_Truck",
		});
		
		SetGoalRole( "MOUNT_Tank", { ROLE.DEFENDER, ROLE.DEFENDER1 } );
		SetGoalRole( ".*LLERY_.*Allies_PastBarr1_.*", { ROLE.DEFENDER, ROLE.DEFENDER1 } );
		SetGoalRole( "AIRSTRIKE_Allies_PastBarr1_.*", { ROLE.DEFENDER, ROLE.DEFENDER1 } );
		
		if ( Map.Tank and !Map.Big_Doors )
		{
			SetAvailableMapGoals( TEAM.ALLIES, true, "MOUNT_Tank");
		}
		
		Map.SetSpawn();
	},
	
	Tank_Depot_Hatch_Moving = function( trigger )
	{
		vel = ToVector( trigger.Action );
		
		if ( vel[ 0 ] > 0 )
		{
			Map.Tank_Depot_Hatch = true;
			Wp.SetWaypointFlag( "Tank_Depot_Hatch_.*", "door", true );
            DynamicPathsUpdated( TEAM.AXIS, TEAM.ALLIES );
            
            Util.MapDebugPrint( "Tank_Depot_Hatch_Closed" );
		}
        else
        {
			Map.Tank_Depot_Hatch = false;
			Wp.SetWaypointFlag( "Tank_Depot_Hatch_.*", "door", false );
			DynamicPathsUpdated( TEAM.AXIS, TEAM.ALLIES );
			
			Util.MapDebugPrint( "Tank_Depot_Hatch_Opened" );
        }
	},

	Allied_Spawn_Hatch_Moving = function( trigger )
	{
		vel = ToVector( trigger.Action );
		
		if ( vel[ 2 ] < 0 )
		{
			Map.Allied_Spawn_Hatch = true;
			Wp.SetWaypointFlag( "Allied_Spawn_Hatch_.*", "door", true );
            DynamicPathsUpdated( TEAM.AXIS, TEAM.ALLIES );
            
            Util.MapDebugPrint( "Allied_Spawn_Hatch_Closed" );
		}
        else
        {
			Map.Allied_Spawn_Hatch = false;
			Wp.SetWaypointFlag( "Allied_Spawn_Hatch_.*", "door", false );
			DynamicPathsUpdated( TEAM.AXIS, TEAM.ALLIES );
			
			Util.MapDebugPrint( "Allied_Spawn_Hatch_Opened" );
        }
	},

	Vent_Destroyed = function( trigger )
	{
		Map.Vent = false;
		
		Util.MapDebugPrint( "Vent_Destroyed" );
	},
	
	SetSpawn1 = function(bot)
	{
		if ( bot.GetTeam() == TEAM.AXIS )
        {
			if ( !Map.Big_Doors )
			{
				if ( bot.HasRole(ROLE.ATTACKER) or bot.HasRole(ROLE.ATTACKER1) )
				{
					if ( RandInt(0,1) < 1)
					{
						bot.ChangeSpawnPoint(2);
					}
					else
					{
						bot.ChangeSpawnPoint(3);
					}
				}
				if ( bot.HasRole(ROLE.ATTACKER2) )
				{
					if ( Map.Pressure_Pipes )
					{
						bot.ChangeSpawnPoint(2);
					}
					else
					{
						if ( !Map.TruckEscaped )
						{
							bot.ChangeSpawnPoint(2);
						}
						else
						{
							bot.ChangeSpawnPoint(3);
						}
					}
				}
			}
		}
	},
	
	SetSpawn = function()
	{
		foreach ( id and bot in BotTable )
		{
			Map.SetSpawn1(bot);
		}
	},
	
	Lift_Goto = function( trigger )
	{
		if ( !Map.Lift_Moving )
		{
			Map.Lift_Moving = true;
			Map.Lift_Down = false;
			Map.Lift_Up = false;
			ent = GetEntityByName("lift01");
			Util.MapDebugPrint( "Lift_Moving" );
			sleep(0.5);
			while ( Map.Lift_Moving )
			{
				z = GetEntPosition(ent).z;
				
				if ( z > 2316 )
				{
					Map.Lift_Moving = false;
					Map.Lift_Up = true;
					Util.MapDebugPrint( "Lift_Is_Up" );
				}
				
				if ( z < 1078 )
				{
					Map.Lift_Moving = false;
					Map.Lift_Down = true;
					Util.MapDebugPrint( "Lift_Is_Down" );
				}
				sleep(0.1);
			}
		}
	},
	
	Gate = function()
	{
		start = Vector3(-1379, -3966, 2336);
		end = Vector3(-1379, -3921, 2336);
		while ( Map.Gate )
		{
			tr = TraceLine( start, end, null, TRACE.SOLID, 0, false );
			if ( tr.fraction == 1 )
			{
				Util.MapDebugPrint( "Gate_Destroyed" );
				
				Wp.SetWaypointFlag( "axisdoor", "closed", false );
				
				Map.Gate = false;
			}
			sleep(0.1);
		}
		
		SetGoalRole( ".*T_Tank", { ROLE.ATTACKER, ROLE.ATTACKER1 });
		
		SetAvailableMapGoals( 0, false,".*Gate_.*" );
		
		SetAvailableMapGoals( TEAM.ALLIES, true,".*_Allies_GateDest_.*" );
		
		SetAvailableMapGoals( TEAM.AXIS, true,".*_Axis_GateDest_[023].*" );
		
		if ( !Map.Pressure_Pipes )
		{
			SetAvailableMapGoals( TEAM.AXIS, true, ".*_Axis_GateDest_1.*" );
		}
		
		if ( Map.Allied_CP )
		{
			SetAvailableMapGoals( TEAM.AXIS, true, "PLANT_Neutral_Command_Post" );
		}
		else
		{
			if ( !Map.Axis_CP )
			{
				SetAvailableMapGoals( TEAM.AXIS, true, "BUILD_Neutral_Command_Post" );
			}
		}
		
		if ( Map.Tank_Barrier_1 )
		{
			SetAvailableMapGoals( TEAM.AXIS, true, "PLANT_Tank_Barrier_1" );
		}
	},
	
	Lift_Player_Count =
	{
		Name = "Lift_Player_Count",
		TriggerOnClass = CLASS.ANYPLAYER,
		OnEnter = function(ent)
		{
			Map.Lift_Shaft_Player_Count += 1;
			
			Util.MapDebugPrint( "Lift_Shaft_Player_Count: " + Map.Lift_Shaft_Player_Count );
		},
		OnExit = function(ent)
		{
			Map.Lift_Shaft_Player_Count -= 1;
			
			Util.MapDebugPrint( "Lift_Shaft_Player_Count: " + Map.Lift_Shaft_Player_Count );
		},
	},
	
	Docs_room =
	{
		Name = "Docs_room",
		TriggerOnClass = CLASS.ANYPLAYER,
		OnEnter = function(ent)
		{
			if ( GetEntTeam(ent) == TEAM.AXIS )
			{
				if (Map.count_axis_DocsRoom[ent])
				{
					Map.count_axis_DocsRoom[ent] += 1;
				}
				else
				{
					Map.count_axis_DocsRoom[ent] = 1;
				}
				
				Util.MapDebugPrint("Axis in docs trigger: " + tableCount(Map.count_axis_DocsRoom));
				
				if ( Map.Documents_1 == "Returned" or Map.Documents_2 == "Returned" )
				{
					SetAvailableMapGoals( TEAM.ALLIES, false, {
						"MOUNT_Tank",
						".*_Allies_PastBarr1_.*",
						".*_Allies_OverSpawn_.*",
						".*_Allies_GateDest_.*",
						".*_Allies_Gate_.*",
					});
					
					ClearGoalRole( "MOUNT_Tank", { ROLE.DEFENDER, ROLE.DEFENDER1 } );
					ClearGoalRole( ".*_Allies_PastBarr1_.*", { ROLE.DEFENDER, ROLE.DEFENDER1 } );
					
					SetAvailableMapGoals( TEAM.ALLIES, true, ".*_Allies_DocsRoom_.*");
					
					yield();
					
					if ( Map.TankPastBarrier_1 )
					{
						SetAvailableMapGoals( TEAM.ALLIES, true, {
							"DEFEND_Allies_PastBarr1_.*",
							"MOBILEMG42_Allies_PastBarr1_.*",
						});
						
						if ( tableCount(Map.count_axis_GenRoom) < 1  )
						{
							SetGoalRole( ".*LLERY_.*Allies_PastBarr1_.*", ROLE.DEFENDER3 );
							SetGoalRole( "AIRSTRIKE_Allies_PastBarr1_.*", ROLE.DEFENDER3 );
							
							if ( !Map.Pressure_Pipes )
							{
								SetGoalRole( ".*LLERY_.*Allies_PastBarr1_.*", ROLE.DEFENDER2 );
								SetGoalRole( "AIRSTRIKE_Allies_PastBarr1_.*", ROLE.DEFENDER2 );
							}
							
							SetAvailableMapGoals( TEAM.ALLIES, true, ".*_Allies_PastBarr1_.*" );
						}
					}
					else
					{
						if ( !Map.Gate )
						{
							SetAvailableMapGoals( TEAM.ALLIES, true, ".*_Allies_GateDest_.*" );
						}
						else
						{
							SetAvailableMapGoals( TEAM.ALLIES, true, ".*_Allies_Gate_.*" );
						}
					}
					
					if ( tableCount(Map.count_axis_GenRoom) < 1 and !Map.Big_Doors and Map.Tank )
					{
						SetAvailableMapGoals( TEAM.ALLIES, true, "MOUNT_Tank");
					}
					
					if ( Map.Big_Doors )
					{
						SetAvailableMapGoals( TEAM.ALLIES, true, ".*_Allies_OverSpawn_.*" );
					}
				}
				else
				{
					if ( !Map.TruckEscaped )
					{
						SetAvailableMapGoals( TEAM.ALLIES, false, "MOUNT_Tank");
						
						ClearGoalRole( "MOUNT_Tank", { ROLE.DEFENDER, ROLE.DEFENDER1 } );
						
						yield();
						
						if ( tableCount(Map.count_axis_GenRoom) < 1 and !Map.Big_Doors and Map.Tank )
						{
							SetAvailableMapGoals( TEAM.ALLIES, true, "MOUNT_Tank");
						}
					}
				}
			}
		},
		OnExit = function(ent)
		{
			if (Map.count_axis_DocsRoom[ent])
			{
				if (Map.count_axis_DocsRoom[ent] > 1)
				{
					Map.count_axis_DocsRoom[ent] -= 1;
				}
				else
				{
					Map.count_axis_DocsRoom[ent] = null;
					Util.MapDebugPrint("Axis in docs trigger: " + tableCount(Map.count_axis_DocsRoom));
				}
				
				if ( tableCount(Map.count_axis_DocsRoom) < 1 or Map.BothDocumentsSecured )
				{
					SetAvailableMapGoals( TEAM.ALLIES, false, ".*_Allies_DocsRoom_.*");
					
					if ( Map.Documents_1 == "Returned" or Map.Documents_2 == "Returned" or Map.TruckEscaped )
					{
						SetGoalRole( ".*LLERY_.*Allies_PastBarr1_.*", { ROLE.DEFENDER, ROLE.DEFENDER1 } );
						SetGoalRole( "AIRSTRIKE_Allies_PastBarr1_.*", { ROLE.DEFENDER, ROLE.DEFENDER1 } );
						
						SetGoalRole( "MOUNT_Tank", { ROLE.DEFENDER, ROLE.DEFENDER1 } );
						
						SetAvailableMapGoals( TEAM.ALLIES, true, ".*_Allies_PastBarr1_.*" );
						
						if ( Map.Tank and !Map.Big_Doors)
						{
							SetAvailableMapGoals( TEAM.ALLIES, true, "MOUNT_Tank");
						}
					}
				}
				
				if ( Map.TankBetween_DamDoor_BigDoors and ( Map.Documents_1 == "Returned" or Map.Documents_2 == "Returned"  ))
				{
					SetAvailableMapGoals( TEAM.ALLIES, true, {
						"MOBILEMG42_Allies_DocsRoom_21",
						"DEFEND_Allies_DocsRoom_30",
					});
				}
			}
		},
	},
	
	Generator_room =
	{
		Name = "Generator_room",
		TriggerOnClass = CLASS.ANYPLAYER,
		OnEnter = function(ent)
		{
			if ( GetEntTeam(ent) == TEAM.AXIS )
			{
				if (Map.count_axis_GenRoom[ent])
				{
					Map.count_axis_GenRoom[ent] += 1;
				}
				else
				{
					Map.count_axis_GenRoom[ent] = 1;
				}
				
				Util.MapDebugPrint("Axis in generator trigger: " + tableCount(Map.count_axis_GenRoom));
				
				SetAvailableMapGoals( TEAM.ALLIES, false, {
					"MOUNT_Tank",
					".*_Allies_PastBarr1_.*",
				});
				
				ClearGoalRole( "MOUNT_Tank", { ROLE.DEFENDER2, ROLE.DEFENDER3 });
				ClearGoalRole( ".*LLERY_.*Allies_PastBarr1_.*", { ROLE.DEFENDER2, ROLE.DEFENDER3 });
				ClearGoalRole( "AIRSTRIKE_Allies_PastBarr1_.*", { ROLE.DEFENDER2, ROLE.DEFENDER3 });
				
				SetAvailableMapGoals( TEAM.ALLIES, true, {
					".*_Allies_Generator_0.*",
					".*_Allies_Generator_1.*",
				});
				
				if ( !Map.Pressure_Pipes )
				{
					SetAvailableMapGoals( TEAM.ALLIES, true, ".*_Allies_Generator_2.*");
				}
				
				yield();
				
				if ( Map.TankPastBarrier_1 )
				{
					SetAvailableMapGoals( TEAM.ALLIES, true, {
						"DEFEND_Allies_PastBarr1_.*",
						"MOBILEMG42_Allies_PastBarr1_.*",
					});
					
					if ( tableCount(Map.count_axis_DocsRoom) < 1 and ( Map.Documents_1 == "Returned" or Map.Documents_2 == "Returned" or Map.TruckEscaped ))
					{
						SetAvailableMapGoals( TEAM.ALLIES, true, ".*_Allies_PastBarr1_.*" );
						
						if ( Map.Tank and !Map.Big_Doors )
						{
							SetAvailableMapGoals( TEAM.ALLIES, true, "MOUNT_Tank" );
						}
					}
				}
			}
		},
		OnExit = function(ent)
		{
			if (Map.count_axis_GenRoom[ent])
			{
				if (Map.count_axis_GenRoom[ent] > 1)
				{
					Map.count_axis_GenRoom[ent] -= 1;
				}
				else
				{
					Map.count_axis_GenRoom[ent] = null;
					Util.MapDebugPrint("Axis in generator trigger: " + tableCount(Map.count_axis_GenRoom));
				}
				
				if ( tableCount(Map.count_axis_GenRoom) < 1 )
				{
					SetAvailableMapGoals( TEAM.ALLIES, false, ".*_Allies_Generator_.*");
					
					SetGoalRole( "MOUNT_Tank", ROLE.DEFENDER3 );
					SetGoalRole( ".*LLERY_.*Allies_PastBarr1_.*", ROLE.DEFENDER3 );
					SetGoalRole( "AIRSTRIKE_Allies_PastBarr1_.*", ROLE.DEFENDER3 );
					
					if ( !Map.Pressure_Pipes )
					{
						SetGoalRole( "MOUNT_Tank", ROLE.DEFENDER2 );
						SetGoalRole( ".*LLERY_.*Allies_PastBarr1_.*", ROLE.DEFENDER2 );
						SetGoalRole( "AIRSTRIKE_Allies_PastBarr1_.*", ROLE.DEFENDER2 );
					}
					
					SetAvailableMapGoals( TEAM.ALLIES, true, ".*_Allies_PastBarr1_.*" );
					
					if ( Map.Tank and !Map.Big_Doors )
					{
						SetAvailableMapGoals( TEAM.ALLIES, true, "MOUNT_Tank");
					}
					
					yield();
					
					if ( Map.TankBetween_Barr2_DamDoor )
					{
						SetAvailableMapGoals( TEAM.ALLIES, true, "MOBILEMG42_Allies_Generator_11" );
					}
					
					if ( !Map.Dam_Doors )
					{
						SetAvailableMapGoals( TEAM.ALLIES, true, "MOBILEMG42_Allies_Generator_10" );
					}
				}
			}
		},
	},
	
	Ignore_Target =
	{
		Name = "Ignore_Target",
		TriggerOnClass = CLASS.ANYPLAYER,
		OnEnter = function(ent)
		{
			b = Util.IsBot(ent);
			if ( b )
			{
				for ( q = 0; q < 64; q += 1 )
				{
					if ( EntityIsValid(q) and q != b.GetGameId() and !GetEntFlags(q,ENTFLAG.CARRYINGGOAL) )
					{
						b.IgnoreTarget(q, 999);
					}
				}
			}
		},
		OnExit = function(ent)
		{
			b = Util.IsBot(ent);
			if ( b )
			{
				for ( q = 0; q < 64; q += 1 )
				{
					if ( EntityIsValid(q) and q != b.GetGameId() )
					{
						b.IgnoreTarget(q, 0.1);
					}
				}
			}
		},
	},
};

