	Pressure_Pipes_Destroyed = function()
	{
		Map.Pressure_Pipes = false;
		
		Wp.SetWaypointFlag( "Pressure_Pipes_1", "allies", false );
		Wp.SetWaypointFlag( "Pressure_Pipes_1", "axis", true );
		
		Util.MapDebugPrint("Pressure_Pipes_Destroyed");
		
		SetGoalRole( ".*LLERY_.*Allies_PastBarr1_.*", ROLE.DEFENDER2 );
		SetGoalRole( "AIRSTRIKE_Allies_PastBarr1_.*", ROLE.DEFENDER2 );
		SetGoalRole( "BUILD_Tank_Barrier_.*", ROLE.DEFENDER2 );
		SetGoalRole( "MOBILEMG42_Allies_Generator_.*", ROLE.DEFENDER2 );
		SetGoalRole( "PLANT_ropes", ROLE.DEFENDER2 );
		
		SetGoalRole( "BUILD_Generator", ROLE.ATTACKER2 );
		SetGoalRole( "BUILD_Tank", ROLE.ATTACKER2 );
		SetGoalRole( "BUILD_Truck", ROLE.ATTACKER2 );
		SetGoalRole( "FLAG_docs_crate", ROLE.ATTACKER2 );
		SetGoalRole( ".*_Axis_CappPlace_.*", ROLE.ATTACKER2 );
		SetGoalRole( ".*_Axis_BarrierOne_.*", ROLE.ATTACKER2 );
		SetGoalRole( ".*_Axis_PastBarrOne_.*", ROLE.ATTACKER2 );
		SetGoalRole( ".*_Axis_BarrierTwo_.*", ROLE.ATTACKER2 );
		SetGoalRole( "SWITCH_Guard", ROLE.ATTACKER2 );
		
		if ( Map.TruckEscaped )
		{
			SetGoalRole( "PLANT_Generator", ROLE.DEFENDER1 );
			SetGoalRole( "BUILD_Generator", ROLE.ATTACKER1 );
			
			SetAvailableMapGoals( TEAM.ALLIES, true, ".*_Allies_PastBarr1_.*" );
		}
		else
		{
			Util.SetMaxUsers(2, ".*_Axis_BarrierOne_.*");
			Util.SetMaxUsers(2, ".*_Axis_PastBarrOne_.*");
			Util.SetMaxUsers(2, ".*_Axis_BarrierTwo_.*");
			
			if ( !Map.Big_Doors )
			{
				Map.SetSpawn();
			}
		}
		
		if ( !Map.TankPastBarrier_1 )
		{
			SetGoalRole( ".*_Neutral_Command_Post", ROLE.DEFENDER2 );
		}
		
		if ( Map.Tank_Barrier_1 or Map.Tank_Barrier_2 )
		{
			SetGoalRole( "PLANT_Tank_Barrier_.*", ROLE.ATTACKER2 );
		}
		
		foreach( goal in Util.GoalTable("DEFUSE_Pressure_Pipes_.*") )
		{
			goal.SetAvailable(TEAM.ALLIES, false);
		}
		
		SetAvailableMapGoals( TEAM.AXIS, false, "PLANT_Pressure_Pipes" );
		
		SetAvailableMapGoals( 0, false, ".*_Pipes.*" );
		
		if ( Map.Dam_Doors )
		{
			SetAvailableMapGoals( TEAM.ALLIES, true, ".*_Allies_DamLadder_.*" );
		}
		
		if ( !Map.TankPastBarrier_1 )
		{
			SetAvailableMapGoals( TEAM.AXIS, true, ".*_Axis_GateDest_1.*" );
		}
		
		if ( !Map.Ropes )
		{
			SetAvailableMapGoals( TEAM.AXIS, true, "BUILD_ropes" );
		}
		
		if ( !Map.Dam_Doors )
		{
			SetAvailableMapGoals( TEAM.AXIS, true, ".*_Axis_Generator_1.*" );
		}
	},
	
