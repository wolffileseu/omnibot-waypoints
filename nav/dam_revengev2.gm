global Map =
{
	Debug = 0,
	Gate = true,
	Vent = true,
	Generator = false,
	Allied_CP = false,
	Axis_CP = false,
	Tank = false,
	Tank_Barrier_1 = false,
	Tank_Barrier_2 = false,
	Truck = true,
	Truck_Barrier_1 = true,
	Ropes = false,
	Pressure_Pipes = true,
	Documents_1 = "Returned",
	Documents_2 = "Returned",
	BothDocumentsSecured = false,
	Dam_Doors = true,
	Big_Doors = true,
	Tank_Depot_Hatch = true,
	Allied_Spawn_Hatch = true,
	Lift_Moving = false,
	Lift_Down = false,
	Lift_Up = true,
	Lift_Shaft_Player_Count = 0,
	Lift_Down_botId = -1,
	Lift_Up_botId = -1,
	TankAtBarrier_1 = false,
	TankPastBarrier_1 = false,
	TankAtBarrier_2 = false,
	TankPastBarrier_2 = false,
	TankBetween_Barr2_DamDoor = false,
	TankBetween_DamDoor_BigDoors = false,
	TruckAtBarrier_1 = false,
	TruckPastBarrier_1 = false,
	TruckHalfWay = false,
	TruckPastBarrier_2 = false,
	TruckEscaped = false,
	count_axis_DocsRoom = {},
	count_axis_GenRoom = {},
	Truck_Barrier_2 = "Closed",
	
	DontDispenseAmmo = true,
	
	Roles =
	{
		AXIS =
		{
			AllBots = true,
			ATTACKER =	
			{
				numbots = 5,
				crucialClass = CLASS.ENGINEER,
			},
			ATTACKER1 =	
			{
				numbots = 5,
				crucialClass = CLASS.ENGINEER,
			},
			ATTACKER2 =	
			{
				numbots = 5,
				crucialClass = CLASS.ENGINEER,
			},
			ATTACKER3 =	
			{
				numbots = 5,
				crucialClass = CLASS.ENGINEER,
			},
		},
		
		ALLIES =
		{
			AllBots = true,
			DEFENDER =	
			{
				numbots = 5,
				crucialClass = {CLASS.ENGINEER, CLASS.SOLDIER},
			},
			DEFENDER1 =	
			{
				numbots = 5,
				crucialClass = {CLASS.FIELDOPS, CLASS.SOLDIER},
			},
			DEFENDER2 =	
			{
				numbots = 5,
				crucialClass = {CLASS.ENGINEER, CLASS.SOLDIER},
			},
			DEFENDER3 =	
			{
				numbots = 5,
				crucialClass = {CLASS.ENGINEER, CLASS.MEDIC},
			},
		},
	},
	
	Navigation =
	{
		//	/bot waypoint_setproperty paththrough Navigation_PT:jump
		jump =
		{
			navigate = function(_this)
			{
				_this.Bot.HoldButton(BTN.JUMP, 0.55);
				sleep(0.55);
			},
		},
		
		//	/bot waypoint_setproperty paththrough Navigation_PT:jump_wait
		jump_wait =
		{
			navigate = function(_this)
			{
				sleep(0.25);
				_this.Bot.HoldButton(BTN.JUMP, 0.55);
				sleep(0.55);
			},
		},
		
		//	/bot waypoint_setproperty paththrough Navigation_PT:tank_depot_hatch
		tank_depot_hatch =
		{
			EvalFunc = function(_this)
			{
				return Map.Tank_Depot_Hatch;
			},
			navigate = function(_this)
			{
				_this.Goto(_this.Bot.GetPosition());
				_this.AddAimRequest(Priority.VeryHigh, "position", Vec3( -1839.610, -3725.125, 2458.851 ));
				sleep(0.75);
				while ( Map.Tank_Depot_Hatch )
				{
					_this.Bot.HoldButton(BTN.USE, 0.1);
					sleep(0.1);
				}
				_this.ReleaseAimRequest();
				sleep(1.5);
			},
		},
		
		//	/bot waypoint_setproperty paththrough Navigation_PT:allied_spawn_hatch
		allied_spawn_hatch =
		{
			EvalFunc = function(_this)
			{
				return Map.Allied_Spawn_Hatch;
			},
			navigate = function(_this)
			{
				_this.Goto(_this.Bot.GetPosition());
				_this.AddAimRequest(Priority.VeryHigh, "position", Vec3( -1421.875, 1216.554, 2711.998 ));
				sleep(0.75);
				while ( Map.Allied_Spawn_Hatch )
				{
					_this.Bot.HoldButton(BTN.USE, 0.1);
					sleep(0.1);
				}
				_this.ReleaseAimRequest();
				sleep(1.5);
			},
		},
		
		//	/bot waypoint_setproperty paththrough Navigation_PT:vent
		vent =
		{
			EvalFunc = function(_this)
			{
				return Map.Vent;
			},
			navigate = function(_this)
			{
				_this.Goto(_this.Bot.GetPosition());
				_this.AddAimRequest(Priority.VeryHigh, "position", Vec3(-9.389, 1497.788, 2679.624));
				
				weaps =
				{
					WEAPON.LUGER,
					WEAPON.LUGER_AKIMBO,
					WEAPON.LUGER_SILENCED,
					WEAPON.LUGER_AKIMBO_SILENCED,
					WEAPON.COLT,
					WEAPON.COLT_AKIMBO,
					WEAPON.COLT_SILENCED,
					WEAPON.COLT_AKIMBO_SILENCED
				};
				
				foreach ( w in weaps )
				{
					if ( _this.Bot.HasWeapon(w) )
					{
						_this.AddWeaponRequest(Priority.High, w);
						break;
					}
				}
				sleep(0.5);
				
				timer = 0;
				weaponchange = false;
				
				while ( Map.Vent )
				{
					if ( !_this.Bot.HasAmmo(w) and !weaponchange )
					{
						timer = 0;
						weaponchange = true;
						_this.ReleaseAimRequest();
						_this.ReleaseWeaponRequest();
						_this.AddWeaponRequest(Priority.High, WEAPON.KNIFE);
						
						while ( _this.Bot.MoveTowards(Vec3(-333.125, 1682.125, 2680.125), 5 ))
						{
							if ( _this.Bot.GetPosition().z < 2600 )
							{
								return;
							}
							
							yield();
						}
						_this.AddAimRequest(Priority.VeryHigh, "position", Vec3(-91.125, 1498.549, 2596.683));
						sleep(0.5);
					}
					
					if ( _this.Bot.GetPosition().z < 2600 )
					{
						return;
					}
					
					_this.Bot.HoldButton(BTN.ATTACK1, 0.2);
					sleep(0.1);
					timer += 1;
					
					if ( timer == 70 )
					{
						return;
					}
				}
			},
		},
		
		//	/bot waypoint_setproperty paththrough Navigation_PT:liftdown
		liftdown =
		{
			OnExit = function(_this)
            {
                if ( Map.Lift_Down_botId == _this.Bot.GetGameId() )
                {
                    Map.Lift_Down_botId = -1;
                }
            },
			navigate = function(_this)
			{
				_this.Goto(_this.Bot.GetPosition());
				
				if ( Map.Lift_Down_botId == -1 )
				{
					Map.Lift_Down_botId = _this.Bot.GetGameId();
				}
				else
				{
					return;
				}
				
				while ( Map.Lift_Shaft_Player_Count != 0 )
				{
					yield();
				}
				
				while ( Map.Lift_Moving )
				{
					yield();
				}
				
				if ( Map.Lift_Up )
				{
					_this.timer = 0;
					while ( !_this.Bot.MoveTowards(Vec3(-2147.813, -2420.337, 1084.125), 15) )
					{
						_this.Bot.PressButton(BTN.WALK);
						sleep(0.1);
						_this.timer += 1;
						
						if ( _this.timer == 50 )
						{
							return;
						}
					}
					_this.Goto(_this.Bot.GetPosition());
					_this.AddAimRequest(Priority.VeryHigh, "position", Vec3( -2149.381, -2382.125, 1104.686 ));
					sleep(0.5);
					_this.timer = 0;
					while ( !Map.Lift_Moving )
					{
						_this.Bot.HoldButton(BTN.USE, 0.2);
						sleep(0.2);
						_this.timer += 2;
						
						if ( _this.timer == 60 )
						{
							return;
						}
					}
					_this.ReleaseAimRequest();
				}
				
				while ( !Map.Lift_Down )
				{
					yield();
				}
				_this.timer = 0;
				while ( !_this.Bot.MoveTowards(Vec3(-2230.862, -2417.600, 1084.125), 15) )
				{
					_this.Bot.PressButton(BTN.WALK);
					sleep(0.1);
					_this.timer += 1;
					
					if ( _this.timer == 50 )
					{
						return;
					}
				}
				_this.Goto(_this.Bot.GetPosition());
				_this.AddAimRequest(Priority.VeryHigh, "position", Vec3( -2282.875, -2417.804, 1097.196 ));
				sleep(0.5);
				_this.timer = 0;
				while ( !Map.Lift_Moving )
				{
					_this.Bot.HoldButton(BTN.USE, 0.2);
					sleep(0.2);
					_this.timer += 2;
					
					if ( _this.timer == 60 )
					{
						return;
					}
				}
				_this.ReleaseAimRequest();
				
				while ( !Map.Lift_Up )
				{
					_this.Goto(_this.Bot.GetPosition());
					yield();
				}
				_this.timer = 0;
				while ( !_this.Bot.MoveTowards(Vec3(-2230.302, -1487.172, 2324.105), 15) )
				{
					sleep(0.1);
					_this.timer += 1;
					
					if ( _this.timer == 80 )
					{
						return;
					}
				}
			},
		},
		
		//	/bot waypoint_setproperty paththrough Navigation_PT:liftup
		liftup =
		{
			OnExit = function(_this)
            {
                if ( Map.Lift_Up_botId == _this.Bot.GetGameId() )
                {
                    Map.Lift_Up_botId = -1;
                }
            },
			navigate = function(_this)
			{
				_this.Goto(_this.Bot.GetPosition());
				
				if ( Map.Lift_Up_botId == -1 )
				{
					Map.Lift_Up_botId = _this.Bot.GetGameId();
				}
				else
				{
					return;
				}
				
				while ( Map.Lift_Shaft_Player_Count != 0 )
				{
					yield();
				}
				
				while ( Map.Lift_Moving )
				{
					yield();
				}
				_this.timer = 0;
				while ( !_this.Bot.MoveTowards(Vec3(-2230.302, -1487.172, 2324.105), 15) )
				{
					_this.Bot.PressButton(BTN.WALK);
					sleep(0.1);
					_this.timer += 1;
					
					if ( _this.timer == 50 )
					{
						return;
					}
				}
				
				if ( Map.Lift_Down )
				{
					_this.Goto(_this.Bot.GetPosition());
					_this.AddAimRequest(Priority.VeryHigh, "position", Vec3( -2268.875, -1484.899, 2344.241 ));
					sleep(0.5);
					_this.timer = 0;
					while ( !Map.Lift_Moving )
					{
						_this.Bot.HoldButton(BTN.USE, 0.2);
						sleep(0.2);
						_this.timer += 2;
						
						if ( _this.timer == 60 )
						{
							return;
						}
					}
					_this.ReleaseAimRequest();
				}
				
				while ( !Map.Lift_Up )
				{
					yield();
				}
				_this.timer = 0;
				while ( !_this.Bot.MoveTowards(Vec3(-2230.107, -1582.787, 2324.156), 15) )
				{
					_this.Bot.PressButton(BTN.WALK);
					sleep(0.1);
					_this.timer += 1;
					
					if ( _this.timer == 50 )
					{
						return;
					}
				}
				_this.Goto(_this.Bot.GetPosition());
				_this.AddAimRequest(Priority.VeryHigh, "position", Vec3( -2282.875, -1582.888, 2329.638 ));
				sleep(0.5);
				_this.timer = 0;
				while ( !Map.Lift_Moving )
				{
					_this.Bot.HoldButton(BTN.USE, 0.2);
					sleep(0.2);
					_this.timer += 2;
					
					if ( _this.timer == 60 )
					{
						return;
					}
				}
				_this.ReleaseAimRequest();
				
				while ( !Map.Lift_Down )
				{
					_this.Goto(_this.Bot.GetPosition());
					yield();
				}
				_this.timer = 0;
				while ( !_this.Bot.MoveTowards(Vec3(-2144.331, -2422.596, 1084.175), 15) )
				{
					sleep(0.1);
					_this.timer += 1;
					
					if ( _this.timer == 80 )
					{
						return;
					}
				}
			},
		},
	},
	
	Allied_CP_Built = function()
	{
		Map.Allied_CP = true;
		
		Util.MapDebugPrint("Allied_CP_Built");
		
		SetAvailableMapGoals( 0, false, "BUILD_Neutral_Command_Post" );
		
		if ( !Map.Gate )
		{
			SetAvailableMapGoals( TEAM.AXIS, true, "PLANT_Neutral_Command_Post" );
		}
	},
	
	Allied_CP_Destroyed = function()
	{
		Map.Allied_CP = false;
		
		Util.MapDebugPrint("Allied_CP_Destroyed");
		
		SetAvailableMapGoals( TEAM.AXIS, false, "PLANT_Neutral_Command_Post" );
		
		if ( !Map.Gate )
		{
			SetAvailableMapGoals( TEAM.AXIS, true, "BUILD_Neutral_Command_Post" );
			
			if ( !Map.TankPastBarrier_1 )
			{
				SetAvailableMapGoals( TEAM.ALLIES, true, "BUILD_Neutral_Command_Post" );
			}
		}
		else
		{
			SetAvailableMapGoals( TEAM.ALLIES, true, "BUILD_Neutral_Command_Post" );
		}
	},

	Axis_CP_Built = function()
	{
		Map.Axis_CP = true;
		
		Util.MapDebugPrint("Axis_CP_Built");
		
		SetAvailableMapGoals( 0, false, "BUILD_Neutral_Command_Post" );
		
		if ( Map.TankPastBarrier_1 )
		{
			ClearGoalRole( "PLANT_Neutral_Command_Post", { ROLE.DEFENDER, ROLE.DEFENDER3 } );
			SetGoalRole( "PLANT_Neutral_Command_Post", ROLE.INFILTRATOR );
		}
		
		SetAvailableMapGoals( TEAM.ALLIES, true, "PLANT_Neutral_Command_Post" );
	},

	Axis_CP_Destroyed = function()
	{
		Map.Axis_CP = false;
		
		Util.MapDebugPrint("Axis_CP_Destroyed");
		
		ClearGoalRole( "PLANT_Neutral_Command_Post", ROLE.INFILTRATOR );
		
		SetAvailableMapGoals( TEAM.ALLIES, false, "PLANT_Neutral_Command_Post" );
		
		if ( !Map.Gate )
		{
			SetAvailableMapGoals( TEAM.AXIS, true, "BUILD_Neutral_Command_Post" );
			
			if ( !Map.TankPastBarrier_1 )
			{
				SetAvailableMapGoals( TEAM.ALLIES, true, "BUILD_Neutral_Command_Post" );
			}
		}
		else
		{
			SetAvailableMapGoals( TEAM.ALLIES, true, "BUILD_Neutral_Command_Post" );
		}
	},
	
	CP_Planted = function()
	{
		Util.MapDebugPrint("CP_Planted");
		
		if ( Map.Allied_CP )
		{
			foreach( goal in Util.GoalTable("DEFUSE_Neutral_Command_Post_.*") )
			{
				goal.SetRoles(ROLE.DEFENDER, ROLE.DEFENDER3);
				if ( !Map.Pressure_Pipes )
				{
					goal.SetRoles(ROLE.DEFENDER2);
				}
				goal.SetGoalPriority( TEAM.ALLIES, 0 , 0.88 );
				goal.MaxUsers_InProgress( 1 );
			}
		}
		else
		{
			foreach( goal in Util.GoalTable("DEFUSE_Neutral_Command_Post_.*") )
			{
				goal.SetRoles(ROLE.ATTACKER, ROLE.ATTACKER1);
				if ( !Map.Pressure_Pipes )
				{
					goal.SetRoles(ROLE.ATTACKER2);
				}
				goal.SetGoalPriority( TEAM.AXIS, 0 , 0.88 );
				goal.MaxUsers_InProgress( 1 );
			}
		}
	},
	
	Tank_Built = function()
	{
		Map.Tank = true;
		
		Util.MapDebugPrint("Tank_Built");
		
		SetAvailableMapGoals( TEAM.AXIS, false, "BUILD_Tank" );
		
		if ( (!Map.TankAtBarrier_1 or !Map.Tank_Barrier_1) and (!Map.TankAtBarrier_2 or !Map.Tank_Barrier_2) and Map.Big_Doors )
		{
			SetAvailableMapGoals( TEAM.AXIS, true, ".*T_Tank" );
		}
		
		sleep(1);
		GetGoal("MOBILEMORTAR_Allies_Gate_10").MortarAim = { Vec3(-0.089, -0.995, -0.044),
		Vec3(-0.132, -0.991, -0.020), Vec3(-0.074, -0.997, 0.011), Vec3(-0.096, -0.994, 0.046), Vec3(-0.148, -0.989, 0.025) };
		GetGoal("MOBILEMORTAR_Allies_Gate_11").MortarAim = { Vec3(0.014, -1.000, 0.014),
		Vec3(-0.020, -0.999, 0.042), Vec3(-0.025, -0.997, 0.071), Vec3(-0.079, -0.995, 0.057), Vec3(-0.059, -0.998, 0.005) };
	},

	Tank_Destroyed = function()
	{
		Map.Tank = false;
		
		Util.MapDebugPrint("Tank_Destroyed");
		
		SetAvailableMapGoals( 0, false, ".*T_Tank" );
		
		if ( (!Map.TankAtBarrier_1 or !Map.Tank_Barrier_1) and (!Map.TankAtBarrier_2 or !Map.Tank_Barrier_2) and Map.Big_Doors )
		{
			SetAvailableMapGoals( TEAM.AXIS, true, "BUILD_Tank" );
		}
	},

	Tank_Barrier_1_Built = function()
	{
		Map.Tank_Barrier_1 = true;
		
		Wp.SetWaypointFlag( "Tank_Barrier_1_2", "closed", false );
        Wp.SetWaypointFlag( "Tank_Barrier_1_3", "closed", true );
		
		Util.MapDebugPrint("Tank_Barrier_1_Built");
		
		SetAvailableMapGoals( TEAM.ALLIES, false, "BUILD_Tank_Barrier_1" );
		
		if ( Map.TankAtBarrier_1 and !Map.Tank )
		{
			SetAvailableMapGoals( TEAM.AXIS, false, "BUILD_Tank" );
		}
		
		if ( !Map.Gate )
		{
			SetAvailableMapGoals( TEAM.AXIS, true, "PLANT_Tank_Barrier_1" );
		}
	},
	
	Tank_At_Barrier_1 = function( trigger )
	{
		Util.MapDebugPrint( "Tank_At_Barrier_1" );
		
		Map.TankAtBarrier_1 = true;
		
		if ( Map.Tank_Barrier_1 )
		{
			SetAvailableMapGoals( TEAM.AXIS, false, "ESCORT_Tank" );
		}
	},
	
	Tank_Barrier_1_Planted = function()
	{
		Util.MapDebugPrint("Tank_Barrier_1_Planted");
		
		foreach( goal in Util.GoalTable("DEFUSE_Tank_Barrier_1_.*") )
		{
			goal.SetRoles(ROLE.DEFENDER, ROLE.DEFENDER3);
			if ( !Map.Pressure_Pipes )
			{
				goal.SetRoles(ROLE.DEFENDER2);
			}
			goal.SetGoalPriority( TEAM.ALLIES, 0 , 0.9 );
		}
	},

	Tank_Barrier_1_Destroyed = function()
	{
		Map.Tank_Barrier_1 = false;
		
		Wp.SetWaypointFlag( "Tank_Barrier_1_2", "closed", true );
        Wp.SetWaypointFlag( "Tank_Barrier_1_3", "closed", false );
		
		Util.MapDebugPrint("Tank_Barrier_1_Destroyed");
		
		foreach( goal in Util.GoalTable("DEFUSE_Tank_Barrier_1_.*") )
		{
			goal.SetAvailable(TEAM.ALLIES, false);
		}
		
		SetAvailableMapGoals( TEAM.AXIS, false, "PLANT_Tank_Barrier_1" );
		
		SetAvailableMapGoals( TEAM.ALLIES, true, "BUILD_Tank_Barrier_1" );
		
		if ( Map.TankAtBarrier_1 )
		{
			if ( !Map.Tank )
			{
				SetAvailableMapGoals( TEAM.AXIS, true, "BUILD_Tank" );
			}
			else
			{
				SetAvailableMapGoals( TEAM.AXIS, true, ".*T_Tank" );
			}
		}
	},
	
	Tank_Past_Barrier_1 = function( trigger )
	{
		Wp.SetWaypointFlag( "Tank_Barrier_1_4", "closed", true );
		Wp.SetWaypointFlag( "Tank_Barrier_1_5", "closed", true );
		Wp.SetWaypointFlag( "Tank_Barrier_1_6", "closed", true );
		Wp.SetWaypointFlag( "Tank_Barrier_1_7", "closed", true );
		Wp.SetWaypointFlag( "Tank_Barrier_1_8", "closed", true );
		Wp.SetWaypointFlag( "Tank_Barrier_1_9", "closed", true );
		Wp.SetWaypointFlag( "Tank_Barrier_1_10", "closed", true );
		Wp.SetWaypointFlag( "Tank_Barrier_1_11", "closed", true );
		
		Util.MapDebugPrint( "Tank_Past_Barrier_1" );
		
		Map.TankAtBarrier_1 = false;
		Map.TankPastBarrier_1 = true;
		
		Util.EnableGoal("ROUTE_DamLedge_.*");
		Util.EnableGoal("ROUTE_BackWay_.*");
		Util.EnableGoal("ROUTE_MainWay_.*");
		
		ClearGoalRole( ".*_Neutral_Command_Post", { ROLE.DEFENDER, ROLE.DEFENDER2, ROLE.DEFENDER3 } );
		SetGoalRole( "PLANT_Neutral_Command_Post", ROLE.INFILTRATOR );
		
		SetAvailableMapGoals( 0, false, ".*_GateDest_.*" );
		
		SetAvailableMapGoals( TEAM.ALLIES, false, {
			"BUILD_Tank_Barrier_1",
			"BUILD_Neutral_Command_Post",
			".*MG42_Bunker_MG42",
			".*_Allies_Lift_.*",
		});
		
		SetAvailableMapGoals( TEAM.ALLIES, true, ".*_Allies_PastBarr1_.*" );
		
		SetAvailableMapGoals( TEAM.AXIS, true, ".*_Axis_PastBarr1_.*" );
		
		if ( Map.Tank_Barrier_2 )
		{
			SetAvailableMapGoals( TEAM.AXIS, true, "PLANT_Tank_Barrier_2" );
		}
		
		Util.DisableGoal("ROUTE_DamLedgeJump");
		Util.DisableGoal("ROUTE_DamTunnel");
		Util.DisableGoal("ROUTE_Thru_CP_Spawn");
		Route_67 =
		{
			MOBILEMG42_Allies_Pipes_00 = {},
		};
		
		Route_67[".*_Allies_Pipes_.*"] =
		{
			ROUTE_Allied_Spawn =
			{
				ROUTE_DamLedgeJump1 =
				{
					ROUTE_DamTunnel1 = {},
				},
			},
		};
		
		Util.Routes(Route_67);
		
		sleep(1);
		
		foreach ( id and bot in BotTable )
		{
			if ( bot.GetTeam() == TEAM.ALLIES )
			{
				if ( bot.HasWeapon(WEAPON.MORTAR) or bot.HasWeapon(WEAPON.PANZERFAUST) )
				{
					ETUtil.WaitForSpawn(TEAM.ALLIES);
					
					bot.ExecCommand( "kill" );
					
					Util.MapDebugPrint("====Killing myself due to weapon====");
				}
			}
		}
	},
	
	Tank_Barrier_2_Built = function()
