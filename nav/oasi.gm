	Ancient_Anti_Gravity_Generator_Destroyed = function( trigger )
	{
		SetAvailableMapGoals( TEAM.ALLIES, true, "DEFEND_basin_.*" );
		SetAvailableMapGoals( TEAM.ALLIES, false, "DEFEND_generator_.*" );
		SetAvailableMapGoals( TEAM.AXIS, true, "DEFEND_basin_.*" );
		SetAvailableMapGoals( TEAM.AXIS, false, "DEFEND_generator_.*" );

		sleep(1);
		ETUtil.WinningChat( TEAM.ALLIES );
		sleep(1.5);
		ETUtil.LosingChat( TEAM.AXIS );

		Util.MapDebugPrint( "Ancient_Anti_Gravity_Generator_Destroyed" );
	},

	Main_Gate_Destroyed = function( trigger )
	{
		sleep(0.1);
		Wp.CheckBlockable();

		SetAvailableMapGoals( TEAM.ALLIES, true, {
			"FLAG_tank_fuel",
			"CAPPOINT_tank_fuel",
			"ATTACK_garage_.*",
			"SNIPE_attack_garage_.*",
			"MOBILEMG42_garage_.*",
			"SMOKEBOMB_alliesgarage_.*",
			"CHECKPOINT_city2flag",
			"SWITCH_piano_.*",
			"MOBILEMORTAR_attack_garage_.*",
			"AMMOCAB_1529",
			"HEALTHCAB_466",
			"CAMP_garage_.*",
		});
		SetAvailableMapGoals( TEAM.ALLIES, false, {
			"ATTACK_city_.*",
			"SNIPE_attack_city_.*",
			"MOBILEMG42_city_.*",
			"SMOKEBOMB_alliescity_.*",
			"CHECKPOINT_oldcityflag",
			"HEALTHCAB_north_healthcabinet",
			"AMMOCAB_north_ammocabinet",
			"CAMP_city_.*",
		});
		SetAvailableMapGoals( TEAM.AXIS, true, {
			"SNIPE_defend_garage_.*",
			"MOBILEMG42_garage_.*",
			"DEFEND_garage_.*",
			"PLANTMINE_axisgarage_.*",
			"CHECKPOINT_city2flag",
			"SWITCH_phone_2",
			"SWITCH_piano_.*",
			"MOBILEMORTAR_defend_garage_.*",
			"AMMOCAB_1529",
			"HEALTHCAB_466",
			"CAMP_garage_.*",
		});
		SetAvailableMapGoals( TEAM.AXIS, false, {
			"SNIPE_defend_city_.*",
			"MOBILEMG42_city_.*",
			"DEFEND_city_.*",
			"MOUNTMG42_mg42_a1",
			"REPAIRMG42_mg42_a1",
			"PLANTMINE_axiscity_.*",
			"CHECKPOINT_oldcityflag",
			"SWITCH_phone_1",
			"HEALTHCAB_north_healthcabinet",
			"AMMOCAB_north_ammocabinet",
			"CAMP_city_.*",
		});

		Util.EnableGoal("ROUTE_maingate");
		Util.MapDebugPrint( "Main_Gate_Destroyed" );

		DeleteTriggerRegion("Sneakin");
		DeleteTriggerRegion("Sneakin2");
		
		sleep(4);
		Util.BotChat(TEAM.AXIS, "vsay", VOICE.DEFEND_OBJECTIVE, 1);
		Util.BotChat(TEAM.ALLIES, "sayteam", "Steal the fuel and deliver it to the tank", 1);
	},

