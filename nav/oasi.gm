	KeyTrigger1 =
	{
		Name = "KeyTrigger1",
		TriggerOnClass = CLASS.ANYPLAYER,
		OnEnter = function(ent)
		{
			if ( GetEntFlags(ent,ENTFLAG.CARRYINGGOAL) )
			{
				SetAvailableMapGoals( TEAM.ALLIES, true, {
					"CAMP_temple_.*",
					"ATTACK_templeout_.*",
					"SNIPE_attack_temple_07",
				});
				SetAvailableMapGoals( TEAM.ALLIES, false, {
					"ATTACK_templein_.*",
					"DEFEND_basin_.*",
					"MOBILEMG42_templein_.*",
				});	
				SetAvailableMapGoals( TEAM.AXIS, true, {
					"DEFEND_temple_.*",
					"CAMP_temple_.*",
					"PLANTMINE_axistemple_.*",
					"SWITCH_hookah_1",
				});
				SetAvailableMapGoals( TEAM.AXIS, false, {
					"DEFEND_templein_.*",
					"DEFEND_basin_.*",
					"SNIPE_defend_templein_.*",
				});

				Util.MapDebugPrint(GetEntName(ent) + "^8Is Still Outside With The Key!");
			}
		},
		OnExit = function(ent)
		{
			if ( GetEntFlags(ent,ENTFLAG.CARRYINGGOAL) )
			{
				SetAvailableMapGoals( TEAM.ALLIES, true, {
					"DEFEND_basin_.*",
					"MOBILEMG42_templein_.*",
					"ATTACK_templein_.*",
				});
				SetAvailableMapGoals( TEAM.ALLIES, false, {
					"CAMP_temple_.*",
					"MOBILEMG42_temple_.*",
					"ATTACK_templeout_.*",
					"SNIPE_attack_temple_07",
					"DEFEND_basin_01",
					"DEFEND_basin_02",
				});
				SetAvailableMapGoals( TEAM.AXIS, true, {
					"DEFEND_templein_.*",
					"DEFEND_basin_.*",
					"MOBILEMG42_templein_.*",
					"SNIPE_defend_templein_.*",
				});
				SetAvailableMapGoals( TEAM.AXIS, false, {
					"DEFEND_temple_.*",
					"CAMP_temple_.*",
					"MOBILEMG42_temple_.*",
					"PLANTMINE_axistemple_.*",
					"SWITCH_hookah_1",
				});
				
				Util.MapDebugPrint(GetEntName(ent) + "^3Is Inside The Temple With The Key!");
			}
		},
	},

	GeneratorPlant =
	{
		Name = "GeneratorPlant",
		TriggerOnClass = CLASS.ENGINEER,
		OnEnter = function(ent)
		{
			if( GetEntTeam(ent) == TEAM.ALLIES )
			{
				foreach ( bot in BotTable )
				{
					if ( bot.GetTeam() == TEAM.AXIS )
					{
						bot.SayTeam("Allies are planting at the Generator!");
						break;
					}
				}
			}
		},

	},

	GeneratorRoom =
	{
		Name = "GeneratorRoom",
		TriggerOnClass = CLASS.ANYPLAYER,
		OnEnter = function(ent)
		{
			if( GetEntTeam(ent) == TEAM.ALLIES || GetEntFlags(ent, ENTFLAG.DISGUISED) )
			{
				SetAvailableMapGoals( TEAM.AXIS, false, "DEFEND_templein_.*" );
				SetAvailableMapGoals( TEAM.AXIS, true, "DEFEND_generator_.*" );

				Util.MapDebugPrint(GetEntName(ent) + "Allies are inside the Generator room!");
			}
		},
		OnExit = function(ent)
		{
			if( GetEntTeam(ent) == TEAM.ALLIES || GetEntFlags(ent, ENTFLAG.DISGUISED) )
			{
				SetAvailableMapGoals( TEAM.AXIS, true, "DEFEND_templein_.*" );
				SetAvailableMapGoals( TEAM.AXIS, false, "DEFEND_generator_.*" );

				Util.MapDebugPrint(GetEntName(ent) + "Generator room is clear.");
			}
		},
	},
	
	CactusB =
	{
		Name = "CactusB",
		TriggerOnClass = CLASS.ANYPLAYER,
		OnEnter = function(ent)
		{
			if( GetEntTeam(ent) == TEAM.ALLIES )
			{
				foreach ( bot in BotTable )
				{
					if ( bot.GetTeam() == TEAM.ALLIES )
					{
						bot.SayTeam("We have a cactus lover!");
						break;
					}
				}
			}
		},
	},

	CactusR =
	{
		Name = "CactusR",
		TriggerOnClass = CLASS.ANYPLAYER,
		OnEnter = function(ent)
		{
			if( GetEntTeam(ent) == TEAM.AXIS )
			{
				foreach ( bot in BotTable )
				{
					if ( bot.GetTeam() == TEAM.AXIS )
					{
						bot.SayTeam("We have a cactus lover!");
						break;
					}
				}
			}
		},
	},
	
	Sneakin =
	{
		Name = "Sneakin",
		TriggerOnClass = CLASS.ANYPLAYER,
		OnEnter = function(ent)
		{
			if( GetEntTeam(ent) == TEAM.ALLIES )
			{
				foreach ( bot in BotTable )
				{
					if ( bot.GetTeam() == TEAM.AXIS )
					{
						bot.SayTeam("Intruder goes to the Tank!");
						break;
					}
				}
			}
		},
	},

	Sneakin2 =
	{
		Name = "Sneakin2",
		TriggerOnClass = CLASS.ANYPLAYER,
		OnEnter = function(ent)
		{
			if( GetEntTeam(ent) == TEAM.ALLIES )
			{
				foreach ( bot in BotTable )
				{
					if ( bot.GetTeam() == TEAM.AXIS )
					{
						bot.SayTeam("Intruder goes to the Tank!");
						break;
					}
				}
			}
		},
	},
};

