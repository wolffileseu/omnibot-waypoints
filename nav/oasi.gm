	SetGoalPriority( "ATTACK_templein_.*", 0.54, TEAM.ALLIES );

	// Axis goals
	SetGoalPriority( "BUILD_second_Tank_Barrier", 0.91, TEAM.AXIS );
	SetGoalPriority( "BUILD_first_Tank_Barrier", 0.92, TEAM.AXIS );
	SetGoalPriority( "BUILD_Side_Entrance", 0.90, TEAM.AXIS );
	SetGoalPriority( "DEFEND_city_.*", 0.50, TEAM.AXIS );
	SetGoalPriority( "DEFEND_garage_.*", 0.51, TEAM.AXIS );
