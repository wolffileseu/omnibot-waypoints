	Util.SetMaxUsers( 1, "SWITCH_piano_.*" );
	Util.SetMaxUsers( 1, "SWITCH_phone_.*" );
	Util.SetMaxUsers( 1, "SWITCH_hookah_1" );

	// Camp times
	SetMapGoalProperties( "MOUNTMG42_.*", {MinCampTime=15, MaxCampTime=40} );
	SetMapGoalProperties( "MOBILEMG42_.*", {MinCampTime=10, MaxCampTime=60} );

	// Allies goals
	SetGoalPriority( "PLANT_Ancient_Anti_Gravity_Generator", 1.11, TEAM.ALLIES );
	SetGoalPriority( "PLANT_Side_Entrance", 0.52, TEAM.ALLIES, CLASS.ENGINEER );
