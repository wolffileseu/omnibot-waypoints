	CactusR = OnTriggerRegion(AABB(851.576,-1091.632,40.134,912.530,-1076.383,189.313), Map.CactusR);
	CactusB = OnTriggerRegion(AABB(5857.803,-4490.821,156.836,5911.862,-4477.878,308.595), Map.CactusB);
	CactusR = OnTriggerRegion(AABB(5857.803,-4490.821,156.836,5911.862,-4477.878,308.595), Map.CactusR);
	CactusB = OnTriggerRegion(AABB(5728.613,-3118.529,14.839,5736.997,-3094.345,115.201), Map.CactusB);
	CactusR = OnTriggerRegion(AABB(5728.613,-3118.529,14.839,5736.997,-3094.345,115.201), Map.CactusR);
	CactusB = OnTriggerRegion(AABB(2581.865,-3782.139,63.527,2617.784,-3770.275,197.106), Map.CactusB);
	CactusR = OnTriggerRegion(AABB(2581.865,-3782.139,63.527,2617.784,-3770.275,197.106), Map.CactusR);
	CactusB = OnTriggerRegion(AABB(-4114.656,-285.291,49.175,-4096.168,-249.008,185.725), Map.CactusB);
	CactusR = OnTriggerRegion(AABB(-4114.656,-285.291,49.175,-4096.168,-249.008,185.725), Map.CactusR);
	CactusB = OnTriggerRegion(AABB(-2746.073,-459.996,25.968,-2728.579,-440.737,135.246), Map.CactusB);
	CactusR = OnTriggerRegion(AABB(-2746.073,-459.996,25.968,-2728.579,-440.737,135.246), Map.CactusR);

	// Register callback functions
	OnTrigger( "^oThe Side Entrance has been built.", Map.Side_Entrance_Built );
	OnTrigger( "^oThe Tank has been repaired!", Map.Tank_Built );
	OnTrigger( "^oThe first Tank Barrier has been constructed.", Map.first_Tank_Barrier_Built );
	OnTrigger( "^oThe second Tank Barrier has been constructed.", Map.second_Tank_Barrier_Built );
	OnTrigger( "Planted at the Ancient Anti-Gravity Generator.", Map.Ancient_Anti_Gravity_Generator_Planted );
	OnTrigger( "Planted at the Main Gate.", Map.Main_Gate_Planted );
	OnTrigger( "Planted at the Side Entrance.", Map.Side_Entrance_Planted );
	OnTrigger( "Planted at the first Tank Barrier.", Map.first_Tank_Barrier_Planted );
	OnTrigger( "Planted at the second Tank Barrier.", Map.second_Tank_Barrier_Planted );
	OnTrigger( "Defused at the Ancient Anti-Gravity Generator.", Map.Ancient_Anti_Gravity_Generator_Defused );
	OnTrigger( "Defused at the Main Gate.", Map.Main_Gate_Defused );
	OnTrigger( "Defused at the Side Entrance.", Map.Side_Entrance_Defused );
	OnTrigger( "Defused at the first Tank Barrier.", Map.first_Tank_Barrier_Defused );
	OnTrigger( "Defused at the second Tank Barrier.", Map.second_Tank_Barrier_Defused );
	OnTrigger( "^oAncient Anti-Gravity Generator destroyed!", Map.Ancient_Anti_Gravity_Generator_Destroyed );
	OnTrigger( "^oThe Allies have destroyed the Main Gate!", Map.Main_Gate_Destroyed );
	OnTrigger( "^oAllies have breached the Side Entrance!", Map.Side_Entrance_Destroyed );
	OnTrigger( "^oAllies team has destroyed the first Tank Barrier!", Map.first_Tank_Barrier_Destroyed );
	OnTrigger( "^oAllies team has destroyed the second Tank Barrier!", Map.second_Tank_Barrier_Destroyed );
	OnTrigger( "^oThe Allies have stolen the Key!", Map.axis_key_Taken );
	OnTrigger( "^oTank Fuel has been stolen!", Map.tank_fuel_Taken );
	OnTrigger( "^oThe Axis have intercepted the stolen Key.", Map.axis_key_Returned );
	OnTrigger( "^oTank Fuel has been returned.", Map.tank_fuel_Returned );
	OnTrigger( "^oThe Allies have secured the Key to open the door.", Map.axis_key_Secured );
	OnTrigger( "^oAllies have secured Tank Fuel.", Map.tank_fuel_Secured );
	OnTrigger( "^oAxis reclaim the Old City!", Map.oldcityflag_Axis_Captured );
	OnTrigger( "^oAxis reclaim the City!", Map.city2flag_Axis_Captured );
	OnTrigger( "^oAllies capture the Old City!", Map.oldcityflag_Allies_Captured );
	OnTrigger( "^oAllies capture the City!", Map.city2flag_Allies_Captured );
	OnTrigger( "^oAllied team has stolen the Tank!", Map.Tank_stolen );
	OnTrigger( "^oThe Tank has entered the Oasi Tunnel.", Map.Tank_inside );
	OnTrigger( "^oAllies are near the Temple.", Map.Tank_outside );
	OnTrigger( "^oAllied team has destroyed the Temple Door!", Map.Tank_end );
	OnTrigger( "^oAllied team has destroyed the City Gate!", Map.City_gate );
	OnTrigger( "thirty second warning.", Map.thirty_second );

	Util.DisableGoal( ".*", true ); // all but routes
	SetAvailableMapGoals( TEAM.ALLIES, true, {
		"ATTACK_city_.*",
		"CHECKPOINT_oldcityflag",
		"PLANT_Main_Gate",
		"SNIPE_attack_city_.*",
		"MOBILEMG42_city_.*",
		"MOBILEMORTAR_attack_city_.*",
		"SMOKEBOMB_alliescity_.*",
