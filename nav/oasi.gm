	Tank_end = function( trigger )
	{
		SetAvailableMapGoals( TEAM.ALLIES, true, {
			"FLAG_axis_key",
			"CAPPOINT_keylock",
			"PLANT_Side_Entrance",
			"SMOKEBOMB_alliestemple_.*",
			"AMMOCAB_538",
			"SNIPE_attack_temple_04",
			"AMMOCAB_1658",
		});
		SetAvailableMapGoals( TEAM.ALLIES, false, {
			"ESCORT_tank",
			"BUILD_Tank",
			"SMOKEBOMB_alliestemple_03",
			"SWITCH_phone_.*",
			"MOBILEMORTAR_attack_temple_.*",
		});
		SetAvailableMapGoals( TEAM.AXIS, true, {
			"DEFEND_temple_.*",
			"BUILD_Side_Entrance",
			"SNIPE_defend_temple_02",
			"DEFEND_temple_02",
			"DEFEND_temple_03",
			"AMMOCAB_1658",
			"MOBILEMORTAR_defend_templein_.*",
		});
		SetAvailableMapGoals( TEAM.AXIS, false, "MOBILEMORTAR_defend_temple_.*" );

		Util.MapDebugPrint( "Tank_end" );
		sleep(4);
		Util.BotChat(TEAM.AXIS, "vsay", VOICE.DEFEND_OBJECTIVE, 1);
		Util.BotChat(TEAM.ALLIES, "sayteam", "Steal the key and unlock the sacred basin", 1);
	},

