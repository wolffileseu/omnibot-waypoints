	SetGoalPriority( "FLAG_tank_fuel", 0.85, TEAM.ALLIES );
	SetGoalPriority( "FLAG_axis_key", 0.86, TEAM.ALLIES );
	SetGoalPriority( "ESCORT_tank", 0.79, TEAM.ALLIES );
	SetGoalPriority( "PLANT_first_Tank_Barrier", 0.84, TEAM.ALLIES );
	SetGoalPriority( "PLANT_second_Tank_Barrier", 0.83, TEAM.ALLIES );
	SetGoalPriority( "GRENADE_mg42_.*", 0.78, TEAM.ALLIES );

	SetGoalPriority( "ATTACK_city_.*", 0.50, TEAM.ALLIES );
	SetGoalPriority( "ATTACK_garage_.*", 0.51, TEAM.ALLIES );
	SetGoalPriority( "ATTACK_tankout_.*", 0.78, TEAM.ALLIES );
