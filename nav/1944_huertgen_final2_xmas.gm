global MapStep =
{
	START					= 0,
	TANK_STOLEN				= 1,
	TANK_NEAR_BRIDGE		= 2,
	TRUCK_GATE_DESTROYED	= 3,
	TRUCK_AT_BRIDGE			= 4,
	TRUCK_AT_AXIS_BUNKER	= 5,

	currentStep,

	Init = function()
	{
		MapStep.currentStep = MapStep.START;
	},

	IsTankStolen = function()
	{
		return MapStep.currentStep >= MapStep.TANK_STOLEN;
	},

	IsTankNearBridge = function()
	{
		return MapStep.currentStep >= MapStep.TANK_NEAR_BRIDGE;
	},

	IsTruckAtBridge = function()
	{
		return MapStep.currentStep >= MapStep.TRUCK_AT_BRIDGE;
	},

	IsTruckAtAxisBunker = function()
	{
		return MapStep.currentStep >= MapStep.TRUCK_AT_AXIS_BUNKER;
	}
};

global Spawn =
{
	ALLIED_FARM_SPAWN,
	AXIS_BUNKER_SPAWN,		// Unavailable once Ammo Bunker destroyed
	FORWARD_SPAWN_ALLIES,	// Relies on Command Post
	TANK_SPAWN,
	FORWARD_SPAWN_AXIS,		// Relies on Command Post
	AXIS_RESERVE_SPAWN,		// Available once Ammo Bunker destroyed

	// Spawn at any time outside roles
	axisSpawn,
	alliedSpawn,

	// Counter for SuicideNextSpawnAlliedCP
	// If several build/destroy events occurs before next spawn
	ssacp,

	Init = function()
	{
		Spawn.ALLIED_FARM_SPAWN		= 1;
		Spawn.AXIS_BUNKER_SPAWN		= 2;
		Spawn.FORWARD_SPAWN_ALLIES	= 3;
		Spawn.TANK_SPAWN			= 4;
		Spawn.FORWARD_SPAWN_AXIS	= 5;
		Spawn.AXIS_RESERVE_SPAWN	= 6;

		Spawn.alliedSpawn = Spawn.ALLIED_FARM_SPAWN;
		Spawn.axisSpawn   = Spawn.TANK_SPAWN;

		Spawn.ssacp = 0;

		Spawn.PrintSpawns();
	},

	DetermineAndSetSpawns = function()
	{
		Spawn.DetermineSpawns();
		Spawn.SetSpawns();
	},

	/**
	 * => Allies
	 * On start: Farm
	 * CP built by Allies: Whole teams move there excepted the mortar bot (ATTACKER2), unless Tank is stolen, in which case everyone
	 * TANK_STOLEN: Split between Tank and CP (if built)
	 * TANK_NEAR_BRIDGE: CP (if built)
	 * TRUCK_AT_AXIS_BUNKER: Split between CP (if built) and Farm
	 * ---
	 * => Axis
	 * On start: Tank (and Bunker/Reserve depending on DEFENDER1 role and Ammo Room status)
	 * TANK_STOLEN: CP (if built), else Bunker if not destroyed, else Reserve
	 * TRUCK_AT_BRIDGE: Split between CP (if built) and Bunker if not destroyed, else Reserve
	 */
	DetermineSpawns = function()
	{
		if ( !MapStep.IsTankStolen() )
		{
			if ( Map.CPStatus == TEAM.ALLIES )
			{
				Spawn.alliedSpawn = Spawn.FORWARD_SPAWN_ALLIES;
			}
			else
			{
				Spawn.alliedSpawn = Spawn.ALLIED_FARM_SPAWN;
			}

			Spawn.axisSpawn = Spawn.TANK_SPAWN;
		}
		else if ( MapStep.IsTruckAtAxisBunker() )
		{
			Spawn.alliedSpawn = Spawn.GetLastAlliedSpawn();
			Spawn.axisSpawn   = Spawn.GetLastAxisSpawn();
		}
		else if ( MapStep.IsTruckAtBridge() )
		{
			Spawn.alliedSpawn = Spawn.GetIntermediaryAlliedSpawn();
			Spawn.axisSpawn   = Spawn.GetTruckAtBridgeAxisSpawn();
		}
		else if ( MapStep.IsTankNearBridge() )
		{
			Spawn.alliedSpawn = Spawn.GetIntermediaryAlliedSpawn();
			Spawn.axisSpawn   = Spawn.GetIntermediaryAxisSpawn();
		}
		else
		{
			// Equivalent of TANK_STOLEN
			if ( Map.CPStatus == TEAM.ALLIES )
			{
				Spawn.alliedSpawn = { Spawn.TANK_SPAWN, Spawn.FORWARD_SPAWN_ALLIES };
			}
			else
			{
				Spawn.alliedSpawn = Spawn.TANK_SPAWN;
			}

			Spawn.axisSpawn = Spawn.GetIntermediaryAxisSpawn();
		}
	},

	GetIntermediaryAlliedSpawn = function()
	{
		if ( Map.CPStatus == TEAM.ALLIES )
		{
			return Spawn.FORWARD_SPAWN_ALLIES;
		}

		return Spawn.TANK_SPAWN;
	},

	GetIntermediaryAxisSpawn = function()
	{
		if ( Map.CPStatus == TEAM.AXIS )
		{
			return Spawn.FORWARD_SPAWN_AXIS;
		}

		return Spawn.GetLastAxisSpawn();
	},

	GetTruckAtBridgeAxisSpawn = function()
	{
		if ( Map.CPStatus == TEAM.AXIS )
		{
			return { Spawn.FORWARD_SPAWN_AXIS, Spawn.GetLastAxisSpawn() };
		}

		return Spawn.GetLastAxisSpawn();
	},

	GetLastAlliedSpawn = function()
	{
		if ( Map.CPStatus == TEAM.ALLIES )
		{
			return { Spawn.ALLIED_FARM_SPAWN, Spawn.FORWARD_SPAWN_ALLIES };
		}

		return Spawn.ALLIED_FARM_SPAWN;
	},

	GetLastAxisSpawn = function()
	{
		if ( !Map.isAxisAmmoBunkerDestroyed )
		{
			return Spawn.AXIS_BUNKER_SPAWN;
		}

		return Spawn.AXIS_RESERVE_SPAWN;
	},

	SetSpawns = function()
	{
		Spawn.PrintSpawns();
		foreach ( bot in BotTable ) { Spawn.SetBotSpawn( bot ); }
	},

	PrintSpawns = function()
	{
		// Extra-informations
		if ( !Map.isAxisAmmoBunkerDestroyed )
		{
			Util.MapDebugPrint( "Axis Ammo Room ^2intact", true );
		}
		else
		{
			Util.MapDebugPrint( "Axis Ammo Room ^1destroyed", true );
		}

		if ( Map.CPStatus == TEAM.ALLIES )
		{
			Util.MapDebugPrint( "CP is owned by ^$ALLIES", true );
		}
		else if ( Map.CPStatus == TEAM.AXIS )
		{
			Util.MapDebugPrint( "CP is owned by ^)AXIS", true );
		}
		else
		{
			Util.MapDebugPrint( "CP is owned by ^3NOBODY", true );
		}

		// Allies
		Util.MapDebugPrint( "Allies spawn(s): " + Spawn.SpawnToStr( Spawn.alliedSpawn ), true );

		// Axis
		Util.MapDebugPrint( "Axis spawn(s): " + Spawn.SpawnToStr( Spawn.axisSpawn ), true );
	},

	SpawnToStr = function( teamSpawn )
	{
		if ( IsTable( teamSpawn ) )
		{
			return Spawn.GetSpawnLabelFromId( teamSpawn[0] ) + ", " + Spawn.GetSpawnLabelFromId( teamSpawn[1] );
		}

		return Spawn.GetSpawnLabelFromId( teamSpawn );
	},

	GetSpawnLabelFromId = function( spawnId )
	{
		switch ( spawnId )
		{
			case Spawn.ALLIED_FARM_SPAWN:		{ return "Farm"; }
			case Spawn.AXIS_BUNKER_SPAWN:		{ return "Bunker"; }
			case Spawn.FORWARD_SPAWN_ALLIES:	{ return "CP (Allies)"; }
			case Spawn.TANK_SPAWN:				{ return "Tank"; }
			case Spawn.FORWARD_SPAWN_AXIS:		{ return "CP (Axis)"; }
			case Spawn.AXIS_RESERVE_SPAWN:		{ return "Reserve"; }
		}
	},

	SetBotSpawn = function( bot )
	{
		if ( !bot ) { return; }
		if ( bot.GetTeam() == TEAM.AXIS )
		{
			// Special case where Axis DEFENDER1 are too far: Tank not stolen, Ammo Room destroyed, CP owned by Allies
			// In that particular case, these bots should be moved like others, regardless of their role
			if ( bot.HasRole( ROLE.DEFENDER1 ) && !MapStep.IsTankStolen()
				&& ( !Map.isAxisAmmoBunkerDestroyed || Map.CPStatus != TEAM.ALLIES ) )
			{
				// If Allies have built the CP, DEFENDER1 bots have been moved to Tank spawn
				// Move them back to either Bunker or Reserve spawn
				if ( Map.isAxisAmmoBunkerDestroyed ) { s = Spawn.AXIS_RESERVE_SPAWN; } else { s = Spawn.AXIS_BUNKER_SPAWN; }
				bot.ChangeSpawnPoint( s );

				Util.MapDebugPrint( "DEFENDER1 bot keeps its current spawn", true );
				return;
			}

			if ( bot.HasRole( ROLE.DEFENDER1 ) )
			{
				Util.MapDebugPrint( "DEFENDER1 bot is changing spawn for: " + Spawn.SpawnToStr( Spawn.axisSpawn ), true );
			}

			spawn = Spawn.axisSpawn ;
		}
		else if ( bot.GetTeam() == TEAM.ALLIES )
		{
			// Mortar bot remains at Farm before Tank_Stolen
			if ( bot.HasRole( ROLE.ATTACKER2 ) && !MapStep.IsTankStolen() ) { return; }
			spawn = Spawn.alliedSpawn;
		}
		else
		{
			// Spectator
			return;
		}

		if ( !IsTable( spawn ) )
		{
			bot.ChangeSpawnPoint( spawn );
		}
		else
		{
			if ( RandInt( 0, 9 ) < 5 )
			{
				bot.ChangeSpawnPoint( spawn[0] );
			}
			else
			{
				bot.ChangeSpawnPoint( spawn[1] );
			}
		}
	},

	SuicideSpawnAlliedCP = function()
	{
		if ( Spawn.ssacp > 0 ) { return; }

		foreach ( bot in BotTable )
		{
			// We filter team and role now, since these are probably not changing later...
			// Only the ATTACKER2 mortar bot remains at the Farm when this function is called
			if ( bot.GetTeam() != TEAM.ALLIES || bot.HasRole( ROLE.ATTACKER2 ) )
			{
				continue;
			}

			thread( Spawn.SuicideNextSpawnAlliedCP, bot );
		}
	},

	// Copied/adapted from ETUtil.SuicideNextSpawn
	SuicideNextSpawnAlliedCP = function( bot )
	{
		Spawn.ssacp += 1;

		ETUtil.WaitForSpawn( bot.GetTeam() );

		if ( bot.Name && bot.Health > 0 && Map.CPStatus == TEAM.ALLIES && Map.IsBotAtFarm( bot ) )
		{
			bot.ExecCommand( "kill" );
		}

		Spawn.ssacp -= 1;
	}
};

global TankBuildOffset =
{
	BACK	= 0,
	RIGHT	= 1,
	LEFT	= 2
};

