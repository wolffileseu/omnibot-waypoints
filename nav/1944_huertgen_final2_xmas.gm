	{
		Map.isAxisAmmoBunkerDestroyed = true;

		Spawn.DetermineAndSetSpawns();

		Util.MapDebugPrint( "Axis_Ammo_Bunker_Destroyed", true );
	},

	Axis_North_Path_Built = function( trigger )
	{
		Map.isAxisNorthPathDestroyed = false;

		Map.ManageAlliesAmbusherRole();
		Map.SetAllyGrenadeLowAmmoPriority();

		sleep( .1 );
		Wp.CheckBlockable();

		SetAvailableMapGoals( TEAM.ALLIES, false, "ATTACK_North_Path1" ); // Avoid teamkill...

		if ( MapStep.IsTruckAtAxisBunker() )
		{
			SetAvailableMapGoals( TEAM.ALLIES, true, "ATTACK_Wait_For_North_Path.*" );
//			SetAvailableMapGoals( TEAM.ALLIES, false, "ATTACK_Echo.*" );
		}

		Util.MapDebugPrint( "Axis_North_Path_Built", true );
	},

	Axis_North_Path_Destroyed = function( trigger )
	{
		Map.isAxisNorthPathDestroyed = true;

		sleep( .1 );
		Wp.CheckBlockable();

		Map.ManageAlliesAmbusherRole();
		Map.SetAllyGrenadeLowAmmoPriority();

		if ( !Map.isATGDestroyed )
		{
			SetAvailableMapGoals( TEAM.ALLIES, true, "PLANT_Anti_Tank_Gun" );
		}

		if ( !Map.isAxisAmmoBunkerDestroyed )
		{
			SetAvailableMapGoals( TEAM.ALLIES, true, "GRENADE_Axis_Ammo_Room" );
		}

		if ( !MapStep.IsTankStolen() && Map.CPStatus != TEAM.ALLIES || MapStep.IsTruckAtAxisBunker() )
		{
			SetAvailableMapGoals( TEAM.ALLIES, true, {
				"ATTACK_North_Path.*",
				"GRENADE_Axis_North_Path_West1"
			});
		}

		if ( !MapStep.IsTankStolen() && !Map.isATGDestroyed )
		{
			SetAvailableMapGoals( TEAM.ALLIES, true, "ATTACK_ATG_Defence" );
		}

//		if ( MapStep.IsTruckAtAxisBunker() )
//		{
//			SetAvailableMapGoals( TEAM.ALLIES, true, "ATTACK_Echo.*" );
//		}

		SetAvailableMapGoals( TEAM.ALLIES, false, "ATTACK_Wait_For_North_Path.*" );

		Util.MapDebugPrint( "Axis_North_Path_Destroyed", true );
	},

	// -------------------------------------------------------------------------

	AdjustFarmAmmoCabRangeForAxisNorthPathGrenades = function()
	{
		cab = GetGoal( "AMMOCAB_north_ammocabinet" );
		mov = GetGoal( "ATTACK_North_Path2" ); // Better than MOVER_axispath1
		dst = ToInt( Ceil( DistanceBetween( cab, mov ) ) );
		cab.SetRange( dst );

		print( Util.DebugColorString + cab.GetName() + "'s range set to " + dst );

		DrawDebugLine( cab.GetPosition(), mov.GetPosition(), COLOR.CYAN, 20 );
	},

	// Note: executed in a thread
	AmbusherToAttackerUponNextAlliedCPSpawn = function()
	{
		ETUtil.WaitForSpawn( TEAM.ALLIES );
		if ( Map.CPStatus == TEAM.ALLIES && !Map.isAxisNorthPathDestroyed )
		{
			Map.ClearAlliesAmbusherRole( Map.GetAlliesGoalsForAmbusherManagement() );
		}
	},

	// Note: only between TANK_NEAR_BRIDGE and TRUCK_AT_BRIDGE
	// Function name would be too long, so just clarifying it in a note
	DetermineAndSetTankMountAimMode = function()
	{
		if ( !MapStep.IsTankNearBridge() || MapStep.IsTruckAtBridge() ) { return; }

		// Axis
		// Depends on CP and Grate
		if ( Map.CPStatus == TEAM.ALLIES )
		{
			aimMode = TankMountAimMode.CP;
		}
		else if ( Map.isGrateDestroyed )
		{
			aimMode = TankMountAimMode.GRATE;
		}
		else
		{
			aimMode = TankMountAimMode.BRIDGE_EAST_ROAD;
		}

		ETUtil.SetAimModeForMount( "MOUNT_Tank_Axis", aimMode );

		// Allies
		// Depends on CP
		if ( Map.CPStatus == TEAM.AXIS )
		{
			aimMode = TankMountAimMode.CP;
		}
		else
		{
			aimMode = TankMountAimMode.BRIDGE_SOUTH_ENTRANCE;
		}

		ETUtil.SetAimModeForMount( "MOUNT_Tank_Allies", aimMode );
	},

	Init = function()
	{
		if ( Map.initialised ) { return; }

		Map.initialised = true;

		MapStep.Init();
		Spawn.Init();
		TankMountAimMode.Init();

		Map.AXIS_NORTH_PATH_X = GetGoal( "MOVER_axispath1_1" ).GetPosition().x;
		Map.GRENADE_AXIS_NORTH_PATH_GOAL = GetGoal( "GRENADE_Axis_North_Path_East1" );

		Map.PEN                 = Map.GetWpPos( "pen" );
		Map.TANK_SPAWN_EXIT_POS = Map.GetWpPos( "tank_spawn_exit" );
		Map.WALL_TOP_IN         = Map.GetWpPos( "wall_top_in" );
		Map.WALL_TOP_OUT        = Map.GetWpPos( "wall_top_out" );
		Map.WOOD_PILE           = Map.GetWpPos( "wood_pile" );
	},

	GetWpPos = function( name )
	{
		wpTable = {};
		w = Wp.GetWaypointByName( name, wpTable );
		return wpTable.position;
	},

	IsBotAtFarm = function( bot )
	{
		botPos = bot.GetPosition();
		return botPos.x > Map.AXIS_NORTH_PATH_X && botPos.y >= 1800;
	},

	// The goal here is the following
	// ---
	// Before Tank_Stolen, upon Axis_North_Path_Destroyed, some west goals are enabled for Allies, with a role
	// Roles are used to split Footbridge/Tank and West goals, to ultimately reach CP and attack Tank from 2 sides
	// (and have strategic advantage for later)
	// If Axis_North_Path_Built happens, there can be Allies on both sides
	// The goal is to split bots depending on their position (east or west), to avoid them trying to travel to the other side...
	// This is also true when the Truck reaches the Bunker, where Allies spawning is split between CP and Farm, or all spawn at Farm if no CP
	// ---
	// Initially, West bots and goals have ATTACKER goal
	// Upon Axis_North_Path_Built, everything west having ATTACKER gets cleared from ATTACKER and gets AMBUSHER
	// The restriction on role is for ATTACKER1 bots travelling by Axis North Path because Footbridge is/was destroyed, so they're unaffected
	// This is different when the Truck reaches the Bunker
	// ---
	// There's a trigger on Farm spawn to restore the roles, since spawning there means the bot is now on the east side
	// This restoration also happens upon Axis_North_Path_Destroyed ofc
	// Also managed around CP built/destroyed before Tank_Stolen
	ManageAlliesAmbusherRole = function()
	{
		goals = Map.GetAlliesGoalsForAmbusherManagement();

		if ( MapStep.IsTruckAtAxisBunker() )
		{
			// Fall-through
		}
		else if ( MapStep.IsTankStolen() || Map.CPStatus == TEAM.ALLIES )
		{
			Map.ClearAlliesAmbusherRole( goals );
			return;
		}

		if ( Map.isAxisNorthPathDestroyed )
		{
			Map.ClearAlliesAmbusherRole( goals );
		}
		else
		{
			Map.AddAlliesAmbusherRole( goals );
		}
	},

	AddAlliesAmbusherRole = function( goals )
	{
		// Goals
		foreach ( expr in goals )
		{
			mgs = Util.GoalTable( expr );
			foreach ( mg in mgs )
			{
				mg.ClearRoles( ROLE.ATTACKER );
				mg.SetRoles( ROLE.AMBUSHER );
			}
		}

		Util.MapDebugPrint( "Swapped role for goals: ATTACKER -> AMBUSHER", true );

		// Bots
		foreach ( bot in BotTable )
		{
			if ( bot.GetTeam() != TEAM.ALLIES ) { continue; }
			if ( !MapStep.IsTankStolen() && !bot.HasRole( ROLE.ATTACKER ) ) { continue; }

			//Util.MapDebugPrint( "(1) " + bot.Name + Util.DebugColorString + " is going for " + bot.GetHighLevelGoalName() + "/" + bot.GetMapGoalName(), true );

			if ( bot.GetPosition().x < Map.AXIS_NORTH_PATH_X )
			{
				bot.ClearRoles( ROLE.ATTACKER );
				bot.SetRoles( ROLE.AMBUSHER );
				Util.MapDebugPrint( /*"(2) " +*/ "Swapped AMBUSHER role for " + bot.Name, true );
				//Util.MapDebugPrint( format( "%s (%f,%f,%f) %s %s", "(2) Position:", bot.GetPosition().x, bot.GetPosition().y, bot.GetPosition().z, "for", bot.Name ), true );
			}

			/*if ( bot.Health <= 0 )
			{
				Util.MapDebugPrint( "(3) " + bot.Name + Util.DebugColorString + " is down", true );
			}

			Util.MapDebugPrint( "(4) " + bot.Name + Util.DebugColorString + " is going for " + bot.GetHighLevelGoalName() + "/" + bot.GetMapGoalName(), true );*/
		}
	},

	ClearAlliesAmbusherRole = function( goals )
	{
		// Goals
		ClearGoalRole( goals, ROLE.AMBUSHER );
		if ( !MapStep.IsTankStolen() )
		{
			SetGoalRole( goals, ROLE.ATTACKER );
			Util.MapDebugPrint( "Swapped role for goals: AMBUSHER -> ATTACKER", true );
		}
		else
		{
			Util.MapDebugPrint( "Cleared role for goals: AMBUSHER", true );
		}

		// Bots
		foreach ( bot in BotTable )
		{
			if ( bot.GetTeam() != TEAM.ALLIES ) { continue; }
			if ( bot.HasRole( ROLE.AMBUSHER ) )
			{
				bot.ClearRoles( ROLE.AMBUSHER );
				Util.MapDebugPrint( "Cleared AMBUSHER role from " + bot.Name, true );

				if ( !MapStep.IsTankStolen() )
				{
					bot.SetRoles( ROLE.ATTACKER );
					Util.MapDebugPrint( "Affected ATTACKER role to " + bot.Name, true );
				}
			}
		}
	},

	GetAlliesGoalsForAmbusherManagement = function()
	{
		if ( !MapStep.IsTruckAtAxisBunker() )
		{
			goals = Groups.ALLIES_START_WEST_GOALS;
		}
		else
		{
			// No AT-Gun since useless now
			goals =
			{
				"ATTACK_Delta.*",
				"ATTACK_North_Path2", // 1 is off while North Path is intact
				"BUILD_Command_Post",
				"BUILD_Truck",
				"ESCORT_Truck",
				"GRENADE_Axis_Ammo_Room",
				"GRENADE_Axis_North_Path_West1",
				"GRENADE_Tower_MG42",
				"PLANT_Command_Post"
			};
		}

		return goals;
	},

	GetAllyGrenadeLowAmmoPriority = function()
	{
		if ( Map.GRENADE_AXIS_NORTH_PATH_GOAL.IsAvailable( TEAM.ALLIES )
			&& !Map.isAxisNorthPathDestroyed )
		{
			p = 0.83; // Above 0.825 of ATTACK_Wait_For_North_Path
		}
		else
		{
			p = .0;
		}

		//Map.PrintAxisNorthPathInfo( p );

		return p;
	},

	PrintAxisNorthPathInfo = function( p )
	{
		Util.MapDebugPrint( "==========", true );

		if ( Map.isAxisNorthPathDestroyed )
		{
			Util.MapDebugPrint( "Axis North Path is ^1destroyed", true );
		}
		else
		{
			Util.MapDebugPrint( "Axis North Path is ^2intact", true );
		}

		if ( Map.GRENADE_AXIS_NORTH_PATH_GOAL.IsAvailable( TEAM.ALLIES ) )
		{
			Util.MapDebugPrint( "Its nading is ^2on", true );
		}
		else
		{
			Util.MapDebugPrint( "Its nading is ^1off", true );
		}

		Util.MapDebugPrint( "ALLY_GRENADE low ammo priority is " + ToString( p ), true );

		Util.MapDebugPrint( "==========", true );
	},

	// For once, I'll not create several functions with a different name
	// If args are given, set the value
	// If args are not given, loop through the bots and call yourself with args
	SetAllyGrenadeLowAmmoPriority = function( bot, p )
	{
		if ( bot == null )
		{
			p = Map.GetAllyGrenadeLowAmmoPriority();
			foreach ( bot in BotTable )
			{
				Map.SetAllyGrenadeLowAmmoPriority( bot, p );
			}
		}
		else
		{
			wpn = bot.GetWeapon( WEAPON.ALLY_GRENADE );
			if ( wpn )
			{
				wpn.PrimaryFire.LowAmmoPriority = p;
			}
		}
	},

	SuicideAttacker1And2AtFarm = function()
	{
		foreach ( bot in BotTable )
		{
			if ( bot.GetTeam() != TEAM.ALLIES || !Map.IsBotAtFarm( bot ) ) { continue; }
			if ( bot.HasRole( ROLE.ATTACKER1 ) || bot.HasRole( ROLE.ATTACKER2 ) )
			{
				bot.ExecCommand( "kill" );
			}
		}
	},

	// -------------------------------------------------------------------------

	vehicle_at_location = function( trigger )
	{
		switch ( Map.VehicleLocation )
		{
			case 1:
			{
				Map.Truck_at_Bridge( trigger );
			}
			case 2:
			{
				// Truck exits Case 1
			}
			case 3:
			{
				Map.Truck_at_Axis_Bunker( trigger );
			}
		}

//		Util.MapDebugPrint( "vehicle at location " + Map.VehicleLocation, true );
	}
};

global OnMapLoad = function()
{
	// *** TRIGGERS ***
	// The announcements are trimmed to 71 chars, the maximum supported by Omni-Bot
	OnTrigger( "Allied Command Post constructed. Charge speed increased! Allies control", Map.Allied_Command_Post_Built );
	OnTrigger( "Axis team has destroyed the Allied Command Post!", Map.Allied_Command_Post_Destroyed );
	OnTrigger( "Axis Command Post constructed. Charge speed increased!, Axis Control th", Map.Axis_Command_Post_Built ); // Version 2.0
	OnTrigger( "Axis Command Post constructed. Charge speed increased! Axis control the", Map.Axis_Command_Post_Built ); // Version 2.1
	OnTrigger( "Allied team has destroyed the Axis Command Post!", Map.Axis_Command_Post_Destroyed );

	OnTrigger( "The Grate has been constructed.", Map.Grate_Built );
	OnTrigger( "The Grate has been destroyed.", Map.Grate_Destroyed );

	OnTrigger( "The Tank has been repaired!", Map.Tank_Built );
	OnTrigger( "Allied team has stolen the Tank!", Map.Tank_Stolen );
	OnTrigger( "The Tank has been damaged!", Map.Tank_Destroyed );

	OnTrigger( "The Truck has been repaired!", Map.Truck_Built );
	OnTrigger( "The Truck has been damaged!", Map.Truck_Destroyed );

	OnTrigger( "The Allied Footbridge has been constructed.", Map.Allied_Foot_Bridge_Built );
	OnTrigger( "The Allied Footbridge has been destroyed.", Map.Allied_Foot_Bridge_Destroyed );

	OnTrigger( "The Axis MG Tower has been constructed.", Map.Axis_MG_Tower_Built );
	OnTrigger( "The Axis MG Tower has been destroyed.", Map.Axis_MG_Tower_Destroyed );

	OnTrigger( "Allied team has destroyed the Truckyard Gate!", Map.Truck_Gate_Destroyed );
	OnTrigger( "Allies have destroyed the Anti Tank Gun!", Map.Anti_Tank_Gun_Destroyed );
	OnTrigger( "The Axis Ammo Bunker has been destroyed, Axis Bunker Spawn disabled.", Map.Axis_Ammo_Bunker_Destroyed );

	OnTrigger( "The Axis North Path has been blockaded.", Map.Axis_North_Path_Built );
	OnTrigger( "The Allies have cleared the Axis North Path.", Map.Axis_North_Path_Destroyed );

	alliedFarmSpawnAABB = AABB( 2447.125, 2959.125, 17.125, 3440.875, 3696.875, 101.354 );
	OnTriggerRegion( alliedFarmSpawnAABB, Map.allied_farm_spawn );
	OnTriggerRegion( alliedFarmSpawnAABB, Map.allied_farm_spawn_attacker_engi_thompson );

	Map.Init();

	// *** CLEAR ALL GOALS FOR BOTH TEAMS ***
	Util.DisableGoal( ".*", true ); // All but routes

	// There's a map entity grouping clipping brushes,
	// so that it's solid for players and non-solid for spectators
	// It's called MOVER_player_clip_only
	// It encompasses almost the whole map,
	// making Map.VehicleLocation increase by the number of triggers it contains...
	// Thus starting at 3 in our case, breaking the expected behaviour
	// Since Map.VehicleLocation is null OnMapLoad, removing it here and now prevents that issue from happening
	Util.RemoveGoal( "MOVER_player_clip_only" );

	// *** AXIS GOALS ***
	Cabinets.SetAvailable( TEAM.AXIS, Cabinets.VILLAGE );
	SetAvailableMapGoals( TEAM.AXIS, true, {
		"BUILD_Axis_North_Path",
		"BUILD_Command_Post",
		"BUILD_Grate",
		"DEFEND_Alpha.*",
		"DEFEND_Echo[89]",
		"PLANT_Command_Post",
		"PLANT_Allied_Foot_Bridge",
		"PLANTMINE_North_Path.*"
	});

	// *** ALLIED GOALS ***
	Cabinets.SetAvailable( TEAM.ALLIES, Cabinets.ALLIED_FARM );
	SetAvailableMapGoals( TEAM.ALLIES, true, {
		"BUILD_Allied_Foot_Bridge",
		"GRENADE_Axis_North_Path_East.*",
		"MOBILEMORTAR_Farm",
		"SNIPE_Alpha.*"
	});

	// *** ROLES ***
	ClearGoalRole( ".*", ROLE );

	// Special case of the CP
	// ATTACKER affected right after using Groups
	SetGoalRole(
		{ "BUILD_Command_Post", "PLANT_Command_Post" },
		{ ROLE.DEFENDER, ROLE.DEFENDER1 } );

	SetGoalRole( "DEFEND_Alpha.*", ROLE.DEFENDER );
	SetGoalRole({
		"BUILD_Axis_North_Path",
		"DEFEND_Echo[89]",
		"PLANTMINE_North_Path.*"
	}, ROLE.DEFENDER1 );

	SetGoalRole( Groups.ALLIES_START_WEST_GOALS, ROLE.ATTACKER );
	SetGoalRole({
		"ATTACK_Alpha.*",
		"BUILD_Allied_Foot_Bridge",
		"BUILD_Tank",
		"ESCORT_Tank",
		"MOUNT_Tank_Allies",
		"SNIPE_Alpha.*"
	}, ROLE.ATTACKER1 );
	SetGoalRole( "DEFUSE_Allied_Foot_Bridge.*", ROLE.ATTACKER1, true ); // Avoid ATTACKER Engis travelling to defuse it...
	SetGoalRole( "MOBILEMORTAR_Farm", ROLE.ATTACKER2 );

	// Special case of GRENADE_Axis_North_Path_East
	SetGoalRole( "GRENADE_Axis_North_Path_East.*", { ROLE.ATTACKER, ROLE.ATTACKER1, ROLE.ATTACKER2 } );

	// *** GOALS PROPERTIES ***
	SetGoalPriority( "ATTACK_North_Path.*", 0.51 ); // Above CAMP_Command_Post
	SetGoalPriority( "ATTACK_Wait_For_North_Path.*", 0.825 ); // Between ESCORT (0.79) and GRENADE (0.80), role boost taken into account
	SetGoalPriority( "BUILD_Command_Post", 0.81 ); // So that it's 0.91 with Role boost (above BUILD_Tank)
	SetGoalPriority( "BUILD_Axis_North_Path", 0.85 ); // So that it's below DEFUSE with Role boost (AT-Gun)
	SetGoalPriority( "BUILD_Tank", 0.80 ); // So that it's default 0.90 with Role boost
	SetGoalPriority( "GRENADE_Axis_North_Path.*", 0.92, TEAM.ALLIES, CLASS.ENGINEER ); // Above BUILD_Command_Post with role boost
	SetGoalPriority( "GRENADE_Axis_North_Path.*", 0.82, TEAM.ALLIES, CLASS.COVERTOPS ); // Above PLANT_Command_Post
	SetGoalPriority( "PLANT_Command_Post", 0.71 ); // So that it's default 0.81 with Role boost...
	SetGoalPriority( "PLANT_Command_Post", 0.81, TEAM.ALLIES ); // ... excepted for Allies, so it's 0.91, just like the related BUILD goal
	SetGoalPriority( "PLANTMINE_North_Path.*", 0.82 ); // So that it's above BUILD_Command_Post with Role boost

	Util.AddUsePoint( "BUILD_Grate", { // Avoid Engis building themselves in...
		Vec3( -1430, -3375, 85 ), // West side
		Vec3( -1520, -3370, 90 )  // East side
	});
	Util.AddUsePoint( "PLANT_Grate", {
		Vec3( -1375, -3300, 110 ), // West side
		Vec3( -1500, -3365,  90 )  // East side
	});
	Util.AddUsePoint( "REPAIRMG42_Axis_MG_Tower", Vec3( -1230, 455, 315 ) ); // Else timeout

	villageMG42Pos = Vec3( -1520, -2620, 220 );
	Util.AddUsePoint( "MOUNTMG42_Village_MG42" , villageMG42Pos ); // Else unreachable
	Util.AddUsePoint( "REPAIRMG42_Village_MG42", villageMG42Pos ); // Else timeout

	Util.ExcludeClass( "MOUNT.*", 0, CLASS.MEDIC, CLASS.ENGINEER );

	Util.SetGoalOffset( 0, 20, 0, "AMMOCAB_north_ammocabinet" ); // Avoid bots trying to step on it

	// Distance between ATTACK_Wait_For_North_Path8 and BUILD_Allied_Foot_Bridge is 1195
	// Distance between ATTACK_Wait_For_North_Path8 and ATTACK_North_Path2 is 1295
	// We roughly would like something inbetween as range for ATTACK_Wait_For_North_Path
	Util.SetGoalRange( "ATTACK_Wait_For_North_Path.*", 1250 );

	Util.SetGoalRange( "GRENADE_Axis_North_Path.*", 2000 );

	Util.SetGoalPosition( -1472, -3350,  72, "BUILD_Grate" );
	Util.SetGoalPosition(  -955,   310, 145, "PLANT_Axis_MG_Tower" );
	Util.SetGoalPosition(  3700,   700,   0, "PLANT_Allied_Foot_Bridge" );
	Util.SetGoalPosition( -3960, -1940, -10, "PLANT_Command_Post" );
	Util.SetGoalPosition( -2430,  1555, 520, "PLANT_Anti_Tank_Gun" );

	ETUtil.SetAimModeForMount( "MOUNT_Tank_Axis", "velocity" );
	ETUtil.SetAimModeForMount( "MOUNT_Tank_Allies", "velocity" );
	ETUtil.SetExcludeIndexes( "BUILD_Tank", { TankBuildOffset.LEFT } );

	// *** VEHICLE TRIGGERS ***
	OnTrigger( "tank at location", Map.vehicle_at_location );
	OnTrigger( "truck at location", Map.vehicle_at_location );

	OnTriggerRegion( AABB( -1664.875, -1051.546, 105.125, -1407.125, -884.309, 179.125 ), RegionTrigger.VehicleTrigger );
	OnTriggerRegion( AABB( -1656.225,   400.432, 105.125, -1409.084,  663.498, 179.125 ), RegionTrigger.VehicleTrigger );

	Util.OnTriggerPosition( "MOVER_tank",                 "region1", 200.0, Map.Tank_Past_First_House );
	Util.OnTriggerPosition( "MOVER_tank", Vec3( -1280, -1790, 128 ), 200.0, Map.Tank_Near_Bridge );

	Util.FixMoverPos( "truck", Vec3( -2889.000, -4430.500, 164.500 ), Vec3( -2888.000, -4576.000, 108.000 ) );

	Map.AdjustFarmAmmoCabRangeForAxisNorthPathGrenades();

	Util.MapDebugPrint( "Omni-bot 0.9x map script for 1944 Huertgen Forest Final 2.x XMas by Mateos" );
};

global OnBotJoin = function( bot )
{
	Map.Init();
	Spawn.SetBotSpawn( bot );

	// Make bots stop shooting the Movers-like targets
	bot.IgnoreTarget( Map.Movers, 9999 );

	// Mainly for targeting the Axis North Path (ammo cabinet at the Allied Farm)
	Map.SetAllyGrenadeLowAmmoPriority( bot, Map.GetAllyGrenadeLowAmmoPriority() );
};

