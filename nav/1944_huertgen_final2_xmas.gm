{
	ALLIED_FARM	= { "AMMOCAB_north_ammocabinet", "HEALTHCAB_north_healthcabinet" },
	VILLAGE		= { "AMMOCAB_south_ammocabinet", "HEALTHCAB_south_healthcabinet" },

	SetAvailable = function( team, goalTable )
	{
		SetAvailableMapGoals( team, true, goalTable );
	}
};

