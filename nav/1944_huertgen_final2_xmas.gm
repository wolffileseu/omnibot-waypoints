		TankMountAimMode.CP                    = Vec3( -3335, -2560,  40 );
		TankMountAimMode.GRATE                 = Vec3( -2115, -3400, 100 );
	}
};

global TruckBuildOffset =
{
	BACK	= 0,
	RIGHT	= 1,
	LEFT	= 2
};

global Map =
{
	Debug = 0,		// Please set to zero before distributing your script

	// -------------------------------------------------------------------------

	AXIS_NORTH_PATH_X,
	GRENADE_AXIS_NORTH_PATH_GOAL,
	PEN,
	TANK_SPAWN_EXIT_POS,
	WALL_TOP_IN,
	WALL_TOP_OUT,
	WOOD_PILE,

	initialised,

	CPStatus = 0,	// Owned by none
	isATGDestroyed = false,
	isAxisAmmoBunkerDestroyed = false,
	isAxisNorthPathDestroyed = false,
	isGrateDestroyed = false,

	// -------------------------------------------------------------------------

	ShowMovers = true,
	Movers =
	{
		"MOVER_aagun_1_clip",
		"MOVER_allied_footbridge_debri",
		"MOVER_axis_ammo_room",
		"MOVER_axis_ammo_room_1",
		"MOVER_axis_bunker_wall",
		"MOVER_axispath1",
		"MOVER_axispath1_1",
		"MOVER_axispath1_2",
		"MOVER_bridge_bldg_door",
		"MOVER_neutral_compost_clip",
		"MOVER_neutral_compost_closed_clip",
		"MOVER_north_healthcabinet_clip",
		"MOVER_south_ammocabinet_clip",
		"MOVER_south_ammocabinet_clip_1",
		"MOVER_south_healthcabinet_clip",
		"MOVER_tankbay_commandpost_wires",
		"MOVER_tower",
		"MOVER_tower_base",
		"MOVER_truck_supplies",
		"MOVER_truckwall",
		"MOVER_truckwall_1",
		"MOVER_truckwall_2",
		"MOVER_truckwall_3"
	},

	// -------------------------------------------------------------------------

	Roles =
	{
		AXIS =
		{
			AllBots = true,		// Each bot is considered for a role

			// Protect the Tank
			DEFENDER =
			{
				AllBots = true,
				numbots			= 2, // Same as DEFENDER1
				voice			= "defend"
			},

			// Cover the North Path + Anticipate CP
			DEFENDER1 =
			{
				crucialClass	= { CLASS.ENGINEER, CLASS.COVERTOPS }, // First bots
				numbots			= 2,		// Maximum of 2 bots
				spawnpt			= 2,		// Users of this role will choose spawnpt 2 (Bunker Spawn)
				voice			= "defend"	// Signals voice chat to randomly announce
			}
		},

		ALLIES =
		{
			AllBots = true,	// Make (almost) sure we have at least one Covi on ATTACKER

			// Make 1 Engi blow the Axis North Path, destroy the AT-Gun then Build CP
			// Also a Covi to destroy the CP if Axis-built
			// And an extra bot for covering purposes
			ATTACKER =
			{
				crucialClass	= { CLASS.ENGINEER, CLASS.COVERTOPS },
				numbots			= 3,
				voice			= "attack"
			},

			// Make 1 Engi build the Foot Bridge
			ATTACKER1 =
			{
				AllBots = true,
				crucialClass	= CLASS.ENGINEER,
				numbots			= 2, // No more than ATTACKER one
				voice			= "attack"
			},

			// Mortar by the Farm
			ATTACKER2 =
			{
				crucialClass	= CLASS.SOLDIER,
				numbots			= 1,
				voice			= "attack"
			}
		}
	},

	// -------------------------------------------------------------------------

	allied_farm_spawn =
	{
		Name = "allied_farm_spawn",
		TriggerOnClass = CLASS.ANYPLAYER,
		OnEnter = function( ent )
		{
			bot = Util.IsBot( ent );

			/*if ( bot && MapStep.IsTruckAtAxisBunker() && !Map.isAxisNorthPathDestroyed )
			{
				Map.PrintDistanceFromGrenadeAndAttackNodes( bot );
			}*/

			if ( !bot || bot.GetTeam() != TEAM.ALLIES || !bot.HasRole( ROLE.AMBUSHER ) ) { return; }

			// Clear the AMBUSHER role in all cases...
			bot.ClearRoles( ROLE.AMBUSHER );

			//Util.MapDebugPrint( "Cleared AMBUSHER role for " + bot.Name, true );

			if ( MapStep.IsTankStolen() ) { return; }

			// ... but only swap in favor of ATTACKER during the 1st phase
			bot.SetRoles( ROLE.ATTACKER );

			Util.MapDebugPrint( /*"(5) " +*/ "Swapped ATTACKER role for " + bot.Name, true );
		}
	},

	// ATTACK_Wait_For_North_Path   1250
	// GRENADE_Axis_North_Path_East 2000
	// Values between 1077 and 2120
	PrintDistanceFromGrenadeAndAttackNodes = function( bot )
	{
		if ( Map.t == null )
		{
			Map.t = Util.GoalTable( "ATTACK_Wait_For_North_Path.*" );
			Map.t = Util.AddTable( Map.t, Util.GoalTable( "GRENADE_Axis_North_Path_East.*" ) );
		}

		foreach ( mg in Map.t )
		{
			Util.MapDebugPrint(
				bot.Name + Util.DebugColorString + " <=> " + mg.GetName() + " = " + ToString( DistanceBetween( bot.GetGameEntity(), mg ) ),
				true );
		}
	},

	// Note: A second table because removed upon Tank_Stolen
	allied_farm_spawn_attacker_engi_thompson =
	{
		Name = "allied_farm_spawn_attacker_engi_thompson",
		TriggerOnClass = CLASS.ENGINEER,
		OnEnter = function( ent )
		{
			bot = Util.IsBot( ent );
			if ( !bot || bot.GetTeam() != TEAM.ALLIES || !bot.HasRole( ROLE.ATTACKER ) ) { return; }

			// Commented-out because OB can choose at some point to change weapon,
			// causing affected bot(s) to be caught in a selfkill loop
			// The trigger table remains here just in case...
			/*if ( bot.HasWeapon( WEAPON.CARBINE ) )
			{
				bot.ChangePrimaryWeapon( WEAPON.THOMPSON );
				Util.MapDebugPrint( bot.Name + Util.DebugColorString + " switched weapon for Thompson", true );
			}*/
		}
	},

	Navigation =
	{
		// /bot waypoint_setproperty paththrough Navigation_PT:exit_pen
		exit_pen =
		{
			navigate = function( _this )
			{
				Map.JumpOverWallNav( _this, Map.PEN, Map.WALL_TOP_OUT );
			}
		},

		// /bot waypoint_setproperty paththrough Navigation_PT:jump_over_distant_high_wall
		jump_over_distant_high_wall =
		{
			navigate = function( _this )
			{
				Map.JumpOverWallNav( _this, Map.WOOD_PILE, Map.WALL_TOP_IN );
			}
		},

		// Avoid spawn exit bottleneck
		// Only care about bots...
		// Class/weapon not taken into account (aka heavy weaps slowing down first movements)
		// ---
		// With the radius of the waypoint, managedBotList and the sleep in OnExit are 'required',
		// because the path through is triggered at least twice per bot told to not move...
		// /bot waypoint_setproperty paththrough Navigation_PT:tank_spawn
		tank_spawn =
		{
			mutex = false,
			botList = {},
			managedBotNameList = {}, // Avoids several navigate triggering on the same bot
			//t = Timer(),
			navigate = function()
			{
				//Util.MapDebugPrint( this.Bot.Name + Util.DebugColorString + " entered the tank_spawn path through", true );

				bot = this.Bot;
				if ( !bot ) { return; }

				// OnExit being triggered as soon as navigate is over, bot would immediately re-enter the path through
				// Bot already managed, let it go!
				if ( Map.Navigation.tank_spawn.managedBotNameList[ bot.Name ] == 1 ) { return; }

				//Util.MapDebugPrint( this.Bot.Name + Util.DebugColorString + " is considered for the tank_spawn path through", true );

				Map.Navigation.tank_spawn.botList[ bot ] = 1;

				// Immediately capture current bot position
				// So it's only queried once
				botPos = bot.GetPosition();

				// Little sleep to let all spawning bots be listed
				sleep( .1 );

				// We want both the mutex to be available AND the current bot to be the closest one
				while ( Map.Navigation.tank_spawn.mutex || !Map.IsClosestBot( bot ) )
				{
					// Don't move until it's your turn to enter the mutex
					this.Goto( botPos );
					//Map.PrintBotPos( bot, botPos );
					yield();
				}

				Map.Navigation.tank_spawn.mutex = true;

				// Let the chosen bot exit the path through without being reconsidered until outside
				// Keep it still in the list for closest bot, else the next one will exit the loop above
				if ( bot ) { Map.Navigation.tank_spawn.managedBotNameList[ bot.Name ] = 1; }

				/*Util.MapDebugPrint(
					ToString( "(" + Map.Navigation.tank_spawn.t.GetElapsedTime() ) + ") Exiting mutex as it is " + bot.Name + Util.DebugColorString + "'s turn",
					true );*/

				// Let the bot move a bit towards the exit before allowing the next one to be selected
				sleep( .50 );

				// Allow the next one to be selected
				if ( bot ) { Map.Navigation.tank_spawn.botList[ bot ] = null; }
			},
			OnExit = function() // OnExit is called after navigate finished or the bot has been killed/disconnected
			{
				//Util.MapDebugPrint( this.Bot.Name + Util.DebugColorString + " OnExit tank_spawn path through", true );

				Map.Navigation.tank_spawn.mutex = false;

				// Reconsider the bot the next time it spawns...
				// ... but allow it to exit the waypoint radius 1st
				// Basic sleep and not a distance check
				botName = this.Bot.Name;
				sleep( 1.5 ); // sleep after the name retrieval to handle the disconnection case (this.Bot is null after yielding)
				Map.Navigation.tank_spawn.managedBotNameList[ botName ] = null;
			}
		}
	},

	JumpOverWallNav = function( _this, startPos, wallPos )
	{
		if ( _this.Goto( startPos ) == EVENT.PATH_SUCCESS )
		{
			_this.AddAimRequest( Priority.High, "position", wallPos );
			sleep( .5 );

			// Start to move a bit forward
			_this.Bot.HoldButton( BTN.FORWARD, .1 );
			sleep( .1 );

			// Do the actual jump
			_this.Bot.HoldButton( BTN.SPRINT, 1 );
			_this.Bot.HoldButton( BTN.FORWARD, 1 );
			_this.Bot.HoldButton( BTN.JUMP, 1 );

			// Release aim request
			sleep( .75 );
			_this.ReleaseAimRequest();
		}
	},

	IsClosestBot = function( bot )
	{
		return bot && bot.Health > 0 && bot.Name == Map.DetermineClosestBot( Map.Navigation.tank_spawn.botList ).Name;
	},

	DetermineClosestBot = function( list )
	{
		closestBot;
		dist = 500;

		foreach ( bot and val in list )
		{
			if ( !bot || bot.Health <= 0 ) { val = 0; continue; } // Disconnected or dead meanwhile
			if ( val != 1 ) { continue; }

			currentDist = DistanceBetween( bot.GetPosition(), Map.TANK_SPAWN_EXIT_POS );
			if ( currentDist < dist )
			{
				closestBot = bot;
				dist = currentDist;
			}
		}

		//Util.MapDebugPrint( "Closest bot: " + closestBot.Name + " (" + ToString( dist ) + ")", true );

		return closestBot;
	},

	PrintBotPos = function( bot, targetPos )
	{
		//Util.MapDebugPrint( bot.Name + Util.DebugColorString + "'s position -> " + ToString( bot.GetPosition() ), true );
		Util.MapDebugPrint( bot.Name + Util.DebugColorString + "'s distance to its target position -> " + ToString( DistanceBetween( bot.GetPosition(), targetPos ) ), true );
	},

	// -------------------------------------------------------------------------

	Allied_Command_Post_Built = function( trigger )
	{
		Map.CPStatus = TEAM.ALLIES;

		Spawn.DetermineAndSetSpawns();

		if ( !MapStep.IsTankStolen() )
		{
			// Not calling Map.ManageAlliesAmbusherRole() here
			Spawn.SuicideSpawnAlliedCP();
			thread( Map.AmbusherToAttackerUponNextAlliedCPSpawn );

			// Go for CP
			SetAvailableMapGoals( TEAM.AXIS, false, {
				"BUILD_Axis_North_Path",
				"DEFEND_Echo[89]",
				"PLANTMINE_North_Path.*"
			});

			SetAvailableMapGoals( TEAM.ALLIES, true, {
				"BUILD_Tank",
				"ESCORT_Tank",
				"GRENADE_Village_MG42",
				"MOUNT_Tank_Allies",
				"PLANT_Grate"
			});
			SetAvailableMapGoals( TEAM.ALLIES, false, {
				"ATTACK_North_Path.*",
				"BUILD_Allied_Foot_Bridge",
				"GRENADE_Axis_North_Path_West1"
			});

			// Add BUILD_Tank to ATTACKER, so Engis with that role also go for it
			// Revise BUILD_Tank priority so that PLANT_Grate is considered
			// Note: Restored upon Tank_Stolen
			SetGoalPriority( "PLANT_Grate", 0.80 ); // Since BUILD_Tank is 0.80 + 0.10, same here
			SetGoalRole( "BUILD_Tank", ROLE.ATTACKER );
		}
		else
		{
			SetAvailableMapGoals( TEAM.AXIS, false, "BUILD_Grate" );
		}

		Map.DetermineAndSetTankMountAimMode();

		Util.MapDebugPrint( "Allied_Command_Post_Built", true );
	},

	Allied_Command_Post_Destroyed = function( trigger )
	{
		Map.CPStatus = 0;

		Spawn.DetermineAndSetSpawns();

		if ( !MapStep.IsTankStolen() )
		{
			Map.ManageAlliesAmbusherRole();

			SetAvailableMapGoals( TEAM.AXIS, true, {
				"BUILD_Axis_North_Path",
				"DEFEND_Echo[89]",
				"PLANTMINE_North_Path.*"
			});
			SetAvailableMapGoals( TEAM.ALLIES, Map.isAxisNorthPathDestroyed, "ATTACK_North_Path1" );
			SetAvailableMapGoals( TEAM.ALLIES, true, {
				"ATTACK_North_Path2",
				"BUILD_Allied_Foot_Bridge",
				"GRENADE_Axis_North_Path_West1"
			});

			// Mirrored from Allied_Command_Post_Built
			ClearGoalRole( "BUILD_Tank", ROLE.ATTACKER );
		}

		if ( !MapStep.IsTruckAtBridge() )
		{
			SetAvailableMapGoals( TEAM.AXIS, true, "BUILD_Grate" );
		}

		Map.DetermineAndSetTankMountAimMode();

		Util.MapDebugPrint( "Allied_Command_Post_Destroyed", true );
	},

