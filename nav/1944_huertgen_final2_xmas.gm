	Tank_Stolen = function( trigger )
	{
		MapStep.currentStep += 1;

		Map.SuicideAttacker1And2AtFarm();

		DeleteTriggerRegion( "allied_farm_spawn_attacker_engi_thompson" );

		Spawn.DetermineAndSetSpawns();

		Map.ManageAlliesAmbusherRole();

		// Focus on Tank, no more need for roles
		ClearGoalRole( ".*", ROLE );

		// And thus, restore some priorities
		SetGoalPriority( "BUILD_Command_Post", 0.90 );
		SetGoalPriority( "BUILD_Tank", 0.90 );
		SetGoalPriority( "PLANT_Command_Post", 0.81 );
		SetGoalPriority( "PLANT_Grate", 0.81 );

		if ( Map.CPStatus == TEAM.ALLIES )
		{
			SetAvailableMapGoals( TEAM.AXIS, false, "BUILD_Grate" );
		}

		SetAvailableMapGoals( TEAM.AXIS, true, "DEFEND_Bravo.*" );
		SetAvailableMapGoals( TEAM.AXIS, false, {
			"BUILD_Axis_North_Path",
			"DEFEND_Alpha.*",
			"DEFEND_Echo[89]",
			"PLANT_Allied_Foot_Bridge",
			"PLANTMINE_North_Path.*"
		});

		SetAvailableMapGoals( TEAM.ALLIES, true, {
			"ATTACK_Bravo.*",
			"BUILD_Command_Post",
			"PLANT_Command_Post",
			"PLANT_Grate"
		});
		SetAvailableMapGoals( TEAM.ALLIES, false, {
			"ATTACK_Alpha.*",
			"ATTACK_North_Path.*",
			"BUILD_Allied_Foot_Bridge",
			"GRENADE_Axis_North_Path.*",
			"MOBILEMORTAR_Farm",
			"SNIPE_Alpha.*"
		});

		ETUtil.SetAimModeForMount( "MOUNT_Tank_Axis", "opposite" );

		Map.SetAllyGrenadeLowAmmoPriority();

		Util.MapDebugPrint( "Tank_Stolen" );
	},

	Tank_Past_First_House = function( trigger )
	{
		SetAvailableMapGoals( TEAM.AXIS, true, "DEFEND_Charlie[2-9]" );
		SetAvailableMapGoals( TEAM.AXIS, false, "DEFEND_Bravo.*" );

		ETUtil.SetExcludeIndexes( "BUILD_Tank", { TankBuildOffset.LEFT, TankBuildOffset.RIGHT } );

		Util.MapDebugPrint( "Tank_Past_First_House" );
	},

	Tank_Near_Bridge = function( trigger )
	{
		MapStep.currentStep += 1;

		Spawn.DetermineAndSetSpawns();

		SetAvailableMapGoals( TEAM.AXIS, true, {
			"BUILD_Axis_MG_Tower",
			"DEFEND_Delta.*",
			"MOUNTMG42_Village_MG42", // Note: special nav on vanilla to exit it (stuck in solid)
			"REPAIRMG42_Village_MG42"
		});
		SetAvailableMapGoals( TEAM.AXIS, false, "DEFEND_Charlie.*" );

		SetAvailableMapGoals( TEAM.ALLIES, true, {
			"GRENADE_Village_MG42",
			"PLANT_Grate",
			//"PLANT_Axis_MG_Tower" // Prefer nading it over planting dynamite
		});

		SetGoalPriority( "PLANT_Grate", 0.9 ); // Same as BUILD

		Map.DetermineAndSetTankMountAimMode();
		ETUtil.SetExcludeIndexes( "BUILD_Tank", { TankBuildOffset.BACK, TankBuildOffset.RIGHT } );

		Util.MapDebugPrint( "Tank_Near_Bridge" );
	},

	Truck_Gate_Destroyed = function( trigger )
	{
		MapStep.currentStep += 1;

		sleep( .4 );
		Wp.CheckBlockable();

		SetAvailableMapGoals( TEAM.AXIS, true, {
			"MOUNTMG42_Axis_MG_Tower",
			"REPAIRMG42_Axis_MG_Tower"
		});

		SetAvailableMapGoals( TEAM.ALLIES, true, {
			"ATTACK_Charlie.*",
			"BUILD_Truck",
			"ESCORT_Truck",
			"GRENADE_Tower_MG42"
		});
		SetAvailableMapGoals( TEAM.ALLIES, false, {
			"ATTACK_Bravo[123]",
			"BUILD_Tank",
			"ESCORT_Tank"
		});

		ETUtil.SetExcludeIndexes( "BUILD_Truck", { TruckBuildOffset.LEFT } );

		Util.MapDebugPrint( "Truck_Gate_Destroyed" );
	},

	Truck_at_Bridge = function( trigger )
	{
		MapStep.currentStep += 1;

		Spawn.DetermineAndSetSpawns();

		Util.DisableGoal( "MOUNT_Tank.*" );

		SetAvailableMapGoals( TEAM.AXIS, true, {
			"BUILD_Axis_North_Path",
			"DEFEND_Echo.*",
			"PLANTMINE_North_Path.*"
		});
		SetAvailableMapGoals( TEAM.AXIS, false, {
			"BUILD_Command_Post",
			"BUILD_Grate",
			"DEFEND_Delta.*",
			"PLANT_Command_Post"
		});

		SetAvailableMapGoals( TEAM.ALLIES, true, "ATTACK_Delta.*" );
		SetAvailableMapGoals( TEAM.ALLIES, false, {
			"ATTACK_Bravo4",
			"ATTACK_Charlie.*",
			"CAMP_Command_Post.*",
			"PLANT_Grate"
		});

		Util.MapDebugPrint( "Truck_at_Bridge" );
	},

	// Move or split Allies at Farm, re-enable North Path related goals (Bridge is suicide)
	Truck_at_Axis_Bunker = function( trigger )
	{
		MapStep.currentStep += 1;

		Spawn.DetermineAndSetSpawns();

		Map.ManageAlliesAmbusherRole();

		SetAvailableMapGoals( TEAM.AXIS, false, {
			"MOUNTMG42_Village_MG42",
			"REPAIRMG42_Village_MG42"
		});
		SetAvailableMapGoals( TEAM.ALLIES, false, "GRENADE_Village_MG42" );

		// Restore North Path nading
		SetGoalPriority( "ATTACK_North_Path.*", 0.51, TEAM.ALLIES ); // Above other ATTACK goals
		SetGoalPriority( "GRENADE_Axis_North_Path.*", 0.85, TEAM.ALLIES ); // Don't go beyond 1.0 with AMBUSHER boost
		SetGoalPriority( "GRENADE_Axis_North_Path.*", 0.95, TEAM.ALLIES, CLASS.ENGINEER ); // Above Engi goals
		SetAvailableMapGoals( TEAM.ALLIES, Map.isAxisNorthPathDestroyed, "ATTACK_North_Path1" );
		SetAvailableMapGoals( TEAM.ALLIES, true, {
			"ATTACK_North_Path2",
			"GRENADE_Axis_North_Path.*"
		});

		if ( !Map.isAxisNorthPathDestroyed )
		{
			SetAvailableMapGoals( TEAM.ALLIES, true, "ATTACK_Wait_For_North_Path.*" );
		}

		Map.SetAllyGrenadeLowAmmoPriority();

		Util.MapDebugPrint( "Truck_at_Axis_Bunker" );
	},

