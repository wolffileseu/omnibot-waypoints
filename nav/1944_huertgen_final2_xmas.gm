	Anti_Tank_Gun_Destroyed = function( trigger )
	{
		// Avoid double-call
		if ( Map.isATGDestroyed ) { return; }

		Map.isATGDestroyed = true;

		// Don't defuse extra dynamites
		foreach ( mg in Util.GoalTable( "DEFUSE_Anti_Tank_Gun.*" ) )
		{
			mg.SetAvailable( TEAM.AXIS, false );
		}

		SetAvailableMapGoals( TEAM.ALLIES, true, {
			"BUILD_Command_Post",
			"PLANT_Command_Post"
		});
		SetAvailableMapGoals( TEAM.ALLIES, false, "ATTACK_ATG_Defence" );

		if ( !MapStep.IsTruckAtAxisBunker() )
		{
			SetAvailableMapGoals( TEAM.ALLIES, true, "CAMP_Command_Post.*" );
		}

		Util.MapDebugPrint( "Anti_Tank_Gun_Destroyed", true );
	},

