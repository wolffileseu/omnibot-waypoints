global OnMapLoad = function()
{
	OnTriggerRegion(AABB(917.055,-503.194,405.709,4173.544,597.964,585.356), RegionTrigger.DisableCombatMovement);

	Util.MapDebugPrint( "Omni-bot map script for " + GetMapName() + " executed." );
};

