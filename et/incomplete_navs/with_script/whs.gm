Map.SnipeMap = true;

global OnMapLoad = function()
{
	Util.DisableGoal("AMMO.*");
	SetMapGoalProperties("SNIPE.*", {MinCampTime=300, MaxCamptime=500});
	Util.LimitToTeam(TEAM.AXIS, "SNIPE_x.*");
	Util.LimitToTeam(TEAM.ALLIES, "SNIPE_l.*");
};

global OnBotJoin = function(bot)
{
	bot.TargetBreakableDist = 500;
	Util.ChangeToSniperWeapons(bot);
};
