{
	MapRoutes =
	{
		BUILD_Entry_Door_Construction =
		{
		},
		PLANT_Entry_Door =
		{
		},
		BUILD_Explosive_1 =
		{
		},
		PLANT_Explosive_1 =
		{
		},
		BUILD_Grate__2_Repair =
		{
		},
		PLANT_Grate__2_Repair =
		{
		},
		BUILD_Grate_3__Repair =
		{
		},
		PLANT_Grate_3__Repair =
		{
		},
		BUILD_Grate_4__Repair =
		{
		},
		PLANT_Grate_4__Repair =
		{
		},
		BUILD_Command_Post =
		{
		},
		PLANT_Command_Post =
		{
		},
		CHECKPOINT_topdamflag =
		{
		},
		BUILD_Dam_Explosives_2 =
		{
		},
		PLANT_Dam_Explosives_2 =
		{
		},
		BUILD_Grate_1_Repair =
		{
		},
		PLANT_Grate_1_Repair =
		{
		},
		BUILD_Electric_Fence_Controls =
		{
		},
		PLANT_Electric_Fence_Controls =
		{
		}
	};

	Util.Routes( MapRoutes );
};
