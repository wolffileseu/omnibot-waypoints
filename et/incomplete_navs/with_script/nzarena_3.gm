global Map =
{
	DeathMatch = 1,
};

global OnMapLoad = function()
{
	OnTriggerRegion(AABB(8261.239,-2192.391,9196.636,9966.262,1904.863,12071.890), RegionTrigger.DisableCombatMovement);

	Util.LimitToTeam(TEAM.AXIS, ".*253");
	Util.LimitToTeam(TEAM.ALLIES, ".*254");
	Util.SetMaxUsers(1, ".*");

	Util.MapDebugPrint("Omni-bot map script for " + GetMapName() + " executed.");
};
