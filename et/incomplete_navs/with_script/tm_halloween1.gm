global OnMapLoad = function()
{
	Util.LimitToTeam(TEAM.AXIS, "DEFEND.*");
	Util.LimitToTeam(TEAM.ALLIES, "ATTACK.*");
	SetGoalPriority("PLANT.*", 0.5, 0, CLASS.ENGINEER);
	Util.SetMaxUsersInProgress(5, "CHECKPOINT.*");
	SetMapGoalProperties({"ATTACK.*", "DEFEND.*"}, {MinCampTime=10, MaxCampTime=30});
	Util.AddUsePoint( "CHECKPOINT_mainflag", {Vec3(1120, 378, 64), Vec3(1120, 325, 64)} );
	Util.MapDebugPrint("Omni-bot map script for " + GetMapName() + " executed.");
};

global OnBotJoin = function(bot)
{
	bot.MaxViewDistance = 1900;
};
