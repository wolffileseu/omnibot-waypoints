			{
				ROUTE_parts5 ={},
				ROUTE_parts6 ={},
				ROUTE_entrance2 ={},
			},
			ROUTE_forward_spawn =
			{
				ROUTE_entrance =
				{
					ROUTE_entrance2 =
					{
						ROUTE_parts4 ={},
						ROUTE_parts5 ={},
					},
					ROUTE_cp1 =
					{
						ROUTE_parts5 ={},
						ROUTE_parts6 ={},
					},
					ROUTE_cp2 =
					{
						ROUTE_parts5 ={},
						ROUTE_parts6 ={},
					},
				},
				ROUTE_barrier =
				{
					ROUTE_parts1 ={},
					ROUTE_parts2 ={},
					ROUTE_parts3 ={},
					ROUTE_parts4 ={},
				},
				ROUTE_side_door =
				{
					ROUTE_parts1 ={},
					ROUTE_parts3 ={},
					ROUTE_parts4 ={},
				},
			},
		},
		CAPPOINT_truck =
		{
			ROUTE_parts =
			{
				ROUTE_entrance =
				{
					ROUTE_truck1 ={},
					ROUTE_truck2 ={},
					ROUTE_truck3 ={},
				},
				ROUTE_side_door ={},
				ROUTE_barrier ={},
			},
		},
	};
	Util.Routes(MapRoutes);
};
