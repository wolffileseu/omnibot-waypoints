						{
						},

						ROUTE_OLDCITY =
						{
						},
					},
				},
			},
		},

		PLANT_Old_Bridge =
		{
			ROUTE_AXIS_SPAWN =
			{
				ROUTE_ROEMERBERG =
				{
					Weight = 2,
					// Eastgate Route
					ROUTE_OLDCITY =
