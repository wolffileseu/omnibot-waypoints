	MapRoutes.REPAIRMG42_mg42_roof = MapRoutes.MOUNTMG42_mg42_roof;

	Util.Routes(MapRoutes);

	Util.MapDebugPrint( "Omnibot Script: Executed for map " + GetMapName() );
	print("Omnibot Script for map " + GetMapName() + " loaded. Attaway, baby!");
};



// ===========================================================================
// Initial settings for bots on joining the game
// ===========================================================================
global OnBotJoin = function( bot )
{
	// limit Bot viewing distance to limit Field Ops "battles" at the river
	bot.MaxViewDistance = 1500;

	// limit func_explosive action distance (only break if *really* close)
	bot.TargetBreakableDist = 32;

	Map.SetSpawn1(bot);
};
