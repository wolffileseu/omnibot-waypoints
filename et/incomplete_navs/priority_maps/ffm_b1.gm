						ROUTE_EASTGATE_LEFT =
						{
							ROUTE_OLDBRIDGE_AXIS = {},
						},

						ROUTE_EASTGATE_RIGHT =
						{
							ROUTE_OLDBRIDGE_AXIS = {},
