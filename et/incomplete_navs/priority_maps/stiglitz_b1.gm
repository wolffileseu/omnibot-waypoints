global Map =
{
	Movers = {"MOVER_stiglitz"},
};

global OnMapLoad = function()
{
	Util.AddInvVehicle("MOVER_stiglitz");
	Util.SetMaxUsers(3, "ESCORT_allies");
	Util.SetMaxUsers(2, "ESCORT_axis");
	Util.MapDebugPrint("Omni-bot map script for " + GetMapName() + " executed.");
};
