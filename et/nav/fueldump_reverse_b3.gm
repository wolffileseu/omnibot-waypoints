	Bridge_Built = function( trigger )
	{
		if (Map.TankInTunnelStatus == false or Map.TankPastBridge == true )
		{
			SetAvailableMapGoals( TEAM.AXIS, false, "PLANT_Bridge" );
	                SetAvailableMapGoals( TEAM.ALLIES, false, "BUILD_Bridge" );
                 //Util.BotChat( 0, "say", "^6THERE_IS_NO_BUILDING_OR_PLANTING_BRIDGE", 3 );
			//Util.MapDebugPrint("^6NO_BUILDING_OR_PLANTING_BRIDGE");

		}
		else
		{
	                SetGoalPriority("PLANT_Bridge", 2.0, TEAM.AXIS, CLASS.ENGINEER, true);
			SetAvailableMapGoals( TEAM.AXIS, true, "PLANT_Bridge" );
			SetAvailableMapGoals( TEAM.ALLIES, true, "BUILD_Bridge" );

		}
		       Map.BridgeStatus = 1;
	ClearGoalRole( "PLANTMINE_bridge_.*", ROLE.DEFENDER2 );

	SetAvailableMapGoals( TEAM.AXIS, false, "PLANTMINE_bridge_1" );
	SetAvailableMapGoals( TEAM.AXIS, false, "PLANTMINE_bridge_2" );
	SetAvailableMapGoals( TEAM.AXIS, false, "PLANTMINE_bridge_3" );
	SetAvailableMapGoals( TEAM.AXIS, false, "PLANTMINE_bridge_4" );
	SetAvailableMapGoals( TEAM.AXIS, false, "PLANTMINE_bridge_5" );
	SetAvailableMapGoals( TEAM.AXIS, false, "PLANTMINE_bridge_6" );
