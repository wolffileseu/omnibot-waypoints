	{
        		if ( Map.TankStatus == true )
        {
		        
	    SetAvailableMapGoals( TEAM.ALLIES, true, "ESCORT_Tank" );
            SetAvailableMapGoals( TEAM.ALLIES, true, "MOUNT_Tank" );
                 //Util.BotChat( 0, "say", "^6ESCORT_TANK", 3 );
			//Util.MapDebugPrint("^6ESCORT_TANK");
                   }
                      else if ( Map.TankStatus == false)
                        {
			SetAvailableMapGoals( TEAM.ALLIES, true, "BUILD_Tank" );
                        }
	SetGoalPriority( "ESCORT_Tank", 1.0, TEAM.ALLIES, CLASS.SOLDIER );
		Map.Tunnel_Doors = false;
	SetAvailableMapGoals( TEAM.AXIS, false, "DEFEND_tunneldoors_1" );
