global OnMapLoad = function()
{
	// Register callback functions



	OnTrigger( "^2Allied Command Post constructed. Charge speed increased!", Map.Allied_Command_Post_Built );
	OnTrigger( "^2Axis Command Post constructed. Charge speed increased!", Map.Axis_Command_Post_Built );
	OnTrigger( "^2Allied team has constructed the bridge!", Map.Bridge_Built );
	OnTrigger( "^2Allied team has reinforced the Bridge!", Map.Bridge_Reinforced );
	OnTrigger( "^2Axis team has constructed the East Axis Base Fortification!", Map.East_Axis_Base_Fortification_Built );
	OnTrigger( "^2Allied team has constructed the Foot Bridge!", Map.Foot_Bridge_Built );
	OnTrigger( "^2Axis team has constructed the Road MG Nest!", Map.Road_MG_Built );
	OnTrigger( "^2Allied team has constructed the Side MG Nest!", Map.Side_MG_Built_by_Allied );
	OnTrigger( "^2Axis team has constructed the Side MG Nest!", Map.Side_MG_Built_by_Axis );
	OnTrigger( "^2The Tank has been repaired", Map.Tank_Built );
	OnTrigger( "^2Allied team has stolen the tank", Map.Tank_Stolen );
	OnTrigger( "^2The Tank has been damaged", Map.Tank_Damaged );
	OnTrigger( "^2Allied team has constructed the Tunnel MG!", Map.Tunnel_MG_Built );
	OnTrigger( "^2Allied team has constructed the West Axis Base Fortification!", Map.West_Axis_Base_Fortification_Built );
	OnTrigger( "^2Axis team has destroyed the Allied Command Post!", Map.Allied_Command_Post_Destroyed );
	OnTrigger( "^2Allied team has destroyed the Axis Command Post!", Map.Axis_Command_Post_Destroyed );
	OnTrigger( "^2Axis team has destroyed the Bridge!", Map.Bridge_Destroyed );
	OnTrigger( "^2Axis team has damaged the Bridge!", Map.Bridge_Damaged );
	OnTrigger( "^2Allied team has breached the Depot Gates!", Map.Depotgate_Destroyed );

	OnTrigger( "^2Allied team has breached the Tunnel Doors!", Map.Tunnel_Doors_Destroyed );
    
    //	OnTrigger( "^2Allied team has damaged the East Base Fortification!", Map.EastsideDamaged );


	OnTrigger( "^2Allied team escorted the tank out of the depotgate", Map.tank_out_of_depotgate );

	OnTrigger( "^2the tank is in the tunnel", Map.tank_in_tunnel );

	OnTrigger( "^2Allied team has destroyed the East Axis Base Fortification!", Map.East_Axis_Base_Fortification_Destroyed );
	OnTrigger( "^2Allied team has destroyed the West Axis Base Fortification!", Map.West_Axis_Base_Fortification_Destroyed );
	OnTrigger( "^2Axis team has destroyed the Foot Bridge!", Map.Foot_Bridge_Destroyed );
	OnTrigger( "^2Allied team has destroyed the Road MG Nest!", Map.Road_MG_Destroyed );
	OnTrigger( "^2Axis team has destroyed the Side MG Nest!", Map.Side_MG_Destroyed_by_Axis );
	OnTrigger( "^2Allied team has destroyed the Side MG Nest!", Map.Side_MG_Destroyed_by_Allied );
	OnTrigger( "^2Allied team has destroyed the Tunnel MG!", Map.Tunnel_MG_Destroyed );
	OnTrigger( "^2Allied team destroyed the side entrance", Map.rear_Basewall_Destroyed );


