		left_window = {
			EvalFunc = function(t){
				return !Map.breakable_left_window;
			},
			navigate = function(t){
				Map.DestroyBreakable(t, Vec3(-371.521, 1976.170, 258.125), Vec3(-116.125, 1954.423, 274.715));
			}
		},
