	 Boot2exit =
	{
		Name="Boot2exit",
		TriggerOnClass = { CLASS.VEHICLE_HVY, CLASS.VEHICLE_NODAMAGE, CLASS.VEHICLE },
		OnEnter = function(ent)
		{
			Util.MapDebugPrint(GetEntName(ent) + " at exit");
	        SetAvailableMapGoals( TEAM.ALLIES, false, "RIDE_boot2" );
		},
		OnExit = function(ent)
		{
		 if ( Map.eleva5 == true )
	     {
			sleep(15);
			 SetAvailableMapGoals( TEAM.ALLIES, true, "RIDE_boot2" );
			 }
			Util.MapDebugPrint(GetEntName(ent) + " return at boat");

		},
	},

	 elevator5 =
 {
 	Name="elevator5",
 	TriggerOnClass = { CLASS.VEHICLE_HVY, CLASS.VEHICLE_NODAMAGE, CLASS.VEHICLE },
 	OnEnter = function(ent)
 	 {
	 	Wp.SetWaypointFlag( "eleva5", "closed", false );
