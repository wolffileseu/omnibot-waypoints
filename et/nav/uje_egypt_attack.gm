	    sleep(5);
		SetAvailableMapGoals( TEAM.AXIS, false, "RIDE_elevator8" );

 		Util.MapDebugPrint(GetEntName(ent) + " at the top");
 	},
 },
 vehicle_at_location = function( trigger )
	{
		switch(Map.VehicleLocation)
		{
			case 1:
			{
            Map.tank_at_barrier1();
			}
			case 2:
			{
		    Map.tank_at_corner();
			}
			case 3:
			{
			Map.tank_at_tower();
			}
			case 4:
			{
			Map.tank_at_barrier2();
			}
			case 5:
			{
				Map.truck_at_barrier1();
			}
			case 6:
			{
				Map.truck_at_barrier2();
			}
		}
		Util.MapDebugPrint("vehicle at location " + Map.VehicleLocation, true);
	},
};
global OnMapLoad = function()
{
	// Register callback functions
	OnTrigger( "Allied Command Post constructed. Charge speed increased!", Map.Allied_Command_Post_Built );
	OnTrigger( "Axis Command Post constructed. Charge speed increased!", Map.Axis_Command_Post_Built );
	OnTrigger( "The Tank has been repaired!", Map.Tank_Built );
	OnTrigger( "Tank Barrier #1 has been constructed.", Map.Tank_Barrier_1_Built );
	OnTrigger( "Tank Barrier #2 has been constructed.", Map.Tank_Barrier_2_Built );
	OnTrigger( "The Truck has been repaired!", Map.Truck_Built );
	OnTrigger( "Truck Barrier #1 has been constructed.", Map.Truck_Barrier_1_Built );
	OnTrigger( "Truck Barrier #2 has been constructed.", Map.Truck_Barrier_2_Built );
	OnTrigger( "Allied team has destroyed the Axis Command Post!", Map.Allied_Command_Post_Destroyed );
	OnTrigger( "Axis team has destroyed the Allied Command Post!", Map.Axis_Command_Post_Destroyed );
	OnTrigger( "The Tank has been damaged!", Map.Tank_Destroyed );
	OnTrigger( "Tank Barrier #1 has been destroyed.", Map.Tank_Barrier_1_Destroyed );
	OnTrigger( "Tank Barrier #2 has been destroyed.", Map.Tank_Barrier_2_Destroyed );
	OnTrigger( "The Truck has been damaged!", Map.Truck_Destroyed );
	OnTrigger( "Truck Barrier #1 has been destroyed.", Map.Truck_Barrier_1_Destroyed );
	OnTrigger( "Truck Barrier #2 has been destroyed.", Map.Truck_Barrier_2_Destroyed );
	OnTrigger( "Allied team has stolen the first Gold Crate!", Map.gold1_crate_Taken );
	OnTrigger( "Allied team has stolen the second Gold Crate!", Map.gold2_crate_Taken );
	OnTrigger( "Allied team has returned the first Gold Crate!", Map.gold1_crate_Returned );
	OnTrigger( "Allied team has returned the second Gold Crate!", Map.gold2_crate_Returned );
	OnTrigger( "Allied team has secured the first Gold Crate!", Map.Gold_Dropoff1_Captured );
	OnTrigger( "Allied team has secured the second Gold Crate!", Map.Gold_Dropoff2_Captured );
	OnTrigger( "Allied team has stolen the Tank!", Map.allies_steal_tank );
	OnTrigger( "Allied team is escaping with the Gold Crates!", Map.allies_taking_gold );
	OnTrigger( "goldrush_allies_tank_barrier1", Map.tank_past_barrier1 );
	OnTrigger( "goldrush_allies_tank_barrier2", Map.tank_past_barrier2 );
	OnTrigger( "goldrush_allies_truck_barrier1", Map.truck_past_barrier1 );
	OnTrigger( "goldrush_allies_truck_barrier2", Map.truck_past_barrier2 );
	OnTrigger( "Allied team has destroyed the Bank Doors!", Map.blow_doors );
	OnTrigger( "Planted at Tank Barrier #1.", Map.planted_at_Tank_Barrier_1 );
	OnTrigger( "Defused at Tank Barrier #1.", Map.defused_at_Tank_Barrier_1 );
	OnTrigger( "Planted at Tank Barrier #2.", Map.planted_at_Tank_Barrier_2 );
	OnTrigger( "Defused at Tank Barrier #2.", Map.defused_at_Tank_Barrier_2 );
	OnTrigger( "Planted at Truck Barrier #1.", Map.planted_at_Truck_Barrier_1 );
	OnTrigger( "Defused at Truck Barrier #1.", Map.defused_at_Truck_Barrier_1 );
	OnTrigger( "Planted at Truck Barrier #2.", Map.planted_at_Truck_Barrier_2 );
	OnTrigger( "Defused at Truck Barrier #2.", Map.defused_at_Truck_Barrier_2 );
	OnTrigger( "tank at location", Map.vehicle_at_location );
	OnTrigger( "truck at location", Map.vehicle_at_location );


	tankatb1 = OnTriggerRegion(AABB(-751.316,3466.479,1025.125,-458.894,3564.867,1099.128), RegionTrigger.VehicleTrigger);
	tankatcorner = OnTriggerRegion(AABB(1464.018,3423.997,897.125,1810.589,3492.511,971.125), RegionTrigger.VehicleTrigger);
	tankattower = OnTriggerRegion(AABB(2079.867,672.777,897.125,2572.952,800.206,971.125), RegionTrigger.VehicleTrigger);
	tankatb2 = OnTriggerRegion(AABB(3127.567,-220.361,897.125,3484.746,-97.582,971.125), RegionTrigger.VehicleTrigger);
	truckatb1 =	OnTriggerRegion(AABB(1765.708,-2067.028,897.125,1978.893,-1960.942,971.125), RegionTrigger.VehicleTrigger);
	truckatb2 = OnTriggerRegion(AABB(302.168,-305.010,897.125,565.521,42.087,971.125), RegionTrigger.VehicleTrigger);
	elevator2 = OnTriggerRegion(AABB(-370.428,4380.403,1153.125,-332.428,4418.403,1203.125), Map.elevator2);
	elevator3 = OnTriggerRegion(AABB(1220.879,4366.178,1153.125,1258.879,4404.178,1203.125), Map.elevator3);
	elevator5 = OnTriggerRegion(AABB(-3479.090,3534.368,1153.125,-3441.090,3572.368,1203.125), Map.elevator5);
	elevator7 =	OnTriggerRegion(AABB(3792.606,-5528.469,513.125,3830.606,-5490.469,563.125), Map.elevator7);
	elevator8 = OnTriggerRegion(AABB(4985.451,-183.270,897.125,5023.451,-145.270,947.125), Map.elevator8);
	boot2exit = OnTriggerRegion(AABB(-4257.677,3404.491,1060.146,-4131.048,3480.171,1149.457),Map.Boot2exit);


	//Allies clear all goals
	SetAvailableMapGoals( TEAM.ALLIES, false, ".*" );
	//activation
	SetAvailableMapGoals( TEAM.ALLIES, true, {
		"RIDE_elevator5",
		"HEALTHCAB_health7",
		"AMMOCAB_ammo7",
		"HEALTHCAB_health8",
		"AMMOCAB_ammo8",
		"RIDE_boot2",
		"ROUTE_bt_.*",
        "BUILD_Tank",
		"ATTACK_garden_.*",
	});

	//Axis clear all goals
	SetAvailableMapGoals( TEAM.AXIS, false, ".*" );
	//activation
	SetAvailableMapGoals( TEAM.AXIS, true, {
	"HEALTHCAB_health3",
	"AMMOCAB_ammo3",
	"HEALTHCAB_health8",
	"AMMOCAB_ammo8",
	"Build_Tank_Barrier_1",
	"Build_Command_Post",
	"DEFEND_garden_.*",
	"PLANTMINE_garden_.*",
	});

	// Max users per goal
	Util.SetMaxUsers( 1, "ATTACK_.*" );
	Util.SetMaxUsers( 1, "DEFEND_.*" );
	Util.SetMaxUsers( 2, "BUILD_.*" );
	Util.SetMaxUsers( 2, "PLANT_.*" );
	Util.SetMaxUsers( 1, "ESCORT_.*" );
	Util.SetMaxUsers( 1, "RIDE_.*" );
	Util.SetMaxUsers( 1, "MOUNT_tank" );
	Util.SetMaxUsers( 1, "CAPPOINT_gold.*" );
	Util.SetMaxUsers( 2, "FLAG_gold_crate" );


	// Camp times
	//SetMapGoalProperties( "MOUNTMG42_.*", {MinCampTime=15, MaxCampTime=90} );
    SetMapGoalProperties( "ATTACK_.*", {MinCampTime=20, MaxCampTime=60} );
	SetMapGoalProperties( "DEFEND_.*", {MinCampTime=20, MaxCampTime=60} );

	// Allied goals
	SetGoalPriority( "BUILD_Truck", 0.83, TEAM.ALLIES, CLASS.ENGINEER );
	SetGoalPriority( "BUILD_Tank", 0.92 );
	SetGoalPriority( "PLANT_Tank_Barrier_1", 0.83, TEAM.ALLIES, CLASS.ENGINEER );
	SetGoalPriority( "PLANT_Tank_Barrier_2", 0.83, TEAM.ALLIES, CLASS.ENGINEER );
	SetGoalPriority( "PLANT_Truck_Barrier_1", 0.82, TEAM.ALLIES, CLASS.ENGINEER );
	SetGoalPriority( "PLANT_Truck_Barrier_2", 0.81, TEAM.ALLIES, CLASS.ENGINEER );
	SetGoalPriority( "ATTACK_.*", 0.80 );
	SetGoalPriority( "ESCORT_.*", 0.92 );
	SetGoalPriority( "MOUNT_tank", 0.83 );
	SetGoalPriority( "RIDE_elevator.*", 0.91 );
	SetGoalPriority( "RIDE_boot2", 0.91 );

	// Axis goals
	SetGoalPriority( "PLANTMINE_.*", 0.93, TEAM.AXIS, CLASS.ENGINEER );
	SetGoalPriority( "BUILD_Command_Post", 0.92, TEAM.AXIS, CLASS.ENGINEER );
	SetGoalPriority( "BUILD_Tank_Barrier_1", 0.93, TEAM.AXIS, CLASS.ENGINEER );
	SetGoalPriority( "BUILD_Tank_Barrier_2", 0.92, TEAM.AXIS, CLASS.ENGINEER );
	SetGoalPriority( "BUILD_Truck_Barrier_1", 0.91, TEAM.AXIS, CLASS.ENGINEER );
	SetGoalPriority( "BUILD_Truck_Barrier_2", 0.91, TEAM.AXIS, CLASS.ENGINEER );
	SetGoalPriority( "DEFEND_.*", 0.91 );

	Util.LimitToClass("RIDE_.*", TEAM.ALLIES, CLASS.SOLDIER, CLASS.MEDIC, CLASS.FIELDOPS, CLASS.COVERTOPS);
	Util.LimitToClass("ATTACK_.*", TEAM.ALLIES, CLASS.SOLDIER, CLASS.MEDIC, CLASS.FIELDOPS, CLASS.COVERTOPS);
	Util.LimitToClass("ESCORT_.*", TEAM.ALLIES, CLASS.SOLDIER, CLASS.ENGINEER);
	Util.MapDebugPrint( "Omni-bot map script for " + GetMapName() + " executed." );

};

global OnBotJoin = function( bot )
{
	bot.TargetBreakableDist = 90.0;
};

