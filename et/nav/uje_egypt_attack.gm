	blow_doors = function( trigger )
	{
	Map.blowdoors = true;
    SetAvailableMapGoals( TEAM.ALLIES, true, {
    	"FLAG_gold_crate",
    	"ATTACK_bank_.*",
    });
	SetAvailableMapGoals( TEAM.ALLIES, false, "ATTACK_tankb2_.*" );

	SetAvailableMapGoals( TEAM.AXIS, true, {
		"DEFEND_bank_.*",
		"Build_Truck_Barrier_.*",
	});
	SetAvailableMapGoals( TEAM.AXIS, false, "DEFEND_tankb2_.*" );
	SetAvailableMapGoals( TEAM.AXIS, true, "RIDE_elevator8" );

        Util.RemoveGoal( "ESCORT_tank" );
		Util.EnableGoal( "AMMOCAB_ammo5" );
		Util.EnableGoal( "HEALTHCAB_health5" );
		Util.MapDebugPrint( "blow_doors" );
	},

	allies_taking_gold = function( trigger )
	{
	Map.blowdoors = false;
	Map.goldtaken = true;

	 if ( Map.truckisbuild == true )
	 {
	 SetAvailableMapGoals( TEAM.ALLIES, true, {
	 	"ESCORT_truck",
	 	"RIDE_truck",
	 });
	 }
	SetAvailableMapGoals( TEAM.ALLIES, true, {
		"ATTACK_truckb1_.*",
		"BUILD_Truck",
	});
	SetAvailableMapGoals( TEAM.ALLIES, false, {
		"ATTACK_bank_.*",
		"FLAG_gold_crate",
		"CAPPOINT_gold.*",
	});

    SetAvailableMapGoals( TEAM.AXIS, true, "DEFEND_truckb1_.*" );
	SetAvailableMapGoals( TEAM.AXIS, false, "DEFEND_bank_.*" );

	    Util.DisableGoal( "RIDE_elevator8" );
		Util.MapDebugPrint( "allies_taking_gold" );
	},

