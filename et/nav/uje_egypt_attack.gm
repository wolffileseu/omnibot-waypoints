global Map =
{
	Debug = 0, // please set to zero before distributing your script

	Build_Command_Post = "BUILD_Command_Post",
	Plant_Command_Post = "PLANT_Command_Post",
	Build_Tank = "BUILD_Tank",
	Build_Tank_Barrier_1 = "BUILD_Tank_Barrier_1",
	Build_Tank_Barrier_2 = "BUILD_Tank_Barrier_2",
	Build_Truck = "BUILD_Truck",
	Build_Truck_Barrier_1 = "BUILD_Truck_Barrier_1",
	Build_Truck_Barrier_2 = "BUILD_Truck_Barrier_2",
	Plant_Tank_Barrier_1 = "PLANT_Tank_Barrier_1",
	Plant_Tank_Barrier_2 = "PLANT_Tank_Barrier_2",
	Plant_Truck_Barrier_1 = "PLANT_Truck_Barrier_1",
	Plant_Truck_Barrier_2 = "PLANT_Truck_Barrier_2",
	Mover_tank = "MOVER_tank",
	Mover_truck = "MOVER_truck",

	//set status' for conditionals
	tankatb1 = false,
	tankatb2 = false,
	truckatb1 = false,
	truckatb2 = false,
	truckisbuild = true,
	eleva5 = true,
	allieseleva = false,
	axiseleva = false,
	tankpasstb2 = false,
	blowdoors = false,
	goldtaken = false,

		Movers =
	{
		// retain these movers
		"MOVER_tank",
		"MOVER_truck",
		"MOVER_elevator2",
		"MOVER_elevator3",
		"MOVER_elevator5",
		"MOVER_elevator7",
		"MOVER_elevator8",
		"MOVER_boot2",
	},

		Navigation =
	{
		cata1 =
		{
          navigate = function(_this)
			{
				timeout = 1;
				while ( timeout > 0 ) {
					_this.AddAimRequest(Priority.High, "facing", Vec3(-0.019, 0.996, 0.087));
					_this.Goto(_this.Bot.GetPosition());
					sleep(1);
					timeout -= 0.5;

						}
				},
			},
		cata2 =
		{
			navigate = function(_this)
			{
			  timeout = 1;
				while ( timeout > 0 ) {
					_this.AddAimRequest(Priority.High, "facing", Vec3(-0.019, 0.996, 0.087));
					_this.Goto(_this.Bot.GetPosition());
					sleep(1);
					timeout -= 0.5;

				}
			},
		},
		boot2 =
 		{
 			navigate = function(_this)
 			{
				_this.AddAimRequest(Priority.High, "facing", Vector3(0.972, -0.041, -0.231));
 				_this.Bot.PressButton(BTN.USE);

			}
		},
	},
	allies_steal_tank = function( trigger )
	{


	 SetAvailableMapGoals( TEAM.AXIS, true, {
	 	"BUILD_Tank_Barrier_2",
	 	"DEFEND_tankb1_.*",
	 });
	 SetAvailableMapGoals( TEAM.AXIS, false, {
	 	"DEFEND_garden_.*",
	 	"PLANTMINE_garden_.*",
	 });

		Util.MapDebugPrint( "allies_steal_tank" );
	},

	Axis_Command_Post_Built = function( trigger )
	{
    SetAvailableMapGoals( TEAM.AXIS, false, "BUILD_Command_Post" );
	SetAvailableMapGoals( TEAM.ALLIES, false, "BUILD_Command_Post" );
	if ( !Map.Tank_Barrier_1_Destroyed )
		{
	SetAvailableMapGoals( TEAM.ALLIES, true, "PLANT_Command_Post" );
    }

	Util.MapDebugPrint( "Command_Post_Built" );
	},

	Allied_Command_Post_Built = function( trigger )
	{
    SetAvailableMapGoals( TEAM.ALLIES, false, {
    	"BUILD_Command_Post",
    	"PLANT_Command_Post",
    });

	SetAvailableMapGoals( TEAM.AXIS, false, {
		"BUILD_Command_Post",
		"PLANT_Command_Post",
	});

		Util.MapDebugPrint( "Allied_Command_Post_Built" );
	},

	Axis_Command_Post_Destroyed = function( trigger )
	{
	if ( !Map.Tank_Barrier_1_Destroyed )
		{
	SetAvailableMapGoals( TEAM.ALLIES, true, "BUILD_Command_Post" );
	SetAvailableMapGoals( TEAM.ALLIES, false, "PLANT_Command_Post" );

	SetAvailableMapGoals( TEAM.AXIS, false, "BUILD_Command_Post" );
    }
		Util.MapDebugPrint( "Command_Post_Destroyed" );
	},

	Allied_Command_Post_Destroyed = function( trigger )
	{
    SetAvailableMapGoals( TEAM.ALLIES, true, "BUILD_Command_Post" );

		Util.MapDebugPrint( "Command_Post_Destroyed" );
	},

	Tank_Built = function( trigger )
	{
    if ( Map.tankatb1 == true && Map.tankatb2 == true )
	{
	SetAvailableMapGoals( TEAM.ALLIES, false, {
        "ESCORT_tank",
	});
	}
	if ( Map.tankatb1 == false && Map.tankatb2 == false )
	{
	SetAvailableMapGoals( TEAM.ALLIES, true, {
        "ESCORT_tank",
	});
    }
	SetAvailableMapGoals( TEAM.ALLIES, false, {
        "BUILD_Tank",
	});
	SetAvailableMapGoals( TEAM.ALLIES, true, {
		"MOUNT_tank"
	});
		Util.MapDebugPrint( "Tank_Built" );
	},

	Tank_Destroyed = function ( trigger )
	{
	SetAvailableMapGoals( TEAM.ALLIES, false, {
        "ESCORT_tank",
		"MOUNT_tank",
	});

	SetAvailableMapGoals( TEAM.ALLIES, true, {
        "BUILD_Tank",
	});
		Util.MapDebugPrint( "Tank_Destroyed" );
	},

	Truck_Built = function( trigger )
	{
	Map.truckisbuild = true;
    if ( Map.truckatb1 == true && Map.truckatb2 == true && Map.goldtaken == false )
	{
	SetAvailableMapGoals( TEAM.ALLIES, false, {
        "ESCORT_Truck",
	});
	}
	if ( Map.truckatb1 == false && Map.truckatb2 == false && Map.goldtaken == true )
	{
	SetAvailableMapGoals( TEAM.ALLIES, true, {
        "ESCORT_truck",
	});
    }
	SetAvailableMapGoals( TEAM.ALLIES, false, {
        "BUILD_truck",
	});

	SetAvailableMapGoals( TEAM.ALLIES, true, "RIDE_truck" );
	SetAvailableMapGoals( TEAM.ALLIES, false, "Build_Truck" );


	Util.MapDebugPrint( "Truck_Built" );
	},

	Truck_Destroyed = function ( trigger )
	{
	Map.truckisbuild = false;

	if ( Map.goldtaken == true )
	{
	SetAvailableMapGoals( TEAM.ALLIES, true, "BUILD_Truck" );
	}
    SetAvailableMapGoals( TEAM.ALLIES, false, {
    	"RIDE_truck",
    	"ESCORT_truck",
    });

		Util.MapDebugPrint( "Truck_Destroyed" );
	},

	tank_at_barrier1 = function()
	{
	 Map.tankatb1 = true;
	 Map.eleva5 = false;
	 Map.axiseleva = true;

    SetAvailableMapGoals( TEAM.ALLIES, true, {
    	"PLANT_Tank_Barrier_1",
    	"PLANT_Command_Post",
    });
    SetAvailableMapGoals( TEAM.ALLIES, false, {
    	"ESCORT_tank",
    	"RIDE_elevator5",
    	"RIDE_boot2",
    });

	SetAvailableMapGoals( TEAM.AXIS, true, {
		"RIDE_elevator2",
		"RIDE_elevator3",
	});

		Util.MapDebugPrint("tank_at_barrier1");
	},

	tank_past_barrier1 = function( trigger )
	{
	Map.allieseleva = true;
	Map.tankatb1 = false;
	SetAvailableMapGoals( TEAM.ALLIES, true, {
		"RIDE_elevator2",
		"RIDE_elevator3",
		"ATTACK_pyra_.*",
		"ESCORT_tank",
		"BUILD_Command_Post",
		"AMMOCAB_ammo3",
		"HEALTHCAB_health3",
	});
	SetAvailableMapGoals( TEAM.ALLIES, false, "ATTACK_garden_.*" );

	SetAvailableMapGoals( TEAM.AXIS, false, {
		"BUILD_Tank_Barrier_1",
		"AMMOCAB_ammo3",
		"HEALTHCAB_health3",
	});

	Util.DisableGoal("HEALTHCAB_health8");
    Util.DisableGoal("AMMOCAB_ammo8");
	Util.DisableGoal("HEALTHCAB_health7");
    Util.DisableGoal("AMMOCAB_ammo7");
	Util.EnableGoal("HEALTHCAB_health2");
    Util.EnableGoal("AMMOCAB_ammo2");

		Util.MapDebugPrint( "tank_past_barrier1" );
	},

	tank_at_corner = function( trigger )
	{
	 Map.axiseleva = false;

	SetAvailableMapGoals( TEAM.AXIS, true, "DEFEND_tankb2_.*" );
	SetAvailableMapGoals( TEAM.AXIS, false, {
		"DEFEND_tankb1_.*",
		"RIDE_elevator2",
		"RIDE_elevator3",
	});

		Util.MapDebugPrint( "tank_at_corner" );
	},

