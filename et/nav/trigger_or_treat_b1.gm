				{
					ROUTE_ladder_axis = {},
					ROUTE_ladder_allied = {},					
				},

			},
			ROUTE_allied_spawn = 
			{
				ROUTE_allied_guillotine = 
				{
					Weight = 1,
					ROUTE_ladder_axis = {},
