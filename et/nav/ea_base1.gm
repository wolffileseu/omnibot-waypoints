global OnMapLoad = function()
{
	if ( TestMapOn )
		{ ETUtil.AutoTestMap(); }
	SetAvailableMapGoals( TEAM.ALLIES, false, "HEALTH_CABINET_.*" );
	SetAvailableMapGoals( TEAM.AXIS, false, "HEALTH_CABINET_.*" );
	SetAvailableMapGoals( TEAM.ALLIES, false, "AMMO_CABINET_.*" );
	SetAvailableMapGoals( TEAM.AXIS, false, "AMMO_CABINET_.*" );
	SetAvailableMapGoals( TEAM.ALLIES, true, "MAP_CONSTRUCTION_allied_cp_open" );
	SetAvailableMapGoals( TEAM.AXIS, true, "MAP_CONSTRUCTION_axis_cp_open" );
	SetAvailableMapGoals( TEAM.ALLIES, false, "MAP_DYNAMITE_TARGET_axis_cp_open" );
	SetAvailableMapGoals( TEAM.AXIS, false, "MAP_DYNAMITE_TARGET_allied_cp_open" );


	OnTrigger( "MISSING_STRING", Map.axis_cp_open_Built );
	OnTrigger( "MISSING_STRING", Map.allied_cp_open_Built );
	OnTrigger( "MISSING_STRING", Map.axis_cp_open_Destroyed );
	OnTrigger( "MISSING_STRING", Map.allied_cp_open_Destroyed );
	OnTrigger( "MISSING_STRING", Map.gate_Destroyed );
//~ 	OnTrigger( "MISSING_STRING", Map.Allies_Capture_Flag );
//~ 	OnTrigger( "MISSING_STRING", Map.Axis_Capture_Flag );

	//~SetAvailableMapGoals( TEAM.ALLIES, false, ".*" );
	//~SetAvailableMapGoals( TEAM.AXIS, false, ".*" );

	print( "OnMapLoad" );
};

