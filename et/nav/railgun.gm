		{
			ROUTE_east_hill = {},
			ROUTE_west_hill = {},
		},
	};

	//copy some routes
	MapRoutes["DEFEND_Railgun.*"] = MapRoutes.PLANT_Rail_Gun_Firing_Controls;
	MapRoutes["PLANTMINE_bTrackswitch.*"] = MapRoutes["DEFEND_Track_Switch_North.*"];
	MapRoutes["ATTACK_Railgun.*"] = MapRoutes.BUILD_Rail_Gun_Firing_Controls;
