global OnMapLoad = function()
{
	//Allies keys
	OnTrigger( "Allies have stolen the Maya Key!", Map.maya_key_Taken );
	OnTrigger( "Troopers team has placed the Maya Key !", Map.maya_key_Secured );

	OnTrigger( "Allies have stolen the Stool Key!", Map.stool_key_Taken );
	OnTrigger( "Troopers team has placed the Stool Key !", Map.stool_key_Secured );

	OnTrigger( "Allies have stolen the Skull Key!", Map.skull_key_Taken );
	OnTrigger( "Troopers team has placed the Skull Key !", Map.skull_key_Secured );

	//Game end key - Allies
	OnTrigger( "Allies have stolen the Inca Key!", Map.t_inca_key_Taken );
	OnTrigger( "^7The ^2Troopers ^7have seized the Inca Key !", Map.t_inca_key_Secured );

	//Axis keys
	OnTrigger( "Axis have stolen the Serenity Key!", Map.serenity_key_Taken );
	OnTrigger( "Raiders team has placed the Serenity Key !", Map.serenity_key_Secured );

	OnTrigger( "Axis have stolen the Azteca Key!", Map.azteca_key_Taken );
	OnTrigger( "Raiders team has placed the Azteca Key !", Map.azteca_key_Secured );

	OnTrigger( "Axis have stolen the Duality Key!", Map.duality_key_Taken );
	OnTrigger( "Raiders team has placed the Duality Key !", Map.duality_key_Secured );

	//Game end key - Axis
	OnTrigger( "Axis have stolen the Inca Key!", Map.inca_key_Taken );
	OnTrigger( "^7The ^1Raiders ^7have seized the Inca Key !", Map.inca_key_Secured );


	Util.DisableGoal( ".*", true );
	Util.EnableGoal(".*CAB_.*");
	Util.DisableGoal(".*CAB_768");
	
	//Allies
	SetAvailableMapGoals( TEAM.ALLIES, 1, {
		//"ATTACK_.*",
		"FLAG_maya_key",
	});

	//Axis
	SetAvailableMapGoals( TEAM.AXIS, 1, {
		//"DEFEND_.*",
		"FLAG_serenity_key",
	});

	Util.SetMaxUsersInProgress(4, "FLAG.*");
	
	Util.MapDebugPrint( "Omni-bot map script for " + GetMapName() + " executed." );
};


global InitializeRoutes = function()
{
	MapRoutes =
	{
		//Allies
		CAPPOINT_Maya = {},

		CAPPOINT_Stool = {},

		CAPPOINT_Skull = {},

		CAPPOINT_T_Inca = {},

		//Axis
		CAPPOINT_Serenity = {},

		CAPPOINT_AztecA = {},

		CAPPOINT_Duality = {},

		CAPPOINT_Inca = {},
	};
	Util.Routes(MapRoutes);
};
