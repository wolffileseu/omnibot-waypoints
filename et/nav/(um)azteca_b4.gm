global Map =
{
	Debug = 0,

	//Allies keys
	maya_key_Taken = function( trigger )
	{
		SetAvailableMapGoals( TEAM.ALLIES, 1, "CAPPOINT_Maya" );
		Util.MapDebugPrint( "maya_key_Taken" );
	},
	maya_key_Secured = function( trigger )
	{
		SetAvailableMapGoals( TEAM.ALLIES, 0, {
			"FLAG_maya_key",
			"CAPPOINT_Maya",
		});
		Util.MapDebugPrint( "maya_key_Secured" );
		sleep(8);
		Wp.CheckBlockable();
		SetAvailableMapGoals( TEAM.ALLIES, 1, "FLAG_stool_key" );
	},

	stool_key_Taken = function( trigger )
	{
		SetAvailableMapGoals( TEAM.ALLIES, 1, "CAPPOINT_Stool" );
		Util.MapDebugPrint( "stool_key_Taken" );
	},
	stool_key_Secured = function( trigger )
	{
		SetAvailableMapGoals( TEAM.ALLIES, 0, {
			"CAPPOINT_Stool",
			"FLAG_stool_key",
		});
		Util.MapDebugPrint( "stool_key_Secured" );
		sleep(8);
		Wp.CheckBlockable();
		SetAvailableMapGoals( TEAM.ALLIES, 1, "FLAG_skull_key" );
	},

