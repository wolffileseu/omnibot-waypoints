		Util.MapDebugPrint( "t_inca_key_Taken" );
	},
	t_inca_key_Secured = function( trigger )
	{
		ETUtil.WinningChat( TEAM.ALLIES );
		Util.MapDebugPrint( "t_inca_key_Secured" );
	},

	//Axis keys

	serenity_key_Taken = function( trigger )
