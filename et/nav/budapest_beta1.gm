	//garage doors
	Trigger_garage_1 = function( trigger )
	{
		if (Map.EnableSwitches && Map.EnableAllGarages && Map.EnableGarage1)		
		{
			Map.bp_Switches.garage_1.LimitTeam = 0;
			closed = TestTraceFunc("garage_1_block_0", "garage_1_block_1", 2.5);
			sleep(3);
			if(!closed)//door is open after moving
			{	
				Map.bp_Switches.garage_1.LimitTeam = (1<<TEAM.ALLIES);
				Map.garage_1_position = 2;	
			}
			else if (closed)//door is closed after moving
			{
				Map.bp_Switches.garage_1.LimitTeam = (1<<TEAM.AXIS);
				Map.garage_1_position = 1;
			}
		}
	//print("Trigger_garage_1");
	},
	Trigger_garage_2 = function( trigger )
	{
		if (Map.EnableSwitches && Map.EnableAllGarages && Map.EnableGarage2)
		{
			Map.bp_Switches.garage_2.LimitTeam = 0;
			closed = TestTraceFunc("garage_2_block_0", "garage_2_block_1", 2.5);
			sleep(3);
			if(!closed)//door is open after moving
			{
				Map.bp_Switches.garage_2.LimitTeam = (1<<TEAM.ALLIES);
				Map.garage_2_position = 2;
			}
			else if (closed)//door closed after moving
			{
				Map.bp_Switches.garage_2.LimitTeam = (1<<TEAM.AXIS);
				Map.garage_2_position = 1;
			}
		}
		//print("Trigger_garage_2");
	},
	Trigger_garage_3 = function( trigger )
	{
		if (Map.EnableSwitches && Map.EnableAllGarages && Map.EnableGarage3)
		{
			Map.bp_Switches.garage_3.LimitTeam = 0;
			closed = TestTraceFunc("garage_3_block_0", "garage_3_block_1", 2.5);
			sleep(3);
			if(!closed)//door is open after moving
			{
				Map.bp_Switches.garage_3.LimitTeam = (1<<TEAM.AXIS);
				Map.garage_3_position = 2;
			}
			else if (closed)//door is closed after moving
			{
				Map.bp_Switches.garage_3.LimitTeam = (1<<TEAM.ALLIES);
				Map.garage_3_position = 1;
			}
		}
		//print("Trigger_garage_3");
	},
	///sewer gates
	East_Gate_Destroyed = function( trigger )
	{
		Wp.SetWaypointFlag("east_gate_block_0", "closed", true);
		Wp.SetWaypointFlag("east_gate_block_1", "closed", true);
		Map.gates_destroyed = Map.gates_destroyed + 1;
		if ((Map.gates_destroyed > 1) || (Map.defences_built == 0))
		{
			SetAvailableMapGoals( TEAM.ALLIES, true, "MAP_DYNAMITE_TARGET_bridge.*");
		}
		else
		{
			SetAvailableMapGoals( TEAM.ALLIES, false, "MAP_DYNAMITE_TARGET_bridge.*");
		}
		//print("East_Gate_Destroyed");
	},
		
	West_Gate_Destroyed = function( trigger )
	{
