global OnBotJoin = function( bot )
{
	//general Goal prioritys
	bot.SetGoalProperty("MOUNT_MG42", "Bias", 0.5);
	bot.SetGoalProperty("GET_HEALTH", "Bias", 0.5);
	bot.SetGoalProperty("HEALTH_CABINET", "Bias", 0.5);
	bot.MaxViewDistance = 2048;//fog distance
	bot.TargetBreakableDist = 150.0;
	if( bot.WaypointThreadId )
	{
	//print ( "Killing Thread: ", bot.WaypointThreadId );
	threadKill( bot.WaypointThreadId );
	}
	if (Map.EnableSwitches || Map.EnableLadders)
	{
		bot.WaypointThreadId = bot:thread(Map.WatchForbp_Switches);
		//print("Creating Thread: ", bot.WaypointThreadId);
	}
	team = bot.GetTeam();	
	my_class = bot.GetClass();
	if (team == TEAM.AXIS)
	{
		if (Map.flag_team == 1 && CURRENT_SECONDSPAWN_BOTS < 3)//allies own flag
		{
			bot.ChangeSpawnPoint(4);
            CURRENT_SECONDSPAWN_BOTS += 1;
		}
		else if (Map.flag_team == 0)//axis own flag
		{
		bot.ChangeSpawnPoint(2);
		}
		/*if ( my_class == CLASS.SOLDIER )
		{
		}
	
		if ( my_class == CLASS.MEDIC )
		{
		}*/
	
		if ( my_class == CLASS.ENGINEER )
		{
			bot.SetGoalProperty("DEFEND", "Bias", 0.0);
			bot.SetGoalProperty("ATTACK", "Bias", 0.0);
			bot.SetGoalProperty( "BUILD_CONSTRUCTION", "IgnoreTargets", true );
			//SetAvailableMapGoals( "MAP_CONSTRUCTION_defences_bridge", "Bias", 1.0);
			bot.SetGoalProperty("MOUNT_MG42", "Bias", 0.0);
		}
	
		/*if ( my_class == CLASS.FIELDOPS )
		{
		}*/
	
		if ( my_class == CLASS.COVERTOPS )
		{
			bot.SetGoalProperty("DEFEND", "Bias", 0.0);
			bot.SetGoalProperty("ATTACK", "Bias", 0.0);
			bot.SetGoalProperty("MOUNT_MG42", "Bias", 0.0);
		}
		
	}
	else if (team == TEAM.ALLIES)
	{
	//engy goal prioritys
	bot.SetGoalProperty("MAP_DYNAMITE_TARGET_bridge.*", "Bias", 1.5);
	bot.SetGoalProperty("MAP_DYNAMITE_TARGET_defences_bridge", "Bias", 1.5);
	bot.SetGoalProperty("MAP_DYNAMITE_TARGET_gate.*", "Bias", 0.7);
		/*if ( my_class == CLASS.SOLDIER )
		{
		}
	
		if ( my_class == CLASS.MEDIC )
		{
		}*/
	
		if ( my_class == CLASS.ENGINEER )
		{
			bot.SetGoalProperty("DEFEND", "Bias", 0.0);
			bot.SetGoalProperty("ATTACK", "Bias", 0.0);
			bot.SetGoalProperty( "BUILD_CONSTRUCTION", "IgnoreTargets", true );
			bot.SetGoalProperty("MOUNT_MG42", "Bias", 0.0);
		}
	
		/*if ( my_class == CLASS.FIELDOPS )
		{	
		}*/
	
		if ( my_class == CLASS.COVERTOPS )
		{
			bot.SetGoalProperty("DEFEND", "Bias", 0.0);
			bot.SetGoalProperty("ATTACK", "Bias", 0.0);
			bot.SetGoalProperty("MOUNT_MG42", "Bias", 0.0);
		}
	
	}
};

global TestTraceFunc = function (a, b, c, botID)
//reusable func for testing tracelines
//is the path blocked, closed = true, open = false return
//a = waypoint1, b = waypoint2, c = delay in seconds
{
//////print(a, b);
	start = Util.GetWpNamePosition( a );//vector3
	end = Util.GetWpNamePosition( b );//vector3
	if (c == null)
	{
		delay = 0;
	}
	else
	{
		delay = c;
	}
	if ( botID == null)
	{
		botID = 0;
	}
//////print(start, end);
	//////print("delay", delay);
	sleep(delay);
	tr = TraceLine(start, end, null, TRACE.SHOT, botID, false); 
	if(tr.fraction < 1)
    {
		//////print("Closed");
		//DrawDebugLine(start, end, COLOR.RED, 2);
		return true;
    }
    else
    {
		//////print("Open");
		//DrawDebugLine(start, end, COLOR.GREEN, 2);
		return false;
    } 
};

global ChangeTo1stSpawn = function ()
{
foreach ( Id and bot in BotTable )//change axis to palace
	{
		if ( bot.GetTeam() == TEAM.AXIS )
		{
			if (Map.flag_team == 0)//axis own the palace
			{
			bot.ChangeSpawnPoint(2);
			}
		}
	}
};

global ChangeTo2ndSpawn = function ()
{
    CURRENT_SECONDSPAWN_BOTS = 0;
    foreach (gameId and bot in BotTable)
    {
        if (bot && bot.GetTeam() == TEAM.AXIS &&
            RandInt(0,10) > 5)
        {
            bot.ChangeSpawnPoint(4);
            CURRENT_SECONDSPAWN_BOTS += 1;
            //print("Axis spawn point changed to 4!");
        }

        if (CURRENT_SECONDSPAWN_BOTS >= MAX_SECONDSPAWN_BOTS)
        {
            break;
        }
    }
};

Map.WatchForbp_Switches = function ()
  {
	//////print("working"); //debug function/thread call
	while (true)//loop always
	{
		if(this.scriptgoal == null)
		{
			//////print(this.WaypointThreadId); //debug check for runaway threads
			if (Map.EnableSwitches)
			{
				foreach ( i and bp_SwitchTable in Map.bp_Switches ) //start switches
				{		
					myTeamMask = (1<<this.GetTeam());
					myClassMask = (1<<this.GetClass());
					if ((myTeamMask & bp_SwitchTable.LimitTeam) && (myClassMask & bp_SwitchTable.LimitClass))//is this switch for my team and class?
					{
						wp_LimitD = bp_SwitchTable.LimitDistance;
						wp_position = bp_SwitchTable.Waypoint.position;
						if ((this.DistanceTo(wp_position) < wp_LimitD) && (myTeamMask & bp_SwitchTable.LimitTeam))
						{
							//print("start", bp_SwitchTable.WaypointName);
							wp_radius = bp_SwitchTable.Waypoint.radius;
							wp_facing = bp_SwitchTable.Waypoint.facing;
							this.SetScriptControlled(true);
							this.scriptgoal = "bp_Switch";	
							//////print(bp_SwitchTable.WaypointName, wp_facing, wp_radius);
							this.GoTo( wp_position, wp_facing );
							if( block(EVENT.GOAL_SUCCESS, EVENT.GOAL_FAILED) == EVENT.GOAL_SUCCESS )	
							{						
								my_delay = bp_SwitchTable.UseDelay;//in seconds
								//////print("unblocked", my_delay);
								use_count = 0;
								while ((this.DistanceTo(wp_position) < 100) && (myTeamMask & bp_SwitchTable.LimitTeam) && (use_count < 10))
								{
									//////print("inner loop");
									this.SetScriptControlledWeapons(true);
									this.MoveTowards( wp_position, wp_radius );
									this.SetDesiredFacing(wp_facing);
									if (this.TurnToFacing(wp_facing))
									{
										sleep(my_delay);
										my_delay = 0;
										this.PressButton( BTN.USE );
										use_count = use_count + 1;
										//////print("pressbutton");
									}
									else
									{
									this.TurnToFacing(wp_facing);
									}
									sleep(0.5);								
								}
							}
							this.SetScriptControlled(false);
							this.SetScriptControlledWeapons(false);
							signal("script_goal_done"); //signal to unblock
							this.scriptgoal = null; //cancel the goal
							//print("end switch"); //debug
						}	
					}
				}//end switches 
			}
			if (Map.EnableLadders)
			{
				foreach ( i and bp_LaddersTable in Map.bp_Ladders ) //start Ladders
				{	
					toppos = bp_LaddersTable.TopWaypoint.position;
					bottompos = bp_LaddersTable.BottomWaypoint.position;
					botID = this.GetGameId();
					//////print(botID);
					run_bool = false;
					blocked = true;
					if (this.DistanceTo(toppos) < 70)
					{
						blocked = TestTraceFunc(bp_LaddersTable.TopWaypointName, bp_LaddersTable.BottomWaypointName, 0, botID); //error checking for bot pileups
						my_Facing = bp_LaddersTable.TopWaypoint.facing;
						run_bool = true;
						////print("at top start", bp_LaddersTable.TopWaypointName);
					}
					else if (this.DistanceTo(bottompos) < 70)
					{
						blocked = TestTraceFunc(bp_LaddersTable.TopWaypointName, bp_LaddersTable.BottomWaypointName, 0, botID); //error checking for bot pileups
						my_Facing = bp_LaddersTable.BottomWaypoint.facing;
						run_bool = true;
						////print("at bottom start", bp_LaddersTable.BottomWaypointName);
					}
					if (!blocked && run_bool)
					{
						this.scriptgoal = "bp_Ladder"; //set this script goal
						ladder_length = (toppos - bottompos).Length(); //ladder length
						wait_delay = (ladder_length + 320) / 160; //wait based on ladder length + 320 / climb speed						
						Adjustment_count = 0;
						this.SetScriptControlled(true); //take control of bot movement
						this.SetScriptControlledWeapons(true); //take control of bot weapons
						this.TurnToFacing(my_Facing); //set facing to waypoints
						this.HoldButton(BTN.FORWARD, wait_delay);//move bot forward
						while(Adjustment_count < 5)
						{
							this.TurnToFacing(my_Facing); //adjust facing
							this.SetDesiredFacing(my_Facing); //adjust facing
							Adjustment_count = Adjustment_count + 1; //add to adjust count
							sleep(wait_delay * 0.20); //wait 1/5 of total time to climb ladder
						}
						this.SetScriptControlled(false);
						this.SetScriptControlledWeapons(false);
						signal("script_goal_done"); //signal to unblock
						this.scriptgoal = null; //cancel the goal
						//print("end ladder"); //debug
					}				
					//////print("fail on blocked ladder"); //debug		
				}//end ladders	
			}
		} 
		else //end scipt goal check
		{
        // someone is controlling the bot, so rather than sleep and loop, lets block
        block("script_goal_done");
		} 
		sleep (0.1);
	} //end while(True) loop
 };

