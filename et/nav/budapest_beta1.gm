	//trigger functions	
	//elevator 1 control
	Axis_Own_Elevator = function( trigger )
	{	
		signal("elevator_1_built");//signal to unblock
		Map.elevator_team = 1;
		//print("Axis_Own_Elevator"); //debug
	},
	Allies_Own_Elevator = function( trigger )
	{
		signal("elevator_1_built");//signal to unblock
		Map.elevator_team = 2;//no team 1 = axis, 2 = allies
		//print("Allies_Own_Elevator"); //debug
		
    },
	Nither_Own_Elevator = function( trigger )
	{	
		Map.elevator_team = 0;
		signal("elevator_1_activated"); //unblock
		//print("Neither_Own_Elevator"); //debug
    },
