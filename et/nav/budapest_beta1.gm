	Wp.SetWaypointFlag("bridge_west_jump_4", "jumplow", true);
	Wp.SetWaypointFlag("bridge_west_jump_5", "jumplow", true);
	Wp.SetWaypointFlag("bridge_west_jump_6", "jumplow", true);
	Wp.SetWaypointFlag("bridge_west_jump_0", "jumplow", true);
	Wp.SetWaypointFlag("bridge_west_blocker_0", "closed", true);
	Wp.SetWaypointFlag("bridge_west_blocker_1", "closed", true);
	},
	
	///forward flag
	Allies_Capture_Flag = function( trigger )
    {
	//Allies Goals
		///palace flag capture///////////////////////
	//attack goals
	SetAvailableMapGoals( TEAM.ALLIES, false, "ATTACK_axis.*");
	SetAvailableMapGoals( TEAM.ALLIES, true, "ATTACK_allies_bridge.*");
	SetAvailableMapGoals( TEAM.ALLIES, false, "ATTACK_allies_palace.*");
	//defend goals
	SetAvailableMapGoals( TEAM.ALLIES, false, "DEFEND_axis.*");
	SetAvailableMapGoals( TEAM.ALLIES, false, "DEFEND_allies_palace.*");
	SetAvailableMapGoals( TEAM.ALLIES, true, "DEFEND_allies_bridge.*");
	//Engy goals
	if ((Map.gates_destroyed > 1) || (Map.defences_built == 0))
	{
		SetAvailableMapGoals( TEAM.ALLIES, true, "MAP_DYNAMITE_TARGET_bridge.*");
	}
	else
	{
		SetAvailableMapGoals( TEAM.ALLIES, false, "MAP_DYNAMITE_TARGET_bridge.*");
	}
	SetAvailableMapGoals( TEAM.ALLIES, true, "MAP_DYNAMITE_TARGET_gate.*");
	SetAvailableMapGoals( TEAM.ALLIES, false, "MAP_CONSTRUCTION_generator_allied");
	SetAvailableMapGoals( TEAM.ALLIES, false, "MAP_DYNAMITE_TARGET_generator_axis");
	SetAvailableMapGoals( TEAM.ALLIES, true, "MAP_CONSTRUCTION_generator_2_allied");
	SetAvailableMapGoals( TEAM.ALLIES, true, "MAP_DYNAMITE_TARGET_generator_2_axis");
	SetAvailableMapGoals( TEAM.ALLIES, true, "MAP_CONSTRUCTION_defences_bridge");
	//Arty goals
	SetAvailableMapGoals( TEAM.ALLIES, false, "MAP_ARTY_SPOT_axis.*");
	//SetAvailableMapGoals( TEAM.ALLIES, false, "MAP_ARTY_TARGET_D_axis.*");
	SetAvailableMapGoals( TEAM.ALLIES, false, "MAP_ARTY_SPOT_allies_palace.*");
	SetAvailableMapGoals( TEAM.ALLIES, true, "MAP_ARTY_SPOT_allies_bridge.*");
	//snipe goals
	SetAvailableMapGoals( TEAM.ALLIES, false, "MAP_SNIPER_SPOT_axis.*");
	SetAvailableMapGoals( TEAM.ALLIES, false, "MAP_SNIPER_SPOT_allies_palace.*");
	SetAvailableMapGoals( TEAM.ALLIES, true, "MAP_SNIPER_SPOT_allies_bridge.*");
    //general
	SetAvailableMapGoals( TEAM.ALLIES, true, "MAP_MOUNTABLE_MG42.*");
	///Axis goals
	//attack goals
	SetAvailableMapGoals( TEAM.AXIS, false, "ATTACK_axis_palace.*");
	SetAvailableMapGoals( TEAM.AXIS, false, "ATTACK_allies.*");
	SetAvailableMapGoals( TEAM.AXIS, true, "ATTACK_axis_bridge.*");
	//defend goals
	SetAvailableMapGoals( TEAM.AXIS, false, "DEFEND_axis_palace.*");
	SetAvailableMapGoals( TEAM.AXIS, true, "DEFEND_axis_bridge.*");
	SetAvailableMapGoals( TEAM.AXIS, false, "DEFEND_allies.*");
	//Engy goals
	SetAvailableMapGoals( TEAM.ALLIES, false, "MAP_CONSTRUCTION_generator_axis");
	SetAvailableMapGoals( TEAM.ALLIES, false, "MAP_DYNAMITE_TARGET_generator_aallied");
	SetAvailableMapGoals( TEAM.ALLIES, true, "MAP_CONSTRUCTION_generator_2_axis");
	SetAvailableMapGoals( TEAM.ALLIES, true, "MAP_DYNAMITE_TARGET_generator_2_allied");
	//Arty goals
	SetAvailableMapGoals( TEAM.AXIS, false, "MAP_ARTY_SPOT_axis_palace.*");
	SetAvailableMapGoals( TEAM.AXIS, true, "MAP_ARTY_SPOT_axis_bridge.*");
	SetAvailableMapGoals( TEAM.AXIS, false, "MAP_ARTY_SPOT_allies.*");
	//snipe goals
	SetAvailableMapGoals( TEAM.AXIS, false, "MAP_SNIPER_SPOT_axis_palace.*");
	SetAvailableMapGoals( TEAM.AXIS, true, "MAP_SNIPER_SPOT_axis_bridge.*");
	SetAvailableMapGoals( TEAM.AXIS, false, "MAP_SNIPER_SPOT_allies.*");
	//general
	SetAvailableMapGoals( TEAM.AXIS, true, "MAP_MOUNTABLE_MG42.*");
	Util.ResetGoals();
	
	//capture Waypoints 
		Wp.SetWaypointFlag("team_capture_0", "team2", true);
		Wp.SetWaypointFlag("team_capture_0", "team1", false);
		Wp.SetWaypointFlag("team_capture_1", "team2", true);
		Wp.SetWaypointFlag("team_capture_1", "team1", false);
		Wp.SetWaypointFlag("team_capture_2", "team2", true);
		Wp.SetWaypointFlag("team_capture_2", "team1", false);
		Wp.SetWaypointFlag("team_capture_3", "team2", true);
		Wp.SetWaypointFlag("team_capture_3", "team1", false);
		Wp.SetWaypointFlag("team_capture_4", "team2", true);
		Wp.SetWaypointFlag("team_capture_4", "team1", false);
		Wp.SetWaypointFlag("team_capture_5", "team2", true);
		Wp.SetWaypointFlag("team_capture_5", "team1", false);
		//conditionals
		if (Map.EnableSwitches)
		{
			if(Map.EnableAllGarages)
			{
				if(Map.EnableGarage1)
				{
					Map.bp_Switches.garage_1.LimitTeam = 0;//shift focus
				}
				if(Map.EnableGarage2)
				{
					Map.bp_Switches.garage_2.LimitTeam = 0;//shift focus
				}
				if(Map.EnableGarage3)
				{
					if (Map.garage_3_position == 1)//door closed
					{
						Map.bp_Switches.garage_3.LimitTeam = (1<<TEAM.ALLIES);
					}
					else if (Map.garage_3_position == 2)//door open
					{
						Map.bp_Switches.garage_3.LimitTeam = (1<<TEAM.AXIS);
					}
				}
			}
			Map.bp_Switches.palace_flag.LimitTeam = (1<<TEAM.AXIS);
		}	
		if(EnablePtBoat)
		{
		Map.FocusOnVehicle = 0;
		}
	Map.flag_team = 1;
	ChangeTo2ndSpawn();
	//print("Allies_Capture_Flag");
	},//end Allies capture

	Axis_Capture_Flag = function( trigger )
    {
	//Allies Goals
		///palace flag capture///////////////////////
	//attack goals
	SetAvailableMapGoals( TEAM.ALLIES, false, "ATTACK_axis.*");
	SetAvailableMapGoals( TEAM.ALLIES, false, "ATTACK_allies_bridge.*");
	SetAvailableMapGoals( TEAM.ALLIES, true, "ATTACK_allies_palace.*");
	//defend goals
	SetAvailableMapGoals( TEAM.ALLIES, false, "DEFEND_axis.*");
	SetAvailableMapGoals( TEAM.ALLIES, false, "DEFEND_allies_palace.*");
	//Engy goals
	SetAvailableMapGoals( TEAM.ALLIES, false, "MAP_DYNAMITE_TARGET_bridge.*");
	SetAvailableMapGoals( TEAM.ALLIES, false, "MAP_DYNAMITE_TARGET_gate.*");
	SetAvailableMapGoals( TEAM.ALLIES, true, "MAP_CONSTRUCTION_generator_allied");
	SetAvailableMapGoals( TEAM.ALLIES, true, "MAP_DYNAMITE_TARGET_generator_axis");
	SetAvailableMapGoals( TEAM.ALLIES, false, "MAP_CONSTRUCTION_generator_2_allied");
	SetAvailableMapGoals( TEAM.ALLIES, false, "MAP_DYNAMITE_TARGET_generator_2_axis");
	SetAvailableMapGoals( TEAM.ALLIES, false, "MAP_CONSTRUCTION_defences_bridge");
	//Arty goals
	SetAvailableMapGoals( TEAM.ALLIES, false, "MAP_ARTY_SPOT_axis.*");
	SetAvailableMapGoals( TEAM.ALLIES, true, "MAP_ARTY_SPOT_allies_palace.*");
	SetAvailableMapGoals( TEAM.ALLIES, false, "MAP_ARTY_SPOT_allies_bridge.*");
	//snipe goals
	SetAvailableMapGoals( TEAM.ALLIES, false, "MAP_SNIPER_SPOT_axis.*");
	SetAvailableMapGoals( TEAM.ALLIES, true, "MAP_SNIPER_SPOT_allies_palace.*");
	SetAvailableMapGoals( TEAM.ALLIES, false, "MAP_SNIPER_SPOT_allies_bridge.*");
	//general
	SetAvailableMapGoals( TEAM.ALLIES, false, "MAP_MOUNTABLE.*");
	///Axis goals/////////////////
	//attack goals
	SetAvailableMapGoals( TEAM.AXIS, true, "ATTACK_axis_palace.*");
	SetAvailableMapGoals( TEAM.AXIS, false, "ATTACK_allies.*");
	SetAvailableMapGoals( TEAM.AXIS, false, "ATTACK_axis_bridge.*");
	//defend goals
	SetAvailableMapGoals( TEAM.AXIS, true, "DEFEND_axis_palace.*");
	SetAvailableMapGoals( TEAM.AXIS, false, "DEFEND_axis_bridge.*");
	SetAvailableMapGoals( TEAM.AXIS, false, "DEFEND_allies.*");
	//Engy goals
	SetAvailableMapGoals( TEAM.ALLIES, false, "MAP_CONSTRUCTION_generator_axis");
	SetAvailableMapGoals( TEAM.ALLIES, false, "MAP_DYNAMITE_TARGET_generator_allied");
	SetAvailableMapGoals( TEAM.ALLIES, true, "MAP_CONSTRUCTION_generator_2_axis");
	SetAvailableMapGoals( TEAM.ALLIES, true, "MAP_DYNAMITE_TARGET_generator_2_allied");
	//Arty goals
	SetAvailableMapGoals( TEAM.AXIS, true, "MAP_ARTY_SPOT_axis_palace.*");
	SetAvailableMapGoals( TEAM.AXIS, false, "MAP_ARTY_SPOT_axis_bridge.*");
	SetAvailableMapGoals( TEAM.AXIS, false, "MAP_ARTY_SPOT_allies.*");
	//snipe goals
	SetAvailableMapGoals( TEAM.AXIS, true, "MAP_SNIPER_SPOT_axis_palace.*");
	SetAvailableMapGoals( TEAM.AXIS, false, "MAP_SNIPER_SPOT_axis_bridge.*");
	SetAvailableMapGoals( TEAM.AXIS, false, "MAP_SNIPER_SPOT_allies.*");
	//general
	SetAvailableMapGoals( TEAM.ALLIES, false, "MAP_MOUNTABLE_MG42.*");
	Util.ResetGoals();
	
	//capture Waypoints
		Wp.SetWaypointFlag("team_capture_0", "team1", true);
		Wp.SetWaypointFlag("team_capture_0", "team2", false);
		Wp.SetWaypointFlag("team_capture_1", "team1", true);
		Wp.SetWaypointFlag("team_capture_1", "team2", false);
		Wp.SetWaypointFlag("team_capture_2", "team1", true);
		Wp.SetWaypointFlag("team_capture_2", "team2", false);
		Wp.SetWaypointFlag("team_capture_3", "team1", true);
		Wp.SetWaypointFlag("team_capture_3", "team2", false);
		Wp.SetWaypointFlag("team_capture_4", "team1", true);
		Wp.SetWaypointFlag("team_capture_4", "team2", false);
		Wp.SetWaypointFlag("team_capture_5", "team1", true);
		Wp.SetWaypointFlag("team_capture_5", "team2", false);
	//conditionals
		if (Map.EnableSwitches)
		{
			if(Map.EnableAllGarages)
			{
				if(Map.EnableGarage1)
				{
					if (Map.garage_1_position == 1)//door closed
					{
						Map.bp_Switches.garage_1.LimitTeam = (1<<TEAM.AXIS);
					}
					else if (Map.garage_1_position == 2)//door open
					{
						Map.bp_Switches.garage_1.LimitTeam = (1<<TEAM.ALLIES);
					}
				}
				if(Map.EnableGarage2)
				{
					if (Map.garage_2_position == 1)//door closed
					{
						Map.bp_Switches.garage_2.LimitTeam = (1<<TEAM.AXIS);
					}
					else if (Map.garage_2_position == 2)//door open
					{
						Map.bp_Switches.garage_2.LimitTeam = (1<<TEAM.ALLIES);
					}
				}
				if(Map.EnableGarage1)
				{				
				Map.bp_Switches.garage_3.LimitTeam = 0;//shift focus
				}
			}
		Map.bp_Switches.palace_flag.LimitTeam = (1<<TEAM.ALLIES);
		}
	Map.flag_team = 0;
	Map.FocusOnVehicle = -1;
	//print("Axis_Capture_Flag");
	ChangeTo1stSpawn();	
	},//end Axis capture
};//end global map

global OnMapLoad = function()
{
	//triger functions
	//flag
	//print("start map load");
	OnTrigger("The Allies have captured the Forward Bunker!", Map.Allies_Capture_Flag);
 	OnTrigger("The Axis have captured the Forward Bunker!", Map.Axis_Capture_Flag);
	//elevator 1
	OnTrigger("The Axis have repaired the First Elevator Generator!", Map.Axis_Own_Elevator);
	OnTrigger("The Allies have repaired the First Elevator Generator!", Map.Allies_Own_Elevator);
	OnTrigger("The First Elevator Generator has been Dammaged!", Map.Nither_Own_Elevator);
	OnTrigger("elevator", Map.Elevator_Activated);
	//elevator 2
	OnTrigger("The Axis have repaired the Second Elevator Generator!", Map.Axis_Own_Elevator_2);
	OnTrigger("The Allies have repaired the Second Elevator Generator!", Map.Allies_Own_Elevator_2);
	OnTrigger("The Second Elevator Generator has been Dammaged!", Map.Nither_Own_Elevator_2);
	OnTrigger("elevator_2", Map.Elevator_2_Activated);
	//Trams
	OnTrigger("tram_r", Map.Right_Tram_Activated);
	OnTrigger("tram_l", Map.Left_Tram_Activated);
	//sewer gates///
	OnTrigger("The Allies have destroyed the East Sewer Gate!", Map.East_Gate_Destroyed);
	OnTrigger("The Allies have destroyed the West Sewer Gate!", Map.West_Gate_Destroyed);
	OnTrigger("The Allies have destroyed the South Sewer Gate!", Map.South_Gate_Destroyed);
	//garage doors
	OnTrigger("g_door_l", Map.Trigger_garage_1);
	OnTrigger("g_door_l1", Map.Trigger_garage_2);
	OnTrigger("g_door_l2", Map.Trigger_garage_3);
	//bridge defences
	OnTrigger("The Axis have Built the Bridge Defences!", Map.Bridge_Defences_Built);
	OnTrigger("The Allies have destroyed the Bridge Defences!", Map.Bridge_Defences_Destroyed);
	//bridge objectives
	OnTrigger("The Allies have destroyed the East Bridge Support!", Map.East_Bridge_Destroyed);
	OnTrigger("The Allies have destroyed the West Bridge Support!", Map.West_Bridge_Destroyed);
	//print("end onTriggers");
  //start waypoints
  //bridge jump waypoints
	Wp.SetWaypointFlag("bridge_east_jump_0", "jumplow", false);
	Wp.SetWaypointFlag("bridge_east_jump_1", "jumplow", false);
	Wp.SetWaypointFlag("bridge_east_jump_2", "jumplow", false);
	Wp.SetWaypointFlag("bridge_east_jump_3", "jumplow", false);
	Wp.SetWaypointFlag("bridge_east_jump_4", "jumplow", false);
	Wp.SetWaypointFlag("bridge_west_jump_0", "jumplow", false);
	Wp.SetWaypointFlag("bridge_west_jump_1", "jumplow", false);
	Wp.SetWaypointFlag("bridge_west_jump_2", "jumplow", false);
	Wp.SetWaypointFlag("bridge_west_jump_3", "jumplow", false);
	Wp.SetWaypointFlag("bridge_west_jump_4", "jumplow", false);
	Wp.SetWaypointFlag("bridge_west_jump_5", "jumplow", false);
	Wp.SetWaypointFlag("bridge_west_jump_6", "jumplow", false);
	Wp.SetWaypointFlag("bridge_west_jump_0", "jumplow", false);
	//unblocked paths at start\\
	Wp.SetWaypointFlag("bridge_west_blocker_0", "closed", false);
	Wp.SetWaypointFlag("bridge_west_blocker_1", "closed", false);
	Wp.SetWaypointFlag("bridge_east_blocker_0", "closed", false);
	Wp.SetWaypointFlag("bridge_east_blocker_1", "closed", false);
	Wp.SetWaypointFlag("east_gate_block_0", "closed", false);
	Wp.SetWaypointFlag("east_gate_block_1", "closed", false);
	Wp.SetWaypointFlag("west_gate_block_0", "closed", false);
	Wp.SetWaypointFlag("west_gate_block_1", "closed", false);
	Wp.SetWaypointFlag("south_gate_block_0", "closed", false);
	Wp.SetWaypointFlag("south_gate_block_1", "closed", false);
	Wp.SetWaypointFlag("bridge_defences_door_0", "team1", false);
	Wp.SetWaypointFlag("bridge_defences_door_1", "team1", false);
	//blocked paths at start
	Wp.SetWaypointFlag("elevator_middle_1", "closed", true);
	Wp.SetWaypointFlag("elevator_middle_2", "closed", true);
	Wp.SetWaypointFlag("elevator_2_middle_1", "closed", true);
	Wp.SetWaypointFlag("elevator_2_middle_2", "closed", true);
	Wp.SetWaypointFlag("elevator_top", "closed", true);
	Wp.SetWaypointFlag("elevator_2_top", "closed", true);
	////////////////////////////////////////////////
	//testing for allies at elevator 1/////////////
	//Wp.SetWaypointFlag("test_0", "closed", true);
	//Wp.SetWaypointFlag("test_1", "closed", true);
	Wp.SetWaypointFlag("test_0", "closed", false);
	Wp.SetWaypointFlag("test_1", "closed", false);	
	////////////////////////////////////////////////
	//print("end waypoints");
	//Utils
	Util.SetMaxUsersInProgress( 1, "MAP_MOUNTABLE_MG42_.*" );
	Util.ResetGoals();
	///map goal tables
	if (Map.EnableSwitches)
	{
		Map.UpdateSwitchData ();
		//print("end switchs");
	}
	if (Map.EnableLadders)
	{
		Wp.SetWaypointFlag("ladder_block", "closed", false);
		Map.UpdateLaddersData ();
		//print("end ladders");
	}
	else
	{
		Wp.SetWaypointFlag("ladder_block", "closed", true); //block the ladder in chirch tower/ covert-opps bots will get stuck here otherwise
	}
	//threads
	if (Map.EnableSwitches && Map.EnableElevator1 && Map.EnableAllElevators)
	{
		thread(Map.Watch_Elevator_1);
	}
	if (Map.EnableSwitches && Map.EnableElevator2 && Map.EnableAllElevators)
	{
	thread(Map.Watch_Elevator_2);
	}
	if (Map.EnableSwitches && Map.EnableRightTram && Map.EnableAllTrams)
	{
		thread(Map.Watch_Right_Tram);	
	}
	if (Map.EnableSwitches && Map.EnableLeftTram && Map.EnableAllTrams)
	{
		thread(Map.Watch_Left_Tram);
	}
	//print("end threads");
	if (Map.EnableSwitches || Map.EnableLadders)
	{
		Map.StartBotThread ();
	}
	Map.FocusOnVehicle = -1;
	ChangeTo1stSpawn();	
	//print("end map load");
};

Map.Watch_Elevator_1 = function()
{	
// pre: this thread watches the elevator 1 and changes the switchs 
	stop_bool = false; //true = run this code, false = stop running this code
	while(true)
	{
		if(Map.elevator_team == 0)
		{	//pre: no team owns this elevator
			Map.bp_Switches.elevator_bottom.LimitTeam = 0; 
			Map.bp_Switches.elevator_switch_bottom.LimitTeam = 0;
			Map.bp_Switches.elevator_top.LimitTeam = 0; 
			Map.bp_Switches.elevator_switch_top.LimitTeam = 0;
			Wp.SetWaypointFlag("elevator_top", "closed", true);
			Wp.SetWaypointFlag("elevator_bottom", "closed", true);
			//print("elevator_1_Blocked");
			block("elevator_1_built");//set and then halt
			//print("elevator_1_unBlocked");
		}  //post: block execution untill the elevator is built
		else if(Map.elevator_team == 2 )//no team 1 = axis, 2 = allies
		{ //pre: the elevator is controled by allies and has been activated
			top = TestTraceFunc("elevator_top", "elevator_middle_1");
			middle = TestTraceFunc("elevator_middle_1", "elevator_middle_2");
			if (top && !middle && !stop_bool)//at top
			{ //pre: at top
				stop_bool = true; //ok to run middle code
				Map.elevator_position = 1;//set elevator to top position.
				Map.bp_Switches.elevator_switch_bottom.LimitTeam = (1<<TEAM.ALLIES); //switch to raise elevator
				Wp.SetWaypointFlag("elevator_top", "closed", false);
				Wp.SetWaypointFlag("elevator_bottom", "closed", true);
				//print("top_1_Allies, blocked");
				block("elevator_1_activated");//set and then halt
				//print("top_1_Allies, unBlocked");
			} //post: moving in the middle
			else if(!top && !middle && !stop_bool)//at bottom
			{ //pre: at bottom
				stop_bool = true; //ok to run middle code
				Map.elevator_position = 2;
				Map.bp_Switches.elevator_bottom.LimitTeam = (1<<TEAM.ALLIES);
				Wp.SetWaypointFlag("elevator_top", "closed", true);
				Wp.SetWaypointFlag("elevator_bottom", "closed", false);
				//print("bottom_1_Allies, blocked");
				block("elevator_1_activated");//set and then halt
				//print("bottom_1_Allies, unBlocked");
			} //post: moving in the middle
			else if (stop_bool)
			{ //pre: moving in the middle
				stop_bool = false; //ok to run top or bottom code
				Map.elevator_position = 0;
				Map.bp_Switches.elevator_bottom.LimitTeam = 0; 
				Map.bp_Switches.elevator_switch_bottom.LimitTeam = 0;
				Wp.SetWaypointFlag("elevator_2_top", "closed", true);
				Wp.SetWaypointFlag("elevator_2_bottom", "closed", false);	
				//print("moving allies");
			} //post: at the top or the bottom
		}
		else if(Map.elevator_team == 1 )//no team 1 = axis, 2 = allies
		{ //pre: the elevator is controled by axis and has been activated
			top = TestTraceFunc("elevator_top", "elevator_middle_1");
			middle = TestTraceFunc("elevator_middle_1", "elevator_middle_2");
			if (top && !middle && !stop_bool)
			{ //pre: at top
				stop_bool = true; //ok to run middle code
				Map.elevator_position = 1;//set elevator to top position.
				Map.bp_Switches.elevator_top.LimitTeam = (1<<TEAM.AXIS); //switch to raise elevator
				Wp.SetWaypointFlag("elevator_top", "closed", false);
				Wp.SetWaypointFlag("elevator_bottom", "closed", true);
				//print("top_1_Axis, blocked");
				block("elevator_1_activated");//set and then halt
				//print("top_1_Axis, unBlocked");
			} //post: moving in the middle
			else if(!top && !middle && !stop_bool)
			{ //pre: at bottom
				stop_bool = true; //ok to run middle code
				Map.elevator_position = 2;
				Map.bp_Switches.elevator_switch_top.LimitTeam = (1<<TEAM.AXIS);
				Wp.SetWaypointFlag("elevator_top", "closed", true);
				Wp.SetWaypointFlag("elevator_bottom", "closed", false);
				//print("bottom_1_Axis, blocked");
				block("elevator_1_activated");//set and then halt
				//print("bottom_1_Axis, unBlocked");
			} //post: moving in the middle
			else if (stop_bool)
			{ //pre: moving in the middle
				stop_bool = false; //ok to run top or bottom code
				Map.elevator_position = 0;
				Map.bp_Switches.elevator_top.LimitTeam = 0; 
				Map.bp_Switches.elevator_switch_top.LimitTeam = 0;
				Wp.SetWaypointFlag("elevator_2_top", "closed", true);
				Wp.SetWaypointFlag("elevator_2_bottom", "closed", false);
				//print("moving axis");
			} //post: at the top or the bottom
		}	
	sleep(0.25);
	}
};		
		
Map.Watch_Elevator_2 = function()
{
	//pre: this thread watches the elevator 2 and changes the switchs 
	stop_bool = false; //true = run this code, false = stop running this code
	while(true)
	{ 
		if(Map.elevator_2_team == 0) 
		{ //pre: no team owns this elevator
			Map.bp_Switches.elevator_2_bottom.LimitTeam = 0; 
			Map.bp_Switches.elevator_2_switch_bottom.LimitTeam = 0;
			Map.bp_Switches.elevator_2_top.LimitTeam = 0; 
			Map.bp_Switches.elevator_2_switch_top.LimitTeam = 0;
			Wp.SetWaypointFlag("elevator_2_top", "closed", true);
			Wp.SetWaypointFlag("elevator_2_bottom", "closed", true);
			//print("elevator_2_Blocked");
			block("elevator_2_built");//set and then halt
			//print("elevator_2_unBlocked");
		} //post: block execution untill the elevator is built
		else if(Map.elevator_2_team == 2)//no team 1 = axis, 2 = allies
		{ //pre: the elevator is controled by allies and has been activated
			top = TestTraceFunc("elevator_2_top", "elevator_2_middle_1");
			middle = TestTraceFunc("elevator_2_middle_1", "elevator_2_middle_2");
			if (top && !middle && !stop_bool) 
			{ //pre: at top
				stop_bool = true; //ok to run code
				Map.elevator_2_position = 1;//set elevator to bottom position.
				Map.bp_Switches.elevator_2_top.LimitTeam = (1<<TEAM.ALLIES); //switch to raise elevator
				Wp.SetWaypointFlag("elevator_2_top", "closed", false);
				Wp.SetWaypointFlag("elevator_2_bottom", "closed", true);
				//print("top_2_Allies, blocked");
				block("elevator_2_activated");//set and then halt
				//print("top_2_Allies, unBlocked");
			} //post: moving in the middle
			else if(!top && !middle && !stop_bool)
			{ //pre: at bottom
				stop_bool = true;
				Map.elevator_2_position = 2;
				Map.bp_Switches.elevator_2_switch_top.LimitTeam = (1<<TEAM.ALLIES);
				Wp.SetWaypointFlag("elevator_2_top", "closed", true);
				Wp.SetWaypointFlag("elevator_2_bottom", "closed", false);
				//print("bottom_2_Allies, blocked");
				block("elevator_2_activated");//set and then halt
				//print("bottom_2_Allies, unBlocked");
			} //post: moving in the middle
			else if (stop_bool)
			{  //pre: moving in the middle
				stop_bool = false; //stop running this code only needs to run 1 time
				Map.elevator_2_position = 0;
				Map.bp_Switches.elevator_2_top.LimitTeam = 0; 
				Map.bp_Switches.elevator_2_switch_top.LimitTeam = 0;
				Wp.SetWaypointFlag("elevator_2_top", "closed", true);
				Wp.SetWaypointFlag("elevator_2_bottom", "closed", true);		
				sleep(1); //timing issue
				//print("moving_2_Allies");
			} //post: at the top or the bottom
		}
		else if(Map.elevator_2_team == 1 )//no team 1 = axis, 2 = allies
		{ //pre: the elevator is controled by axis and has been activated
			top = TestTraceFunc("elevator_2_top", "elevator_2_middle_1");
			middle = TestTraceFunc("elevator_2_middle_1", "elevator_2_middle_2");
			if (top && !middle && !stop_bool)
			{ //pre: at top
				stop_bool = true;
				Map.elevator_2_position = 1;//set elevator to bottom position.
				Map.bp_Switches.elevator_2_switch_bottom.LimitTeam = (1<<TEAM.AXIS); //switch to raise elevator
				Wp.SetWaypointFlag("elevator_2_top", "closed", false);
				Wp.SetWaypointFlag("elevator_2_bottom", "closed", true);
				//print("top_2_Axis, blocked");
				block("elevator_2_activated");//set and then halt
				//print("top_2_Axis, unBlocked");
			} //post: moving in the middle
			else if(!top && !middle && !stop_bool)
			{ //pre: at bottom
				stop_bool = true; //ok to run middle code
				Map.elevator_2_position = 2;
				Map.bp_Switches.elevator_2_bottom.LimitTeam = (1<<TEAM.AXIS);
				Wp.SetWaypointFlag("elevator_2_top", "closed", true);
				Wp.SetWaypointFlag("elevator_2_bottom", "closed", false);
				//print("bottom_2_Axis, blocked");
				block("elevator_2_activated");//set and then halt
				//print("bottom_2_Axis, unBlocked");
			} //post: moving in the middle
			else if (stop_bool) 
			{ //pre: moving in the middle
				stop_bool = false; //ok to run top or bottom code
				Map.elevator_2_position = 0;
				Map.bp_Switches.elevator_2_bottom.LimitTeam = 0; 
				Map.bp_Switches.elevator_2_switch_bottom.LimitTeam = 0;
				Wp.SetWaypointFlag("elevator_2_top", "closed", true);
				Wp.SetWaypointFlag("elevator_2_bottom", "closed", true); 
				//print("moving_2_Axis");
				sleep(1); //timing issue
			} //post: at the top or the bottom
		}
		sleep(0.25);
	}
};

Map.Watch_Right_Tram = function()
{
//print("starting Right_Tram thread");	
block_bool = true; //true = blocked, false = not blocked
stop_bool = false; //true = run, false = dont run
	while(true)
	{
	//this thread watches the right tram and changes the switchs 	
		top = TestTraceFunc("tram_r_top", "tram_r_block_top");
		bottom = TestTraceFunc("tram_r_bottom", "tram_r_block_bottom");
		if (top && !stop_bool)
		{ //pre: vehical is at the top
			stop_bool = true; //ok to run moving code now
			Map.bp_Switches.tram_r_switch_bottom.LimitTeam = (1<<TEAM.AXIS);
			Map.bp_Switches.tram_r_top.LimitTeam = (1<<TEAM.ALLIES);
			if (!block_bool) //has the vehical moved?
			{
				//print("Right Tram blocked top");
				block("Activate_Right_Tram"); //block thread untill activated
				block_bool = true; //was just blocked dont block tell after move
				//print("Right Tram unblocked top");
			} //post: block execution untill used
		} //post: vehical is moving in the middle
		else if (bottom && !stop_bool)//at bottom going up
		{ //pre: vehical is at the top
			stop_bool = true; //ok to run moving code now
			Map.bp_Switches.tram_r_bottom.LimitTeam = (1<<TEAM.AXIS);
			Map.bp_Switches.tram_r_switch_top.LimitTeam = (1<<TEAM.ALLIES);
			if (!block_bool) //has the vehical moved?
			{
				//print("Right Tram blocked bottom");
				block("Activate_Right_Tram"); //block thread untill activated
				block_bool = true; //was just blocked dont block tell after move
				//print("Right Tram unblocked bottom");
			} //post: block execution untill used
		} //post: vehical is moving in the middle
		else if (stop_bool)
		{ //pre: this runs if vehical is not at top or bottom ie. moving in the middle
			stop_bool = false; //ok to run top/bottom code
			block_bool = false; //now its ok to block
			Map.bp_Switches.tram_r_switch_bottom.LimitTeam = 0;
			Map.bp_Switches.tram_r_bottom.LimitTeam = 0;
			Map.bp_Switches.tram_r_switch_top.LimitTeam = 0;
			Map.bp_Switches.tram_r_top.LimitTeam = 0;
			//print("Right_Tram Moving");
			sleep(1); //timing issue on up
		}//post: vehical is at the top or the bottom	
		sleep(0.25);
	}
};

Map.Watch_Left_Tram = function()
{
//print("starting Left_Tram thread");	
block_bool = true; //true = blocked, false = not blocked
stop_bool = false; //true = run, false = dont run
	while(true)
	{
	//this thread watches the left tram and changes the switchs & is basicly a copy of the above one execpt for waypoint names 	
		top = TestTraceFunc("tram_l_top", "tram_l_block_top");
		bottom = TestTraceFunc("tram_l_bottom", "tram_l_block_bottom");
		if (top && !stop_bool)
		{ //pre: vehical is at the top
			stop_bool = true; //ok to run moving code now
			Map.bp_Switches.tram_l_switch_bottom.LimitTeam = (1<<TEAM.AXIS);
			Map.bp_Switches.tram_l_top.LimitTeam = (1<<TEAM.ALLIES);
			if (!block_bool) //has the vehical moved?
			{
				//print("Left Tram blocked top");
				block("Activate_Left_Tram"); //block thread untill activated
				block_bool = true; //was just blocked dont block tell after move
				//print("Left Tram unblocked top");
			} //post: block execution untill used
		} //post: vehical is moving in the middle
		else if (bottom && !stop_bool)
		{ //pre: vehical is at the bottom
			stop_bool = true; //ok to run moving code now
			Map.bp_Switches.tram_l_bottom.LimitTeam = (1<<TEAM.AXIS);
			Map.bp_Switches.tram_l_switch_top.LimitTeam = (1<<TEAM.ALLIES);
			if (!block_bool) //has the vehical moved?
			{
				//print("Left Tram blocked bottom");
				block("Activate_Left_Tram"); //block thread untill activated
				block_bool = true; //was just blocked dont block tell after move
				//print("Left Tram unblocked bottom");
			} //post: block execution untill used
		} //post: vehical is moving in the middle
		else if (stop_bool)
		{ //pre: this runs if vehical is not at top or bottom ie. moving in the middle
			stop_bool = false; //ok to run top/bottom code now
			block_bool = false; //now its ok to block
			Map.bp_Switches.tram_l_switch_bottom.LimitTeam = 0;
			Map.bp_Switches.tram_l_bottom.LimitTeam = 0;
			Map.bp_Switches.tram_l_switch_top.LimitTeam = 0;
			Map.bp_Switches.tram_l_top.LimitTeam = 0;
			//print("Left_Tram Moving");
			sleep(1); //timing issue on up
		} //post: vehical is at the top or the bottom
		sleep(0.25);
	}
};

Map.StartBotThread = function()
{
	//print("Map.StartBotThread"); 
	foreach ( Id and bot in BotTable )
	{
	//--------create threads after map loads-------------//
	if( bot.WaypointThreadId )
	{
	//print ( "Killing Thread: ", bot.WaypointThread );
	threadKill( bot.WaypointThread );
	}
	bot.WaypointThreadId = bot:thread(Map.WatchForbp_Switches);
	//print("Creating Thread: ", bot.WaypointThreadId);
	}
};

Map.UpdateSwitchData = function()
{
//print( "Switches_Updating");
	foreach ( i and bp_SwitchTable in Map.bp_Switches )
	{
		bp_SwitchTable.Waypoint = table();
		if( Wp.GetWaypointByName( bp_SwitchTable.WaypointName, bp_SwitchTable.Waypoint ) )
		{
			//print( "switch Data Suceeded, Waypoint:", bp_SwitchTable.WaypointName );
		}
		else
		{
			//print( "Error: switch Data Failed, Waypoint:", bp_SwitchTable.WaypointName );
		}
		if (bp_SwitchTable.LimitClass == null)//no setting all classes as default
		{	
		bp_SwitchTable.LimitClass = (1<<CLASS.SOLDIER) | 
			(1<<CLASS.COVERTOPS) | 
			(1<<CLASS.FIELDOPS) |
			(1<<CLASS.ENGINEER) |
			(1<<CLASS.MEDIC);
			//print("defualt classes set");
		}
		if (bp_SwitchTable.UseDelay == null)
		{
			bp_SwitchTable.UseDelay = 0; //no value set a default value
			//print("defualt delay set");
		}
		
	}
};


