/*
 * TODO:
 *	- Not much concerning for me but worth noting: while Axis Split is on, Axis mortar can potentially spawn at the Island while Guardpost is available
 *	---
 *	- Manage the Nebelwerfer (Compound)?
 *	  * Multiple rocket launcher to take down the Glider; max load: 6; hits to take down the Glider: 3; not very accurate
 *	  * Panzer can also do this, perhaps have a bot on this?
 */

global MapStep =
{
	START = 0,
	ALLIED_CP_BUILT_ONCE = 1,
	GENERATOR_DESTROYED = 2,
	TANK_PAST_FIRST_BARRIER = 3, // For spawn management
	GUARDPOST_REACHED = 4,
	ME109_AIRSTRIKES_AVAILABLE = 5, // run_43 (tank_range_check)
	ME109_AIRSTRIKES_UNAVAILABLE = 6 // run_83 (tank_range_check)
};

global Spawn =
{
	PARACHUTE	= 1, // Only available at start, mirror of Outpost team owning; unavailable once Allied CP built once
	OUTPOST		= 2, // Capturable at first, both teams can spawn, then unavailable upon Allied PC built once, then Axis-only once Guardpost reached
	RUINS		= 3, // Allied spawn, unlocked definitively upon building related CP, unavailable once Guardpost reached
	GUARDPOST	= 4, // Capturable, both teams can spawn; then Allied-only once Guardpost reached
	COMPOUND	= 5, // Axis spawn at start, unavailable once Guardpost reached
	ISLAND		= 6, // Capturable, Axis spawning only
	TANK_GARAGE	= 7, // Capturable once Generator destroyed, Allied spawning only, unavailable once Guardpost reached

	Init = function()
	{
		if ( Spawn.InitDone ) { return; }

		Spawn.Axis		= Spawn.OUTPOST;
		Spawn.Allies	= Spawn.PARACHUTE;

		Spawn.GuardpostOwner	= TEAM.ALL;
		Spawn.IslandOwner		= TEAM.ALLIES;
		Spawn.OutpostOwner		= TEAM.AXIS;
		Spawn.TankGarageOwner	= TEAM.AXIS;

		Spawn.AxisSplit = false;

		Util.MapDebugPrint( "Spawn-related variables initialized", true );

		Spawn.InitDone = true;

		Spawn.MoveTeam( TEAM.AXIS ); // If they were spawning at the Compound before a map_restart...
	},

	Manage = function()
	{
		previousAxis = Spawn.Axis;
		previousAllies = Spawn.Allies;

		previousAxisSplit = Spawn.AxisSplit;

		// We ignore the steps where there's no much important choice about spawning, or it is handled by the map itself
		// Thus, the focus of this function is between Tank past 1st barrier and Guardpost reached
		if ( Map.Step == MapStep.TANK_PAST_FIRST_BARRIER )
		{
			// Each team has between 1 and 3 spawn(s) available during this phase
			// Axis: Compound, Island, Guardpost
			// Allies: Ruins, Tank Garage, Guardpost
			// ---
			// Axis should spawn at Guardpost or Island, to be in position (possible spawn split if both owned)
			// Allies should spawn at the closest spawn to the Tank, either Tank Garage or Guardpost
			Spawn.AxisSplit = false;
			axisScore = Spawn.GetAxisScore();
			switch ( axisScore )
			{
				case 1: { Spawn.Axis = Spawn.COMPOUND; }
				case 3: { Spawn.Axis = Spawn.ISLAND; }
				case 5: { Spawn.Axis = Spawn.GUARDPOST; }
				case 7:
				{
					Spawn.Axis = Spawn.GUARDPOST;
					Spawn.AxisSplit = DistanceBetweenSpawnPolesAndTankTracker.currentClosestSpawn == Spawn.TANK_GARAGE;
				}
				default: { Error( "Unexpected Axis score: " + axisScore ); }
			}

			alliesScore = Spawn.GetAlliesScore();
			switch ( alliesScore )
			{
				case 1: { Spawn.Allies = Spawn.RUINS; }
				case 3: { Spawn.Allies = Spawn.TANK_GARAGE; }
				case 5: { Spawn.Allies = Spawn.GUARDPOST; }
				case 7: { Spawn.Allies = DistanceBetweenSpawnPolesAndTankTracker.currentClosestSpawn; }
				default: { Error( "Unexpected Allies score: " + alliesScore ); }
			}
		}
		else if ( Map.Step == MapStep.GENERATOR_DESTROYED )
		{
			// This step only matters for Allies
			if ( Spawn.TankGarageOwner == TEAM.ALLIES )
			{
				Spawn.Allies = Spawn.TANK_GARAGE;
			}
			else
			{
				Spawn.Allies = Spawn.RUINS;
			}
		}
		else if ( Map.Step == MapStep.GUARDPOST_REACHED )
		{
			// This step mainly matters for Axis, if they spawn at the Island
			Spawn.Axis		= Spawn.OUTPOST;
			Spawn.Allies	= Spawn.GUARDPOST;
		}

		//Util.MapDebugPrint( Spawn.GetName( previousAxis ) + " -> " + Spawn.GetName( Spawn.Axis ), true );
		//Util.MapDebugPrint( Spawn.GetName( previousAllies ) + " -> " + Spawn.GetName( Spawn.Allies ), true );

		if ( Spawn.Axis != previousAxis || Spawn.AxisSplit != previousAxisSplit )
		{
			Spawn.MoveTeam( TEAM.AXIS );
		}

		if ( Spawn.Allies != previousAllies )
		{
			Spawn.MoveTeam( TEAM.ALLIES );
		}
	},

	GetAxisScore = function()
	{
		score = 1; // Compound-only
		if ( Spawn.IslandOwner == TEAM.AXIS ) { score += 2; }
		if ( Spawn.GuardpostOwner == TEAM.AXIS ) { score += 4; }
		return score;
	},

	GetAlliesScore = function()
	{
		score = 1; // Ruins-only
		if ( Spawn.TankGarageOwner == TEAM.ALLIES ) { score += 2; }
		if ( Spawn.GuardpostOwner == TEAM.ALLIES ) { score += 4; }
		return score;
	},

	MoveTeam = function( team )
	{
		if ( Map.Debug )
		{
			spawnName;
			if ( team == TEAM.AXIS ) { spawnName = Spawn.GetName( Spawn.Axis ); } else { spawnName = Spawn.GetName( Spawn.Allies ); }
			print( Util.DebugColorString + "Moving " + Util.TeamName( team ) + " to " + spawnName + " spawn" );
			if ( team == TEAM.AXIS) { print( Util.DebugColorString + "=> Axis split: " + ToString( Spawn.AxisSplit ) ); }
		}

		foreach ( bot in BotTable )
		{
			if ( bot.GetTeam() != team ) { continue; }
			Spawn.MoveBot( bot );
		}
	},

	MoveBot = function( bot )
	{
		if ( bot.GetTeam() == TEAM.AXIS )
		{
			if ( !Spawn.AxisSplit ) { bot.ChangeSpawnPoint( Spawn.Axis ); }
			else
			{
				spawn;
				if ( RandInt( 0, 9 ) < 5 ) { spawn = Spawn.GUARDPOST; } else { spawn = Spawn.ISLAND; }
				bot.ChangeSpawnPoint( spawn );
			}
		}
		else
		{
			bot.ChangeSpawnPoint( Spawn.Allies );
		}
	},

	GetName = function( spawnId )
	{
		switch ( spawnId )
		{
			case Spawn.PARACHUTE:	{ return "Parachute"; }
			case Spawn.OUTPOST:		{ return "Outpost"; }
			case Spawn.RUINS:		{ return "Ruins"; }
			case Spawn.GUARDPOST:	{ return "Guardpost"; }
			case Spawn.COMPOUND:	{ return "Compound"; }
			case Spawn.ISLAND:		{ return "Island"; }
			case Spawn.TANK_GARAGE:	{ return "Tank Garage"; }
		}

		return "{Unknown spawn ID: " + spawnId + "}";
	}
};

global Map =
{
	Debug = 0, // Please set to zero before distributing your script

	Step = MapStep.START,

	IsTankDestroyed = false,

	/**
	 * Function which handles Axis classes,
	 * once the Tank has passed the Guardpost and is in sight
	 * It does override the default configuration from et_autoexec.gm,
	 * but just for Axis, and just for the end of this map
	 */
	AxisClassManager = function()
	{
		nbAxisBots = Server.Team[TEAM.AXIS].NumBots;

		if ( nbAxisBots < 4 )
		{
			return;
		}

		if ( nbAxisBots > 16 )
		{
			nbAxisBots = 16;
		}

		switch( nbAxisBots )
		{
			case  4: { Map.ChangeAxisMinClassCount( 0, 1, 1, 1, 1 ); }
			case  5: { Map.ChangeAxisMinClassCount( 0, 1, 2, 1, 1 ); }
			case  6: { Map.ChangeAxisMinClassCount( 0, 2, 2, 1, 1 ); }
			case  7: { Map.ChangeAxisMinClassCount( 0, 2, 2, 1, 2 ); }
			case  8: { Map.ChangeAxisMinClassCount( 1, 2, 2, 1, 2 ); }
			case  9: { Map.ChangeAxisMinClassCount( 1, 2, 3, 1, 2 ); }
			case 10: { Map.ChangeAxisMinClassCount( 1, 3, 3, 1, 2 ); }
			case 11: { Map.ChangeAxisMinClassCount( 1, 3, 3, 2, 2 ); }
			case 12: { Map.ChangeAxisMinClassCount( 1, 3, 3, 2, 3 ); }
			case 13: { Map.ChangeAxisMinClassCount( 1, 3, 4, 2, 3 ); }
			case 14: { Map.ChangeAxisMinClassCount( 1, 4, 4, 2, 3 ); }
			case 15: { Map.ChangeAxisMinClassCount( 1, 4, 4, 3, 3 ); }
			case 16: { Map.ChangeAxisMinClassCount( 1, 4, 4, 4, 3 ); }
		}
	},

	/**
	 * Sets the MinClassCount value of the Axis for each class
	 * No value check since this is just used here...
	 * Each param is explicitely named
	 */
	ChangeAxisMinClassCount = function( soldierCount, medicCount, engineerCount, fieldopsCount, covertopsCount )
	{
		Server.MinClassCount[TEAM.AXIS][CLASS.SOLDIER]		= soldierCount;
		Server.MinClassCount[TEAM.AXIS][CLASS.MEDIC]		= medicCount;
		Server.MinClassCount[TEAM.AXIS][CLASS.ENGINEER]		= engineerCount;
		Server.MinClassCount[TEAM.AXIS][CLASS.FIELDOPS]		= fieldopsCount;
		Server.MinClassCount[TEAM.AXIS][CLASS.COVERTOPS]	= covertopsCount;
	},

	Movers =
	{
		"MOVER_glider_sm"
	},

	// Navigation ladder
	Navigation =
	{
		// Generator Room Ladder
		// /bot waypoint_setproperty paththrough Navigation_PT:bunkerladderf
		bunkerladderf =
		{
			navigate = function(_this)
			{
				if ( !Map.BunkerLadderFacing )
				{
					Map.BunkerLadderFacing = Util.WpNameInfo("LD1");
				}

				_this.AddAimRequest(Priority.High, "facing", Map.BunkerLadderFacing.facing);
				_this.Bot.HoldButton( BTN.FORWARD, 4 );

				Map.BunkerLadderFacing = null;

				sleep( 4 ); // For how ever long the bot should keep the aim request
			}
		},

		// Make Axis jump through a window at the Compound
		window_jump =
		{
			navigate = function(_this)
			{
				_this.Bot.HoldButton( BTN.JUMP, 1 );
				sleep( .5 );
				_this.Bot.HoldButton( BTN.CROUCH, 1 );
				sleep( 1 );
			}
		}
	},

	// ---

	// *** TRIGGER CALLBACKS ***

	Allied_Command_Post_Built = function( trigger )
	{
		if ( Map.Step >= MapStep.ALLIED_CP_BUILT_ONCE )
		{
			Util.MapDebugPrint( "Allied_Command_Post_Built", true );
			return;
		}

		Map.Step = MapStep.ALLIED_CP_BUILT_ONCE;

		// ---

		Spawn.Axis = Spawn.COMPOUND;
		Spawn.Allies = Spawn.RUINS;

		// Saw them still spawn at the Outpost...
		Spawn.MoveTeam( TEAM.AXIS );
		Spawn.MoveTeam( TEAM.ALLIES );

		// Make all bots under Ruins Hill self kill and spawn at Allied CP/Axis Base
		// Thanks crapshoot :)
		Map.Kill_Bots_Upon_Allied_CP_First_Built();

		// ---

		Util.DisableGoal( ".*", true ); // All but routes
		Map.Enable_Cabinets();

		// Open the falling ways near Ruins, base side,
		// so Allies can reach bottom spots
		Wp.SetWaypointFlag( "ruins[34]", "closed", false );

		// Let the game update the waypoints flags
		Wp.CheckBlockable();

		SetAvailableMapGoals( TEAM.AXIS, true, {
			"CHECKPOINT_guardpost_flag",
			"DEFEND_GA.*",
			"BUILD_Tank_Barrier_1",
			"MOUNTMG42_Compound_MG42_2",
			"REPAIRMG42_Compound_MG42_2"
		});

		SetAvailableMapGoals( TEAM.ALLIES, true, {
			"DEFEND_CP1",
			"DEFEND_CP3",
			"DEFEND_CP6",
			"DEFEND_CP7",
			"BUILD_Assault_Ramp",
			"MOBILEMORTAR_AlliedCP"
		});

		Util.SetMaxUsers( 1, "CHECKPOINT_.*" ); // Only 1 Axis going for Guardpost

		Util.MapDebugPrint( "Allied_Command_Post_First_Built" );
	},

	Kill_Bots_Upon_Allied_CP_First_Built = function()
	{
		foreach ( bot in BotTable )
		{
			if ( bot.Health <= 0 ) { continue; }
			if ( bot.GetPosition().y >= 8445 ) { continue; }
			thread( Map.Kill_Bot, bot );
		}
	},

	Kill_Bot = function( bot )
	{
		while ( bot.GetPosition().y < 8445 && bot.Health > 0 )
		{
			bot.ExecCommand( "kill" );

			// Revive/Spawn invulnerability
			sleep( 1 );
		}
	},

