	KeySmile_Dropped = function( trigger )
	{
		Map.KeySmileTaken = false;
		Map.KeySmileDropped = true;
		Util.MapDebugPrint( "Keysmile Dropped" );
//		Util.MapDebugPrint( "^3KeySmileTaken = " + Map.KeySmileTaken );
//		Util.MapDebugPrint( "^3KeySmileDropped = " + Map.KeySmileDropped );
//		Util.MapDebugPrint( "^3KeySmileReturned = " + Map.KeySmileReturned );
//		Util.MapDebugPrint( "^3KeySmileSecured = " + Map.KeySmileSecured );
	},
	
	keysmile_Returned = function( trigger )
	{
		Map.KeySmileDropped = false;
		Map.KeySmileReturned = true;

		if(Map.GasVentilator)
		{
			SetAvailableMapGoals(TEAM.AXIS, true, "DEFEND_Smile_key_0.*");
			SetAvailableMapGoals(TEAM.ALLIES, true, "DEFEND_Smile_key_.*");
			SetAvailableMapGoals(TEAM.ALLIES, true, "PLANT_Gas_ventilator");
		}
		else
		{
			SetAvailableMapGoals(TEAM.AXIS, true, "BUILD_Gas_ventilator");
			SetAvailableMapGoals(TEAM.AXIS, true, "DEFEND_Smile_key_1.*");
			SetAvailableMapGoals(TEAM.ALLIES, false, "DEFEND_Smile_key_1.*");
		}
		SetAvailableMapGoals(TEAM.AXIS, false,
		{
			"CAPPOINT_keysmile",
			"ATTACK_KeySmile_.*",
			"DEFEND_Altar_Right_0.*",
			"MOBILEMG42_Smile_Key_.*",
		});
		Wp.SetWaypointFlag("keysmile_temple_entrance", "allies", false);
		Wp.SetWaypointFlag("keysmile_temple_entrance_out", "allies", false);
		if(Map.KeyMadTaken || Map.KeyMadDropped && !Map.KeyMadSecured)
		{
			SetAvailableMapGoals(TEAM.ALLIES, false,
			{
				"DEFEND_Cappoint_Keys_.*",
			});
		}

		Util.MapDebugPrint( "Keysmile_Returned!" );
//		Util.MapDebugPrint( "^3KeySmileTaken = " + Map.KeySmileTaken );
//		Util.MapDebugPrint( "^3KeySmileDropped = " + Map.KeySmileDropped );
//		Util.MapDebugPrint( "^3KeySmileReturned = " + Map.KeySmileReturned );
//		Util.MapDebugPrint( "^3KeySmileSecured = " + Map.KeySmileSecured );
//		Util.MapDebugPrint("^5KeyMad_TAKEN = " + Map.KeyMadTaken );
//		Util.MapDebugPrint("^5KeyMad_SECURED = " + Map.KeyMadSecured );
	},

	keysmile_Secured = function( trigger )
	{
		Wp.SetWaypointFlag("keysmile_temple_entrance", "allies", false);
		Wp.SetWaypointFlag("keysmile_temple_entrance_out", "allies", false);
		Map.KeySmileTaken = false;
		Map.KeySmileSecured = true;
		SetAvailableMapGoals(TEAM.AXIS, false,
		{
			"BUILD_Gas_ventilator",
			"CAPPOINT_keysmile",
			"FLAG_keysmile",
			"ATTACK_KeySmile_.*",
			"DEFEND_Smile_key_.*",
			"DEFEND_Altar_Right_0.*",
			"DEFEND_Gas_Ventillator",
			"DEFUSE_Gas_ventillator_.*",
			"MOBILEMG42_Smile_Key_.*",
		});
		if(Map.KeyMadSecured)
		{
			SetAvailableMapGoals(TEAM.AXIS, true,
			{
				"FLAG_book_of_wisdom",
				"PLANTMINE_alt_.*",
				"CALLARTILLERY_Book_1",
				"ARTILLERY_S_MG42",
				"ATTACK_Book_.*",
				"MOBILEMG42_Mad_Key_.*",
				"HEALTHCAB_first_healthcabinet_1",
				"AMMOCAB_first_ammocabinet_1",
			});
			
			if(GetCvar("g_friendlyFire") == 1)
			{
				SetAvailableMapGoals(TEAM.AXIS, true, "ARTILLERY_S_Book");
			}
			SetAvailableMapGoals(TEAM.ALLIES, false,
			{
				"DEFEND_Mad_key_.*",
				"DEFEND_Cappoint_Keys_.*",
				"BUILD_Allied_Command_Post",
			});			
			SetAvailableMapGoals(TEAM.ALLIES, true,
			{
				"BUILD_MG42",
				"BUILD_Mansion_MG42_nest",
				"DEFEND_Book_.*",
			});
			SetAvailableMapGoals(TEAM.AXIS, false,
			{
				"CALLARTILLERY_SmileTemple",
				"ARTILLERY_S_AltarRight",
				"ATTACK_MadKey_.*",
				"DEFEND_Cappoint_Keys_.*",
				"MOBILEMG42_Mad_Key_.*",
				"MOBILEMG42_Smile_Key_.*",
				"PLANT_Allied_Command_Post",
			});
			if(Map.MG42 && Map.Mansion_MG42)
			{
				SetAvailableMapGoals(TEAM.ALLIES, true,
				{
					"PLANTMINE_Truck_.*",
					"PLANTMINE_omega",
					"MOUNTMG42_M.*",
				});
			}
			if(Map.AlliedSupplies)
			{
				SetAvailableMapGoals(TEAM.ALLIES, false, "BUILD_M.*");
			}
		}
		else
		{
			SetAvailableMapGoals(TEAM.AXIS, true,
			{
				"PLANTMINE_AlliSpawn_.*",
				"MOBILEMG42_Smile_Key_.*",
			});
			if(!Map.KeyMadTaken || !Map.KeyMadDropped)
			{
				SetAvailableMapGoals(TEAM.ALLIES, true, "DEFEND_Mad_key_.*");
				SetAvailableMapGoals(TEAM.ALLIES, false, "DEFEND_Cappoint_Keys_.*");
				SetAvailableMapGoals(TEAM.AXIS, true,
				{
					"CALLARTILLERY_MainGate",
					"ARTILLERY_S_AltarLeft",
				});
			}
		}
		SetAvailableMapGoals(TEAM.ALLIES, false,
		{
			"PLANT_Gas_ventilator",
			"DEFEND_Smile_key_.*",
			"SNIPE_SmileKey_.*",
		});
		Util.MapDebugPrint( "Keysmile Secured!" );
//		Util.MapDebugPrint( "^3KeySmileTaken = " + Map.KeySmileTaken );
//		Util.MapDebugPrint( "^3KeySmileDropped = " + Map.KeySmileDropped );
//		Util.MapDebugPrint( "^3KeySmileReturned = " + Map.KeySmileReturned );
//		Util.MapDebugPrint( "^3KeySmileSecured = " + Map.KeySmileSecured );
	},
	
	keymad_Taken = function( trigger )
	{
		Map.KeyMadDropped = false;
		Map.KeyMadReturned = false;
		Map.KeyMadTaken = true;
		
		SetAvailableMapGoals(TEAM.AXIS, true,
		{
			"CAPPOINT_keymad",
			"DEFEND_Altar_Left_0.*",
			"MOBILEMG42_Mad_Key_.*",
		});
		
		SetAvailableMapGoals(TEAM.ALLIES, false, "DEFEND_Mad_key_.*");
		SetAvailableMapGoals(TEAM.ALLIES, true,
		{
			"DEFEND_Cappoint_Keys_.*",
			"SNIPE_MadKey_.*",
		});
		Util.MapDebugPrint( "keymad_Taken" );
//		Util.MapDebugPrint( "^3KeyMadTaken = " + Map.KeyMadTaken );
//		Util.MapDebugPrint( "^3KeyMadDropped = " + Map.KeyMadDropped );
//		Util.MapDebugPrint( "^3KeyMadReturned = " + Map.KeyMadReturned );
//		Util.MapDebugPrint( "^3KeyMadSecured = " + Map.KeyMadSecured );

		SetAvailableMapGoals(TEAM.AXIS, false,
		{
			"SMOKEBOMB_Left_Temple_Entrance",
			"SMOKEBOMB_Left_Temple_1",
			"ATTACK_MadKey_.*",
		});
	},
	
	KeyMad_Dropped = function( trigger )
	{
		Map.KeyMadTaken = false;
		Map.KeyMadDropped = true;
		Util.MapDebugPrint("KeyMad Dropped");
//		Util.MapDebugPrint( "^3KeyMadTaken = " + Map.KeyMadTaken );
//		Util.MapDebugPrint( "^3KeyMadDropped = " + Map.KeyMadDropped );
//		Util.MapDebugPrint( "^3KeyMadReturned = " + Map.KeyMadReturned );
//		Util.MapDebugPrint( "^3KeyMadSecured = " + Map.KeyMadSecured );
	},

	keymad_Returned = function( trigger )
	{
		Map.KeyMadDropped = false;
		Map.KeyMadReturned = true;
		SetAvailableMapGoals(TEAM.AXIS, true,
		{
			"FLAG_keymad",
			"ATTACK_MadKey_.*",
			"MOBILEMG42_MadKey_Temple_Entrance_.*",
		});
		SetAvailableMapGoals(TEAM.AXIS, false,
		{
			"CAPPOINT_keymad",
			"DEFEND_Altar_Left_0.*",
			"MOBILEMG42_Mad_Key_.*",
		});
		SetAvailableMapGoals(TEAM.ALLIES, true, "DEFEND_Mad_key_.*");
		if(!Map.KeySmileTaken || Map.KeySmileSecured)
		{
			SetAvailableMapGoals(TEAM.ALLIES, false, "DEFEND_Cappoint_Keys_.*");
		}
		if(Map.AlliedSupplies && !Map.StairsWay)
		{
			SetAvailableMapGoals(TEAM.ALLIES, false, "DEFEND_Mad_key_.*");
		}
		Util.MapDebugPrint( "Keymad_Returned!" );
//		Util.MapDebugPrint("^5Keysmile_TAKEN = " + Map.KeySmileTaken );
//		Util.MapDebugPrint("^5Keysmile_SECURED = "+  Map.KeySmileSecured );
//		Util.MapDebugPrint( "^3KeyMadTaken = " + Map.KeyMadTaken );
//		Util.MapDebugPrint( "^3KeyMadDropped = " + Map.KeyMadDropped );
//		Util.MapDebugPrint( "^3KeyMadReturned = " + Map.KeyMadReturned );
//		Util.MapDebugPrint( "^3KeyMadSecured = " + Map.KeyMadSecured );
		
	},
	
	keymad_Secured = function( trigger )
	{
		Map.KeyMadTaken = false;
		Map.KeyMadSecured = true;
		SetGoalPriority("BUILD_Archeologist_stairway", 0.85, TEAM.AXIS, CLASS.ENGINEER);
		SetAvailableMapGoals(TEAM.AXIS, false,
		{
			"FLAG_keymad",
			"ATTACK_KeySmile_.*",
			"CAPPOINT_keymad",
			"ATTACK_MadKey_.*",
			"DEFEND_Altar_Left_0.*",
			"MOBILEMG42_MadKey_Temple_Entrance_.*",
			
		});
		if(Map.KeySmileSecured)
		{
			SetAvailableMapGoals(TEAM.AXIS, true,
			{
				"FLAG_book_of_wisdom",
				"ATTACK_Book_.*",
				"PLANTMINE_alt_.*",
				"HEALTHCAB_first_healthcabinet_1",
				"AMMOCAB_first_ammocabinet_1",
			});
			SetAvailableMapGoals(TEAM.ALLIES, false,
			{
				"BUILD_Allied_Command_Post",
				"DEFEND_Smile_key_.*",
			});
			
			SetAvailableMapGoals(TEAM.ALLIES, true,
			{
				"BUILD_MG42",
				"BUILD_Mansion_MG42_nest",
				"DEFEND_Book_.*",
			});
			
			SetAvailableMapGoals(TEAM.ALLIES, false, "DEFEND_Cappoint_Keys_.*");
			SetAvailableMapGoals(TEAM.AXIS, false,
			{
				"DEFEND_Cappoint_Keys_.*",
				"MOBILEMG42_Mad_Key_.*",
				"MOBILEMG42_Smile_Key_.*",
				"PLANT_Allied_Command_Post",
				"CALLARTILLERY_SmileTemple",
				"ARTILLERY_S_AltarRight",
				"DEFUSE_Gas_ventillator_.*",
				"BUILD_Gas_ventilator",
				"DEFEND_Smile_key_.*",
			});
			if(Map.MG42 && Map.Mansion_MG42)
			{
				SetAvailableMapGoals(TEAM.ALLIES, true,
				{
					"PLANTMINE_omega",
					"PLANTMINE_Truck.*",
				});
			}
		}
		else
		{
			if(!KeySmileTaken)
			{
				SetAvailableMapGoals(TEAM.ALLIES, true, "DEFEND_Smile_key_.*");
				SetAvailableMapGoals(TEAM.AXIS, true,
				{
				//	"DEFEND_Cappoint_Keys_.*",
					
				});

			}
			if(!Map.KeySmileDropped)
			{
				SetAvailableMapGoals(TEAM.ALLIES, false, "DEFEND_Cappoint_Keys_.*");
			}
			SetAvailableMapGoals(TEAM.AXIS, false, "CALLARTILLERY_MainGate");
			SetAvailableMapGoals(TEAM.AXIS, true,
			{
				"ARTILLERY_S_AltarRight",
				"CALLARTILLERY_SmileTemple",
			});
			SetAvailableMapGoals(TEAM.ALLIES, true, "SNIPE_SmileKey_.*");
			if(Map.GasVentilator)
			{
				SetAvailableMapGoals(TEAM.ALLIES, true, "DEFEND_Smile_key_.*");
				SetAvailableMapGoals(TEAM.AXIS, true, "DEFEND_Smile_key_0.*");
			}
			else
			{
				SetAvailableMapGoals(TEAM.ALLIES, true, "DEFEND_Smile_key_.*");
				SetAvailableMapGoals(TEAM.ALLIES, false, "DEFEND_Smile_key_1.*");
				SetAvailableMapGoals(TEAM.AXIS, false, "DEFEND_Smile_key_.*");
				SetAvailableMapGoals(TEAM.AXIS, true, "DEFEND_Smile_key_0.*");
			}
			SetAvailableMapGoals(TEAM.AXIS, true, "MOBILEMG42_Mad_Key_.*");
			SetAvailableMapGoals(TEAM.AXIS, false, "PLANT_Allied_Command_Post");
		}
		
		
		if(Map.AlliedSupplies)
		{
			SetAvailableMapGoals(TEAM.AXIS, false, "ATTACK_KeySmile_.*");
		}
		
		SetAvailableMapGoals(TEAM.ALLIES, false,
		{
			"SNIPE_MadKey_.*",
			"DEFEND_Mad_key_.*",
		});
		
		Util.MapDebugPrint( "KeyMad Secured!" );
//		Util.MapDebugPrint( "^3KeyMadTaken = " + Map.KeyMadTaken );
//		Util.MapDebugPrint( "^3KeyMadDropped = " + Map.KeyMadDropped );
//		Util.MapDebugPrint( "^3KeyMadReturned = " + Map.KeyMadReturned );
//		Util.MapDebugPrint( "^3KeyMadSecured = " + Map.KeyMadSecured );
	},
	
	book_of_wisdom_Taken = function( trigger )
	{
		Map.BookTaken = true;
		Util.ChangeSpawnForRole(TEAM.AXIS, ROLE.ATTACKER, 3);
		Util.ChangeSpawnForRole(TEAM.AXIS, ROLE.ATTACKER1, 3);
		SetAvailableMapGoals(TEAM.AXIS, true, "CAPPOINT_Place_Of_Book");
		SetAvailableMapGoals(TEAM.AXIS, false, "ATTACK_Book_.*");
		SetAvailableMapGoals(TEAM.ALLIES, false,
		{
			"DEFEND_Book_.*",
			"BUILD.*",
		});
		SetAvailableMapGoals(TEAM.ALLIES, true, "DEFEND_Cappoint_Book_.*");
		SetAvailableMapGoals(TEAM.ALLIES, true, "DEFEND_Allied_Supplies_.*");
		SetAvailableMapGoals(TEAM.ALLIES, true, "CAPPOINT_Place_Of_Book");
		Util.MapDebugPrint( "book_of_wisdom_Taken" );
		sleep (4.0);
		if(!Map.BookReturned)
		{
			SetAvailableMapGoals(TEAM.ALLIES, false,
			{
				"MOUNTMG42.*",
				"BUILD_MG42",
				"BUILD_Mansion_MG42_nest",
			});
		}
	},
	
	Book_Dropped = function( trigger )
	{
		Map.BookDropped = true;
		SetAvailableMapGoals(TEAM.AXIS, false, "CAPPOINT_Place_Of_Book");
		SetAvailableMapGoals(TEAM.ALLIES, false,
		{
			"DEFEND_Allied_Supplies_.*",
			"CAPPOINT_Place_Of_Book",
			"DEFEND_Cappoint_Book_.*",
		});
		Util.MapDebugPrint( "Book of Wisdom Dropped!" );
	},
	
	book_of_wisdom_Returned = function( trigger )
	{
		Map.BookReturned = true;
		SetAvailableMapGoals(TEAM.AXIS, true,
		{
			"FLAG_book_of_wisdom",
			"ATTACK_Book_.*",
		});
		SetAvailableMapGoals(TEAM.AXIS, false, "CAPPOINT_Place_Of_Book");
		SetAvailableMapGoals(TEAM.ALLIES, true, "DEFEND_Book_.*");
		SetAvailableMapGoals(TEAM.ALLIES, false, "DEFEND_Cappoint_Book_.*");
		if(Map.MG42)
		{
			SetAvailableMapGoals(TEAM.ALLIES, true, "MOUNTMG42_MG42");
		}
		else
		{
			SetAvailableMapGoals(TEAM.ALLIES, true, "BUILD_MG42");
		}
		if(Map.Mansion_MG42)
		{
			SetAvailableMapGoals(TEAM.ALLIES, true, "MOUNTMG42_Mansion_MG42_nest");
		}
		else
		{
			SetAvailableMapGoals(TEAM.ALLIES, true, "BUILD_Mansion_MG42_nest");
		}
		Util.MapDebugPrint( "Book of wisdom Returned" );
	},
	
	book_of_wisdom_Secured = function( trigger )
	{
		Map.BookSecured = true;
		Util.MapDebugPrint( "book_of_wisdom_Secured Axis Won!" );
	},
};

global OnMapLoad = function()
{
	// Register callback functions
	OnTrigger( "allies_hq_compost_constructed", Map.Allied_Command_Post_Built );
	OnTrigger( "Planted at the Allied Command Post.", Map.Allied_CP_Planted );
	OnTrigger( "Defused at the Allied Command Post.", Map.Allied_CP_Defused );
	OnTrigger( "allies_hq_compost_damaged", Map.Allied_Command_Post_Destroyed );
	
	OnTrigger( "TT_ax_DoneRamp", Map.Archeologist_stairway_Built );
	OnTrigger( "Planted at Archeologist stairway.", Map.Archeologist_stairway_Planted );
	OnTrigger( "Defused Archeologist stairway.", Map.Archeologist_stairway_Defused );
	OnTrigger( "TT_ax_DestRamp", Map.Archeologist_stairway_Destroyed );
	
	OnTrigger( "axis_hq_compost_constructed", Map.Axis_Command_Post_Built );
	OnTrigger( "Planted at the Axis Command Post.", Map.Axis_CP_planted );
	OnTrigger( "Defused at the Axis Command Post.", Map.Axis_CP_Defused );
	OnTrigger( "axis_hq_compost_damaged", Map.Axis_Command_Post_Destroyed );
	
	OnTrigger( "^1Axis have built ventilator! Room is free from gas!", Map.Gas_ventilator_Built );
	OnTrigger( "Planted at Gas ventilator.", Map.Ventilator_Planted );
	OnTrigger( "Defused at Gas Ventilator.", Map.Gas_ventilator_Defused );
	OnTrigger( "^5Alies blown ventilation! Room takes full of gas again!", Map.Gas_ventilator_Destroyed );
	OnTrigger( "^5Allied team have built MG42!", Map.MG42_Built );
	OnTrigger( "Planted at the MG42.", Map.MG42_Planted );
	OnTrigger( "Defused at MG42.", Map.MG42_Defused );
	OnTrigger( "axisconstruct_house_mg42_mg42", Map.MG42_Destroyed );
	
	OnTrigger( "^5Allies have built the mansion MG42 nest!", Map.Mansion_MG42_Built );
	OnTrigger( "Planted at the Mansion MG42 nest.", Map.MG42_Mansion_Planted );
	OnTrigger( "Defused at the Mansion MG42 nest.", Map.Mansion_MG42_defused );
	OnTrigger( "^1Axis have destroyed the mansion MG42 nest!", Map.MG42_Mansion_Destroyed );
	
	OnTrigger( "Planted at the Allied supplies.", Map.Allied_Supplies_Planted );
	OnTrigger( "Defused at the Allied supplies.", Map.Allied_Supplies_Defused );
	OnTrigger( "TT_ax_city_forced", Map.Allied_supplies_Destroyed );

	OnTrigger( "Planted at Main town gate.", Map.Main_Town_Gate_PLanted );
	OnTrigger( "Defused at Main town gate.", Map.Main_Town_Gate_Defused );
	OnTrigger( "Main town gate Destroyed.", Map.Main_town_gate_Destroyed );
	
	OnTrigger( "Planted at Weak city wall.", Map.Weak_City_Wall_Planted );
	OnTrigger( "TT_al_wall_breached", Map.City_Wall_Breached );
	//OnTrigger( "^1Axis damaged hard the city wall!", Map.City_Wall_Hard_Damaged );
	//OnTrigger( "TT_ax_wall_breached", Map.Weak_city_wall_Destroyed );
	//OnTrigger( "^5Allies trying to repair city wall!", Map.Allies_Trying_Repair_The_Wall );
	//OnTrigger( "^5Allies almost finished city wall!", Map.Allies_Almost_Finished_The_Wall );
	OnTrigger( "^5Allied build wall barricade!", Map.Weak_city_wall_Built );
	OnTrigger( "^1Axis destroyed wall barricade!", Map.Weak_city_wall_Destroyed );
	
	OnTrigger( "Axis have stolen Book of Wisdom!", Map.book_of_wisdom_Taken );
	OnTrigger( "Flag dropped book_of_wisdom!", Map.Book_Dropped );
	OnTrigger( "Flag returned book_of_wisdom!", Map.book_of_wisdom_Returned );
	OnTrigger( "^1The Axis escape with Book of wisdom!", Map.book_of_wisdom_Secured );
	
	OnTrigger( "Axis have stolen Montesuma's angry  mask!", Map.keymad_Taken );
	OnTrigger( "Flag dropped keymad!", Map.KeyMad_Dropped );
	OnTrigger( "Flag returned keymad!", Map.keymad_Returned );
	OnTrigger( "^1Angry Montesuma's mask captured!", Map.keymad_Secured );
	
	OnTrigger( "Axis have stolen Montesuma smile mask!", Map.keysmile_Taken );
	OnTrigger( "Flag dropped keysmile!", Map.KeySmile_Dropped );
	OnTrigger( "Flag returned keysmile!", Map.keysmile_Returned );
	OnTrigger( "^1Smile Montesuma's mask captured!", Map.keysmile_Secured );

	Util.SetGoalOffset(0.0, 0.0, 0.0, "BUILD_Archeologist_stairway");
	Util.SetGoalOffset(0.0, 0.0, -110.0, "BUILD_Weak_city_wall");
	Util.SetGoalOffset(0, 0, -100, "PLANT_Main_town_gate");
	Util.SetGoalOffset(0, 0, -50, "BUILD_Mansion_MG42_nest");
	Util.SetGoalOffset(0, 0, -80, "PLANT_Mansion_MG42_nest");
	Util.SetGoalOffset(0, 0, -40, "BUILD_MG42");
	Util.SetGoalOffset(0, 0, -150, "PLANT_Wall_barricade");
	Util.SetGoalRange("BUILD_Axis_Command_Post", 1000);
	Util.SetGoalRange("PLANTMINE_Truck_.*", 12000);
	Util.AddUsePoint("PLANT_Main_town_gate",Vec3(-540.378, -4132.850, 120.125));
	Util.AddUsePoint("PLANT_Weak_city_wall", Vec3(-2543.635, -4144.533, 24.125));
	Util.AddUsePoint("PLANT_Wall_barricade", {Vec3(-2808.488, -4099.574, 24.125), Vec3(-2861.613, -3925.133, 24.126)});
	Util.AddUsePoint("PLANT_MG42", Vec3(-251.458, 4648.948, 408.125));
	Util.AddUsePoint("PLANT_Allied_supplies",{Vec3(-4537.840, -3703.956, 24.125)});
	Util.AddUsePoint("BUILD_Archeologist_stairway", Vec3(-3084.79, -2374.74, 24.154));  //, Vec3(-3160.784, -2317.038, 24.125)}
	Util.AddUsePoint("BUILD_Wall_barricade", {Vec3(-2592.958, -3942.332, 24.125), Vec3(-2622.498, -3838.826, 24.125)});
	Util.AddUsePoint("BUILD_Gas_ventilator",/* Vec3(2323.049, 295.095, 152.159), */Vec3(2427.961, 274.010, 152.125));
	Util.AddUsePoint("PLANT_Gas_ventilator", Vec3(2370.362, 298.592, 152.126));
	Util.AddUsePoint("PLANT_Axis_Command_Post", Vec3(1663.983, -5335.625, 56.127));
	Util.AddUsePoint("BUILD_MG42", Vec3(-372.125, 4632.358, 408.125));
	SetGoalPriority("ATTACK_.*", 0.0, 0, CLASS.ENGINEER);
	SetGoalPriority("ATTACK_Main_Gate_5", 0.79, TEAM.AXIS, 0);
	SetGoalPriority("ATTACK_Allied_Supplies_1", 0.75, TEAM.AXIS, 0);
	SetGoalPriority("DEFEND_.*", 0.0, 0, CLASS.ENGINEER);
	SetGoalPriority("ATTACK_.*", 0.0, 0, CLASS.COVERTOPS);
	//SetGoalPriority("DEFEND_.*", 0.0, 0, CLASS.COVERTOPS);
	SetGoalPriority("DEFEND_Smile_key_01", 0.6, 0, 0);
	SetGoalPriority("DEFEND_Cappoint_Keys_.*", 0.69, TEAM.ALLIES, 0);
	SetGoalPriority("DEFEND_Allied_Supplies_3", 0.6, TEAM.ALLIES, CLASS.ENGINEER);
