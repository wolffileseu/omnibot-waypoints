global Map =
{
	Debug = 0, // please set to zero before distributing your script
	
	MainTownGate = true,
	WeakWall = true,
	StairsWay = true,
	KeyMadTaken = false,
	KeyMadDropped = false,
	KeyMadReturned = false,
	KeyMadSecured = false,
	KeySmileTaken = false,
	KeySmileDropped = false,
	KeySmileReturned = false,
	KeySmileSecured = false,
	BookTaken = false,
	BookDropped = false,
	BookReturned = false,
	BookSecured = false,
	AlliedSupplies = true,
	GasVentilator = false,
	MG42 = false,
	Mansion_MG42 = false,
	Allied_CP = false,
	Axis_CP = false,
	AirstrikeWellTrigger = 0,
	rifle_g_bots1 = 0,
	bot_in_1_trigger = false,
	bot_in_2_trigger = 0,
	SmileTriggerCount = 0,
	MG42TriggerCount = 0,
	MansionMG42_triggercount = 0,
	
	Navigation =
	{
		well =
		{
			navigate = function(_this)
			{
				_this.AddAimRequest(Priority.High, "facing", Vec3(0.055, 0.967, -0.249));
				_this.Bot.HoldButton(BTN.CROUCH, BTN.FORWARD, 1.2);
				sleep(1.2);
			},
		},
		
		near_well =
		{
			navigate = function(_this)
			{
				_this.AddAimRequest(Priority.High, "facing", Vec3(0.057, 0.977, 0.055));
				_this.Bot.HoldButton(BTN.FORWARD, BTN.JUMP, 0.8);
				sleep(0.8);
			},
		},
		
		jump_to_generator_1 =
		{
			navigate = function()
			{
				this.AddAimRequest(Priority.High, "facing", Vec3(0.236, 0.970, -0.058));	//0.509, 0.861, -0.013//0.334, 0.936, -0.111
				this.Bot.HoldButton(BTN.JUMP, BTN.FORWARD, BTN.SPRINT, 0.06);
				sleep(0.06);
			},
		},
		
		stop =
		{
			EvalFunc = function()
			{
				return !this.StopTime || GetTime() - this.StopTime > 11;
			},
			
			navigate = function()
			{
				this.Goto(this.Bot.GetPosition());
				sleep(12);
				this.StopTime = GetTime();
			},
		},
		
		jump_to_generator_2 =
		{
			navigate = function()
			{
				this.AddAimRequest(Priority.High, "facing", Vec3(0.226, 0.974, -0.001));
				this.Bot.HoldButton(BTN.JUMP, BTN.FORWARD, BTN.SPRINT,  0.3);
				sleep(0.3);
			},
		},
		
		jump_to_generator_3 =
		{
			navigate = function()
			{
				this.AddAimRequest(Priority.High, "facing", Vec3(-0.364, 0.914, -0.179));
				this.Bot.HoldButton(BTN.JUMP, BTN.FORWARD, BTN.FORWARD, 0.5);
				sleep(0.5);
			},
		},
		
		big_jump = 
		{
			navigate = function()
			{
				this.AddAimRequest(Priority.VeryHigh, "facing", Vec3(-0.040, -0.982, 0.183));
				this.Bot.HoldButton(BTN.JUMP, BTN.FORWARD, BTN.SPRINT,  1.9);
				sleep(1.9);
			},
		},
		
		gpg40_attack =			//waypoint_setproperty paththrough Navigation_PT:gpg40_attack
		{
			wpInfo = Util.WpNameInfo("grenade_shot"),	//name of waypoint (Waypoint_setname)
			EvalFunc = function(_this)
			{
				return Map.rifle_g_bots1 < 1 && !Map.StairsWay && Map.bot_in_2_trigger || Map.bot_in_1_trigger && _this.Bot.HasWeapon(WEAPON.GPG40) && _this.Bot.HasAmmo(WEAPON.GPG40);
			},
			navigate = function(_this)
			{
				Map.rifle_g_bots1 += 1;

				
				_this.AddAimRequest(Priority.VeryHigh, "facing", Vec3(-0.430, -0.876, 0.216));
				_this.AddWeaponRequest(Priority.VeryHigh, WEAPON.GPG40);	
				if ( _this.Goto(Map.Navigation.gpg40_attack.wpInfo.position) == EVENT.PATH_SUCCESS )
				{
					print("You will die!");
					_this.AddWeaponRequest( WEAPON.GPG40);
					_this.BlockForWeaponChange( WEAPON.GPG40 );
					_this.Bot.HoldButton(BTN.ATTACK2, 0.5);
					sleep(2);
					_this.Bot.HoldButton(BTN.ATTACK1, 0.5);
					sleep(1);
				}
				Map.rifle_g_bots1 -= 1;
				yield();
			},
		},
	},
	
	mg_42 =
	{
		Name = "mg_42",
		TriggerOnClass = CLASS.ANYPLAYER,
		OnEnter = function(ent)
		{
			if(GetEntTeam(ent) == TEAM.ALLIES)
			{
				Map.MG42TriggerCount += 1;
				if(Map.MG42TriggerCount > 0 && Map.MG42)
				{
					SetAvailableMapGoals(TEAM.AXIS, true, "GRENADE_MG42");
					Wp.SetWaypointFlag("axis_attack_3","allies", true);
					Wp.SetWaypointFlag("axis_attack_4","allies", true);
					Util.MapDebugPrint("Allies at Mg42");
				}
			}
		},
		OnExit = function(ent)
		{
			if(GetEntTeam(ent) == TEAM.ALLIES)
			{
				Map.MG42TriggerCount -= 1;
				if(Map.MG42TriggerCount < 1)
				{
					SetAvailableMapGoals(TEAM.AXIS, false, "GRENADE_MG42");
					Wp.SetWaypointFlag("axis_attack_1","allies", false);
					Wp.SetWaypointFlag("axis_attack_2","allies", false);
					Util.MapDebugPrint("Allies leave MG42");
				}
			}
		},
	},
	
	MansionMG42 = 
	{
		Name = "MansionMG42",
		TriggerOnClass = CLASS.ANYPLAYER,
		OnEnter = function(ent)
		{
			if(GetEntTeam(ent) == TEAM.ALLIES)
			{
				Map.MansionMG42_triggercount += 1;
				if(MansionMG42_triggercount > 0)
				{
					Wp.SetWaypointFlag("templestairs_1", "allies", true);
					Wp.SetWaypointFlag("axis_attack_1","allies", true);
					Wp.SetWaypointFlag("axis_attack_2","allies", true);
					Util.MapDebugPrint("Allies at MansionMG42");
				}
			}
		},
		OnExit = function(ent)
		{
			if(GetEntTeam(ent) == TEAM.ALLIES)
			{
				Map.MansionMG42_triggercount -= 1;
				if(Map.MansionMG42_triggercount < 1)
				{
					Wp.SetWaypointFlag("templestairs_1", "allies", false);
					Wp.SetWaypointFlag("axis_attack_1","allies", false);
					Wp.SetWaypointFlag("axis_attack_2","allies", false);
					Util.MapDebugPrint("Allies leave Mansion_MG42");
				}
			}
		},		
	},
	
	one_trigger =
	{
		Name = "one_trigger",
		TriggerOnClass = CLASS.ANYPLAYER,
		OnEnter = function(ent)
		{
			if(GetEntTeam(ent) == TEAM.ALLIES)
			{
				Map.bot_in_1_trigger = true;
				if(Map.AlliedSupplies)
				{
					SetAvailableMapGoals(TEAM.AXIS, true,
					{
						"CALLARTILLERY_Truc.*",
						"ARTILLERY_S_Truc.*",
					});
				}
			}
		},
		OnExit = function(ent)
		{
			if(GetEntTeam(ent) == TEAM.ALLIES)
			{
				Map.bot_in_1_trigger = false;
				if(!Map.bot_in_1_trigger)
				{
					SetAvailableMapGoals(TEAM.AXIS, false,
					{
						"CALLARTILLERY_Truc.*",
						"ARTILLERY_S_Truc.*",
					});
				}
			}
		},
	},
	
	two_trigger = 
	{
		Name = "two_trigger",
		TriggerOnClass = CLASS.ANYPLAYER,
		OnEnter = function(ent)
		{
			if(GetEntTeam(ent) == TEAM.ALLIES)
			{
				Map.bot_in_2_trigger += 1;
				
				if(Map.bot_in_2_trigger > 0)
				{
					SetAvailableMapGoals(TEAM.AXIS, true, "GRENADE_Truck");
				}
				if(Map.AlliedSupplies)
				{
					SetAvailableMapGoals(TEAM.AXIS, true,
					{
						"CALLARTILLERY_Truc.*",
						"ARTILLERY_S_Truc.*",
					});
				}
			}
		},
		OnExit = function(ent)
		{
			if(GetEntTeam(ent) == TEAM.ALLIES)
			{
				Map.bot_in_2_trigger -= 1;
				
				if(Map.bot_in_2_trigger < 1)
				{
					SetAvailableMapGoals(TEAM.AXIS, false, "GRENADE_Truck");
				}
				if(!Map.bot_in_1_trigger)
				{
					SetAvailableMapGoals(TEAM.AXIS, false,
					{
						"CALLARTILLERY_Truc.*",
						"ARTILLERY_S_Truc.*",
					});
				}
			}
		},
	},
	
	Airstrike__well = 
	{
		Name = "Airstike__well",
		TriggerOnClass = CLASS.ANYPLAYER,
		playerlist = {},
		OnEnter = function(ent)
		{
			if(GetEntTeam(ent) == TEAM.ALLIES)
			{
				list = Map.Airstrike__well.playerlist;
				if(list[ent])
				{
					list[ent] += 1;
				}
				else
				{
					list[ent] = 1;
					if(tableCount(list) == 1)
					{
						//SetAvailableMapGoals(TEAM.AXIS, true, "AIRSTRIKE_Well");
					}
				}
			}
		},
		OnExit = function(ent)
		{
			list = Map.Airstrike__well.playerlist;
			if(list[ent])
			{
				if(list[ent] > 1)
				{
					list[ent] -= 1;
				}
				else
				{
					list[ent] = null;
					if(tableCount(list) == 0)
					{
						SetAvailableMapGoals(TEAM.AXIS, false, "AIRSTRIKE_Well");
					}
				}
			}
		},
	},
	
	GPG_Attack = 
	{
		Name = "GPG_Attack",
		TriggerOnClass = CLASS.ENGINEER,
		OnEnter = function(ent)
		{
			if(GetEntTeam(ent) == TEAM.AXIS)
			{
				Wp.SetWaypointFlag("allies_1", "closed", false);
				Wp.SetWaypointFlag("allies_2", "closed", true);
			}
		},
		OnExit = function(ent)
		{
			if(GetEntTeam(ent) == TEAM.AXIS)
			{
				Wp.SetWaypointFlag("allies_1", "closed", true);
				Wp.SetWaypointFlag("allies_2", "closed", false);
			}
		},
	},
	
	fence = 
	{
		Name = "fence",
		TriggerOnClass = CLASS.ANYPLAYER,
		OnEnter = function(ent)
		{
			ent1 = GetGameEntityFromId(90);
			ent2 = GetGameEntityFromId(89);
			ent3 = GetGameEntityFromId(88);
			ent4 = GetGameEntityFromId(91);
			ent5 = GetGameEntityFromId(92);
			ent6 = GetGameEntityFromId(93);

			if(!ent1 && !ent2 && !ent3)
			{
				print("^1Entity 88, 89 ,90 isn't valid");
				Wp.SetWaypointFlag("fence_1", "closed", false);
				Wp.SetWaypointFlag("fence_2", "closed", false);
				Wp.SetWaypointFlag("fence_3", "closed", false);
			}
			if(!ent4 && !ent5)
			{
				Wp.SetWaypointFlag("fence_4", "closed", false);
				Wp.SetWaypointFlag("fence_5", "closed", false);
			}
			if(!ent1 && !ent2 && ! ent3 && !ent4 && !ent5)
			{
				DeleteTriggerRegion("fence");
			}
		},
	},
	
	smile_trigger =
	{
		Name = "smile_trigger",
		TriggerOnClass = CLASS.ANYPLAYER,
		OnEnter = function(ent)
		{
			if(GetEntTeam(ent) == TEAM.AXIS)
			{
				Map.SmileTriggerCount += 1;
				Util.MapDebugPrint("SmileTriggerCount = ^5" + Map.SmileTriggerCount);
			}
		},
		OnExit = function(ent)
		{
			if(GetEntTeam(ent) == TEAM.AXIS)
			{
				Map.SmileTriggerCount -= 1;
				if(!Map.StairsWay && Map.SmileTriggerCount < 1)
				{
					SetAvailableMapGoals(TEAM.AXIS, false, "FLAG_keymad");
				}
				Util.MapDebugPrint("SmileTriggerCount = ^5" + Map.SmileTriggerCount);
			}
		},
	},

	Roles =
	{
		AXIS =
		{
			AllBots = false, // each bot is considered for a role
			ATTACKER =
			{
				//spawnpt = 4,
				numbots = 8,
				crucialClass = CLASS.ENGINEER,
			},
			ATTACKER1=
			{
				//spawnpt = 4,
				numbots = 4,
				crucialClass = CLASS.ENGINEER,
			},
			INFILTRATOR=
			{
				numbots = 4,
				crucialClass = CLASS.COVERTOPS,
			},
		},
		ALLIES =
		{
			AllBots = false, // each bot is considered for a role
			DEFENDER =
			{
				//spawnpt = 4,
				numbots = 8,
				crucialClass = CLASS.ENGINEER,
			},
			DEFENDER1 =
			{
				//spawnpt = 4,
				numbots = 4,
				crucialClass = CLASS.ENGINEER,
			},
		},

	},

	Axis_Command_Post_Built = function( trigger )
	{
		Map.Axis_CP = true;
		SetAvailableMapGoals(TEAM.AXIS, true, 
		{
			"PLANTMINE_Axis_CP_.*",
		});
		SetGoalPriority("PLANTMINE_Axis_CP_.*", 0.85, TEAM.AXIS, CLASS.ENGINEER);
		SetAvailableMapGoals(TEAM.AXIS, false, "BUILD_Axis_Command_Post");
		SetAvailableMapGoals(TEAM.ALLIES, true, "PLANT_Axis_Command_Post");
	
		Util.MapDebugPrint( "Axis_Command_Post_Built" );
	},
	
	Axis_CP_planted = function( trigger )
	{
		Util.MapDebugPrint("Axis Comman Post Planted");
	},
	
	Axis_CP_Defused = function( trigger )
	{
		Util.MapDebugPrint("Axis Command Post Defused");
	},

	Axis_Command_Post_Destroyed = function( trigger )
	{
		Map.Axis_CP = false;
		//SetGoalPriority("BUILD_Axis_Command_Post", 0.0, TEAM.AXIS, 0);
		SetAvailableMapGoals(TEAM.AXIS, true, "BUILD_Axis_Command_Post");
		SetAvailableMapGoals(TEAM.AXIS, false, "DEFUSE_Axis_Command_Post_.*");
		SetAvailableMapGoals(TEAM.ALLIES, false, "PLANT_Axis_Command_Post");
		Util.MapDebugPrint( "Axis_Command_Post_Destroyed" );
	},
	
	Allied_Command_Post_Built = function( trigger )
	{
		Map.Allied_CP = true;
		
		SetAvailableMapGoals(TEAM.ALLIES, false, "BUILD_Allied_Command_Post");
		if(!Map.AlliedSupplies && Map.KeyMadSecured && !Map.KeySmileSecured)
		{
			SetAvailableMapGoals(TEAM.AXIS, false, "PLANT_Allied_Command_Post");
		}
		else
		{
			SetAvailableMapGoals(TEAM.AXIS, true, "PLANT_Allied_Command_Post");
		}
		Util.MapDebugPrint( "Allied_Command_Post_Built" );
	},
	
	Allied_CP_Planted = function( trigger )
	{
		Util.MapDebugPrint("Planted at the Allied Command Post");
	},
	
	Allied_CP_Defused = function( trigger )
	{
		Util.MapDebugPrint("Defused at Allied CommandPost");
	},
	
	Allied_Command_Post_Destroyed = function( trigger )
	{
		Map.Allied_CP = false;
		if(!Map.KeyMadSecured || !Map.KeySmileSecured)
		{
			SetAvailableMapGoals(TEAM.ALLIES, true, "BUILD_Allied_Command_Post");
		}
		Util.MapDebugPrint( "Allied_Command_Post_Destroyed" );
	},

	MG42_Built = function( trigger )
	{
		Map.MG42 = true;
		SetAvailableMapGoals(TEAM.ALLIES, true, "MOUNTMG42_MG42");
		SetAvailableMapGoals(TEAM.ALLIES, false, "BUILD_MG42");

		if(Map.KeySmileSecured && Map.KeyMadSecured)
		{
			if(!Map.BookTaken)
			{
				SetAvailableMapGoals(TEAM.AXIS, true, "CALLARTILLERY_Book");
			}
			if(Map.Mansion_MG42)
			{
				SetGoalRole( "PLANTMINE_omega", { ROLE.DEFENDER, ROLE.DEFENDER1});
				SetGoalRole( "PLANTMINE_Truck_0.*",  ROLE.DEFENDER);
				SetGoalRole( "PLANTMINE_Truck_1.*",  ROLE.DEFENDER1);
				SetAvailableMapGoals(TEAM.ALLIES, true,
				{
					"PLANTMINE_Truck_.*",
					"PLANTMINE_omega",
				});
			}
			SetAvailableMapGoals(TEAM.AXIS, true,
			{
				"PLANT_MG42",
				"GRENADE_MG42",
			});
		}
		Util.MapDebugPrint( "MG42_Built" );
	},
	
	MG42_Planted = function( trigger )
	{
		Util.MapDebugPrint("MG42 Planted");
	},
	
	MG42_Defused = function( trigger )
	{
		SetAvailableMapGoals(TEAM.AXIS, true, "PLANT_MG42");
		Util.MapDebugPrint("MG42 Defused");
	},

	MG42_Destroyed = function( trigger )
	{
		Map.MG42 = false;
		Map.MG42TriggerCount = 0;
		if(Map.KeyMadSecured && Map.KeySmileSecured)
		{
			SetAvailableMapGoals(TEAM.ALLIES, true,
			{
				"BUILD_MG42",
			});
		}
		Wp.SetWaypointFlag("axis_attack_3","allies", false);
		Wp.SetWaypointFlag("axis_attack_4","allies", false);
		SetAvailableMapGoals(TEAM.ALLIES, false, "MOUNTMG42_MG42");
		SetAvailableMapGoals(TEAM.AXIS, false, "PLANT_MG42");
		SetAvailableMapGoals(TEAM.AXIS, false, "GRENADE_MG42");
		Util.MapDebugPrint( "MG42_Destroyed" );
	},
	
	Mansion_MG42_Built = function( trigger )
	{
		Map.Mansion_MG42 = true;
		SetAvailableMapGoals(TEAM.ALLIES, true, "MOUNTMG42_Mansion_MG42_nest");
		SetAvailableMapGoals(TEAM.ALLIES, false, "BUILD_Mansion_MG42_nest");
		SetAvailableMapGoals(TEAM.AXIS, true, "PLANT_Mansion_MG42_nest");
		if(Map.MG42 && Map.KeyMadSecured && Map.KeySmileSecured)
		{
			SetAvailableMapGoals(TEAM.ALLIES, true,
			{
				"PLANTMINE_Truck_.*",
				"PLANTMINE_omega",
			});
		}
		Util.MapDebugPrint("Mansion MG42 Built");
	},
	
	MG42_Mansion_Planted = function( trigger )
	{
		Util.MapDebugPrint("Mansion MG42 Planted");
	},
	
	Mansion_MG42_defused = function( trigger )
	{
		SetAvailableMapGoals(TEAM.AXIS, true, "PLANT_Mansion_MG42_nest");
		Util.MapDebugPrint("Mansion MG42 defused");
	},
	
	MG42_Mansion_Destroyed = function( trigger )
	{
		Map.Manson_MG42 = false;
		Wp.SetWaypointFlag("axis_attack_3","allies", false);
		Wp.SetWaypointFlag("axis_attack_4","allies", false);
		SetAvailableMapGoals(TEAM.ALLIES, false,
		{
			"MOUNTMG42_Mansion_MG42_nest",
			"DEFUSE_Mansion.*",
		});
		SetAvailableMapGoals(TEAM.AXIS, false, "PLANT_Mansion_MG42_nest");
		if(Map.KeySmileSecured && Map.KeyMadSecured)
		{
			SetAvailableMapGoals(TEAM.ALLIES, true, "BUILD_Mansion_MG42_nest");
		}
		Util.MapDebugPrint("Mansion MG42 nest destroyed");
	},
	
	Allied_Supplies_Planted = function( trigger )
	{
		SetAvailableMapGoals(TEAM.AXIS, true, "PLANTMINE_Supplies_1");
		Util.MapDebugPrint("Allied supplies planted");
	},
	
	Allied_Supplies_Defused = function( trigger )
	{
		Util.MapDebugPrint("Allied supplies defused");
	},

	Allied_supplies_Destroyed = function( trigger )
	{
		Map.AlliedSupplies = false;
		DeleteTriggerRegion("smile_trigger");
		Map.SmileTriggerCount = 0;
		
		ClearGoalRole( "FLAG_keymad", ROLE.INFILTRATOR );
		
		Map.bot_in_2_trigger = false;
		Map.bot_in_1_trigger = false;
		
		DeleteTriggerRegion("Airstrike_well");
		DeleteTriggerRegion("one_trigger");
		DeleteTriggerRegion("two_trigger");
		DeleteTriggerRegion("GPG_Attack");
		Wp.SetWaypointFlag("allies_1", "closed", false);
		Wp.SetWaypointFlag("allies_2", "closed", false);
		
		if(!Map.StairsWay)
		{
			SetAvailableMapGoals(TEAM.AXIS, true, "BUILD_Archeologist_stairway");
		}

		SetGoalPriority("PLANT_Allied_Command_Post", 0.78, TEAM.AXIS, CLASS.ENGINEER);
		
		SetAvailableMapGoals(TEAM.AXIS, false,
		{
			"CALLARTILLERY_Truc.*",
			"CALLARTILLERY_Weak_Wall",
			"ARTILLERY_S_Truc.*",
		//	"ARTILLERY_S_Weak_Wall",
			"ATTACK_Allied_Supplies_.*",
			"ATTACK_Weak_Wall_.*",
			"MOBILEMORTAR_To_Truck_.*",
			"MOBILEMORTAR_To_Statue_.*",
			"MOBILEMG42_Attack_Weak_Wall_.*",
			"MOBILEMG42_Near_Allied_Supply_.*",
			"MOBILEMG42_Near_Weak_Wall_.*",
			"CAMP_Wood_Barricade_.*",
			"CAMP_Truck_Ax.*",
			"GRENADE_Truck",
		});
		
		if(Map.KeyMadSecured)
		{
			SetAvailableMapGoals(TEAM.AXIS, false,
			{
				"ATTACK_MadKey_.*",
				"FLAG_keymad",
				"CAPPOINT_keymad",
				"MOBILEMG42_MadKey_Temple_Entrance_",
			});
			
			SetAvailableMapGoals(TEAM.ALLIES, false, "DEFEND_Mad_key_.*");
		}
		else
		{
			SetAvailableMapGoals(TEAM.ALLIES, true, "DEFEND_Mad_key_.*");
			SetAvailableMapGoals(TEAM.AXIS, true,
			{
				"ATTACK_MadKey_.*",
				"FLAG_keymad",
				"SMOKEBOMB_Left_Temple_Entrance",
				"MOBILEMG42_MadKey_Temple_Entrance_.*",
			});
		}
		
		if(Map.KeySmileSecured)
		{
			SetAvailableMapGoals(TEAM.AXIS, false,
			{
				"ATTACK_KeySmile_.*",
				"DEFEND_Smile_key_.*",
				"FLAG_keysmile",
				"CAPPOINT_keysmile",
				"BUILD_Gas_ventilator",
				"DEFUSE_Gas_ventillator_.*",
			});
			SetAvailableMapGoals(TEAM.ALLIES, false, "DEFEND_Smile_key_.*");
		}
		else
		{
			if(!Map.GasVentilator)
			{
				SetAvailableMapGoals(TEAM.AXIS, true,
				{
					"BUILD_Gas_ventilator",
					"DEFEND_Smile_key_0.*",
				});
				SetAvailableMapGoals(TEAM.ALLIES, true, "DEFEND_Smile_key_0.*");
			}
			else
			{
				SetAvailableMapGoals(TEAM.AXIS, true,
				{
					"FLAG_keysmile",
					"DEFEND_Smile_key_0.*",
				});
				SetAvailableMapGoals(TEAM.ALLIES, true, "DEFEND_Smile_key_.*");
				SetAvailableMapGoals(TEAM.ALLIES, true, "PLANT_Gas_ventilator");
			}
		}
		
		//Util.MapDebugPrint( "MG42 state is " + Map.MG42 );
		//Util.MapDebugPrint( "Mansion_MG42 state is " + Map.Mansion_MG42 );
		Util.MapDebugPrint( "KeyMadSecured state is " + Map.KeyMadSecured );
		Util.MapDebugPrint( "KeySmileSecured state is " + Map.KeySmileSecured );
		
		if(Map.KeyMadSecured && Map.KeySmileSecured)
		{
			if(!Map.BookTaken || !Map.BookDropped)
			{
				SetAvailableMapGoals(TEAM.AXIS, true,
				{
					"FLAG_book_of_wisdom",
					"ATTACK_Book_.*",
				});
				
				SetAvailableMapGoals(TEAM.ALLIES, true,
				{
					"DEFEND_Book_.*",
				});
			}
			else
			{
				SetAvailableMapGoals(TEAM.ALLIES, true,
				{
					"DEFEND_Allied_Supplies_.*",
					"DEFEND_Cappoint_Book_.*",
				});
			}
			if(Map.MG42)
			{
				SetAvailableMapGoals(TEAM.ALLIES, true, "MOUNTMG42_MG42");
				SetAvailableMapGoals(TEAM.AXIS, true,
				{
					"PLANT_MG42",
					"GRENADE_MG42",
				});
				
				if(Map.Mansion_MG42)
				{
					SetAvailableMapGoals(TEAM.ALLIES, true, "PLANTMINE_Truck.*");
					Util.MapDebugPrint( "MG42 state is azaz mindkettő kész van" + Map.MG42 + Mansion_MG42);
				}
				else
				{
					SetAvailableMapGoals(TEAM.ALLIES, false, "PLANTMINE_Truck.*");
				}
				
			}
			else
			{
				SetAvailableMapGoals(TEAM.ALLIES, true, "BUILD_MG42");
				SetAvailableMapGoals(TEAM.ALLIES, false, "MOUNTMG42_MG42");
				SetAvailableMapGoals(TEAM.ALLIES, false, "PLANTMINE_Truck_.*");
				//Util.MapDebugPrint( "MG42 state is " + Map.MG42 );
			}
			
			if(Map.Mansion_MG42)
			{
				SetAvailableMapGoals(TEAM.ALLIES, true, "MOUNTMG42_Mansion_MG42_nest");
				SetAvailableMapGoals(TEAM.AXIS, true, "PLANT_Mansion_MG42_nest");
				if(Map.MG42)
				{
					SetAvailableMapGoals(TEAM.ALLIES, true,
					{
						"PLANTMINE_Truck_.*",
						"MOUNTMG42_MG42",
					});
					SetAvailableMapGoals(TEAM.AXIS, true, "PLANT_MG42");
				}
				else
				{
					SetAvailableMapGoals(TEAM.ALLIES, false, "PLANTMINE_Truck_.*");
					SetAvailableMapGoals(TEAM.ALLIES, true, "BUILD_MG42");
				}
			}
			else
			{
				SetAvailableMapGoals(TEAM.ALLIES, true, "BUILD_Mansion_MG42_nest");
				SetAvailableMapGoals(TEAM.ALLIES, false, "MOUNTMG42_Mansion_MG42_nest");
				SetAvailableMapGoals(TEAM.ALLIES, false, "PLANTMINE_Truck_.*");
			}
		}	
		else
		{
			SetAvailableMapGoals(TEAM.ALLIES, false, "PLANT_Gas_ventilator");
			SetAvailableMapGoals(TEAM.AXIS, false, "BUILD_Gas_ventilator");
			SetAvailableMapGoals(TEAM.AXIS, false, "DEFUSE_Gas_ventillator_.*");
		}
		
		SetAvailableMapGoals(TEAM.AXIS, false,
		{
			"MOBILEMG42_Attack_Weak_Wall_.*",
			"MOBILEMORTAR_To_Truck_.*",
			"PLANTMINE_Supplies_1",
			"PLANT_Weak_city_wall",
		//	"CAMP_Near_Truck",
			"MOBILEMG42_MainGate_AlliedSide_.*",
			"CALLARTILLERY_Main_Gate",
			"ARTILLERY_S_Main_Gate",
			"ARTILLERY_S_Truck",
			"AIRSTRIKE_Weak_Wall",
			"PLANT_Wall_barricade",
		});
		
		SetAvailableMapGoals(TEAM.ALLIES, false,
		{
			"BUILD_Weak_city_wall",
			"DEFUSE_Weak_city_wall_.*",
			"DEFUSE_Allied_supplies_.*",
			"DEFEND_Maingate_.*",
			"DEFEND_Allied_Supplies_.*",
			"PLANTMINE_Maingate_.*",
			"PLANTMINE_Weakwall_.*",
			"HEALTHCAB_first_healthcabinet",
			"AMMOCAB_first_ammocabinet",
			"BUILD_Wall_barricade",
			"DEFUSE_Wall_barricade",
		});
		
		if(Map.MainTownGate)
		{
			SetAvailableMapGoals(TEAM.AXIS, false,
			{
				"ATTACK_Main_Gate_.*",
				"PLANTMINE_Maingate_.*",
				"PLANTMINE_Supplies_1",
				"PLANT_Main_town_gate",
				//"MOBILEMG42_Main_Gate_Axis_.*",
				//"MOBILEMG42_Near_Allied_Supply_.*",
			});
		}
		
		Wp.SetWaypointFlag("second_door_inside", "allies", false);
		Wp.SetWaypointFlag("second_door_outside", "allies", false);
		Wp.SetWaypointFlag("sidedoor_inside", "closed", false);
		Wp.SetWaypointFlag("sidedoor_overside", "closed", false);
		
		SetAvailableMapGoals(TEAM.ALLIES, true, "BUILD_Allied_Command_Post");
	
		Util.MapDebugPrint( "Allied_supplies_Destroyed" );
	},
	
	Archeologist_stairway_Built = function( trigger )
	{
		Map.StairsWay = true;
		Wp.SetWaypointFlag("stairsway","closed", false);
		Wp.SetWaypointFlag("stairsway2", "closed", false);
		Wp.SetWaypointFlag("understairs", "closed", true);
		
		sleep(1);
		
		if(!Map.KeyMadSecured)
		{
			SetAvailableMapGoals(TEAM.AXIS, true,
			{
				"FLAG_keymad",
				"ATTACK_MadKey_.*",
				"MOBILEMG42_MadKey_Temple_Entrance_.*",
			});
			SetAvailableMapGoals(TEAM.ALLIES, true, "DEFEND_Mad_key_.*");
		}
		else
		{
			SetAvailableMapGoals(TEAM.AXIS, false,
			{
				"FLAG_keymad",
				"ATTACK_MadKey_.*",
				"MOBILEMG42_MadKey_Temple_Entrance_.*",
			});
			SetAvailableMapGoals(TEAM.ALLIES, false, "DEFEND_Mad_key_.*");
		}

		if(!Map.KeySmileSecured)
		{
			if(Map.GasVentilator)
			{
				SetAvailableMapGoals(TEAM.AXIS, true,
				{
					"FLAG_keysmile",
					"DEFEND_Smile_key_0.*",
				});
				SetAvailableMapGoals(TEAM.ALLIES, true, "DEFEND_Smile_key_.*");
			}
			else
			{
				SetAvailableMapGoals(TEAM.AXIS, true,
				{
					"BUILD_Gas_ventilator",
					"DEFEND_Smile_key_1.*",
				});
				SetAvailableMapGoals(TEAM.ALLIES, true, "DEFEND_Smile_key_0.*");
			}
		}
		else
		{
			SetAvailableMapGoals(TEAM.AXIS, false,
			{
				"BUILD_Gas_ventilator",
				"DEFEND_Smile_key_.*",
				"DEFUSE_Gas_ventillator_.*",
			});
			SetAvailableMapGoals(TEAM.ALLIES, false, "DEFEND_Smile_key_.*");
		}
		
		SetAvailableMapGoals(TEAM.AXIS, false, "BUILD_Archeologist_stairway");
		SetAvailableMapGoals(TEAM.ALLIES, true, "PLANT_Archeologist_stairway");
		Util.MapDebugPrint( "Archeologist_stairway_Built ^5" + Map.SmileTriggerCount );
	},
	
	Archeologist_stairway_Planted = function( trigger )
	{
		if(MainTownGate && AlliedSupplies)
		{
			SetAvailableMapGoals(TEAM.AXIS, false, "DEFUSE_Archeologist_stairsway_.*");
		}
		Util.MapDebugPrint( "Archeologist_stairway_Planted" );
	},
	
	Archeologist_stairway_Defused = function( trigger )
	{
		SetAvailableMapGoals(TEAM.ALLIES, true, "PLANT_Archeologist_stairway");
		Util.MapDebugPrint("Archeologist stairway defused");
	},

	Archeologist_stairway_Destroyed = function( trigger )
	{
		Map.StairsWay = false;
		if(!Map.MainTownGate)
		{
			SetAvailableMapGoals(TEAM.AXIS, true, "BUILD_Archeologist_stairway");
		}
		SetAvailableMapGoals(TEAM.ALLIES, false, "PLANT_Archeologist_stairway");
		Wp.SetWaypointFlag("stairsway","closed", true);
		Wp.SetWaypointFlag("stairsway2", "closed", true);
		Wp.SetWaypointFlag("understairs", "closed", false);
		sleep(1);
		if(Map.SmileTriggerCount < 1)
		{
			SetAvailableMapGoals(TEAM.AXIS, false, "FLAG_keymad");
		}
		
		
		Util.MapDebugPrint( "Archeologist_stairsway_Destroyed ^5" + Map.SmileTriggerCount );
	},
	
	Gas_ventilator_Built = function( trigger )
	{
		Map.GasVentilator = true;
		Wp.SetWaypointFlag("gasroom_1", "closed", false);
		Wp.SetWaypointFlag("gasroom_2", "closed", false);
		
		if(!Map.KeySmileSecured && !Map.KeySmileTaken)
		{
			SetAvailableMapGoals(TEAM.AXIS, true, "FLAG_keysmile");
		}
		SetAvailableMapGoals(TEAM.AXIS, true, "DEFEND_Gas_Ventillator");
		SetAvailableMapGoals(TEAM.AXIS, false, "BUILD_Gas_ventilator");
		if(!Map.KeySmileSecured)
		{
			SetAvailableMapGoals(TEAM.ALLIES, true,
			{
				"PLANT_Gas_ventilator",
			});
			if(!Map.KeySmileTaken || !Map.KeySmileReturned || !Map.KeySmileDropped)
			{
				SetAvailableMapGoals(TEAM.ALLIES, true, "DEFEND_Smile_key_.*");
				SetAvailableMapGoals(TEAM.AXIS, true, "DEFEND_Smile_key_0.*");
			}
		}
		else
		{
			SetAvailableMapGoals(TEAM.ALLIES, false, "DEFEND_Smile_key_.*");
			SetAvailableMapGoals(TEAM.ALLIES, false, "PLANT_Gas_ventilator");
			SetAvailableMapGoals(TEAM.AXIS, false, "DEFEND_Smile_key_.*");
		}
		if(Map.AlliedSupplies)
		{
			SetGoalPriority("FLAG_keysmile", 1.1, TEAM.AXIS, CLASS.ENGINEER);
		}
		Util.MapDebugPrint( "Gas_ventilator_Built" );
	},
	
	Ventilator_Planted = function( trigger )
	{
		if(!Map.KeySmileSecured)
		{
			SetAvailableMapGoals(TEAM.AXIS, true, "DEFUSE_Gas_ventillator_.*");
		}
		else
		{
			SetAvailableMapGoals(TEAM.AXIS, false, "DEFUSE_Gas_ventillator_.*");
		}
		Util.MapDebugPrint("Ventilator Planted");
		//SetAvailableMapGoals(TEAM.ALLIES, false, "DEFEND_Smile_key_1.*");
	},
	
	Gas_ventilator_Defused = function( trigger )
	{
		//SetAvailableMapGoals(TEAM.ALLIES, true, "DEFEND_Smile_key_.*");
		SetAvailableMapGoals(TEAM.ALLIES, true, "PLANT_Gas_ventilator");
		Util.MapDebugPrint("Defused at Gas Ventilator");
	},

	Gas_ventilator_Destroyed = function( trigger )
	{
		Map.GasVentilator = false;
		
		Wp.SetWaypointFlag("gasroom_1", "closed", true);
		Wp.SetWaypointFlag("gasroom_2", "closed", true);
		
		if(!Map.KeySmileSecured)
		{
			SetAvailableMapGoals(TEAM.AXIS, true, "BUILD_Gas_ventilator");
			SetAvailableMapGoals(TEAM.AXIS, true, "DEFEND_Smile_key_0.*");
		}
		
		SetAvailableMapGoals(TEAM.ALLIES, false,
		{
			"PLANT_Gas_ventilator",
			"DEFEND_Smile_key_1.*",
		});

		SetAvailableMapGoals(TEAM.AXIS, false,
		{
			"DEFUSE_Gas.*",
			"FLAG_keysmile",
			"DEFEND_Gas_Ventillator",
		});
		Util.MapDebugPrint( "Gas_ventilator_Destroyed" );
	},
	
	Main_Town_Gate_PLanted = function( trigger )
	{
		SetAvailableMapGoals(TEAM.AXIS, true, "BUILD_Axis_Command_Post");
		SetGoalPriority("ATTACK_Main_Gate_1", 0.79, TEAM.AXIS, 0);
		SetGoalPriority("ATTACK_Main_Gate_2", 0.79, TEAM.AXIS, 0);
		SetGoalPriority("ATTACK_Main_Gate_5", 0.6, TEAM.AXIS, 0);
		SetAvailableMapGoals(TEAM.AXIS, true, "ATTACK_Main_Gate_.*");
		WeaponTable.SetWeaponTeamAvailability(TEAM.AXIS, CLASS.ENGINEER, WEAPON.MP40, false);
		Util.MapDebugPrint("Main town gate planted");
	},
	
	Main_Town_Gate_Defused = function( trigger )
	{
		Util.MapDebugPrint("Defused at the Main Town Gate");
	},

	Main_town_gate_Destroyed = function( trigger )
	{
		Map.MainTownGate = false;
		Wp.SetWaypointFlag("main_gate_door_inside", "allies", false);
		Wp.SetWaypointFlag("main_gate_door_outside", "allies", false);
		Wp.SetWaypointFlag("weakwall_3", "closed", false);
		SetAvailableMapGoals(TEAM.AXIS, false, 
		{	
			"ATTACK_Main_Gate_.*",
			"MOBILEMG42_Main_Gate_Axis_.*",
			"MOBILEMG42_MainGate_AlliedSide_.*",
			"MOBILEMG42_Near_Weak_Wall_.*",
			"CALLARTILLERY_MainGate_.*",
			"ARTILLERY_S_Main_Gate",
			"CAMP_Wood_Barricade_.*",
		});
		SetAvailableMapGoals(TEAM.AXIS, true,
		{
			"PLANT_Weak_city_wall",
			"ATTACK_Weak_Wall_1.*",
			"AMMOCAB_first_ammocabinet",
			"HEALTHCAB_first_healthcabinet",
			"HEALTHCAB_food01_heal",
			"HEALTHCAB_food02",
			"PLANT_Allied_supplies",
			"CALLARTILLERY_Weak_Wall",
			"CALLARTILLERY_Truc.*",
			"MOBILEMORTAR_To_Statue_0.*",
			"ARTILLERY_S_Truc.*",
			"CAMP_Truck_Ax.*",
		});
		SetAvailableMapGoals(TEAM.ALLIES, true,
		{
			"DEFEND_Allied_Supplies_.*",
			"AMMOCAB_first_ammocabinet_1",
			"HEALTHCAB_first_healthcabinet_1",
		});
		SetAvailableMapGoals(TEAM.ALLIES, false,
		{
			"DEFEND_Maingate_.*",
			"DEFUSE_Main_town_gate_.*",
			"PLANTMINE_Maingate_.*",
		});
		
		if(!Map.StairsWay)
		{
			SetAvailableMapGoals(TEAM.AXIS, true, "BUILD_Archeologist_stairway");
		}
		else
		{
			SetAvailableMapGoals(TEAM.AXIS, true, "FLAG_keymad");
		}
		
		if(!Map.AlliedSupplies)
		{
			SetAvailableMapGoals(TEAM.AXIS, false, "ATTACK_Weak_Wall_.*");
			SetAvailableMapGoals(TEAM.ALLIES, false, "DEFEND_Allied_Supplies_.*");
			SetAvailableMapGoals(TEAM.AXIS, false,
			{
				"PLANT_Weak_city_wall",
				"ATTACK_Weak_Wall_",
				"MOBILEMORTAR_To_Truck_.*",
				"MOBILEMORTAR_To_Statue_.*",
				"MOBILEMG42_Attack_Weak_Wall_.*",
				"MOBILEMG42_Near_Allied_Supply_.*",
				"MOBILEMG42_Near_Weak_Wall_",
				"CALLARTILLERY_Gate_To_Truc.*",
				"ARTILLERY_S_Truc.*",
				"CALLARTILLERY_Weak_Wal.*",
				//"ARTILLERY_S_Weak_Wall",
				"CAMP_Truck_Ax.*",
			});
		}
		else
		{
			SetAvailableMapGoals(TEAM.AXIS, true, "MOBILEMORTAR_To_Statue_0.*");
		}
	
		Util.MapDebugPrint( "Main_town_gate_Destroyed" );
	},
	
	Weak_city_wall_Built = function( trigger )  //Wood Barricade Built
	{
		Map.WeakWall = true;
		SetGoalPriority("PLANT_Wall_barricade", 0.0, TEAM.AXIS, CLASS.ENGINEER);
		SetGoalPriority("PLANT_Wall_barricade", 0.8, TEAM.AXIS, CLASS.COVERTOPS);
		if(Map.AlliedSupplies)
		{
			SetAvailableMapGoals(TEAM.AXIS, true, "PLANT_Wall_barricade");
			SetAvailableMapGoals(TEAM.AXIS, false,
			{
				"AIRSTRIKE_Weak_Wall",
				"CAMP_Wood_Barricade_.*",
			});
			SetAvailableMapGoals(TEAM.ALLIES, true,
			{
				"PLANTMINE_Weakwall_1",
				"PLANTMINE_Weakwall_2",
			});
		}
		Util.MapDebugPrint("Allies reconsctructed the Wall");
	},
	
	Weak_City_Wall_Planted = function( trigger )
	{
		SetAvailableMapGoals(TEAM.ALLIES, false, "DEFUSE_Weak_city_wall_.*", true);
		SetGoalPriority("PLANT_Weak_city_wall", 0.0, TEAM.AXIS, CLASS.COVERTOPS);
		Util.MapDebugPrint("Planted at weak city wall");
	},
	
	City_Wall_Breached = function( trigger )
	{
		Map.WeakWall = false;
		
		if(ETUtil.CountClass(TEAM.AXIS, CLASS.SOLDIER) < 2)
		{
			SetAvailableMapGoals(TEAM.AXIS, false,
			{
				"MOBILEMG42_Near_Allied_Supply_.*",
				"MOBILEMG42_Attack_Weak_Wall_.*",
				"MOBILEMG42_Near_Weak_Wall_.*",
			});
		}
		SetAvailableMapGoals(TEAM.AXIS, true,
		{
			"PLANT_Allied_supplies",
			"PLANT_Weak_city_wall",
			//"MOBILEMORTAR_To_Truck_",
		});
		SetGoalPriority("PLANT_Weak_city_wall", 0.9, TEAM.AXIS, CLASS.COVERTOPS );

		SetAvailableMapGoals(TEAM.ALLIES, false,
		{
			"PLANTMINE_Weakwall_1",
			"PLANTMINE_Weakwall_2",
		});
		if(!Map.StairsWay)
		{
			SetAvailableMapGoals(TEAM.AXIS, true,
			{
				"CALLARTILLERY_Weak_Wall",
				//"ARTILLERY_S_Weak_Wall",
			});
		}
		else
		{
			SetAvailableMapGoals(TEAM.AXIS, true,
			{
				//"ARTILLERY_S_Weak_Wall",
			});
		}
		if(Map.AlliedSupplies)
		{
			SetAvailableMapGoals(TEAM.AXIS, true,
			{
				"ATTACK_Allied_Supplies_.*",
				"PLANT_Allied_supplies",
				"PLANT_Weak_city_wall",
			});
			SetAvailableMapGoals(TEAM.ALLIES, true,
			{
				"BUILD_Wall_barricade",
				"DEFEND_Allied_Supplies_.*",
				"PLANTMINE_Weakwall_3",
				"PLANTMINE_Weakwall_4",
				"PLANTMINE_Weakwall_5",
			});
		}
		Util.MapDebugPrint("City Wall Breached");
	},
