		PLANT_Main_Generator =
		{
		},
		PLANT_Axis_Command_Post =
		{
		},
		PLANT_generator_door_constructible =
		{
		},
		FLAG_keycard =
		{
		},
	};
	Util.Routes(MapRoutes);
};
