global Map =
{
	Debug = 1, // please set to zero before distributing your script
	ShowMovers = false,

	Allied_Command_Post_Dyno = 0,
	Axis_Command_Post_Dyno = 0,
	Main_Generator_Dyno = 0,
	generator_door_constructible_Dyno = 0,

	Allied_Command_Post_Built = function( trigger )
	{
		if ( TestMap )
			{ return; }
			
		SetAvailableMapGoals( TEAM.ALLIES, true, "PLANT_generator_door_constructible" );	
		SetAvailableMapGoals( TEAM.ALLIES, true, "DEFEND_Main_Generator_5" );
	      SetAvailableMapGoals( TEAM.ALLIES, true, "DEFEND_Main_Generator_6" );
	      SetAvailableMapGoals( TEAM.ALLIES, true, "DEFEND_Main_Generator_7" );
	      SetAvailableMapGoals( TEAM.ALLIES, true, "DEFEND_Main_Generator_8" );
		SetAvailableMapGoals( TEAM.AXIS, true, "DEFEND_Main_Generator_1" );
	      SetAvailableMapGoals( TEAM.AXIS, true, "DEFEND_Main_Generator_2" );
	      SetAvailableMapGoals( TEAM.AXIS, true, "DEFEND_Main_Generator_3" );
	      SetAvailableMapGoals( TEAM.AXIS, true, "DEFEND_Main_Generator_4" );
		SetAvailableMapGoals( TEAM.ALLIES, false, "DEFEND_Outside_Fence_8" );
	      SetAvailableMapGoals( TEAM.ALLIES, false, "DEFEND_Command_Post_1" );
	      SetAvailableMapGoals( TEAM.ALLIES, false, "DEFEND_Command_Post_2" );
      	SetAvailableMapGoals( TEAM.ALLIES, false, "DEFEND_Command_Post_3" );
	      SetAvailableMapGoals( TEAM.ALLIES, false, "DEFEND_Command_Post_4" );
		SetAvailableMapGoals( TEAM.AXIS, false, "DEFEND_Command_Post_1" );
	      SetAvailableMapGoals( TEAM.AXIS, false, "DEFEND_Command_Post_2" );
	      SetAvailableMapGoals( TEAM.AXIS, false, "DEFEND_Command_Post_3" );
	      SetAvailableMapGoals( TEAM.AXIS, false, "DEFEND_Command_Post_4" );

		Util.MapDebugPrint( "Allied_Command_Post_Built" );
	},

	Axis_Command_Post_Built = function( trigger )
	{
		if ( TestMap )
			{ return; }

		Util.MapDebugPrint( "Axis_Command_Post_Built" );
	},

	generator_door_constructible_Built = function( trigger )
	{
		if ( TestMap )
			{ return; }

		Util.MapDebugPrint( "generator_door_constructible_Built" );
	},

	Allied_Command_Post_Planted = function( trigger )
	{
		if ( TestMap )
			{ return; }

		Map.Allied_Command_Post_Dyno += 1;
		Util.MapDebugPrint( "Allied_Command_Post_Planted" );
	},

	Axis_Command_Post_Planted = function( trigger )
	{
		if ( TestMap )
			{ return; }

		Map.Axis_Command_Post_Dyno += 1;
		Util.MapDebugPrint( "Axis_Command_Post_Planted" );
	},

	Main_Generator_Planted = function( trigger )
	{
		if ( TestMap )
			{ return; }

		Map.Main_Generator_Dyno += 1;
		Util.MapDebugPrint( "Main_Generator_Planted" );
	},

	generator_door_constructible_Planted = function( trigger )
	{
		if ( TestMap )
			{ return; }

		Map.generator_door_constructible_Dyno += 1;
		Util.MapDebugPrint( "generator_door_constructible_Planted" );
	},

	Allied_Command_Post_Defused = function( trigger )
	{
		if ( TestMap )
			{ return; }

		Map.Allied_Command_Post_Dyno -= 1;
		Util.MapDebugPrint( "Allied_Command_Post_Defused" );
	},

	Axis_Command_Post_Defused = function( trigger )
	{
		if ( TestMap )
			{ return; }

		Map.Axis_Command_Post_Dyno -= 1;
		Util.MapDebugPrint( "Axis_Command_Post_Defused" );
	},

	Main_Generator_Defused = function( trigger )
	{
		if ( TestMap )
			{ return; }

		Map.Main_Generator_Dyno -= 1;
		Util.MapDebugPrint( "Main_Generator_Defused" );
	},

	generator_door_constructible_Defused = function( trigger )
	{
		if ( TestMap )
			{ return; }

		Map.generator_door_constructible_Dyno -= 1;
		Util.MapDebugPrint( "generator_door_constructible_Defused" );
	},

	Allied_Command_Post_Destroyed = function( trigger )
	{
		if ( TestMap )
			{ return; }

		Map.Allied_Command_Post_Dyno = 0;

		Util.MapDebugPrint( "Allied_Command_Post_Destroyed" );
	},

	Axis_Command_Post_Destroyed = function( trigger )
	{
		if ( TestMap )
			{ return; }

		Map.Axis_Command_Post_Dyno = 0;

		Util.MapDebugPrint( "Axis_Command_Post_Destroyed" );
	},

	Main_Generator_Destroyed = function( trigger )
	{
		if ( TestMap )
			{ return; }

		Map.Main_Generator_Dyno = 0;
		
		SetAvailableMapGoals( TEAM.ALLIES, false, "PLANT_generator_door_constructible" );
		SetAvailableMapGoals( TEAM.ALLIES, false, "DEFEND_Main_Generator_5" );
	      SetAvailableMapGoals( TEAM.ALLIES, false, "DEFEND_Main_Generator_6" );
	      SetAvailableMapGoals( TEAM.ALLIES, false, "DEFEND_Main_Generator_7" );
	      SetAvailableMapGoals( TEAM.ALLIES, false, "DEFEND_Main_Generator_8" );
		SetAvailableMapGoals( TEAM.ALLIES, true, "DEFEND_Missile_3" );
	      SetAvailableMapGoals( TEAM.ALLIES, true, "DEFEND_Missile_4" );
		SetAvailableMapGoals( TEAM.ALLIES, true, "DEFEND_Missile_5" );
		SetAvailableMapGoals( TEAM.ALLIES, true, "FLAG_keycard" );
		SetAvailableMapGoals( TEAM.AXIS, false, "BUILD_generator_door_constructible" );
		SetAvailableMapGoals( TEAM.AXIS, false, "PLANT_Allied_Command_Post" );
		SetAvailableMapGoals( TEAM.AXIS, false, "DEFEND_Main_Generator_1" );
	      SetAvailableMapGoals( TEAM.AXIS, false, "DEFEND_Main_Generator_2" );
	      SetAvailableMapGoals( TEAM.AXIS, false, "DEFEND_Main_Generator_3" );
	      SetAvailableMapGoals( TEAM.AXIS, false, "DEFEND_Main_Generator_4" );
		SetAvailableMapGoals( TEAM.AXIS, true, "DEFEND_Missile_1_1" );
	      SetAvailableMapGoals( TEAM.AXIS, true, "DEFEND_Missile_2" );
	      SetAvailableMapGoals( TEAM.AXIS, true, "DEFEND_Missile_3" );
	      SetAvailableMapGoals( TEAM.AXIS, true, "DEFEND_Missile_4" );
		SetAvailableMapGoals( TEAM.AXIS, true, "DEFEND_Keycard_1" );
	      SetAvailableMapGoals( TEAM.AXIS, true, "DEFEND_Keycard_2" );

		Util.MapDebugPrint( "Main_Generator_Destroyed" );
	},

	generator_door_constructible_Destroyed = function( trigger )
	{
		if ( TestMap )
			{ return; }

		Map.generator_door_constructible_Dyno = 0;
		
		SetAvailableMapGoals( TEAM.ALLIES, true, "PLANT_Main_Generator" );

		Util.MapDebugPrint( "generator_door_constructible_Destroyed" );
	},

	keycard_Taken = function( trigger )
	{
		if ( TestMap )
			{ return; }
			
		SetAvailableMapGoals( TEAM.AXIS, false, "DEFEND_Keycard_1" );
	      SetAvailableMapGoals( TEAM.AXIS, false, "DEFEND_Keycard_2" );	
		SetAvailableMapGoals( TEAM.ALLIES, false, "FLAG_keycard" );

		Util.MapDebugPrint( "keycard_Taken" );
	},

	keycard_Returned = function( trigger )
	{
		if ( TestMap )
			{ return; }
			
		SetAvailableMapGoals( TEAM.AXIS, true, "DEFEND_Keycard_1" );
	      SetAvailableMapGoals( TEAM.AXIS, true, "DEFEND_Keycard_2" );	
		SetAvailableMapGoals( TEAM.ALLIES, true, "FLAG_keycard" );

		Util.MapDebugPrint( "keycard_Returned" );
	},

	keycard_Secured = function( trigger )
	{
		if ( TestMap )
			{ return; }

		Util.MapDebugPrint( "keycard_Secured" );
	},
	
		Outdoor_Fence_Destroyed = function( trigger )
	{
		if ( TestMap )
			{ return; }
			
		SetAvailableMapGoals( TEAM.ALLIES, true, "BUILD_Allied_Command_Post" );	
	      SetAvailableMapGoals( TEAM.ALLIES, true, "DEFEND_Command_Post_1" );
	      SetAvailableMapGoals( TEAM.ALLIES, true, "DEFEND_Command_Post_2" );
	      SetAvailableMapGoals( TEAM.ALLIES, true, "DEFEND_Command_Post_3" );
	      SetAvailableMapGoals( TEAM.ALLIES, true, "DEFEND_Command_Post_4" );
		SetAvailableMapGoals( TEAM.ALLIES, false, "DEFEND_Outside_Fence_5" );
	      SetAvailableMapGoals( TEAM.ALLIES, false, "DEFEND_Outside_Fence_6" );
	      SetAvailableMapGoals( TEAM.ALLIES, false, "DEFEND_Outside_Fence_7" );
	      SetAvailableMapGoals( TEAM.ALLIES, false, "DEFEND_Outside_Fence_8" );
		SetAvailableMapGoals( TEAM.AXIS, false, "DEFEND_Outside_Fence_1" );
	      SetAvailableMapGoals( TEAM.AXIS, false, "DEFEND_Outside_Fence_2" );
	      SetAvailableMapGoals( TEAM.AXIS, false, "DEFEND_Outside_Fence_3" );
	      SetAvailableMapGoals( TEAM.AXIS, false, "DEFEND_Outside_Fence_4" );
		SetAvailableMapGoals( TEAM.AXIS, true, "DEFEND_Command_Post_1" );
	      SetAvailableMapGoals( TEAM.AXIS, true, "DEFEND_Command_Post_2" );
	      SetAvailableMapGoals( TEAM.AXIS, true, "DEFEND_Command_Post_3" );
	      SetAvailableMapGoals( TEAM.AXIS, true, "DEFEND_Command_Post_4" );

		Util.MapDebugPrint( "Outdoor_Fence_Destroyed" );
	},
	
		Generator_Destroyed = function( trigger )
	{
		if ( TestMap )
			{ return; }
			
		SetAvailableMapGoals( TEAM.ALLIES, true, "PLANT_Outdoor_Fence" );	
		SetAvailableMapGoals( TEAM.ALLIES, true, "DEFEND_Outside_Fence_5" );
	      SetAvailableMapGoals( TEAM.ALLIES, true, "DEFEND_Outside_Fence_6" );
       	SetAvailableMapGoals( TEAM.ALLIES, true, "DEFEND_Outside_Fence_7" );
	      SetAvailableMapGoals( TEAM.ALLIES, true, "DEFEND_Outside_Fence_8" );
		SetAvailableMapGoals( TEAM.AXIS, true, "DEFEND_Outside_Fence_1" );
	      SetAvailableMapGoals( TEAM.AXIS, true, "DEFEND_Outside_Fence_2" );
	      SetAvailableMapGoals( TEAM.AXIS, true, "DEFEND_Outside_Fence_3" );
	      SetAvailableMapGoals( TEAM.AXIS, true, "DEFEND_Outside_Fence_4" );
		SetAvailableMapGoals( TEAM.AXIS, false, "DEFEND_Generator_1" );
	      SetAvailableMapGoals( TEAM.AXIS, false, "DEFEND_Generator_2" );
	      SetAvailableMapGoals( TEAM.AXIS, false, "DEFEND_Generator_3" );
	      SetAvailableMapGoals( TEAM.AXIS, false, "DEFEND_Generator_4" );
		SetAvailableMapGoals( TEAM.ALLIES, false, "DEFEND_Generator_1" );
	      SetAvailableMapGoals( TEAM.ALLIES, false, "DEFEND_Generator_2" );
	      SetAvailableMapGoals( TEAM.ALLIES, false, "DEFEND_Generator_3" );
	      SetAvailableMapGoals( TEAM.ALLIES, false, "DEFEND_Generator_4" );

		Util.MapDebugPrint( "Generator_Destroyed" );
	},
	
		Forward_Spawn_Captured = function( trigger )
	{
		if ( TestMap )
			{ return; }
			
		SetAvailableMapGoals( TEAM.AXIS, true, "CHECKPOINT_flag" );	
	

		Util.MapDebugPrint( "Forward_Spawn_Captured" );
	},
	
		Axis_Forward_Spawn_Captured = function( trigger )
	{
		if ( TestMap )
			{ return; }
			
		SetAvailableMapGoals( TEAM.AXIS, false, "CHECKPOINT_flag" );	
	

		Util.MapDebugPrint( "Axis_Forward_Spawn_Captured" );
	},

};

global OnMapLoad = function()
{
	if ( TestMapOn )
		{ Util.AutoTestMap(); }

	// Register callback functions
	OnTrigger( "Allied Command Post constructed. Charge speed increased!", Map.Allied_Command_Post_Built );
	OnTrigger( "Axis Command Post constructed. Charge speed increased!", Map.Axis_Command_Post_Built );
	OnTrigger( "The generator door has been constructed.", Map.generator_door_constructible_Built );
	OnTrigger( "Axis team has destroyed the Allied Command Post!", Map.Allied_Command_Post_Destroyed );
	OnTrigger( "Allied team has destroyed the Axis Command Post!", Map.Axis_Command_Post_Destroyed );
	OnTrigger( "The Main Generator has been destroyed", Map.Main_Generator_Destroyed );
	OnTrigger( "The generator door has been destroyed.", Map.generator_door_constructible_Destroyed );
	OnTrigger( "The Outdoor Fence has been destroyed.", Map.Outdoor_Fence_Destroyed );
	OnTrigger( "The generator has been destroyed", Map.Generator_Destroyed );
	OnTrigger( "The Allies have captured the Forward Spawn !", Map.Forward_Spawn_Captured );
	OnTrigger( "The Axis have captured the Forward Spawn !", Map.Axis_Forward_Spawn_Captured );
	OnTrigger( "Allies have stolen the keycard!", Map.keycard_Taken );
	OnTrigger( "Axis have returned the keycard!", Map.keycard_Returned );
	
	
	SetAvailableMapGoals( TEAM.ALLIES, false, "PLANT_generator_door_constructible" );
	SetAvailableMapGoals( TEAM.ALLIES, false, "PLANT_Outdoor_Fence" );
	SetAvailableMapGoals( TEAM.ALLIES, false, "BUILD_Allied_Command_Post" );
	SetAvailableMapGoals( TEAM.ALLIES, false, "FLAG_keycard" );
	SetAvailableMapGoals( TEAM.ALLIES, false, "MOUNTMG42_914" );
	SetAvailableMapGoals( TEAM.ALLIES, false, "MOUNTMG42_1171" );
	SetAvailableMapGoals( TEAM.ALLIES, false, "PLANT_Axis_Command_Post" );
	SetAvailableMapGoals( TEAM.ALLIES, false, "PLANT_Main_Generator" );
	SetAvailableMapGoals( TEAM.ALLIES, false, "DEFEND_Outside_Fence_5" );
	SetAvailableMapGoals( TEAM.ALLIES, false, "DEFEND_Outside_Fence_6" );
	SetAvailableMapGoals( TEAM.ALLIES, false, "DEFEND_Outside_Fence_7" );
	SetAvailableMapGoals( TEAM.ALLIES, false, "DEFEND_Outside_Fence_8" );
	SetAvailableMapGoals( TEAM.ALLIES, false, "DEFEND_Command_Post_1" );
	SetAvailableMapGoals( TEAM.ALLIES, false, "DEFEND_Command_Post_2" );
	SetAvailableMapGoals( TEAM.ALLIES, false, "DEFEND_Command_Post_3" );
	SetAvailableMapGoals( TEAM.ALLIES, false, "DEFEND_Command_Post_4" );
	SetAvailableMapGoals( TEAM.ALLIES, false, "DEFEND_Main_Generator_5" );
	SetAvailableMapGoals( TEAM.ALLIES, false, "DEFEND_Main_Generator_6" );
	SetAvailableMapGoals( TEAM.ALLIES, false, "DEFEND_Main_Generator_7" );
	SetAvailableMapGoals( TEAM.ALLIES, false, "DEFEND_Main_Generator_8" );
	SetAvailableMapGoals( TEAM.ALLIES, false, "DEFEND_Missile_3" );
	SetAvailableMapGoals( TEAM.ALLIES, false, "DEFEND_Missile_4" );
	SetAvailableMapGoals( TEAM.ALLIES, false, "DEFEND_Missile_5" );
	SetAvailableMapGoals( TEAM.AXIS, false, "DEFEND_Command_Post_1" );
	SetAvailableMapGoals( TEAM.AXIS, false, "DEFEND_Command_Post_2" );
	SetAvailableMapGoals( TEAM.AXIS, false, "DEFEND_Command_Post_3" );
	SetAvailableMapGoals( TEAM.AXIS, false, "DEFEND_Command_Post_4" );
	SetAvailableMapGoals( TEAM.AXIS, false, "MOUNTMG42_914" );
	SetAvailableMapGoals( TEAM.AXIS, false, "MOUNTMG42_1171" );
	SetAvailableMapGoals( TEAM.AXIS, false, "CHECKPOINT_flag" );
	SetAvailableMapGoals( TEAM.AXIS, false, "DEFEND_Outside_Fence_1" );
	SetAvailableMapGoals( TEAM.AXIS, false, "DEFEND_Outside_Fence_2" );
	SetAvailableMapGoals( TEAM.AXIS, false, "DEFEND_Outside_Fence_3" );
	SetAvailableMapGoals( TEAM.AXIS, false, "DEFEND_Outside_Fence_4" );
	SetAvailableMapGoals( TEAM.AXIS, false, "DEFEND_Main_Generator_1" );
	SetAvailableMapGoals( TEAM.AXIS, false, "DEFEND_Main_Generator_2" );
	SetAvailableMapGoals( TEAM.AXIS, false, "DEFEND_Main_Generator_3" );
	SetAvailableMapGoals( TEAM.AXIS, false, "DEFEND_Main_Generator_4" );
	SetAvailableMapGoals( TEAM.AXIS, false, "DEFEND_Missile_1_1" );
	SetAvailableMapGoals( TEAM.AXIS, false, "DEFEND_Missile_2" );
	SetAvailableMapGoals( TEAM.AXIS, false, "DEFEND_Missile_3" );
	SetAvailableMapGoals( TEAM.AXIS, false, "DEFEND_Missile_4" );
	SetAvailableMapGoals( TEAM.AXIS, false, "DEFEND_Keycard_1" );
	SetAvailableMapGoals( TEAM.AXIS, false, "DEFEND_Keycard_2" );
	SetAvailableMapGoals( TEAM.AXIS, true, "DEFEND_Generator_1" );
	SetAvailableMapGoals( TEAM.AXIS, true, "DEFEND_Generator_2" );
	SetAvailableMapGoals( TEAM.AXIS, true, "DEFEND_Generator_3" );
	SetAvailableMapGoals( TEAM.AXIS, true, "DEFEND_Generator_4" );
	SetAvailableMapGoals( TEAM.ALLIES, true, "DEFEND_Generator_1" );
	SetAvailableMapGoals( TEAM.ALLIES, true, "DEFEND_Generator_2" );
	SetAvailableMapGoals( TEAM.ALLIES, true, "DEFEND_Generator_3" );
	SetAvailableMapGoals( TEAM.ALLIES, true, "DEFEND_Generator_4" );
	
	
	

	//~Util.DisableGoal( ".*", true ); // all but routes
	//~SetAvailableMapGoals( TEAM.AXIS, true, "ATTACK_.*" );
	//~SetAvailableMapGoals( TEAM.ALLIES, true, "ATTACK_.*" );

	// Max users per goal
	//Util.SetMaxUsers( 1, "DEFEND_.*" );
	//Util.SetMaxUsers( 1, "GRENADE_.*" );
	//Util.SetMaxUsers( 1, "MOUNTMG42_.*" );

	// Camp times
	SetMapGoalProperties( "MOUNTMG42_.*", {MinCampTime=15, MaxCampTime=90} );
	SetMapGoalProperties( "MOBILEMG42_.*", {MinCampTime=10, MaxCampTime=60} );


	Util.MapDebugPrint( "Omni-bot map script for " + GetMapName() + " executed." );
};

