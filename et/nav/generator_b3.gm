	Door_1_Destroyed = function( trigger )
	{
		if ( TestMap )
			{ return; }
			
		SetAvailableMapGoals( TEAM.AXIS, false, "DEFEND_Flag_1" );	
		SetAvailableMapGoals( TEAM.AXIS, false, "DEFEND_Flag_2" );
		SetAvailableMapGoals( TEAM.AXIS, false, "DEFEND_Flag_3" );
		SetAvailableMapGoals( TEAM.AXIS, false, "DEFEND_Flag_4" );
		SetAvailableMapGoals( TEAM.AXIS, false, "DEFEND_Flag_5" );
		SetAvailableMapGoals( TEAM.AXIS, false, "DEFEND_Flag_6" );
		SetAvailableMapGoals( TEAM.AXIS, true, "BUILD_Axis_Team_Door" );
		SetAvailableMapGoals( TEAM.AXIS, true, "BUILD_Axis_Command_Post" );
		SetAvailableMapGoals( TEAM.AXIS, true, "SNIPE_Tower" );
	      SetAvailableMapGoals( TEAM.AXIS, true, "MOBILEMG42_Main_Base" );
	      SetAvailableMapGoals( TEAM.AXIS, true, "DEFEND_Base_1" );
	      SetAvailableMapGoals( TEAM.AXIS, true, "DEFEND_Base_2" );
	      SetAvailableMapGoals( TEAM.AXIS, true, "DEFEND_Base_3" );
	      SetAvailableMapGoals( TEAM.AXIS, true, "DEFEND_Base_4" );
		SetAvailableMapGoals( TEAM.ALLIES, false, "SWITCH_Tram_1" );
		SetAvailableMapGoals( TEAM.ALLIES, false, "SWITCH_Tram_2" );
		SetAvailableMapGoals( TEAM.ALLIES, false, "SNIPE_Trambay_1" );
		SetAvailableMapGoals( TEAM.ALLIES, false, "SNIPE_Trambay_2" );
		SetAvailableMapGoals( TEAM.ALLIES, false, "DEFEND_Tram_Area_1" );	
		SetAvailableMapGoals( TEAM.ALLIES, false, "DEFEND_Tram_Area_2" );	
		SetAvailableMapGoals( TEAM.ALLIES, false, "DEFEND_Tram_Area_3" );	
		SetAvailableMapGoals( TEAM.ALLIES, false, "DEFEND_Tram_Area_4" );	
		SetAvailableMapGoals( TEAM.ALLIES, true, "ARTILLERY_S_Axis_Wall" );
            SetAvailableMapGoals( TEAM.ALLIES, true, "CALLARTILLERY_bank" );
		SetAvailableMapGoals( TEAM.ALLIES, true, "PLANT_Door_2" );
		SetAvailableMapGoals( TEAM.ALLIES, false, "DEFEND_Tram_Attack_1" );
		SetAvailableMapGoals( TEAM.ALLIES, false, "DEFEND_Tram_Attack_2" );
		SetAvailableMapGoals( TEAM.ALLIES, false, "DEFEND_Tram_Attack_3" );

		//selfkill for change spawnpoint
		ETUtil.SuicideSpawn( TEAM.ALLIES, 0 );	
		
		Map.Door_1_Dyno = 0;

		Util.MapDebugPrint( "Door_1_Destroyed" );
	},

	Door_2_Destroyed = function( trigger )
	{
		if ( TestMap )
			{ return; }
			
		SetAvailableMapGoals( TEAM.ALLIES, true, "BUILD_Allied_Command_Post" );
		SetAvailableMapGoals( TEAM.ALLIES, true, "PLANT_Bunker_Door" );
		SetAvailableMapGoals( TEAM.ALLIES, true, "DEFEND_Approach_1" );
		SetAvailableMapGoals( TEAM.ALLIES, true, "DEFEND_Approach_2" );
		SetAvailableMapGoals( TEAM.ALLIES, true, "DEFEND_Approach_3" );
		SetAvailableMapGoals( TEAM.ALLIES, true, "DEFEND_Approach_4" );
		SetAvailableMapGoals( TEAM.ALLIES, true, "PLANT_Axis_Team_Door" );

		Map.Door_2_Dyno = 0;

