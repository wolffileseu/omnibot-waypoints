		SetAvailableMapGoals( TEAM.ALLIES, false, "DEFEND_Approach_2" );
		SetAvailableMapGoals( TEAM.ALLIES, false, "DEFEND_Approach_3" );
		SetAvailableMapGoals( TEAM.ALLIES, false, "DEFEND_Approach_4" );
		SetAvailableMapGoals( TEAM.ALLIES, false, "PLANT_Axis_Team_Door" );
		SetAvailableMapGoals( TEAM.AXIS, false, "DEFEND_Base_1" );
	      SetAvailableMapGoals( TEAM.AXIS, false, "DEFEND_Base_2" );
	      SetAvailableMapGoals( TEAM.AXIS, false, "DEFEND_Base_3" );
	      SetAvailableMapGoals( TEAM.AXIS, false, "DEFEND_Base_4" );
		SetAvailableMapGoals( TEAM.AXIS, false, "BUILD_Axis_Team_Door" );
		SetAvailableMapGoals( TEAM.AXIS, true, "DEFEND_Generator_1" );
		SetAvailableMapGoals( TEAM.AXIS, true, "DEFEND_Generator_2" );
		SetAvailableMapGoals( TEAM.AXIS, true, "DEFEND_Generator_3" );
		SetAvailableMapGoals( TEAM.AXIS, true, "DEFEND_Generator_4" );
		SetAvailableMapGoals( TEAM.ALLIES, true, "DEFEND_Plant_1" );
	      SetAvailableMapGoals( TEAM.ALLIES, true, "DEFEND_Plant_2" );
	      SetAvailableMapGoals( TEAM.ALLIES, true, "DEFEND_Plant_3" );
		SetAvailableMapGoals( TEAM.ALLIES, true, "DEFEND_Generator_2" );
		SetAvailableMapGoals( TEAM.ALLIES, true, "DEFEND_Generator_3" );

		Map.You_are_near_Bunker_Door_Dyno = 0;

