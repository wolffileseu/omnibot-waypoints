	Navigation =
	{
		//	/bot waypoint_setproperty paththrough Navigation_PT:jump_wait
		jump_wait =
		{
			navigate = function(_this)
			{
				sleep(0.25);
				_this.Bot.HoldButton(BTN.JUMP, 0.55);
				sleep(0.55);
			},
		},
		
		//	/bot waypoint_setproperty paththrough Navigation_PT:elevator
		elevator =
		{
			OnExit = function()
			{
				for ( i = 0; i <= 3; i += 1 )
				{
					if ( Map.Elevator_botId[i] == this.Bot.GetGameId() )
					{
						Map.Elevator_botId[i] = -1;
						Map.Bot_Ready[i] = false;
						Map.boarding = false;
						this.Bot.DisableCombatMovement = false;
					}
				}
			},
			navigate = function()
			{
				this.Goto(this.Bot.GetPosition());
				this.Bot.DisableCombatMovement = true;
				
				for ( i = 0; ; i += 1 )
				{
					if ( i > 3 )
					{
						sleep(0.5);
						return;
					}
					
					if ( Map.Elevator_botId[i] == -1 )
					{
						Map.Elevator_botId[i] = this.Bot.GetGameId();
						slot = i;
						break;
					}
				}
				
				while ( Map.Elevator_Bottom_Door != "Opened" or Map.boarding )
				{
					yield();
				}
				
				if ( Map.Elevator_botId[slot] != -1 )
				{
					Map.boarding = true;
					
					timer = 0;
					while ( !this.Bot.MoveTowards(Map.Elevator_Positions[4], 15) )
					{
						sleep(0.1);
						timer += 1;
						
						if ( timer == 50 )
						{
							return;
						}
					}
					
					timer = 0;
					while ( !this.Bot.MoveTowards(Map.Elevator_Positions[5], 15) )
					{
						this.Bot.PressButton(BTN.WALK);
						sleep(0.1);
						timer += 1;
						
						if ( timer == 50 )
						{
							return;
						}
					}
					
					timer = 0;
					while ( !this.Bot.MoveTowards(Map.Elevator_Positions[slot], 5) )
					{
						this.Bot.PressButton(BTN.WALK);
						sleep(0.1);
						timer += 1;
						
						if ( timer == 50 )
						{
							break;
						}
					}
					
					Map.boarding = false;
					Map.Bot_Ready[slot] = true;
				}
				
				if ( Map.Elevator_botId[0] == this.Bot.GetGameId() )
				{
					for ( i = 1; i <= 3; i += 1 )
					{
						if ( Map.Elevator_botId[i] != -1 )
						{
							while ( !Map.Bot_Ready[i] and Map.Elevator_botId[i] != -1 )
							{
								yield();
							}
						}
					}
					
					this.AddAimRequest(Priority.VeryHigh, "position", Vec3(1597.875, 2665.034, -140.066));
					sleep(0.5);
					
					timer = 0;
					while ( Map.Elevator_Bottom_Door != "Moving" )
					{
						sleep(0.1);
						timer += 1;
						this.Bot.PressButton(BTN.USE);
						
						if ( timer == 50 )
						{
							return;
						}
					}
					this.ReleaseAimRequest();
				}
				
				while ( Map.Elevator != "Up" )
				{
					this.Goto(this.Bot.GetPosition());
					
					if ( Map.Elevator_botId[0] == -1 )
					{
						return;
					}
					
					yield();
				}
				
				while ( Map.Elevator_Top_Door != "Opened" )
				{
					yield();
				}
			},
		},
		
		//	/bot waypoint_setproperty paththrough Navigation_PT:lift
		lift =
		{
			navigate = function()
			{
				this.Goto(this.Bot.GetPosition());
				
				while ( Map.Lift != "Down" )
				{
					yield();
				}
				
				timer = 0;
				while ( !this.Bot.MoveTowards(Vec3(-3729.386, 14910.157, -280.875), 45) )
				{
					sleep(0.1);
					timer += 1;
					
					if ( timer == 100 )
					{
						return;
					}
				}
				
				while ( Map.Lift != "Up" )
				{
					this.Goto(this.Bot.GetPosition());
					yield();
				}
			},
		},
	},
	
