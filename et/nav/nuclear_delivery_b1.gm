	Door_Controls_Built = function()
	{
		Map.Door_Controls = true;
		Map.Forward_Bunker = TEAM.ALLIES;
		
		Util.MapDebugPrint( "Door_Controls_Built" );
		
		SetAvailableMapGoals(0, false, "CHECKPOINT_forwardbunkerflag");
		
		Util.ChangeCrucialClassForRole(TEAM.ALLIES,ROLE.ATTACKER1,{CLASS.ENGINEER, CLASS.COVERTOPS});
		Util.ChangeCrucialClassForRole(TEAM.ALLIES,ROLE.ATTACKER2,{CLASS.ENGINEER, CLASS.COVERTOPS});
		
		SetGoalRole( ".*_Axis_DoorControls_.*", {ROLE.DEFENDER, ROLE.DEFENDER3} );
		SetGoalRole( ".*_Allies_DoorControls_.*", {ROLE.ATTACKER, ROLE.ATTACKER3} );
		
		SetAvailableMapGoals(TEAM.AXIS, false, {
			".*_Axis_ForwBunkerStart.*",
			".*_Axis_EW_Destroyed_.*",
			".*_Axis_WW_Destroyed_.*",
		});
		
		SetAvailableMapGoals(TEAM.AXIS, true, {
			".*_Axis_DoorControls_.*",
			".*_Axis_CappTruck_.*"
		});
		
		SetAvailableMapGoals(TEAM.ALLIES, false, {
			"CAMP_Allies_ForwBunker_.*",
			"BUILD_Door_Controls"
		});
		
		if ( Map.East_Wall )
		{
			SetAvailableMapGoals(TEAM.ALLIES, false,"PLANT_East_Wall");
		}
		if ( Map.West_Wall )
		{
			SetAvailableMapGoals(TEAM.ALLIES, false,"PLANT_West_Wall");
		}
		
		SetAvailableMapGoals(TEAM.ALLIES, true, {
			"ATTACK_Allies_DoorControls_1.*",
			"SWITCH_Door",
			"FLAG_axis_gold1",
			".*_Allies_CappTruck_.*"
		});
		
		if ( tableCount(Util.GoalTable("DEFUSE_West_Wall.*")) > 0 or tableCount(Util.GoalTable("DEFUSE_East_Wall.*")) > 0 )
		{
			foreach( goal in Util.GoalTable("DEFUSE_.*_Wall_.*") )
			{
				goal.SetAvailable(TEAM.AXIS, false);
			}
		}
	},

	DoorControlsArea =
	{
		Name = "DoorControlsArea",
		TriggerOnClass = CLASS.ANYPLAYER,
		OnEnter = function(ent)
		{
			if ( GetEntTeam(ent) == TEAM.ALLIES )
			{
				if (Map.count_ally[ent])
				{
					Map.count_ally[ent] += 1;
				}
				else
				{
					Map.count_ally[ent] = 1;
					//Util.MapDebugPrint("Allied players in trigger: " + tableCount(Map.count_ally));
				}
				
				if ( !Map.Door_Controls )
				{
					if ( Map.Forward_Bunker == TEAM.ALLIES )
					{
						SetGoalRole( "CHECKPOINT_forwardbunkerflag", {ROLE.DEFENDER, ROLE.DEFENDER1, ROLE.DEFENDER2} );
						ClearGoalRole( "CHECKPOINT_forwardbunkerflag", ROLE.DEFENDER3 );
					}
					
					SetAvailableMapGoals(TEAM.AXIS, false, ".*_Axis_ForwBunkerStart3_.*");
					
					SetAvailableMapGoals(TEAM.AXIS, true, ".*_Axis_DoorControls_0.*");
				}
				else
				{
					SetGoalRole( ".*_Axis_DoorControls_.*", {ROLE.DEFENDER, ROLE.DEFENDER3} );
					
					SetAvailableMapGoals(TEAM.AXIS, false, ".*_Axis_DC_Access_.*");
					
					SetAvailableMapGoals(TEAM.AXIS, true, ".*_Axis_DoorControls_.*");
				}
			}
		},
		OnExit = function(ent)
		{
			if (Map.count_ally[ent])
			{
				if (Map.count_ally[ent] > 1)
				{
					Map.count_ally[ent] -= 1;
					//Util.MapDebugPrint("Allied players in trigger: " + tableCount(Map.count_ally));
				}
				else
				{
					Map.count_ally[ent] = null;
				}
				
				if ( tableCount(Map.count_ally) < 1 )
				{
					if ( !Map.Door_Controls )
					{
						SetAvailableMapGoals(TEAM.AXIS, false, ".*_Axis_DoorControls_.*");
						
						if ( Map.Forward_Bunker == TEAM.AXIS )
						{
							SetAvailableMapGoals(TEAM.AXIS, true, ".*_Axis_ForwBunkerStart[03]_.*");
						}
						else
						{
							SetGoalRole( "CHECKPOINT_forwardbunkerflag", {ROLE.DEFENDER, ROLE.DEFENDER3} );
						}
					}
					else
					{
						ClearGoalRole( ".*_Axis_DoorControls_.*", ROLE.DEFENDER );
						
						SetAvailableMapGoals(TEAM.AXIS, false, ".*_Axis_DoorControls_1.*");
						
						SetAvailableMapGoals(TEAM.AXIS, true, ".*_Axis_DC_Access_.*");
					}
				}
			}
		},
	},

	Door_Opening = function()
	{
		Map.Door_Opened = true;
		
		Util.MapDebugPrint( "Door_Opening" );
		
		SetAvailableMapGoals(TEAM.ALLIES, false, {
			"SWITCH_Door",
			"CAPPOINT_Fake_.*"
		});
		
		if ( Map.Dynamite_1 == "Taken" or Map.Dynamite_2 == "Taken" )
		{
			SetAvailableMapGoals(TEAM.ALLIES, true, "CAPPOINT_Truck");
		}
		
		if ( Map.Dynamite_2 != "Secured" )
		{
			SetAvailableMapGoals(TEAM.AXIS, true, "SWITCH_Door");
		}
	},

	Door_Closing = function()
	{
		Map.Door_Opened = false;
		
		Util.MapDebugPrint( "Door_Closing" );
		
		SetAvailableMapGoals(TEAM.AXIS, false, "SWITCH_Door");
		
		if ( Map.Dynamite_2 != "Secured" )
		{
			SetAvailableMapGoals(TEAM.ALLIES, true, "SWITCH_Door");
		}
		
		sleep(2);
		
		if ( !Map.Door_Opened )
		{
			SetAvailableMapGoals(TEAM.ALLIES, false, "CAPPOINT_Truck");
			
			SetAvailableMapGoals(TEAM.ALLIES, true, "CAPPOINT_Fake_.*");
		}
	},

	Dynamite_1_Taken = function()
	{
		Map.Dynamite_1 = "Taken";
		
		Util.MapDebugPrint( "Dynamite_1_Taken" );
		
		SetAvailableMapGoals(TEAM.ALLIES, false, "FLAG_axis_gold1");
		
		if ( Map.Door_Opened )
		{
			SetAvailableMapGoals(TEAM.ALLIES, true, "CAPPOINT_Truck");
		}
		else
		{
			SetAvailableMapGoals(TEAM.ALLIES, true, "CAPPOINT_Fake_.*");
		}
	},

