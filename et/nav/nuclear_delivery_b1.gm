	Forward_Bunker_Axis_Captured = function()
	{
		Map.Forward_Bunker = TEAM.AXIS;
		
		Util.MapDebugPrint( "Forward_Bunker_Axis_Captured" );
		
		ClearGoalRole( "CHECKPOINT_forwardbunkerflag", {ROLE.DEFENDER, ROLE.DEFENDER1, ROLE.DEFENDER2, ROLE.DEFENDER3} );
		
		SetGoalRole( "BUILD_Door_Controls", ROLE.ATTACKER3 );
		ClearGoalRole( ".*_Allies_DoorControls_0.*", ROLE.ATTACKER );
		
		SetAvailableMapGoals(TEAM.AXIS, false, "CHECKPOINT_forwardbunkerflag");
		
		SetAvailableMapGoals(TEAM.ALLIES, false, {
			"CAMP_Allies_ForwBunker_.*",
			"ATTACK_Allies_DoorControls_1.*"
		});
		
		SetAvailableMapGoals(TEAM.ALLIES, true, "CHECKPOINT_forwardbunkerflag");
		
		if ( tableCount(Map.count_ally) < 1 )
		{
			if ( Map.East_Wall and Map.West_Wall )
			{
				SetAvailableMapGoals(TEAM.AXIS, true, ".*_Axis_ForwBunkerStart.*");
			}
			else
			{
				if ( Map.East_Wall )
				{
					SetAvailableMapGoals(TEAM.AXIS, true, {
						".*_Axis_ForwBunkerStart[023].*",
						".*_Axis_WW_Destroyed_.*"
					});
				}
				else
				{
					SetAvailableMapGoals(TEAM.AXIS, true, {
						".*_Axis_ForwBunkerStart[013].*",
						".*_Axis_EW_Destroyed_.*"
					});
				}
			}
		}
		else
		{
			if ( Map.East_Wall and Map.West_Wall )
			{
				SetAvailableMapGoals(TEAM.AXIS, true, ".*_Axis_ForwBunkerStart[12].*");
			}
			else
			{
				if ( Map.East_Wall )
				{
					SetAvailableMapGoals(TEAM.AXIS, true, {
						".*_Axis_ForwBunkerStart2.*",
						".*_Axis_WW_Destroyed_.*"
					});
				}
				else
				{
					SetAvailableMapGoals(TEAM.AXIS, true, {
						".*_Axis_ForwBunkerStart1.*",
						".*_Axis_EW_Destroyed_.*"
					});
				}
			}
		}
	},

	Forward_Bunker_Allies_Captured = function()
	{
		Map.Forward_Bunker = TEAM.ALLIES;
		
		Util.MapDebugPrint( "Forward_Bunker_Allies_Captured" );
		
		ClearGoalRole( "BUILD_Door_Controls", ROLE.ATTACKER3 );
		
		SetGoalRole( ".*_Allies_DoorControls_.*", {ROLE.ATTACKER, ROLE.ATTACKER3} );
		
		SetAvailableMapGoals(TEAM.ALLIES, false, "CHECKPOINT_forwardbunkerflag");
		
		SetAvailableMapGoals(TEAM.ALLIES, true, {
			"CAMP_Allies_ForwBunker_.*",
			"ATTACK_Allies_DoorControls_1.*"
		});
		
		SetAvailableMapGoals(TEAM.AXIS, true, "CHECKPOINT_forwardbunkerflag");
		
		if ( tableCount(Map.count_ally) < 1 )
		{
			if ( !Map.Door_Controls )
			{
				SetGoalRole( "CHECKPOINT_forwardbunkerflag", {ROLE.DEFENDER, ROLE.DEFENDER1, ROLE.DEFENDER2, ROLE.DEFENDER3} );
			}
			else
			{
				SetGoalRole( "CHECKPOINT_forwardbunkerflag", {ROLE.DEFENDER, ROLE.DEFENDER1, ROLE.DEFENDER2} );
			}
		}
		else
		{
			if ( !Map.Door_Controls )
			{
				SetGoalRole( "CHECKPOINT_forwardbunkerflag", {ROLE.DEFENDER, ROLE.DEFENDER1, ROLE.DEFENDER2} );
			}
			else
			{
				SetGoalRole( "CHECKPOINT_forwardbunkerflag", {ROLE.DEFENDER1, ROLE.DEFENDER2} );
			}
		}
	},

	East_Wall_Planted = function()
	{
		Util.MapDebugPrint( "East_Wall_Planted" );
		
		foreach( goal in Util.GoalTable("DEFUSE_East_Wall_.*") )
		{
			if ( !Map.Door_Controls )
			{
				goal.SetRoles(ROLE.DEFENDER, ROLE.DEFENDER1, ROLE.DEFENDER2);
			}
			else
			{
				goal.SetAvailable(TEAM.AXIS, false);
			}
		}
	},

	East_Wall_Destroyed = function()
	{
		Map.East_Wall = false;
		
		Util.MapDebugPrint( "East_Wall_Destroyed" );
		
		Wp.SetWaypointFlag( "East_Wall_[12]", "closed", true );
		Wp.SetWaypointFlag( "East_Wall_[345]", "closed", false );
		
		Util.EnableGoal("ROUTE_EastWallWay");
		
		SetGoalRole( "CALLARTILLERY_Axis_ForwBunkerStart0.*", ROLE.DEFENDER1 );
		
		SetAvailableMapGoals(TEAM.AXIS, false, ".*_Axis_ForwBunkerStart1.*");
		
		if ( Map.Forward_Bunker == TEAM.AXIS )
		{
			SetAvailableMapGoals(TEAM.AXIS, true, ".*_Axis_EW_Destroyed_.*");
		}
		
		foreach( goal in Util.GoalTable("DEFUSE_East_Wall_.*") )
		{
			goal.SetAvailable(TEAM.AXIS, false);
		}
	},

