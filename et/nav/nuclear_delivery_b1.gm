	Dynamite_2_Secured = function()
	{
		Map.Dynamite_2 = "Secured";
		
		Util.MapDebugPrint( "Dynamite_2_Secured" );
		
		DeleteTriggerRegion("DoorControlsArea");
		
		SetAvailableMapGoals( 0, false, "SWITCH_Door" );
		
		SetGoalPriority( "AIRSTRIKE_.*", 0.80, 0 );
		SetGoalPriority( "CALLARTILLERY_.*", 0.80, 0 );
		SetGoalPriority( "TRIPMINE_.*", 0.81, 0 );
		SetGoalPriority( "PLANT_.*", 0.81, 0 );
		SetGoalPriority( "MOBILEMG42_.*", 0.89, 0 );
		
		SetGoalPriority( "BUILD_.*", 0.84, 0 );
		SetGoalPriority( "PLANT_Truck_Bridge", 0.86, 0 );
		SetGoalPriority( "SWITCH_Generator", 1.10, 0 );
		
		sleep(4);
		
		SetAvailableMapGoals(TEAM.AXIS, false, {
			".*_Axis_DoorControls_.*",
			".*_Axis_DC_Access_.*",
			".*_Axis_CappTruck_.*"
		});
		
		SetAvailableMapGoals(TEAM.ALLIES, false, {
			"CAPPOINT_.*",
			".*_Allies_DoorControls_.*",
			".*_Allies_CappTruck_.*"
		});
		
		SetAvailableMapGoals(TEAM.AXIS, true, {
			".*_Axis_TruckStolen_.*",
			"PLANTMINE_Axis_OverBridge_.*"
		});
		
		if ( !Map.Truck_Barrier )
		{
			SetAvailableMapGoals(TEAM.AXIS, true,"BUILD_Tank_Barrier_2");
		}
		
		if ( !Map.Base_MG42 )
		{
			SetAvailableMapGoals(TEAM.AXIS, true,"BUILD_base_MG42");
		}
		
		if ( !Map.Truck )
		{
			SetAvailableMapGoals(TEAM.ALLIES, true,"BUILD_truck");
		}
		else
		{
			SetAvailableMapGoals(TEAM.ALLIES, true,"ESCORT_Truck");
		}
		
		SetAvailableMapGoals(TEAM.ALLIES, true, {
			"BUILD_Truck_Bridge",
			".*_Allies_TruckStolen_.*"
		});
	},

	Truck_Built = function()
	{
		Map.Truck = true;
		
		Util.MapDebugPrint( "Truck_Built" );
		
		SetAvailableMapGoals(TEAM.ALLIES, false,"BUILD_truck");
		
		if ( Map.Dynamite_2 == "Secured" )
		{
			if ( Map.Truck_End or ( Map.TruckAtBridge and !Map.Truck_Bridge ) or ( Map.TruckAtBarrier and Map.Truck_Barrier ) )
			{
				SetAvailableMapGoals(TEAM.ALLIES, false,"ESCORT_Truck");
			}
			else
			{
				SetAvailableMapGoals(TEAM.ALLIES, true,"ESCORT_Truck");
			}
		}
	},
	
	Truck_Stolen = function()
	{
		Util.MapDebugPrint( "Truck_Stolen" );
		
		ETUtil.SetExcludeIndexes( "ESCORT_Truck", {} );
		ETUtil.SetExcludeIndexes( "BUILD_truck", {} );
	},
	
	Truck_Destroyed = function()
	{
		Map.Truck = false;
		
		Util.MapDebugPrint( "Truck_Destroyed" );
		
		SetAvailableMapGoals(TEAM.ALLIES, false,"ESCORT_Truck");
		
		if ( Map.Dynamite_2 == "Secured" )
		{
			if ( Map.Truck_End or ( Map.TruckAtBridge and !Map.Truck_Bridge ) or ( Map.TruckAtBarrier and Map.Truck_Barrier ) )
			{
				SetAvailableMapGoals(TEAM.ALLIES, false,"BUILD_truck");
			}
			else
			{
				SetAvailableMapGoals(TEAM.ALLIES, true,"BUILD_truck");
			}
		}
	},

	Truck_Bridge_Built = function()
	{
		Map.Truck_Bridge = true;
		Wp.SetWaypointFlag( "Bridge_.*", "closed", false );
		
		Util.MapDebugPrint( "Truck_Bridge_Built" );
		
		SetAvailableMapGoals(TEAM.ALLIES, false,"BUILD_Truck_Bridge");
		
		if ( !Map.TruckOverBridge )
		{
			SetAvailableMapGoals(TEAM.AXIS, true,"PLANT_Truck_Bridge");
		}
		
		if ( !Map.Truck and Map.TruckAtBridge )
		{
			SetAvailableMapGoals(TEAM.ALLIES, true,"BUILD_truck");
		}
	},

	Truck_Bridge_Destroyed = function()
	{
		Map.Truck_Bridge = false;
		Wp.SetWaypointFlag( "Bridge_.*", "closed", true );

		Util.MapDebugPrint( "Truck_Bridge_Destroyed" );
		
		foreach( goal in Util.GoalTable("DEFUSE_Truck_Bridge_.*") )
		{
			goal.SetAvailable(TEAM.ALLIES, false);
		}
		
		if ( !Map.Truck and Map.TruckAtBridge )
		{
			SetAvailableMapGoals(TEAM.ALLIES, false,"BUILD_truck");
		}
		
		if ( !Map.TruckOverBridge )
		{
			SetAvailableMapGoals(TEAM.ALLIES, true,"BUILD_Truck_Bridge");
		}
	},
	
	Truck_Left_Storage = function()
	{
		Util.MapDebugPrint( "Truck_Left_Storage" );
		
		ETUtil.SetExcludeIndexes( "BUILD_truck", {2, 3} );
	},
	
	Truck_Outside = function()
	{
		Util.MapDebugPrint( "Truck_Outside" );
		
		ETUtil.SetExcludeIndexes( "BUILD_truck", {0, 1, 2, 3} );
	},
	
	Truck_At_Bridge = function()
	{
		Util.MapDebugPrint( "Truck_At_Bridge" );
		
		Map.TruckAtBridge = true;
	},

	Truck_Over_Bridge = function()
	{
		Util.MapDebugPrint( "Truck_Over_Bridge" );
		
		Map.TruckAtBridge = false;
		Map.TruckOverBridge = true;
		
		Util.ChangeCrucialClassForRole(TEAM.ALLIES,ROLE.ATTACKER1,{CLASS.ENGINEER, CLASS.SOLDIER});
		Util.ChangeCrucialClassForRole(TEAM.ALLIES,ROLE.ATTACKER2,{CLASS.ENGINEER, CLASS.SOLDIER});
		
		Util.SetMaxUsers(4, "BUILD_truck");
		
		SetGoalPriority( "PLANTMINE_Axis_OverBridge_.*", 0.79, TEAM.AXIS );
		
		if ( Map.Truck_Bridge )
		{
			SetAvailableMapGoals( TEAM.AXIS, false,"PLANT_Truck_Bridge" );
		}
		else
		{
			SetAvailableMapGoals(TEAM.ALLIES, false,"BUILD_Truck_Bridge");
		}
		
		SetAvailableMapGoals(0, false,".*_TruckStolen_.*");
		
		SetAvailableMapGoals( TEAM.AXIS, true, {
			".*_Axis_OverBridge_.*",
			"PLANTMINE_Axis_PastBarrier_.*"
		});
		
		SetAvailableMapGoals( TEAM.ALLIES, true,".*_Allies_OverBridge_.*" );
		
		if ( !Map.Allied_Command_Post )
		{
			SetAvailableMapGoals(TEAM.ALLIES, true,"BUILD_Allied_Command_Post");
		}
		else
		{
			SetAvailableMapGoals(TEAM.ALLIES, false, {
				"MOBILEMORTAR_Allies_OverBridge_.*",
				"CALLARTILLERY_Allies_OverBridge_.*"
			});
		}
		
		if ( Map.Truck_Barrier )
		{
			SetAvailableMapGoals(TEAM.ALLIES, true,"PLANT_Tank_Barrier_2");
		}
	},

	Base_MG42_Built = function()
	{
		Map.Base_MG42 = true;
		
		Util.MapDebugPrint( "Base_MG42_Built" );
		
		SetAvailableMapGoals( TEAM.AXIS, false,"BUILD_base_MG42" );
		
		if ( Map.TruckAtBarrier or ( Map.TruckPastBarrier and !Map.TruckEnteredAxisBase ))
		{
			SetAvailableMapGoals( TEAM.AXIS, true,".*MG42_base_MG42" );
		}
	},

	Base_MG42_Destroyed = function()
	{
		Map.Base_MG42 = false;
		
		Util.MapDebugPrint( "Base_MG42_Destroyed" );
		
		SetAvailableMapGoals( TEAM.AXIS, false,".*MG42_base_MG42" );
		
		if ( !Map.TruckEnteredAxisBase )
		{
			SetAvailableMapGoals( TEAM.AXIS, true,"BUILD_base_MG42" );
		}
	},

	Truck_Barrier_Built = function()
	{
		Map.Truck_Barrier = true;
		Wp.SetWaypointFlag( "Tank_Barrier_2_0", "closed", false );
		
		Util.MapDebugPrint( "Truck_Barrier_Built" );
		
		SetAvailableMapGoals(TEAM.AXIS, false,"BUILD_Tank_Barrier_2");
		
		if ( !Map.Truck and Map.TruckAtBarrier )
		{
			SetAvailableMapGoals(TEAM.ALLIES, false,"BUILD_truck");
		}
		
		if ( Map.TruckOverBridge )
		{
			SetAvailableMapGoals(TEAM.ALLIES, true,"PLANT_Tank_Barrier_2");
		}
	},

	Truck_Barrier_Destroyed = function()
	{
		Map.Truck_Barrier = false;
		Wp.SetWaypointFlag( "Tank_Barrier_2_0", "closed", true );
		
		Util.MapDebugPrint( "Truck_Barrier_Destroyed" );
		
		foreach( goal in Util.GoalTable("DEFUSE_Tank_Barrier_2_.*") )
		{
			goal.SetAvailable(TEAM.AXIS, false);
		}
		
		SetAvailableMapGoals(TEAM.ALLIES, false,"PLANT_Tank_Barrier_2");
		
		if ( !Map.Truck and Map.TruckAtBarrier )
		{
			SetAvailableMapGoals(TEAM.ALLIES, true,"BUILD_truck");
		}
		
		if ( !Map.TruckPastBarrier )
		{
			SetAvailableMapGoals(TEAM.AXIS, true,"BUILD_Tank_Barrier_2");
		}
	},

	Truck_At_Barrier = function()
	{
		Util.MapDebugPrint( "Truck_At_Barrier" );
		
		Map.TruckAtBarrier = true;
		
		SetGoalPriority( "PLANTMINE_Axis_PastBarrier_.*", 0.79, TEAM.AXIS );
		
		SetAvailableMapGoals( TEAM.AXIS, false,"PLANTMINE_Axis_OverBridge_.*" );
		
		if ( Map.Base_MG42 )
		{
			SetAvailableMapGoals(TEAM.AXIS, true,".*MG42_base_MG42");
		}
	},

	Truck_Past_Barrier = function()
	{
		Util.MapDebugPrint( "Truck_Past_Barrier" );
		
		Map.TruckAtBarrier = false;
		Map.TruckPastBarrier = true;
		
		SetAvailableMapGoals( 0, false,".*_OverBridge_.*" );
		
		SetAvailableMapGoals(TEAM.AXIS, false,"BUILD_Tank_Barrier_2");
		
		SetAvailableMapGoals( TEAM.AXIS, true, {
			".*_Axis_PastBarrier_.*",
			"PLANTMINE_Axis_Base_.*"
		});
		
		SetAvailableMapGoals( TEAM.ALLIES, true,".*_Allies_PastBarrier_.*" );
	},

	Allied_Command_Post_Built = function()
	{
		Map.Allied_Command_Post = true;
		
		Util.MapDebugPrint( "Allied_Command_Post_Built" );
		
		SetAvailableMapGoals(TEAM.ALLIES, false, {
			"BUILD_Allied_Command_Post",
			"MOBILEMORTAR_Allies_OverBridge_.*",
			"CALLARTILLERY_Allies_OverBridge_.*"
		});
		
		SetAvailableMapGoals(TEAM.AXIS, true,"PLANT_Allied_Command_Post");
		
		if ( Map.Generator and !Map.Launch_Sequence )
		{
			SetAvailableMapGoals(TEAM.ALLIES, true,"SWITCH_Generator");
		}
	},

	Allied_Command_Post_Destroyed = function()
	{
		Map.Allied_Command_Post = false;
		
		Util.MapDebugPrint( "Allied_Command_Post_Destroyed" );
		
		SetAvailableMapGoals(TEAM.AXIS, false,"PLANT_Allied_Command_Post");
		
		if ( Map.TruckOverBridge )
		{
			SetAvailableMapGoals(TEAM.ALLIES, true, "BUILD_Allied_Command_Post");
			
			if ( !Map.TruckPastBarrier )
			{
				SetAvailableMapGoals(TEAM.ALLIES, true, {
					"MOBILEMORTAR_Allies_OverBridge_.*",
					"CALLARTILLERY_Allies_OverBridge_.*"
				});
			}
		}
		
		if ( Map.Generator and !Map.Launch_Sequence )
		{
			SetAvailableMapGoals(TEAM.ALLIES, false,"SWITCH_Generator");
		}
	},
	
	Truck_Entered_Axis_Base = function()
	{
		Util.MapDebugPrint( "Truck_Entered_Axis_Base" );
		
		Map.TruckEnteredAxisBase = true;
		
		SetGoalPriority( "PLANTMINE_Axis_Base_.*", 0.79, TEAM.AXIS );
		SetGoalPriority( "PLANT_Allied_Command_Post", 0.77, TEAM.AXIS, CLASS.ENGINEER );
		
		Util.ChangeCrucialClassForRole(TEAM.AXIS,ROLE.DEFENDER2,{CLASS.COVERTOPS, CLASS.SOLDIER});
		Util.ChangeCrucialClassForRole(TEAM.AXIS,ROLE.DEFENDER3,{CLASS.COVERTOPS, CLASS.FIELDOPS});
		
		SetAvailableMapGoals( 0, false,".*_PastBarrier_.*" );
		
		SetAvailableMapGoals(TEAM.AXIS, true, {
			".*_Axis_Base_.*",
			".*_Axis_Windows_.*"
		});
		
		SetAvailableMapGoals(TEAM.ALLIES, true,".*_Allies_Base_.*");
	},

	Truck_At_The_End = function()
	{
		Map.Truck_End = true;
		
		Util.MapDebugPrint( "Truck_At_The_End" );
		
		SetAvailableMapGoals(TEAM.ALLIES, false, {
			"ESCORT_Truck",
			"BUILD_truck"
		});
		
		SetAvailableMapGoals(TEAM.ALLIES, true,"BUILD_Generator");
	},

	Generator_Built = function()
	{
		Map.Generator = true;
		Wp.SetWaypointFlag( "Generator_0", "closed", false );
		
		Util.MapDebugPrint( "Generator_Built" );
		
		SetAvailableMapGoals(TEAM.ALLIES, false,"BUILD_Generator");
		
		SetAvailableMapGoals(TEAM.AXIS, true,"PLANT_Generator");
		
		if ( Map.Allied_Command_Post )
		{
			SetAvailableMapGoals(TEAM.ALLIES, true,"SWITCH_Generator");
		}
	},

	Generator_Destroyed = function()
	{
		Map.Generator = false;
		Wp.SetWaypointFlag( "Generator_0", "closed", true );
		
		Util.MapDebugPrint( "Generator_Destroyed" );
		
		SetAvailableMapGoals(TEAM.AXIS, false,"PLANT_Generator");
		
		SetAvailableMapGoals(0, false,"SWITCH_Generator");
		
		SetAvailableMapGoals(TEAM.ALLIES, true,"BUILD_Generator");
	},

	Launch_Sequence_Activated = function()
	{
		Map.Launch_Sequence = true;
		
		Util.MapDebugPrint( "Launch_Sequence_Activated" );
		
		SetAvailableMapGoals(TEAM.ALLIES, false,"SWITCH_Generator");
		
		SetAvailableMapGoals(TEAM.AXIS, true,"SWITCH_Generator");
	},

	Launch_Sequence_Aborted = function()
	{
		Map.Launch_Sequence = false;
		
		Util.MapDebugPrint( "Launch_Sequence_Aborted" );
		
		SetAvailableMapGoals(TEAM.AXIS, false,"SWITCH_Generator");
		
		SetAvailableMapGoals(TEAM.ALLIES, true,"SWITCH_Generator");
	},

	Nuclear_Launch_Confirmed = function()
	{
		Util.MapDebugPrint( "Nuclear_Launch_Confirmed" );
		
		ETUtil.WinningChat( TEAM.ALLIES );
		ETUtil.LosingChat( TEAM.AXIS );
	},

	Elevator_Position = function()
	{
		tr1 = TraceLine( Vec3(1533.437, 2716.322, -51.875), Vec3(1533.437, 2716.322, -175.639), null, TRACE.SOLID, 0, false );
		tr2 = TraceLine( Vec3(1626.125, 2676.421, -175.875), Vec3(1555.154, 2676.186, -174.902), null, TRACE.SOLID, 0, false );
		tr3 = TraceLine( Vec3(1626.125, 2676.421, 88.125), Vec3(1555.154, 2676.186, 88.125), null, TRACE.SOLID, 0, false );
		lift = GetEntityByName("sniperlift");
		while ( 1 )
		{
			if ( Round(GetEntPosition(tr1.entity).z ) == -141 )
			{
				if ( Map.Elevator != "Down" )
				{
					Map.Elevator = "Down";
					Util.MapDebugPrint( "Elevator_Down" );
				}
			}
			else if ( Round(GetEntPosition(tr1.entity).z ) == 123 )
			{
				if ( Map.Elevator != "Up" )
				{
					Map.Elevator = "Up";
					Util.MapDebugPrint( "Elevator_Up" );
				}
			}
			else
			{
				if ( Map.Elevator != "Moving" )
				{
					Map.Elevator = "Moving";
					Util.MapDebugPrint( "Elevator_Moving" );
				}
			}
			
			if ( Round(GetEntPosition(tr2.entity).y ) == 2696 )
			{
				if ( Map.Elevator_Bottom_Door != "Closed" )
				{
					Map.Elevator_Bottom_Door = "Closed";
					Util.MapDebugPrint( "Elevator_Bottom_Door_Closed" );
				}
			}
			else if ( Round(GetEntPosition(tr2.entity).y ) == 2658 )
			{
				if ( Map.Elevator_Bottom_Door != "Opened" )
				{
					Map.Elevator_Bottom_Door = "Opened";
					Util.MapDebugPrint( "Elevator_Bottom_Door_Opened" );
				}
			}
			else
			{
				if ( Map.Elevator_Bottom_Door != "Moving" )
				{
					Map.Elevator_Bottom_Door = "Moving";
					Util.MapDebugPrint( "Elevator_Bottom_Door_Moving" );
				}
			}
			
			if ( Round(GetEntPosition(tr3.entity).y ) == 2696 )
			{
				if ( Map.Elevator_Top_Door != "Closed" )
				{
					Map.Elevator_Top_Door = "Closed";
					Util.MapDebugPrint( "Elevator_Top_Door_Closed" );
				}
			}
			else if ( Round(GetEntPosition(tr3.entity).y ) == 2658 )
			{
				if ( Map.Elevator_Top_Door != "Opened" )
				{
					Map.Elevator_Top_Door = "Opened";
					Util.MapDebugPrint( "Elevator_Top_Door_Opened" );
				}
			}
			else
			{
				if ( Map.Elevator_Top_Door != "Moving" )
				{
					Map.Elevator_Top_Door = "Moving";
					Util.MapDebugPrint( "Elevator_Top_Door_Moving" );
				}
			}
			
			if ( Round(GetEntPosition(lift).z ) == -589 )
			{
				if ( Map.Lift != "Down" )
				{
					Map.Lift = "Down";
					Util.MapDebugPrint( "Lift_Down" );
				}
			}
			else if ( Round(GetEntPosition(lift).z ) == -92 )
			{
				if ( Map.Lift != "Up" )
				{
					Map.Lift = "Up";
					Util.MapDebugPrint( "Lift_Up" );
				}
			}
			else
			{
				if ( Map.Lift != "Moving" )
				{
					Map.Lift = "Moving";
					Util.MapDebugPrint( "Lift_Moving" );
				}
			}
			sleep(0.2);
		}
	},
	
	Elevator_Position_Debug = function()
	{
		for (;;)
        {
            for ( i = 0; i <= 5; i += 1 )
            {
                pos = Map.Elevator_Positions[i];
                DrawText3d( pos + Vec3(0,0,40), Map.Strings[i], COLOR.LIGHT_GREY, 0.2 );
				
                if ( i > 3 )
                {
                    c = COLOR.BLUE;
                }
                else if ( Map.Elevator_botId[i] == -1 )
                {
                    c = COLOR.GREEN;
                }
                else if ( Map.Bot_Ready[i] )
                {
                    c = COLOR.RED;
                }
                else
                {
                    c = COLOR.YELLOW;
                }
				
                DrawDebugLine( pos + Vec3(0,0,40), pos - Vec3(0,0,25), c, 0.2 );
            }
            sleep(0.2);
        }
	},
	
	Ignore_Target =
	{
		Name = "Ignore_Target",
		TriggerOnClass = CLASS.ANYPLAYER,
		OnEnter = function(ent)
		{
			b = Util.IsBot(ent);
			if ( b )
			{
				for ( q = 0; q < 64; q += 1 )
				{
					if ( EntityIsValid(q) and q != b.GetGameId() )
					{
						b.IgnoreTarget(q, 999);
					}
				}
			}
		},
		OnExit = function(ent)
		{
			b = Util.IsBot(ent);
			if ( b )
			{
				for ( q = 0; q < 64; q += 1 )
				{
					if ( EntityIsValid(q) and q != b.GetGameId() )
					{
						b.IgnoreTarget(q, 0.1);
					}
				}
			}
		},
	},
};

global OnMapLoad = function()
{
	thread ( Map.Elevator_Position );
	
	if ( Map.Debug )
	{
		thread ( Map.Elevator_Position_Debug );
	}
	
	OnTrigger( "^1Allied Command Post constructed. Charge speed increased!", Map.Allied_Command_Post_Built );
	OnTrigger( "^1Axis team has destroyed the Allied Command Post!", Map.Allied_Command_Post_Destroyed );
	
	OnTrigger( "^1The Door Controls have been constructed!", Map.Door_Controls_Built );
	
	OnTrigger( "^1Allies have constructed the Nuclear-Launch Generator!!", Map.Generator_Built );
	OnTrigger( "^1Axis team has destroyed the Nuclear-Launch Generator!", Map.Generator_Destroyed );
	
	OnTrigger( "^1Barrier has been constructed.", Map.Truck_Barrier_Built );
	OnTrigger( "^1Barrier has been destroyed.", Map.Truck_Barrier_Destroyed );
	
	OnTrigger( "^1The Bridge has been constructed.", Map.Truck_Bridge_Built );
	OnTrigger( "^1The Bridge has been destroyed.", Map.Truck_Bridge_Destroyed );
	
	OnTrigger( "^1Axis have built the Base MG42!", Map.Base_MG42_Built );
	OnTrigger( "^1Allies have destroyed the Base MG42!", Map.Base_MG42_Destroyed );
	
	OnTrigger( "^1The truck has been repaired!", Map.Truck_Built );
	OnTrigger( "^1The truck has been damaged", Map.Truck_Destroyed );
	
	OnTrigger( "Planted at the East Wall.", Map.East_Wall_Planted );
	OnTrigger( "^1Allies have damaged the East Wall!", Map.East_Wall_Destroyed );
	OnTrigger( "Planted at the West Wall.", Map.West_Wall_Planted );
	OnTrigger( "^1Allies have damaged the West Wall!", Map.West_Wall_Destroyed );
	
	OnTrigger( "^1The Allies have stolen the first Dynamite!", Map.Dynamite_1_Taken );
	OnTrigger( "Flag returned axis_gold1!", Map.Dynamite_1_Returned );
	OnTrigger( "^1The Allies have secured the first Dynamite!", Map.Dynamite_1_Secured );
	
	OnTrigger( "^1The Allies have stolen the second Dynamite!", Map.Dynamite_2_Taken );
	OnTrigger( "Flag returned axis_gold2!", Map.Dynamite_2_Returned );
	OnTrigger( "^1The Allies have secured the second Dynamite!", Map.Dynamite_2_Secured );
	
	OnTrigger( "^1Axis reclaim the Forward Bunker!", Map.Forward_Bunker_Axis_Captured );
	OnTrigger( "^1Allies capture the Forward Bunker!", Map.Forward_Bunker_Allies_Captured );
	
	OnTrigger( "^1The Loading Door is opening!", Map.Door_Opening );
	OnTrigger( "^1The Loading Doors are closing!", Map.Door_Closing );
	
	OnTrigger( "^1!!^7Truck reached its final stage ^1- ^7Dynamites loaded^1!!", Map.Truck_At_The_End );
	
	OnTrigger( "^1Nuclear launch sequence activated! Axis can abort within 10 seconds!", Map.Launch_Sequence_Activated );
	OnTrigger( "^1Axis have aborted the nuclear launch! Allies must trigger it again!", Map.Launch_Sequence_Aborted );
	
	OnTriggerRegion(AABB(-2534.625,9227.802,-255.445,-2524.625,9304.178,175.950), Map.Ignore_Target );
	
	Util.OnTriggerPosition( "MOVER_truck", Vector3( 1570.000, 4548.500, -175.500 ), 75, Map.Truck_Stolen );
	Util.OnTriggerPosition( "MOVER_truck", Vector3( 420.063, 7404.000, -173.638 ), 75, Map.Truck_Left_Storage );
	Util.OnTriggerPosition( "MOVER_truck", Vector3( -605.279, 7791.220, -178.500 ), 75, Map.Truck_Outside );
	Util.OnTriggerPosition( "MOVER_truck", Vector3( -587, 8213.96, -175.117 ), 75, Map.Truck_At_Bridge );
	Util.OnTriggerPosition( "MOVER_truck", Vector3( -587, 9318.29, -171.973 ), 75, Map.Truck_Over_Bridge );
	Util.OnTriggerPosition( "MOVER_truck", Vector3( -5791.000, 11637.400, -221.538 ), 75, Map.Truck_Entered_Axis_Base );
	Util.OnTriggerPosition( "MOVER_truck", Vector3( -5308.5, 9790, -180.5 ), 75, Map.Truck_At_Barrier );
	OnTrigger( "^1The truck is passed the barrier!", Map.Truck_Past_Barrier );
	
	OnTrigger( "^1Nuclear launch confirmed!", Map.Nuclear_Launch_Confirmed );

	Util.DisableGoal(".*", true);
	Util.DisableGoal("ROUTE_.*WallWay");
	
	Util.AddUseWp( "PLANT_West_Wall", "West_Wall_0" );
	Util.AddUseWp( "PLANT_East_Wall", "East_Wall_0" );
