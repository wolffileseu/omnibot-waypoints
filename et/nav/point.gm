				ROUTE_underground =
				{
					Weight = 2,
				},

				ROUTE_ax_a_left =
				{
					ROUTE_house_front =
					{
						ROUTE_house_back4 = {},
					},
					ROUTE_hill_left = {},
					ROUTE_hill_center = {},
				},

				ROUTE_ax_a_right =
				{
					ROUTE_hill_right = {},
					ROUTE_hill_center = {},
				},


				ROUTE_trench1 =
				{
					ROUTE_trench2 =
					{
