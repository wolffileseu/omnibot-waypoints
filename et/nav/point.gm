global OnBotJoin = function( bot )
{
	bot.MaxViewDistance = 3400;
};

global InitializeRoutes = function()
{
	MapRoutes =
	{
		DEFEND_al_b5 =
		{
			ROUTE_al_spawn =
			{
				ROUTE_house_back4 =
				{
				},
				ROUTE_al_a_left =
				{
				},
				ROUTE_al_a_right =
				{
				},
				ROUTE_trench6 =
				{
