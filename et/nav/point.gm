			},
		},

		DEFEND_ax_b5 =
		{
			ROUTE_ax_spawn =
			{
				ROUTE_house_back1 =
				{
				},
				ROUTE_ax_a_left =
				{
				},
				ROUTE_ax_a_right =
				{
				},
				ROUTE_trench1 =
				{
				},
			},
		},

		CAPPOINT_red =
		{
