	},

	allied_compost_built_Destroyed = function( trigger )
	{
		if ( TestMap )
			{ return; }

		print( "allied_compost_built_Destroyed" );
	},

	gate_Destroyed = function( trigger )
	{
		if ( TestMap )
			{ return; }
	SetAvailableMapGoals( TEAM.AXIS, false, "DEFEND_gate_.*" );
	SetAvailableMapGoals( TEAM.AXIS, true, "DEFEND_rocket_.*" );
	SetAvailableMapGoals( TEAM.ALLIES, false, "ATTACK_agate_.*" );
	SetAvailableMapGoals( TEAM.ALLIES, true, "ATTACK_arocket_.*" );


		print( "gate_Destroyed" );
	},

	controls_Destroyed = function( trigger )
	{
		if ( TestMap )
			{ return; }

		print( "controls_Destroyed" );
	},

//~ 	Allies_Capture_Flag = function( trigger )
