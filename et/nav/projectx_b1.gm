global Map =
{
	Ammo_Cabinet_first_ammocabinet = "AMMO_CABINET_first_ammocabinet",
	Ammo_Cabinet_first_ammocabinet = "AMMO_CABINET_first_ammocabinet",
	Build_axis_compost_built = "MAP_CONSTRUCTION_axis_compost_built",
	Build_allied_compost_built = "MAP_CONSTRUCTION_allied_compost_built",
	Destroy_controls = "MAP_DYNAMITE_TARGET_controls",
	Destroy_allied_compost_built = "MAP_DYNAMITE_TARGET_allied_compost_built",
	Destroy_gate = "MAP_DYNAMITE_TARGET_gate",

	axis_compost_built_Built = function( trigger )
	{
		if ( TestMap )
			{ return; }

		print( "axis_compost_built_Built" );
	},

	allied_compost_built_Built = function( trigger )
	{
