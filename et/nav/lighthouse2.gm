	Tower_Climbing_Ropes_Planted = function( trigger )
	{
		Util.MapDebugPrint( "Tower_Climbing_Ropes_Planted" );

		SetGoalRole( "DEFUSE_tower_climbing_ropes.*", ROLE.ROAMER, true );

		if ( Map.Anti_Ship_Gun or Map.Compound_Gate )
		{
			if (( Map.South_Ropes or Map.West_Ropes ) and !Map.Compound_Wall )
			{
				if ( Map.Comms_Bunker and Map.Light )
				{
					SetGoalRole( "DEFUSE_tower_climbing_ropes.*", { ROLE.ATTACKER3, ROLE.SNIPER, ROLE.ROAMER });
				}

				if ( !Map.Comms_Bunker and Map.Light )
				{
					SetGoalRole( "DEFUSE_tower_climbing_ropes.*", { ROLE.ATTACKER2, ROLE.ATTACKER3, ROLE.SNIPER, ROLE.ROAMER });
				}
			}
		}
		else
		{
			if (( Map.South_Ropes or Map.West_Ropes ) and !Map.Compound_Wall )
			{
				if ( Map.Comms_Bunker and Map.Light )
				{
					SetGoalRole( "DEFUSE_tower_climbing_ropes.*", { ROLE.ATTACKER, ROLE.ATTACKER1,
																	ROLE.ATTACKER3, ROLE.SNIPER, ROLE.ROAMER });
				}

				if ( !Map.Comms_Bunker and Map.Light )
				{
					SetGoalRole( "DEFUSE_tower_climbing_ropes.*", { ROLE.ATTACKER, ROLE.ATTACKER1, ROLE.ATTACKER2,
																	ROLE.ATTACKER3, ROLE.SNIPER, ROLE.ROAMER });
				}
			}
			else
			{
				SetGoalRole( "DEFUSE_tower_climbing_ropes.*", { ROLE.ATTACKER, ROLE.ATTACKER1, ROLE.ROAMER });
			}
		}
	},

