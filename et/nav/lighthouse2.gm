	Light_Defused = function( trigger )
	{
		Util.MapDebugPrint( "Light_Defused" );

		if ( tableCount(Util.GoalTable("DEFUSE_light.*")) == 1 )
		{
			if ( Map.Tower_Climbing_Ropes )
			{
				SetAvailableMapGoals( TEAM.ALLIES, true, {
					"PLANT_tower_climbing_ropes",
				});
			}
		}
	},

	Light_Destroyed = function( trigger )
	{
		Map.Light = false;

		Util.MapDebugPrint( "Light_Destroyed" );

		foreach( goal in Util.GoalTable("DEFUSE_light.*") )
		{
			goal.SetAvailable(TEAM.ALLIES, false);
		}

		SetAvailableMapGoals( TEAM.ALLIES, false, {
			".*_Allies_LightUp_.*",
		});

		SetAvailableMapGoals( TEAM.AXIS, false, {
			".*_Axis_LightUp_.*",
			"PLANT_light",
		});

		if ( !Map.Tower_Climbing_Ropes )
		{
			SetAvailableMapGoals( TEAM.AXIS, false, {
				"BUILD_tower_climbing_ropes",
			});
		}
		else
		{
			SetAvailableMapGoals( TEAM.ALLIES, false, {
				"PLANT_tower_climbing_ropes",
			});
		}

		if ( !Map.Comms_Bunker )
		{
			SetGoalRole( "BUILD_Command_Post", { ROLE.ATTACKER2, ROLE.ATTACKER3, ROLE.DEFENDER2, ROLE.DEFENDER3 });
			SetGoalRole( "PLANT_Command_Post", { ROLE.ATTACKER2, ROLE.ATTACKER3, ROLE.DEFENDER2, ROLE.DEFENDER3 });
			SetGoalRole( "CHECKPOINT_forwardspawn", { ROLE.ATTACKER2, ROLE.ATTACKER3, ROLE.DEFENDER2, ROLE.DEFENDER3 });
			SetGoalRole( "PLANT_compound_gate", { ROLE.ATTACKER2, ROLE.ATTACKER3 });
			SetGoalRole( "PLANT_anti_ship_gun", { ROLE.ATTACKER2, ROLE.ATTACKER3 });
			SetGoalRole( ".*_Axis_LightBelow_.*", { ROLE.ATTACKER2, ROLE.ATTACKER3 });
			SetGoalRole( ".*_Axis_CommsLightDest_.*", { ROLE.ATTACKER2, ROLE.ATTACKER3 });
			SetGoalRole( ".*MG42_Command_Post", { ROLE.ATTACKER2, ROLE.ATTACKER3 });
			SetGoalRole( "SMOKEBOMB_Axis_JumpWay_.*", { ROLE.ATTACKER2, ROLE.ATTACKER3 });

			Util.SetMaxUsers( 8, "CHECKPOINT_forwardspawn" );

			SetAvailableMapGoals( TEAM.AXIS, false, {
				".*_Axis_LightBelow_0.*",
			});

			SetAvailableMapGoals( TEAM.ALLIES, true, {
				".*_Allies_AntiShipReinf_.*",
			});

			if ( Map.Compound_Gate )
			{
				SetGoalPriority( "PLANT_compound_gate", 0.71, 0, 0 );
			}
		}
		else
		{
			if (( Map.West_Ropes or Map.South_Ropes ) and !Map.Compound_Wall )
			{
				SetGoalRole( ".*_Axis_CommsBunker_1.*", ROLE.ATTACKER3 );
			}

			SetAvailableMapGoals( TEAM.ALLIES, true, {
				".*_Allies_CommsBunker_1.*",
			});
		}

		if ( !Map.Comms_Bunker and !Map.Anti_Ship_Gun )
		{
			ETUtil.WinningChat( TEAM.AXIS );
			ETUtil.LosingChat( TEAM.ALLIES );
		}
	},

