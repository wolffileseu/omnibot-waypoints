		Util.MapDebugPrint( "Compound_Gate_Defused" );
	},

	Compound_Gate_Destroyed = function( trigger )
	{
		Map.Compound_Gate = false;

		Wp.SetWaypointFlag( "Compound_Gate_Door_.*", { "door", "allies", "infiltrator" }, false );

		Util.MapDebugPrint( "Compound_Gate_Destroyed" );

		foreach( goal in Util.GoalTable("DEFUSE_compound_gate.*") )
		{
			goal.SetAvailable(TEAM.ALLIES, false);
		}

		SetAvailableMapGoals( TEAM.AXIS, false, {
			"PLANT_compound_gate",
			"ROUTE_Tanks_00",
			".*_Axis_CompoundGate_.*",
		});

		if (Map.Light or Map.Comms_Bunker)
		{
			if ( Map.Anti_Ship_Gun )
			{
				SetAvailableMapGoals( TEAM.ALLIES, false, {
					".*_Allies_WestRopes_.*",
					".*_Allies_CompoundWall_.*",
				});

				if ( tableCount(Map.count_axis_ins) < 1 )
				{
					SetAvailableMapGoals( TEAM.ALLIES, true, {
						".*_Allies_CompGateDest_.*",
						".*_Allies_RopesWest_.*",
						".*_Allies_RopesSouth_.*",
					});
				}
			}
			else
			{
				if ( !Map.Compound_Wall )
				{
					SetAvailableMapGoals( TEAM.ALLIES, true, {
						"DEFEND_Allies_CompGateIns_.*",
					});
				}
			}
		}

		if ( !Map.Anti_Ship_Gun )
		{
			SetGoalRole( "PLANT_comms_bunker", { ROLE.ATTACKER, ROLE.ATTACKER1 });
			SetGoalRole( "PLANT_light", { ROLE.ATTACKER, ROLE.ATTACKER1 } );
			SetGoalRole( "BUILD_tower_climbing_ropes", { ROLE.ATTACKER, ROLE.ATTACKER1 } );
			SetGoalRole( "PLANT_tower_climbing_ropes", { ROLE.DEFENDER, ROLE.DEFENDER1 } );
			SetGoalRole( ".*_Axis_LightBelow_.*", { ROLE.ATTACKER, ROLE.ATTACKER1 });

			if ( Map.Light )
			{
				SetAvailableMapGoals( TEAM.AXIS, true, {
					".*_Axis_LightBelow_.*",
				});
			}
			else
			{
				SetAvailableMapGoals( TEAM.AXIS, true, {
					".*_Axis_LightBelow_1.*",
				});
			}
		}
		else
		{
			SetGoalRole( ".*_Axis_AntiShipGun_1.*", ROLE.ATTACKER1 );

			SetAvailableMapGoals( TEAM.AXIS, true, {
				".*_Axis_AntiShipGun_.*",
			});
		}
	},

	Compound_Wall_Planted = function( trigger )
	{
		Util.MapDebugPrint( "Compound_Wall_Planted" );

		SetGoalPriority( "DEFUSE_compound_wall.*", 0.85, TEAM.ALLIES, 0 );

		if ( Map.Anti_Ship_Gun )
		{
			SetGoalRole( "DEFUSE_compound_wall.*", { ROLE.DEFENDER2, ROLE.DEFENDER3 });
		}
		else
		{
			SetGoalRole( "DEFUSE_compound_wall.*", { ROLE.DEFENDER, ROLE.DEFENDER1, ROLE.DEFENDER2, ROLE.DEFENDER3 });
		}
	},

	Compound_Wall_Defused = function( trigger )
	{
		Util.MapDebugPrint( "Compound_Wall_Defused" );
	},

	Compound_Wall_Destroyed = function( trigger )
	{
		Map.Compound_Wall = false;

		Wp.SetWaypointFlag( "Compound_Wall_1", "jump", true );
		Wp.SetWaypointFlag( "Compound_Wall_2", "jump", true );
		Wp.SetWaypointFlag( "Compound_Wall_3", "jump", true );

		Util.MapDebugPrint( "Compound_Wall_Destroyed" );

		Util.EnableGoal( "ROUTE_CompoundWallWay_.*" );

		SetGoalPriority( "BUILD_ropes", 0.80, 0, 0 );
		SetGoalPriority( "BUILD_west_ropes", 0.80, 0, 0 );

		foreach( goal in Util.GoalTable("DEFUSE_compound_wall.*") )
		{
			goal.SetAvailable(TEAM.ALLIES, false);
		}

		SetGoalRole( "PLANT_compound_gate", ROLE.SNIPER );
		SetGoalRole( "PLANT_comms_bunker", ROLE.SNIPER );
		SetGoalRole( "PLANT_light", ROLE.SNIPER );
		SetGoalRole( "BUILD_tower_climbing_ropes", ROLE.SNIPER );
		SetGoalRole( ".*_Axis_CommsBunker_.*", ROLE.SNIPER );
		SetGoalRole( ".*_Axis_LightUp_.*", ROLE.SNIPER );

		if ( !Map.Anti_Ship_Gun and !Map.Compound_Gate )
		{
			SetAvailableMapGoals( TEAM.ALLIES, true, {
				"DEFEND_Allies_CompGateIns_.*",
			});
		}

		if ( Map.West_Ropes or Map.South_Ropes )
		{
			ClearGoalRole( ".*_Axis_CommsBunker_.*", ROLE.ROAMER );
			ClearGoalRole( ".*_Axis_LightUp_.*", ROLE.ROAMER );

			SetGoalRole( "PLANT_compound_gate", { ROLE.ATTACKER2, ROLE.ATTACKER3 });

			if ( Map.Comms_Bunker and Map.Light )
			{
				SetGoalRole( ".*_Axis_CommsBunker_0.*", ROLE.ATTACKER2 );
				SetGoalRole( ".*_Axis_LightUp_0.*", ROLE.ATTACKER3 );
				SetGoalRole( "PLANT_comms_bunker", ROLE.ATTACKER2 );
				SetGoalRole( "PLANT_light", ROLE.ATTACKER3 );
				SetGoalRole( "BUILD_tower_climbing_ropes", ROLE.ATTACKER3 );
			}
			else
			{
				if ( !Map.Comms_Bunker and Map.Light )
				{
					SetGoalRole( ".*_Axis_LightUp_0.*", ROLE.ATTACKER3 );
					SetGoalRole( ".*_Axis_LightUp_1.*", ROLE.ATTACKER2 );
					SetGoalRole( "PLANT_light", { ROLE.ATTACKER2, ROLE.ATTACKER3 } );
					SetGoalRole( "BUILD_tower_climbing_ropes", { ROLE.ATTACKER2, ROLE.ATTACKER3 } );
				}
				else
				{
					if ( Map.Comms_Bunker and !Map.Light )
					{
						SetGoalRole( ".*_Axis_CommsBunker_0.*", ROLE.ATTACKER2 );
						SetGoalRole( ".*_Axis_CommsBunker_1.*", ROLE.ATTACKER3 );
						SetGoalRole( "PLANT_comms_bunker", { ROLE.ATTACKER2, ROLE.ATTACKER3 } );
					}
				}
			}
		}

		if ( !Map.Comms_Bunker and !Map.Light )
		{
			SetGoalRole( ".*_Axis_LightBelow_.*", { ROLE.ATTACKER2, ROLE.ATTACKER3 });
		}

		SetAvailableMapGoals( TEAM.AXIS, false, {
			"PLANT_compound_wall",
			"CAMP_Axis_CompoundWall_.*",
		});
	},

