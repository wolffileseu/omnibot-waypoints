			SetGoalRole( ".*_Axis_CompoundGate_0.*", ROLE.ATTACKER1 );

			SetAvailableMapGoals( TEAM.AXIS, true, {
				".*_Axis_AntiShipGun_0.*",
				".*_Axis_CompoundGate_0.*",
			});
		}
		else
		{
			if ( !Map.Compound_Gate and Map.Anti_Ship_Gun )
			{
				SetGoalRole( ".*_Axis_AntiShipGun_0.*", ROLE.ATTACKER );
				SetGoalRole( ".*_Axis_AntiShipGun_1.*", ROLE.ATTACKER1 );

				SetAvailableMapGoals( TEAM.AXIS, true, {
					".*_Axis_AntiShipGun_.*",
				});
			}
			else
			{
				if ( Map.Compound_Gate and !Map.Anti_Ship_Gun )
				{
					SetGoalRole( ".*_Axis_CompoundGate_1.*", ROLE.ATTACKER );
					SetGoalRole( ".*_Axis_CompoundGate_0.*", ROLE.ATTACKER1 );

					SetAvailableMapGoals( TEAM.AXIS, true, {
						".*_Axis_CompoundGate_.*",
					});
				}
			}
		}
	},

	Forward_Bunker_Axis_Captured = function( trigger )
	{
		Map.Forward_Bunker_Allied = false;

		Wp.SetWaypointFlag( "Bunker_Door_.*", { "door", "allies", "infiltrator" }, false );

		Util.MapDebugPrint( "Forward_Bunker_Axis_Captured" );

		Map.Roles.AXIS.ATTACKER.spawnpt = 3;
		Map.Roles.AXIS.ATTACKER1.spawnpt = 3;
		Map.Roles.AXIS.ATTACKER2.spawnpt = 2;
		Map.Roles.AXIS.ATTACKER3.spawnpt = 2;

		Map.Roles.ALLIES.DEFENDER.spawnpt = 1;
		Map.Roles.ALLIES.DEFENDER1.spawnpt = 1;
		Map.Roles.ALLIES.DEFENDER2.spawnpt = 1;
		Map.Roles.ALLIES.DEFENDER3.spawnpt = 1;

		Map.SetSpawn();

		SetGoalPriority( "BUILD_Command_Post", 0.58, TEAM.ALLIES, 0 );

		if ( Map.Main_Entrance )
		{
			SetGoalRole( "BUILD_Command_Post", { ROLE.ATTACKER, ROLE.ATTACKER1 });
			SetGoalRole( "PLANT_Command_Post", { ROLE.ATTACKER, ROLE.ATTACKER1 });
			SetGoalRole( "CHECKPOINT_forwardspawn", { ROLE.ATTACKER, ROLE.ATTACKER1 });
			SetGoalRole( "PLANT_compound_gate", { ROLE.ATTACKER, ROLE.ATTACKER1 });
			SetGoalRole( "PLANT_anti_ship_gun", { ROLE.ATTACKER, ROLE.ATTACKER1 });
		}
		else
		{
			SetGoalPriority( "BUILD_Command_Post", 0.78, TEAM.AXIS, 0 );
		}

		SetAvailableMapGoals( TEAM.AXIS, false, {
			"CHECKPOINT_forwardspawn",
			"SMOKEBOMB_Axis_MainEntrDest_.*",
		});

		SetAvailableMapGoals( TEAM.ALLIES, true, {
			"CHECKPOINT_forwardspawn",
		});
	},

	Forward_Bunker_Allies_Captured = function( trigger )
	{
		Map.Forward_Bunker_Allied = true;

		Wp.SetWaypointFlag( "Bunker_Door_.*", { "door", "allies", "infiltrator" }, true );

		Util.MapDebugPrint( "Forward_Bunker_Allies_Captured" );

		Map.Roles.AXIS.ATTACKER.spawnpt = 2;
		Map.Roles.AXIS.ATTACKER1.spawnpt = 2;
		Map.Roles.AXIS.ATTACKER2.spawnpt = 2;
		Map.Roles.AXIS.ATTACKER3.spawnpt = 2;

		Map.Roles.ALLIES.DEFENDER.spawnpt = 3;
		Map.Roles.ALLIES.DEFENDER1.spawnpt = 3;
		Map.Roles.ALLIES.DEFENDER2.spawnpt = 1;
		Map.Roles.ALLIES.DEFENDER3.spawnpt = 1;

		Map.SetSpawn();

		SetGoalPriority( "BUILD_Command_Post", 0.58, TEAM.AXIS, 0 );

		if ( Map.Main_Entrance )
		{
			ClearGoalRole( "BUILD_Command_Post", { ROLE.ATTACKER, ROLE.ATTACKER1 });
			ClearGoalRole( "PLANT_Command_Post", { ROLE.ATTACKER, ROLE.ATTACKER1 });
			ClearGoalRole( "CHECKPOINT_forwardspawn", { ROLE.ATTACKER, ROLE.ATTACKER1 });
			ClearGoalRole( "PLANT_compound_gate", { ROLE.ATTACKER, ROLE.ATTACKER1 });
			ClearGoalRole( "PLANT_anti_ship_gun", { ROLE.ATTACKER, ROLE.ATTACKER1 });
		}
		else
		{
			SetGoalPriority( "BUILD_Command_Post", 0.78, TEAM.ALLIES, 0 );

			SetAvailableMapGoals( TEAM.AXIS, true, {
				"SMOKEBOMB_Axis_MainEntrDest_.*",
			});
		}

		SetAvailableMapGoals( TEAM.AXIS, true, {
			"CHECKPOINT_forwardspawn",
		});

		SetAvailableMapGoals( TEAM.ALLIES, false, {
			"CHECKPOINT_forwardspawn",
		});
	},

	Ignore_Target =
	{
		Name = "Ignore_Target",
		TriggerOnClass = CLASS.ANYPLAYER,
		OnEnter = function(ent)
		{
			b = Util.IsBot(ent);
			if ( b )
			{
				for ( q = 0; q < 64; q += 1 )
				{
					if ( EntityIsValid(q) )
					{
						b.IgnoreTarget(q, 999);
					}
				}
			}
		},
		OnExit = function(ent)
		{
			b = Util.IsBot(ent);
			if ( b )
			{
				for ( q = 0; q < 64; q += 1 )
				{
					if ( EntityIsValid(q) )
					{
						b.IgnoreTarget(q, 0.1);
					}
				}
			}
		},
	},

	Inside =
	{
		Name = "Inside",
		TriggerOnClass = CLASS.ANYPLAYER,
		OnEnter = function(ent)
		{
			if ( GetEntTeam(ent) == TEAM.AXIS )
			{
				bot = Util.IsBot(ent);
				if(bot)
				{
					if ( Map.Compound_Gate and Map.Compound_Wall )
					{
						bot.SetRoles(ROLE.ROAMER);
					}
				}

				if (Map.count_axis_ins[ent])
				{
					Map.count_axis_ins[ent] += 1;
				}
				else
				{
					Map.count_axis_ins[ent] = 1;
				}

				if ( tableCount(Map.count_axis_ins) > 0 )
				{
					SetAvailableMapGoals( TEAM.ALLIES, false, {
						".*_Allies_WestRopes_.*",
						".*_Allies_CompoundWall_.*",
						".*_Allies_CompGateDest_.*",
						".*_Allies_RopesWest_.*",
						".*_Allies_RopesSouth_.*",
					});

					if ( Map.Light and Map.Comms_Bunker )
					{
						SetAvailableMapGoals( TEAM.ALLIES, true, {
							".*_Allies_CommsBunker_0.*",
							".*_Allies_LightUp_0.*",
						});
					}
					else
					{
						if ( !Map.Light and Map.Comms_Bunker )
						{
							SetAvailableMapGoals( TEAM.ALLIES, true, {
								".*_Allies_CommsBunker_.*",
							});
						}
						else
						{
							if ( Map.Light and !Map.Comms_Bunker )
							{
								SetAvailableMapGoals( TEAM.ALLIES, true, {
									".*_Allies_LightUp_.*",
								});
							}
						}
					}
				}
			}
		},
		OnExit = function(ent)
		{
			bot = Util.IsBot(ent);
			if(bot){ bot.ClearRoles(ROLE.ROAMER); }

			if (Map.count_axis_ins[ent])
			{
				if (Map.count_axis_ins[ent] > 1)
				{
					Map.count_axis_ins[ent] -= 1;
				}
				else
				{
					Map.count_axis_ins[ent] = null;
				}

				if ( tableCount(Map.count_axis_ins) < 1 )
				{
					Util.MapDebugPrint("Inside trigger is clear");

					SetAvailableMapGoals( TEAM.ALLIES, false, {
						".*_Allies_CommsBunker_.*",
						".*_Allies_LightUp_.*",
					});

					if ( Map.Light or Map.Comms_Bunker )
					{
						if ( Map.Anti_Ship_Gun )
						{
							if ( Map.Compound_Gate )
							{
								SetAvailableMapGoals( TEAM.ALLIES, true, {
									".*_Allies_WestRopes_.*",
									".*_Allies_CompoundWall_.*",
								});
							}
							else
							{
								SetAvailableMapGoals( TEAM.ALLIES, true, {
									".*_Allies_CompGateDest_.*",
									".*_Allies_RopesWest_.*",
									".*_Allies_RopesSouth_.*",
								});
							}
						}
						else
						{
							SetAvailableMapGoals( TEAM.ALLIES, true, {
								".*_Allies_WestRopes_.*",
								".*_Allies_CompoundWall_.*",
							});
						}
					}
				}
			}
		},
	},

	Behind_Main_entrance =
	{
		Name = "Behind_Main_entrance",
		TriggerOnClass = CLASS.ANYPLAYER,
		OnEnter = function(ent)
		{
			if ( GetEntTeam(ent) == TEAM.AXIS )
			{
				bot = Util.IsBot(ent);
				if(bot)
				{
					if ( Map.Main_Entrance )
					{
						bot.SetRoles(ROLE.AMBUSHER);
					}
				}

				if (Map.count_axis_beh[ent])
				{
					Map.count_axis_beh[ent] += 1;
				}
				else
				{
					Map.count_axis_beh[ent] = 1;
				}

				if ( tableCount(Map.count_axis_beh) > 0 )
				{
					SetAvailableMapGoals( TEAM.ALLIES, false, {
						".*_Allies_MainEntrance.*",
					});

					if ( Map.Anti_Ship_Gun )
					{
						SetAvailableMapGoals( TEAM.ALLIES, true, {
							".*_Allies_AntiShipGun_.*",
						});
					}
					else
					{
						SetAvailableMapGoals( TEAM.ALLIES, true, {
							".*_Allies_CompGate_.*",
						});
					}
				}
			}
		},
		OnExit = function(ent)
		{
			bot = Util.IsBot(ent);
			if(bot){ bot.ClearRoles(ROLE.AMBUSHER); }

			if (Map.count_axis_beh[ent])
			{
				if (Map.count_axis_beh[ent] > 1)
				{
					Map.count_axis_beh[ent] -= 1;
				}
				else
				{
					Map.count_axis_beh[ent] = null;
				}

				if ( tableCount(Map.count_axis_beh) < 1 )
				{
					Util.MapDebugPrint("Behind_Main_entrance trigger is clear");

					if ( Map.Anti_Ship_Gun )
					{
						SetAvailableMapGoals( TEAM.ALLIES, false, {
							".*_Allies_AntiShipGun_.*",
							".*_Allies_CompGate_.*",
						});

						SetAvailableMapGoals( TEAM.ALLIES, true, {
							".*_Allies_MainEntrance.*",
						});
					}
				}
			}
		},
	},

	Walls_above_ropes =
	{
		Name = "\r\n\r\nWalls_above_ropes",
		TriggerOnClass = CLASS.ANYPLAYER,
		OnEnter = function(ent)
		{
			if ( GetEntTeam(ent) == TEAM.AXIS )
			{
				bot = Util.IsBot(ent);
				if(bot)
				{
					if ( !Map.South_Ropes and !Map.West_Ropes )
					{
						bot.SetRoles(ROLE.SNIPER);
					}
				}
			}
		},
		OnExit = function(ent)
		{
			bot = Util.IsBot(ent);
			if(bot){ bot.ClearRoles(ROLE.SNIPER); }
		},
	},

	West_Ropes_Left =
	{
		Name = "West_Ropes_Left",
		TriggerOnClass = CLASS.ANYPLAYER,
		OnEnter = function(ent)
		{
			Map.West_Ropes_Left_Player_Count += 1;
		},
		OnExit = function(ent)
		{
			Map.West_Ropes_Left_Player_Count -= 1;

			if ( Map.West_Ropes_Left_Player_Count == 0 )
			{
				Map.West_Ropes_Left_Way_In_Use = false;
			}
		},
	},

	West_Ropes_Right =
	{
		Name = "West_Ropes_Right",
		TriggerOnClass = CLASS.ANYPLAYER,
		OnEnter = function(ent)
		{
			Map.West_Ropes_Right_Player_Count += 1;
		},
		OnExit = function(ent)
		{
			Map.West_Ropes_Right_Player_Count -= 1;
		},
	},

	South_Ropes_Left =
	{
		Name = "South_Ropes_Left",
		TriggerOnClass = CLASS.ANYPLAYER,
		OnEnter = function(ent)
		{
			Map.South_Ropes_Left_Player_Count += 1;
		},
		OnExit = function(ent)
		{
			Map.South_Ropes_Left_Player_Count -= 1;
		},
	},

	South_Ropes_Right =
	{
		Name = "South_Ropes_Right",
		TriggerOnClass = CLASS.ANYPLAYER,
		OnEnter = function(ent)
		{
			Map.South_Ropes_Right_Player_Count += 1;
		},
		OnExit = function(ent)
		{
			Map.South_Ropes_Right_Player_Count -= 1;
		},
	},

	Lighthouse_Door = function()
	{
		sleep(0.5);
		start = Vector3(-750, -220.527, 1115);
		end = Vector3(-750, -250, 1115);
		while ( 1 )
		{
			tr = TraceLine( start, end, null, TRACE.FLOODFILLENT, 0, false );
			if ( tr.fraction == 1 )
			{
				if ( Map.Lighthouse_Door_Open )
				{
					Map.Lighthouse_Door_Open = false;

					Wp.SetWaypointFlag( "Lighthouse_Door", "closed", false );

					DynamicPathsUpdated( TEAM.AXIS, TEAM.ALLIES );

					Util.MapDebugPrint( "Lighthouse_Door_Closed" );
				}

				if ( Map.Debug )
				{
					DrawDebugLine( start, end, COLOR.GREEN, 0.1 );
				}
			}
			else
			{
				if ( !Map.Lighthouse_Door_Open )
				{
					Map.Lighthouse_Door_Open = true;

					Wp.SetWaypointFlag( "Lighthouse_Door", "closed", true );

					DynamicPathsUpdated( TEAM.AXIS, TEAM.ALLIES );

					Util.MapDebugPrint( "Lighthouse_Door_Opened" );
				}

				if ( Map.Debug )
				{
					DrawDebugLine( start, end, COLOR.RED, 0.1 );
				}
			}
			sleep(0.1);
		}
	},

	Ignore_Breakable =
	{
		Name = "Ignore_Breakable",
		TriggerOnClass = CLASS.ANYPLAYER,
		OnEnter = function(ent)
		{
			b = Util.IsBot(ent);
			if ( b )
			{
				b.TargetBreakableDist = 0;
			}
		},
		OnExit = function(ent)
		{
			b = Util.IsBot(ent);
			if ( b )
			{
				b.TargetBreakableDist = 100;
			}
		},
	},

	Mast_Ladder =
	{
		Name = "\r\nMast_Ladder",
		TriggerOnClass = CLASS.ANYPLAYER,
		OnEnter = function(ent)
		{
			Map.Mast_Ladder_In_Use += 1;
			b = Util.IsBot(ent);

			if ( b )
			{
				b.SetRoles(ROLE.ESCORT);

				sleep(5);
				if ( b )
				{
					if ( b.HasRole(ROLE.ESCORT) )
					{
						b.ExecCommand( "kill" );
					}
				}
			}
		},
		OnExit = function(ent)
		{
			Map.Mast_Ladder_In_Use -= 1;
			b = Util.IsBot(ent);
			if ( b )
			{
				b.ClearRoles(ROLE.ESCORT);
			}
		},
	},

	Compound_Wall_Jump =
	{
		Name = "\r\nCompound_Wall_Jump",
		TriggerOnClass = CLASS.ANYPLAYER,
		OnEnter = function(ent)
		{
			Map.Mast_Ladder_In_Use += 1;
			b = Util.IsBot(ent);

			if ( b )
			{
				b.SetRoles(ROLE.ESCORT);

				sleep(5);
				if ( b )
				{
					if ( b.HasRole(ROLE.ESCORT) )
					{
						b.ExecCommand( "kill" );
					}
				}
			}
		},
		OnExit = function(ent)
		{
			Map.Mast_Ladder_In_Use -= 1;
			b = Util.IsBot(ent);
			if ( b )
			{
				b.ClearRoles(ROLE.ESCORT);
			}
		},
	},

	Thirty_second = function( trigger )
	{
		Util.MapDebugPrint( "Thirty_second" );

		sleep(30);

		if ( Map.Light or Map.Comms_Bunker or Map.Anti_Ship_Gun )
		{
			Util.MapDebugPrint( "Allies_Win" );

			ETUtil.WinningChat( TEAM.ALLIES );
			ETUtil.LosingChat( TEAM.AXIS );
		}
	},

	SetSpawn = function()
	{
		foreach ( id and bot in BotTable )
		{
			Map.SetSpawn1(bot);
		}
	},

	SetSpawn1 = function(bot)
	{
		if ( Map.Forward_Bunker_Allied )
		{
			if ( bot.GetTeam() == TEAM.ALLIES )
			{
				if ( bot.HasRole(ROLE.DEFENDER) or bot.HasRole(ROLE.DEFENDER1) )
				{
					bot.ChangeSpawnPoint(3);
				}
				else
				{
					bot.ChangeSpawnPoint(1);
				}
			}
			else
			{
				bot.ChangeSpawnPoint(2);
			}
		}
		else
		{
			if ( bot.GetTeam() == TEAM.AXIS )
			{
				if ( bot.HasRole(ROLE.ATTACKER) or bot.HasRole(ROLE.ATTACKER1) )
				{
					bot.ChangeSpawnPoint(3);
				}
				else
				{
					bot.ChangeSpawnPoint(2);
				}
			}
			else
			{
				bot.ChangeSpawnPoint(1);
			}
		}
	},
};

global OnMapLoad = function()
{
	if ( Map.Debug )
	{
		Util.DebugColorString = "^3";
	}

	thread ( Map.Lighthouse_Door );

