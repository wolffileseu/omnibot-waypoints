global Map =
{
	Debug = 0,
	Allied_CP = false,
	Axis_CP = false,
	South_Ropes = false,
	Tower_Climbing_Ropes = false,
	West_Ropes = false,
	Anti_Ship_Gun = true,
	Comms_Bunker = true,
	Compound_Gate = true,
	Compound_Wall = true,
	Light = true,
	Main_Entrance = true,
	Forward_Bunker_Allied = true,
	count_axis_ins = {},
	count_axis_beh = {},
	West_Ropes_Left_Player_Count = 0,
	West_Ropes_Right_Player_Count = 0,
	South_Ropes_Left_Player_Count = 0,
	South_Ropes_Right_Player_Count = 0,
	West_Ropes_botId_1 = -1,
	West_Ropes_botId_2 = -1,
	South_Ropes_botId_1 = -1,
	South_Ropes_botId_2 = -1,
	Lighthouse_Door_Open = false,
	Mast_Ladder_In_Use = 0,
	Mast_Ladder_botId = -1,

	DontDispenseAmmo = true,

	Roles =
	{
		AXIS =
		{
			AllBots = true, // each bot is considered for a role
			ATTACKER =
			{
				numbots = 5,
				crucialClass = {CLASS.ENGINEER, CLASS.COVERTOPS},
			},
			ATTACKER1 =
			{
				numbots = 5,
				crucialClass = CLASS.ENGINEER,
			},
			ATTACKER2 =
			{
				numbots = 5,
				crucialClass = CLASS.ENGINEER,
			},
			ATTACKER3 =
			{
				numbots = 5,
				crucialClass = {CLASS.ENGINEER, CLASS.COVERTOPS},
			},
		},

		ALLIES =
		{
			AllBots = true, // each bot is considered for a role
			DEFENDER =
			{
				spawnpt = 3,
				numbots = 5,
				crucialClass = {CLASS.ENGINEER, CLASS.COVERTOPS},
			},
			DEFENDER1 =
			{
				spawnpt = 3,
				numbots = 5,
				crucialClass = CLASS.ENGINEER,
			},
			DEFENDER2 =
			{
				spawnpt = 1,
				numbots = 5,
				crucialClass = {CLASS.ENGINEER, CLASS.COVERTOPS},
			},
			DEFENDER3 =
			{
				spawnpt = 1,
				numbots = 5,
				crucialClass = CLASS.ENGINEER,
			},
		},
	},

	Navigation =
	{
		//  /bot waypoint_setproperty paththrough Navigation_PT:wrong_position_0
		wrong_position_0 =
		{
			navigate = function(_this)
			{
				if ( _this.Bot.GetPosition().z < 1200 )
				{
					_this.Goto(_this.Bot.GetPosition());
					Util.MapDebugPrint( "wrong_position_0" );
				}
				else
				{
					Util.MapDebugPrint( "good_position_0" );
				}
			},
		},

		//  /bot waypoint_setproperty paththrough Navigation_PT:wrong_position_1
		wrong_position_1 =
		{
			navigate = function(_this)
			{
				if ( _this.Bot.GetPosition().z < 1450 )
				{
					_this.Goto(_this.Bot.GetPosition());
					Util.MapDebugPrint( "wrong_position_1" );
				}
				else
				{
					Util.MapDebugPrint( "good_position_1" );
				}
			},
		},

		//  /bot waypoint_setproperty paththrough Navigation_PT:wrong_position_2
		wrong_position_2 =
		{
			navigate = function(_this)
			{
				if ( _this.Bot.GetPosition().z < 1650 )
				{
					_this.Goto(_this.Bot.GetPosition());
					Util.MapDebugPrint( "wrong_position_2" );
				}
				else
				{
					Util.MapDebugPrint( "good_position_2" );
				}
			},
		},

		//  /bot waypoint_setproperty paththrough Navigation_PT:jump
		jump =
		{
			navigate = function(_this)
			{
				_this.Bot.HoldButton(BTN.JUMP, 0.55);
				sleep(0.55);
			},
		},

		//  /bot waypoint_setproperty paththrough Navigation_PT:jump_wait
		jump_wait =
		{
			navigate = function(_this)
			{
				sleep(0.25);
				_this.Bot.HoldButton(BTN.JUMP, 0.55);
				sleep(0.55);
			},
		},

		//  /bot waypoint_setproperty paththrough Navigation_PT:compound_wall_jump
		compound_wall_jump =
		{
			navigate = function(_this)
			{
				Util.MapDebugPrint( "" + GetModName() );

				if ( GetModName() == "Jaymod" or GetModName() == "silEnT" )
				{
					_this.Goto(_this.Bot.GetPosition());
					_this.AddAimRequest(Priority.VeryHigh, "facing", Vec3( 0.939, 0.028, -0.344 ));
					while ( !_this.Bot.MoveTowards(Vec3(-130.536, -686.843, 1084.125), 5) )
					{
						yield();
					}
					_this.Goto(_this.Bot.GetPosition());
					sleep(1);
					_this.Bot.PressButton(BTN.JUMP);
					sleep(0.15);
					_this.Bot.HoldButton(BTN.FORWARD, 3);
					_this.Bot.HoldButton(BTN.SPRINT, 0.1);
					sleep(0.6);
					_this.Bot.HoldButton(BTN.JUMP, 1);
					_this.Bot.HoldButton(BTN.SPRINT, 1.5);
					sleep(1.5);
				}
				else if ( GetModName() == "noquarter" or GetModName() == "etpub" )
				{
					_this.Goto(_this.Bot.GetPosition());
					_this.AddAimRequest(Priority.VeryHigh, "facing", Vec3( 0.952, 0.015, -0.297 ));
					while ( !_this.Bot.MoveTowards(Vec3(-130.536, -686.843, 1084.125), 5) )
					{
						yield();
					}
					_this.Goto(_this.Bot.GetPosition());
					sleep(1);
					_this.Bot.PressButton(BTN.JUMP);
					sleep(0.15);
					_this.Bot.HoldButton(BTN.FORWARD, 3);
					sleep(0.6);
					_this.Bot.HoldButton(BTN.JUMP, 1);
					_this.Bot.HoldButton(BTN.SPRINT, 1.5);
					sleep(1.5);
				}
				else
				{
					_this.Goto(_this.Bot.GetPosition());
					_this.AddAimRequest(Priority.VeryHigh, "facing", Vec3( 0.939, 0.028, -0.344 ));
					while ( !_this.Bot.MoveTowards(Vec3(-130.536, -686.843, 1084.125), 5) )
					{
						yield();
					}
					_this.Goto(_this.Bot.GetPosition());
					sleep(1);
					_this.Bot.PressButton(BTN.JUMP);
					sleep(0.15);
					_this.Bot.HoldButton(BTN.FORWARD, 3);
					_this.Bot.HoldButton(BTN.SPRINT, 3);
					sleep(0.6);
					_this.Bot.HoldButton(BTN.JUMP, 1);
					sleep(1.5);
				}
			},
		},

		//  /bot waypoint_setproperty paththrough Navigation_PT:west_ropes_wait
		west_ropes_wait =
		{
			OnExit = function(_this)
			{
				if ( Map.West_Ropes_botId_1 == _this.Bot.GetGameId() )
				{
					sleep(1.5);
					Map.West_Ropes_botId_1 = -1;
				}

				if ( Map.West_Ropes_botId_2 == _this.Bot.GetGameId() )
				{
					sleep(1.5);
					Map.West_Ropes_botId_2 = -1;
				}
			},
			navigate = function(_this)
			{
				_this.Goto(_this.Bot.GetPosition());

				if ( Map.West_Ropes_botId_1 == -1 )
				{
					Map.West_Ropes_botId_1 = _this.Bot.GetGameId();
					_this.v = Vector3( -2334.632, 93.499, 241.749 );    //left
				}
				else if ( Map.West_Ropes_botId_2 == -1 )
				{
					Map.West_Ropes_botId_2 = _this.Bot.GetGameId();
					_this.v = Vector3( -2331.721, 29.125, 260.077 );    //right
				}
				else
				{
					return;
				}

				while ( Map.West_Ropes_Left_Player_Count != 0 and Map.West_Ropes_Right_Player_Count != 0 )
				{
					yield();
				}

				_this.timer = 0;

				if ( Map.West_Ropes_Left_Player_Count == 0 and Map.West_Ropes_botId_1 == _this.Bot.GetGameId() )
				{
					while ( !_this.Bot.MoveTowards(_this.v, 25) )
					{
						sleep(0.1);
						_this.timer += 1;

						if ( _this.timer == 50 )
						{
							while ( !_this.Bot.MoveTowards(Vec3(-2354.569, 220.195, 233.408), 35) )
							{
								yield();
							}
							break;
						}
					}
				}

				if ( Map.West_Ropes_Right_Player_Count == 0 and Map.West_Ropes_botId_2 == _this.Bot.GetGameId() )
				{
					while ( !_this.Bot.MoveTowards(_this.v, 25) )
					{
						sleep(0.1);
						_this.timer += 1;

						if ( _this.timer == 50 )
						{
							while ( !_this.Bot.MoveTowards(Vec3(-2351.910, -78.048, 243.096), 35) )
							{
								yield();
							}
							break;
						}
					}
				}
			},
		},

		//  /bot waypoint_setproperty paththrough Navigation_PT:mast_ladder_wait
		mast_ladder_wait =
		{
			EvalFunc = function(_this)
			{
				goal = _this.Bot.GetMapGoalName();
				if ( goal )
				{
					pos = Util.GetMapGoalPosition(goal);
					if ( pos )
					{
						return DistanceBetween(pos, Vec3(-484, 2154, 360)) > 200;
					}
				}
				return true;
			},
			OnExit = function(_this)
			{
				if ( Map.Mast_Ladder_botId == _this.Bot.GetGameId() )
				{
					Map.Mast_Ladder_botId = -1;
				}
			},
			navigate = function(_this)
			{
				_this.Goto(_this.Bot.GetPosition());

				while ( Map.Mast_Ladder_In_Use != 0 )
				{
					yield();
				}

				if ( Map.Mast_Ladder_botId == -1 )
				{
					Map.Mast_Ladder_botId = _this.Bot.GetGameId();
				}
				else
				{
					return;
				}

				_this.timer = 0;

				while ( !_this.Bot.MoveTowards(Vec3(-352.927, 85.596, 1054.125), 15) )
				{
					sleep(0.1);
					_this.timer += 1;
					_this.Bot.PressButton(BTN.WALK);

					if ( _this.timer == 50 )
					{
						_this.timer = 0;
						while ( !_this.Bot.MoveTowards(Vec3(-426.775, 68.187, 1048.159), 35) )
						{
							sleep(0.1);
							_this.timer += 1;
							if ( _this.timer == 50 )
							{
								_this.Bot.ExecCommand( "kill" );
							}
						}
						break;
					}
				}
			},
		},

		//  /bot waypoint_setproperty paththrough Navigation_PT:south_ropes_wait
		south_ropes_wait =
		{
			OnExit = function(_this)
			{
				if ( Map.South_Ropes_botId_1 == _this.Bot.GetGameId() )
				{
					Map.South_Ropes_botId_1 = -1;
				}
				if ( Map.South_Ropes_botId_2 == _this.Bot.GetGameId() )
				{
					Map.South_Ropes_botId_2 = -1;
				}
			},
			navigate = function(_this)
			{
				_this.Goto(_this.Bot.GetPosition());

				if ( Map.South_Ropes_botId_1 == -1 )
				{
					Map.South_Ropes_botId_1 = _this.Bot.GetGameId();
					_this.v = Vector3( -607.503, -1355.218, 248.132 );    //left
				}
				else if ( Map.South_Ropes_botId_2 == -1 )
				{
					Map.South_Ropes_botId_2 = _this.Bot.GetGameId();
					_this.v = Vector3( -363.227, -1547.562, 160.244 );    //right
				}
				else
				{
					return;
				}

				while ( Map.South_Ropes_Left_Player_Count != 0 and Map.South_Ropes_Right_Player_Count != 0 )
				{
					yield();
				}

				_this.timer = 0;

				if ( Map.South_Ropes_Left_Player_Count == 0 and Map.South_Ropes_botId_1 == _this.Bot.GetGameId() )
				{
					while ( !_this.Bot.MoveTowards(_this.v, 15) )
					{
						sleep(0.1);

						if ( Map.South_Ropes_Left_Player_Count > 0 )
						{
							_this.Goto(_this.Bot.GetPosition());
							while ( Map.South_Ropes_Left_Player_Count != 0 )
							{
								yield();
							}
						}

						_this.timer += 1;

						if ( _this.timer == 100 )
						{
							while ( !_this.Bot.MoveTowards(Vec3(-567.541, -1358.454, 245.576), 35) )
							{
								yield();
							}
							break;
						}
					}
				}

				if ( Map.South_Ropes_Right_Player_Count == 0 and Map.South_Ropes_botId_2 == _this.Bot.GetGameId() )
				{
					while ( !_this.Bot.MoveTowards(_this.v, 15) )
					{
						sleep(0.1);

						if ( Map.South_Ropes_Right_Player_Count > 0 )
						{
							_this.Goto(_this.Bot.GetPosition());
							while ( Map.South_Ropes_Right_Player_Count != 0 )
							{
								yield();
							}
						}

						_this.timer += 1;

						if ( _this.timer == 100 )
						{
							while ( !_this.Bot.MoveTowards(Vec3(-354.227, -1814.292, 125.160), 35) )
							{
								yield();
							}
							break;
						}
					}
				}
			},
		},


		//  /bot waypoint_setproperty paththrough Navigation_PT:west_ropes_1
		west_ropes_1 =
		{
			navigate = function(_this)
			{
				_this.Goto(_this.Bot.GetPosition());
				_this.AddAimRequest(Priority.VeryHigh, "position", Vec3( -1629, 96, 1200 ));
				sleep(0.75);
				_this.timer = 0;
				while ( _this.Bot.GetPosition().z < 1040 )
				{
					if ( !Map.West_Ropes )
					{
						return;
					}

					_this.Bot.MoveTowards(Vec3( -1629, 96, 1044 ));
					sleep(0.1);
					_this.timer += 1;

					if ( _this.timer == 120 )
					{
						_this.timer = 0;
						_this.ReleaseAimRequest();
						_this.Bot.MoveTowards(Vec3( -2365, 92, 228 ));
						_this.AddAimRequest(Priority.VeryHigh, "position", Vec3( -2365, 92, 228 ));
						while ( _this.Bot.GetPosition().z > 240 )
						{
							_this.timer += 1;
							_this.Bot.HoldButton(BTN.WALK, 0.1);
							if ( _this.timer == 120 )
							{
								_this.timer = 0;
								_this.Bot.ExecCommand( "kill" );
							}
							sleep(0.1);
						}
						break;
					}
				}
			},
		},

		//  /bot waypoint_setproperty paththrough Navigation_PT:west_ropes_2
		west_ropes_2 =
		{
			navigate = function(_this)
			{
				_this.Goto(_this.Bot.GetPosition());
				_this.AddAimRequest(Priority.VeryHigh, "position", Vec3( -1629.555, 27.044, 1150 ));
				sleep(0.75);
				_this.timer = 0;
				while ( _this.Bot.GetPosition().z < 1040 )
				{
					if ( !Map.West_Ropes )
					{
						return;
					}

					_this.Bot.MoveTowards(Vec3( -1630, 27, 1044 ));
					sleep(0.1);
					_this.timer += 1;
					if ( _this.timer == 120 )
					{
						_this.timer = 0;
						_this.ReleaseAimRequest();
						_this.Bot.MoveTowards(Vec3( -2443, -36, 197 ));
						_this.AddAimRequest(Priority.VeryHigh, "position", Vec3( -2443, -36, 197 ));
						while ( _this.Bot.GetPosition().z > 240 )
						{
							_this.timer += 1;
							_this.Bot.HoldButton(BTN.WALK, 0.1);
							if ( _this.timer == 120 )
							{
								_this.timer = 0;
								_this.Bot.ExecCommand( "kill" );
							}
							sleep(0.1);
						}
						break;
					}
				}
			},
		},

		//  /bot waypoint_setproperty paththrough Navigation_PT:south_ropes_1
		south_ropes_1 =
		{
			navigate = function(_this)
			{
				_this.Goto(_this.Bot.GetPosition());
				_this.AddAimRequest(Priority.VeryHigh, "position", Vec3( -518.668, -835.924, 987.464 ));
				sleep(0.75);
				_this.timer = 0;
				while ( _this.Bot.GetPosition().z < 975 )
				{
					if ( !Map.South_Ropes )
					{
						return;
					}

					_this.Bot.MoveTowards(Vec3( -518.668, -835.924, 987.464 ));

					if ( _this.Bot.GetPosition().x < -514 )
					{
						_this.Bot.HoldButton(BTN.STRAFE_R, 0.1);
					}

					sleep(0.1);
					_this.timer += 1;
					if ( _this.timer == 120 )
					{
						_this.timer = 0;
						_this.ReleaseAimRequest();
						_this.Bot.MoveTowards(Vec3( -584.822, -1397.072, 221.741 ));
						_this.AddAimRequest(Priority.VeryHigh, "position", Vec3( -584.822, -1397.072, 221.741 ));
						while ( _this.Bot.GetPosition().z > 240 )
						{
							_this.Bot.HoldButton(BTN.WALK, 0.2);
							sleep(0.2);
						}
						break;
					}
				}
			},
		},

		//  /bot waypoint_setproperty paththrough Navigation_PT:south_ropes_2
		south_ropes_2 =
		{
			navigate = function(_this)
			{
				_this.Goto(_this.Bot.GetPosition());
				_this.AddAimRequest(Priority.VeryHigh, "facing", Vec3( -0.036, 0.720, 0.693 ));
				sleep(1);

				_this.Bot.HoldButton(BTN.FORWARD, 1.5);
				_this.Bot.HoldButton(BTN.SPRINT, 1.5);
				sleep(0.4);
				_this.Bot.HoldButton(BTN.JUMP, 1.15);
				sleep(1.15);

				if ( _this.Bot.GetPosition().z > 305 )
				{
					_this.AddAimRequest(Priority.VeryHigh, "position", Vec3( -398.476, -828.539, 1050 ));
					while ( !_this.Bot.MoveTowards(Vec3(-398.476, -828.539, 1003.795), 35) )
					{
						if ( !Map.South_Ropes )
						{
							return;
						}

						if ( _this.Bot.GetPosition().x > -400 )
						{
							_this.Bot.PressButton(BTN.STRAFE_L);
						}
						yield();
					}
				}
				else
				{
					while ( !_this.Bot.MoveTowards(Vec3(-242.183, -1459.534, 173.727), 35) )
					{
						yield();
					}
				}

			},
		},
	},

	Allied_CP_Built = function( trigger )
	{
		Map.Allied_CP = true;

		Util.MapDebugPrint( "Allied_CP_Built" );

		Util.DisableGoal( {
			"BUILD_Command_Post",
		});

		SetAvailableMapGoals( TEAM.AXIS, true, {
			"PLANT_Command_Post",
		});
	},

	Allied_CP_Destroyed = function( trigger )
	{
		Map.Allied_CP = false;

		Util.MapDebugPrint( "Allied_CP_Destroyed" );

		SetAvailableMapGoals( TEAM.AXIS, false, {
			"PLANT_Command_Post",
		});

		Util.EnableGoal( {
			"BUILD_Command_Post",
		});
	},

	CP_Planted = function( trigger )
	{
		Util.SetGoalRange( "DEFUSE_Command_Post.*", 850);

		SetGoalRole( "DEFUSE_Command_Post.*", { ROLE.DEFENDER, ROLE.DEFENDER1, ROLE.AMBUSHER });

		if ( !Map.Main_Entrance )
		{
			if ( Map.Comms_Bunker or Map.Light )
			{
				SetGoalRole( "DEFUSE_Command_Post.*", { ROLE.DEFENDER, ROLE.DEFENDER1, ROLE.ATTACKER, ROLE.ATTACKER1, ROLE.AMBUSHER });
			}
			else
			{
				SetGoalRole( "DEFUSE_Command_Post.*", { ROLE.ATTACKER, ROLE.ATTACKER1, ROLE.ATTACKER2, ROLE.ATTACKER3, ROLE.AMBUSHER,
														ROLE.DEFENDER, ROLE.DEFENDER1, ROLE.DEFENDER2, ROLE.DEFENDER3 });
			}
		}
		else
		{
			if ( !Map.Comms_Bunker and !Map.Light )
			{
				SetGoalRole( "DEFUSE_Command_Post.*", { ROLE.ATTACKER2, ROLE.ATTACKER3, ROLE.AMBUSHER,
														ROLE.DEFENDER, ROLE.DEFENDER1, ROLE.DEFENDER2, ROLE.DEFENDER3 });
			}
		}
	},

	CP_Defused = function( trigger )
	{
		if ( Map.Allied_CP )
		{
			Util.MapDebugPrint( "Allied_CP_Defused" );
		}
		else
		{
			Util.MapDebugPrint( "Axis_CP_Defused" );
		}
	},

	Axis_CP_Built = function( trigger )
	{
		Map.Axis_CP = true;

		Util.MapDebugPrint( "Axis_CP_Built" );

		Util.DisableGoal( {
			"BUILD_Command_Post",
		});

		SetAvailableMapGoals( TEAM.ALLIES, true, {
			"PLANT_Command_Post",
		});
	},

	Axis_CP_Destroyed = function( trigger )
	{
		Map.Axis_CP = false;

		Util.MapDebugPrint( "Axis_CP_Destroyed" );

		SetAvailableMapGoals( TEAM.ALLIES, false, {
			"PLANT_Command_Post",
		});

		Util.EnableGoal( {
			"BUILD_Command_Post",
		});
	},

	South_Ropes_Built = function( trigger )
	{
		Map.South_Ropes = true;

