global OnMapLoad = function()
{
	Util.SetGoalOffset( 0, 160, 0, "PLANT_Tank_Barrier_1" );
	Util.SetGoalOffset( 0, 174, 0, "PLANT_Tank_Barrier_2" );

	// close these waypoints until tank is past barrier
	Map.slopeNodes(true);
    
////// BEGIN trigger section  ///////////////////////////////////////// BEGIN TRIGGER SECTION   ////////////////////////////////////////////////////////////////////////////////////////


    //NEW TRIGGER STUFF
    zone_NULL = OnTriggerRegion(AABB(1643.155,-2799.885,524.952,2106.908,-2664.418,785.163), Map.planemoving);
    zone_1 = OnTriggerRegion(AABB(641.330,1526.699,184.529,952.875,1677.401,267.442), Map.zone_1);//firstcorner
    zone_2 = OnTriggerRegion(AABB(660.253,828.462,59.548,960.874,1040.700,173.040), Map.zone_2);//barrier1
    zone_3 = OnTriggerRegion(AABB(2151.544,-64.875,-147.159,2313.876,184.875,-36.052), Map.zone_3);//bridgehill
    zone_4 = OnTriggerRegion(AABB(2300.261,938.122,-416.814,2571.191,1218.338,-342.679), Map.zone_4);//bridgemg
    zone_5 = OnTriggerRegion(AABB(1656.194,353.729,-416.801,2034.268,526.966,-337.425), Map.zone_5);//barrier2
    zone_6 = OnTriggerRegion(AABB(480.061,-720.472,-332.313,634.705,-478.740,-222.440), Map.zone_6);//barrier3
	//RegionTrigger.Create(AABB(-1818.902,-1406.621,-47.144,-1658.912,-1076.801,37.125), "VehicleTrigger", "barrier4");//Map.zone_null
	//updated for moved truck barrier2:
    zone_7 = OnTriggerRegion(AABB(-550.548,-1592.873,-167.892,-448.344,-1277.766,-76.511), Map.zone_7);//barrier4
   
    bombs = OnTriggerRegion(AABB(1594.740,-58.157,26.720,1914.693,93.983,6835.837), Map.bombs);    
    fuckdbytankbarrier2 = OnTriggerRegion(AABB(1647.208,337.914,-414.875,2048.875,568.581,-326.706), Map.fuckdbytankbarrier2);
    newroutestart = OnTriggerRegion(AABB(1115.311,1663.129,157.699,1369.953,2297.422,261.183), Map.newroutestart);    
    underoverpass = OnTriggerRegion(AABB(986.875,-48.866,-62.224,1037.296,208.875,15.129), Map.underoverpass);    
    tunnelexitcornerinside = OnTriggerRegion(AABB(2263.968,3453.135,-299.320,2522.289,3776.392,-166.329), Map.tunnelexitcornerinside);    
    tankatboombarrier = OnTriggerRegion(AABB(2852.490,2773.908,-411.358,3216.872,3358.218,-292.901), Map.tankatboombarrier);
    almostoutofnewpath = OnTriggerRegion(AABB(2791.158,1616.228,-430.875,2997.673,2069.238,-354.411), Map.almostoutofnewpath);
    //exitbridge = OnTriggerRegion(AABB(1753.920,-65.141,-177.378,1847.146,97.504,-73.922), Map.exitbridge);    
    Truck_Leaving_The_Bank_Fast = OnTriggerRegion(AABB(961.336,-824.847,-414.874,1311.260,-694.805,-332.070), Map.Truck_Leaving_The_Bank_Fast);
    planemoving = OnTriggerRegion(AABB(1643.155,-2799.885,524.952,2106.908,-2664.418,785.163), Map.planemoving);
    planeexit = OnTriggerRegion(AABB(1705.686,1295.484,236.160,2218.766,1379.999,2597.814), Map.planeexit); 
    b1tob2mgnestammorak = OnTriggerRegion(AABB(-1640.752,-1904.875,-76.376,-888.189,-1509.534,78.172), Map.b1tob2mgnestammorak);
       
// do NOT use vehiclelocation triggers they are broken with 2 routes use custom triggerbounds triggers   
    OnTrigger( "^2Axis have constructed the battery for the airstrike control panel!", Map.battery_to_control_the_axis_airstrike_panel_Built );
	OnTrigger( "MISSING_STRING", Map.battery_to_control_the_axis_airstrike_panel_Destroyed );
	OnTrigger( "^2Axis have breached the door to the Battery room", Map.door_to_the_Battery_room_Destroyed );
	OnTrigger( "junker_button", Map.axisbeginingonly );    
    
    OnTrigger( " ^2The Axis have destroyed the bridge. The Tank will take the alternati", Map.NEW_ROUTE );    
    OnTrigger( "^2The Axis have destroyed the bridge.", Map.NEW_ROUTE ); 
    OnTrigger( " ^1The Axis have destroyed the bridge.", Map.NEW_ROUTE );    
    OnTrigger( "^1The Axis have destroyed the bridge.", Map.NEW_ROUTE );  
    OnTrigger( " The Axis have destroyed the bridge.  The Tank will take the alternati", Map.NEW_ROUTE );    
    OnTrigger( "The Axis have destroyed the bridge.", Map.NEW_ROUTE );                  
                                      
	//Truck
	OnTrigger( "^2The Truck has been repaired!", Map.Truck_Built );
	OnTrigger( "^2The Truck has been damaged!", Map.Truck_Destroyed );
    
    //CHECKPOINT
    OnTrigger( "CHECKPOINT_roadbunker to team 1", Map.roadbunker_Axis_Captured );
	OnTrigger( "CHECKPOINT_roadbunker to team 2", Map.roadbunker_Allies_Captured );

    OnTrigger( "^2Allied team has destroyed Road Blockade", Map.Tank_Destroyed_Blockade );    
    OnTrigger( "^2Allied team has destroyed the Tunnel Doors!", Map.Tank_Destroyed_Tunnel_Doors );
    OnTrigger( "^1The Tank is taking the alternative path", Map.NEW_ROUTE );  

	//Goldgoldrush_axis_gold2_returned
    //GOLD CRATE RETURNED
    OnTrigger( "Goldgoldrush_axis_gold1_returned", Map.GoldCrateReturned );
    OnTrigger( "Goldgoldrush_axis_gold2_returned", Map.GoldCrateReturned );
    //OnTrigger( "FLAGRETURN flag_gold_crate_returned", Map.GoldCrateReturned );
	OnTrigger( "goldrush_allies_gold1_taken", Map.gold_crate_Taken );
	OnTrigger( "goldrush_allies_gold2_taken", Map.gold_crate_Taken );
	OnTrigger( "^2Allied team has secured the first Gold Crate!", Map.Gold_Dropoff_Captured );
	OnTrigger( "^2Allied team has secured the second Gold Crate!", Map.Gold_Dropoff_Captured );
	OnTrigger( "^2Allied team is escaping with the Gold Crates!", Map.allies_taking_gold );//truck is leaving?

	//Truck Barriers
	OnTrigger( "^2Truck Barrier #1 has been constructed.", Map.Truck_Barrier_1_Built );
	OnTrigger( "^2Truck Barrier #1 has been destroyed.", Map.Truck_Barrier_1_Destroyed );    
	OnTrigger( "goldrush_allies_truck_barrier1", Map.truck_past_barrier1 );
	OnTrigger( "^2Truck Barrier #2 has been constructed.", Map.Truck_Barrier_2_Built );     
	OnTrigger( "^2Truck Barrier #2 has been destroyed.", Map.Truck_Barrier_2_Destroyed );
	OnTrigger( "goldrush_allies_truck_barrier2", Map.truck_past_barrier2 );
                                
	//Generic CP
	OnTrigger( "^2Allied Command Post constructed. Charge speed increased!", Map.Allied_CP_Built );
	OnTrigger( "^2Axis team has destroyed the Allied Command Post!", Map.Allied_CP_Destroyed );
	OnTrigger( "^2Axis Command Post constructed. Charge speed increased!", Map.Axis_CP_Built );
	OnTrigger( "^2Allied team has destroyed the Axis Command Post!", Map.Axis_CP_Destroyed );

	//Tank
	OnTrigger( "^2The Tank has been repaired!", Map.Tank_Built );
	OnTrigger( "goldrush_allies_tank_stolen", Map.allies_steal_tank );//Allied team has stolen the Tank!
	OnTrigger( "^2The Tank has been damaged!", Map.Tank_Destroyed );

	//Tank Barriers
    OnTrigger( "^2Allied team has destroyed Road Blockade", Map.Tank_Destroyed_Blockade );//THIS IS DOUBLE    
    OnTrigger( "^2Allied team has destroyed the Tunnel Doors!", Map.Tank_Destroyed_Tunnel_Doors );    
    OnTrigger( "^2Allied team has destroyed Road Blockade", Map.New_Prebuilt_Tank_Barrier_Destroyed );//THIS IS DOUBLE
	OnTrigger( "^2Tank Barrier #1 has been constructed.", Map.Tank_Barrier_1_Built );
	OnTrigger( "Planted at Tank Barrier #1.", Map.Tank_Barrier_1_Planted );

	OnTrigger( "^2Tank Barrier #1 has been destroyed.", Map.Tank_Barrier_1_Destroyed );
	OnTrigger( "goldrush_allies_tank_barrier1", Map.tank_past_barrier1 );

