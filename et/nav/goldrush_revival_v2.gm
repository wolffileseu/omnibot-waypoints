    battery_to_control_the_axis_airstrike_panel_Built = function( trigger )//TURN TANK BUILD OFF HAD TO GO HERE
	{

        SetAvailableMapGoals( TEAM.AXIS, false, "ATTACK_battery" );
            ClearGoalRole( "BUILD_battery_that_controls_the_Axis_airstrike_panel", ROLE.DEFENDER );
            SetAvailableMapGoals( TEAM.ALLIES, false, "ATTACK_battery" );
            SetAvailableMapGoals( TEAM.ALLIES, false, "ATTACK_door" );
            SetAvailableMapGoals( TEAM.ALLIES, false, "BUILD_tank" ); //THIS MUST BE HERE TO PROTECT AGAINST THE GLITCH IN THE MAP
            SetAvailableMapGoals( TEAM.AXIS, true, "AIRSTRIKE_rDepot.*" );
            SetAvailableMapGoals( TEAM.AXIS, false, "DEFEND_door" );
            Map.Switches.axisbegining.Enabled = true;
            Map.SwitchesaxisbeginingEnabled = true;
            Map.controlpanelbuilt = true; 
            SetGoalPriority( "DEFEND_door", 0.0);
            SetGoalPriority( "SWITCH_axisbegining", 5.99);
            ClearGoalRole( "DEFEND_door", ROLE.DEFENDER1 );
            //SetGoalRole( "SWITCH_axisbegining", ROLE.DEFENDER2 );
            //ClearGoalRole( "CAMP_switch", ROLE.DEFENDER2 );
            SetAvailableMapGoals( TEAM.AXIS, false, "CAMP_switch" );
            ClearGoalRole( "CAMP_switch", ROLE.DEFENDER1 );
            SetGoalRole( "SWITCH_axisbegining", ROLE.DEFENDER1 );     
            SetAvailableMapGoals( TEAM.AXIS, false, "BUILD_battery_that_controls_the_Axis_airstrike_panel" );                    
            SetAvailableMapGoals( TEAM.AXIS, true, "SWITCH_axisbegining" );
            SetAvailableMapGoals( TEAM.ALLIES, false, "SWITCH_axisbegining" );
            //Util.DisableGoal( "SWITCH_axisbegining", false );
            //Util.EnableGoal( "SWITCH_axisbegining", true );    
		    Util.MapDebugPrint( "^6BUILD_battery_that_controls_the_Axis_airstrike_panel_Built" );
	},

