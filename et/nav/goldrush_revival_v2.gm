	},

	allies_steal_tank = function( trigger )
	{
        SetAvailableMapGoals( TEAM.AXIS, false, "ATTACK_battery" );
                SetGoalPriority( "ARTILLERY_S_thehill_.*", 0.99, TEAM.AXIS );
            SetAvailableMapGoals( TEAM.AXIS, false, "DEFEND_door" );
             SetAvailableMapGoals( TEAM.ALLIES, false, "ATTACK_door" );                        
        SetAvailableMapGoals( TEAM.AXIS, true, "ARTILLERY_S_balcony2tunneldoors_.*" );
         SetAvailableMapGoals( TEAM.AXIS, true, "CALLARTILLERY_balcony2tunneldoors" ); 
                             SetAvailableMapGoals( TEAM.AXIS, true, "ARTILLERY_S_thehill_.*" );           
        SetGoalPriority( "ARTILLERY_S_balcony2tunneldoors_.*", 0.99, TEAM.AXIS );
        SetGoalPriority( "CALLARTILLERY_balcony2tunneldoors", 0.99, TEAM.AXIS );   
        //Util.DisableGoal( "SWITCH_axisbegining", true );
        //SetAvailableMapGoals( TEAM.ALLIES, false, "SWITCH_axisbegining" );
                //SetAvailableMapGoals( TEAM.AXIS, false, "SWITCH_axisbegining" ); 
        //Map.Switches.axisbegining.Enabled = false;
        //Map.SwitchesaxisbeginingEnabled = false; 
        
        if (Map.newroute == true)
        {
                    SetAvailableMapGoals( TEAM.AXIS, false, "ARTILLERY_S_thehill_.*" );
        SetAvailableMapGoals( TEAM.ALLIES, false, "ARTILLERY_S_thehill_.*" );
        //SetAvailableMapGoals( TEAM.AXIS, true, "CALLARTILLERY_balcony2tunneldoors" );
                   		SetAvailableMapGoals( TEAM.ALLIES, false, "ATTACK_Tank_Barrier1_.*" );
                		SetAvailableMapGoals( TEAM.AXIS, false, "DEFEND_Tank_Barrier1_.*" );
		SetAvailableMapGoals( TEAM.ALLIES, false, {
			//"BUILD_North_Command_Post",
			"ATTACK_Tank_Barrier1_.*",
		});
                SetAvailableMapGoals( TEAM.AXIS, true, "DEFEND_newtunnel_.*" );
		Map.Airstrike.tankassist.Enabled = false;
        SetAvailableMapGoals( TEAM.AXIS, true, "CHECKPOINT_roadbunker" );
        SetAvailableMapGoals( TEAM.ALLIES, true, "CHECKPOINT_roadbunker" );
        SetAvailableMapGoals( TEAM.AXIS, false, "DEFEND_Tank_Barrier1_.*" );
        SetAvailableMapGoals( TEAM.AXIS, false, "TRIPMINE_Tank_Barrier1_.*" );
        SetAvailableMapGoals( TEAM.AXIS, false, "CAMP_rTbarrier1_.*" );
        SetAvailableMapGoals( TEAM.AXIS, false, "AIRSTRIKE_rTbarrier1_.*" );
         SetAvailableMapGoals( TEAM.AXIS, false, "BUILD_Tank_Barrier_1" );
        }
        else 
        {
                 		SetAvailableMapGoals( TEAM.ALLIES, true, "ATTACK_Tank_Barrier1_.*" );
                		SetAvailableMapGoals( TEAM.AXIS, true, "DEFEND_Tank_Barrier1_.*" );
		SetAvailableMapGoals( TEAM.ALLIES, true, {
			//"BUILD_North_Command_Post",
			"ATTACK_Tank_Barrier1_.*",
			"ESCORT_tank",
		});
		Map.Airstrike.tankassist.Enabled = false;
        SetAvailableMapGoals( TEAM.AXIS, true, "DEFEND_Tank_Barrier1_.*" );
        SetAvailableMapGoals( TEAM.AXIS, true, "TRIPMINE_Tank_Barrier1_.*" );
        SetAvailableMapGoals( TEAM.AXIS, true, "CAMP_rTbarrier1_.*" );
        SetAvailableMapGoals( TEAM.AXIS, true, "AIRSTRIKE_rTbarrier1_.*" ); 
          SetAvailableMapGoals( TEAM.AXIS, true, "BUILD_Tank_Barrier_1" ); 
        }
        SetAvailableMapGoals( TEAM.AXIS, true, "ARTILLERY_S_balcony2tunneldoors_1" );
        SetAvailableMapGoals( TEAM.AXIS, true, "ARTILLERY_S_balcony2tunneldoors_2" );
        SetAvailableMapGoals( TEAM.AXIS, true, "ARTILLERY_S_balcony2tunneldoors_3" );
        SetAvailableMapGoals( TEAM.AXIS, true, "ARTILLERY_S_balcony2tunneldoors_4" );
        SetAvailableMapGoals( TEAM.AXIS, true, "CALLARTILLERY_balcony2tunneldoors" );        
                Util.DisableGoal( "SWITCH_axisbegining", true );
		// Allied goals
		SetAvailableMapGoals( TEAM.ALLIES, false, "ATTACK_Depot_.*" );
                     SetAvailableMapGoals( TEAM.ALLIES, false, "ATTACK_battery" );
                      SetAvailableMapGoals( TEAM.AXIS, false, "CALLARTILLERY_depot" );
                                
                 ClearGoalRole( "DEFEND_tankarea", ROLE.DEFENDER2 );
                             SetAvailableMapGoals( TEAM.AXIS, false, "DEFEND_tankarea" );   
        	Util.SetMaxUsers( 1, "DEFEND_tankarea" );
         SetGoalPriority( "DEFEND_tankarea", 0.0);
                 SetAvailableMapGoals( TEAM.AXIS, false, "ARTILLERY_S_depottank_.*" );
         SetAvailableMapGoals( TEAM.AXIS, false, "CALLARTILLERY_depotagain" );               
        SetGoalPriority( "ARTILLERY_S_depottank_.*", 0.0, TEAM.AXIS );
        SetGoalPriority( "CALLARTILLERY_depotagain", 0.0, TEAM.AXIS );
		// Axis goals
        
        		//Map.Airstrike.tankassist.Enabled = false;
        //SetAvailableMapGoals( TEAM.ALLIES, false, "DEFEND_Tank_Barrier1_.*" );
        //SetAvailableMapGoals( TEAM.AXIS, false, "TRIPMINE_Tank_Barrier1_.*" );
        //SetAvailableMapGoals( TEAM.ALLIES, false, "CAMP_rTbarrier1_.*" );
        //SetAvailableMapGoals( TEAM.AXIS, false, "AIRSTRIKE_rTbarrier1_.*" );

		//SetGoalPriority( "BUILD_North_Command_Post", 0.5, TEAM.AXIS);
		SetAvailableMapGoals( TEAM.AXIS, false, {
			"DEFEND_Depot_.*",
			"AIRSTRIKE_rDepot.*",
			"PLANTMINE_rTank.*",
			"TRIPMINE_Depot_.*",
		});
                        
                        
                        
                        SetAvailableMapGoals( TEAM.AXIS, false, "CAMP_switch" );
                        SetAvailableMapGoals( TEAM.AXIS, false, "SWITCH_axisbegining" ); 
                        ClearGoalRole( "SWITCH_axisbegining", ROLE.DEFENDER1 );
                        ClearGoalRole( "CAMP_switch", ROLE.DEFENDER1 );
                        ClearGoalRole( "PLANTMINE_rTank.*", ROLE.ROAMER );
   SetGoalPriority( "CAMP_switch", 0.0);
 SetGoalPriority( "SWITCH_axisbegining", 0.0);
 SetGoalPriority( "BUILD_battery_that_controls_the_Axis_airstrike_panel", 0.0);     
    SetAvailableMapGoals( TEAM.AXIS, false, "BUILD_battery_that_controls_the_Axis_airstrike_panel" );                    
ClearGoalRole( "SWITCH_axisbegining", ROLE.DEFENDER2 );
            SetAvailableMapGoals( TEAM.ALLIES, false, "SWITCH_axisbegining" );
    Util.DisableGoal( "SWITCH_axisbegining", true );
    Util.EnableGoal( "SWITCH_axisbegining", false );                          
		// use build offsets instead of forced routing
		Util.ForceRouting( "BUILD_Tank", false );
//Util.BotChat( 0, "say", "^5ALLIES HAVE STOLEN THE TANK STOP THEM !!!!!!", 2 );
		Util.MapDebugPrint( "^6allies_steal_tank" );
