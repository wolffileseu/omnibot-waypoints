			"MOUNTMG42_mg42_bank",
			"DEFEND_Bank_.*",
			"REPAIRMG42_mg42_bank",
			"BUILD_Truck_Barrier_1",
			"PLANTMINE_rBank.*",
			"CALLARTILLERY_rBank1",
			"ARTILLERY_S_rBank1",
		});

        SetAvailableMapGoals( TEAM.AXIS, false, "AIRSTRIKE_barrier2axis_1" );//NEW
        SetAvailableMapGoals( TEAM.AXIS, true, "AIRSTRIKE_pastbarrier2axis_1" );//NEW
        SetAvailableMapGoals( TEAM.AXIS, false, "BUILD_Command_Post" );        
        //SetAvailableMapGoals( TEAM.AXIS, false, "DEFEND_Bank_Roam4" );
        SetAvailableMapGoals( TEAM.AXIS, false, "DEFEND_Tank_Barrier2_.*" );
        SetAvailableMapGoals( TEAM.AXIS, false, "TRIPMINE_Tank_Barrier2_.*" );
        //SetAvailableMapGoals( TEAM.AXIS, false, "DEFEND_Bank_[89]" );
        //SetAvailableMapGoals( TEAM.AXIS, false, "BUILD_Truck_Barrier_2" );
        
        
        //SetAvailableMapGoals( TEAM.AXIS, true, "DEFEND_Bank_Roam4" );
        SetAvailableMapGoals( TEAM.AXIS, true, "TRIPMINE_Bank.*" );
        //SetAvailableMapGoals( TEAM.AXIS, true, "DEFEND_Bank_[89]" );
        SetAvailableMapGoals( TEAM.AXIS, true, "MOUNTMG42_mg42_bank" );
        SetAvailableMapGoals( TEAM.AXIS, true, "BUILD_Truck_Barrier_1" );
        SetAvailableMapGoals( TEAM.AXIS, true, "BUILD_Truck_Barrier_2" );
		Util.ForceRouting( "BUILD_Tank", false );

		// routing isn't super reliable here, and we want allies avoiding south stairs
		Wp.SetWaypointFlag( "southstairs1", "axis", true );
		Wp.SetWaypointFlag( "southstairs3", "axis", true );

		Util.MapDebugPrint( "^6tank_past_barrier2" );
	},

	blow_doors = function( trigger )
	{
        
        if (Map.newroute == true)
        {
            	        SetAvailableMapGoals( TEAM.AXIS, false, "AIRSTRIKE_barrier2axis_1" );//NEW
    	SetAvailableMapGoals( TEAM.AXIS, false, {
            "AIRSTRIKE_bBarrier2_1",
            "AIRSTRIKE_bBarrier2_2",
		});
        SetGoalPriority( "CALLARTILLERY_bank2spawn", 0.9, TEAM.AXIS );              	
        SetGoalPriority( "CALLARTILLERY_bank2b1", 0.9, TEAM.AXIS );
        SetGoalPriority( "ARTILLERY_D_bank2spawn_.*", 0.9, TEAM.AXIS );              	
        SetGoalPriority( "ARTILLERY_D_bank2b1_.*", 0.9, TEAM.AXIS );  
    SetAvailableMapGoals( TEAM.ALLIES, false, "CALLARTILLERY_bank2spawn" );     
        SetAvailableMapGoals( TEAM.AXIS, true, "CALLARTILLERY_bank2spawn" );
    SetAvailableMapGoals( TEAM.AXIS, true, "ARTILLERY_D_bank2spawn_.*" );
            SetAvailableMapGoals( TEAM.AXIS, true, "CALLARTILLERY_bank2b1" );
    SetAvailableMapGoals( TEAM.AXIS, true, "ARTILLERY_D_bank2b1_.*" );    
        }
       
		sleep( 2 ); //wait for waypoint connection to change from red to green
       SetAvailableMapGoals( TEAM.ALLIES, false, "BUILD_Tank" );
		// Allied goals
		SetAvailableMapGoals( TEAM.ALLIES, false, {
			"BUILD_Tank",
			"MOUNT_tank",
		});
		//SetGoalPriority( "BUILD_North_Command_Post", 0.5, TEAM.ALLIES );
		SetAvailableMapGoals( TEAM.ALLIES, true, {
			"BUILD_Truck",
			"FLAG_gold_crate",
			"CAPPOINT_Gold_Dropoff",
		});
         SetAvailableMapGoals( TEAM.AXIS, false, "TRIPMINE_Tank_Barrier2_.*" );       				//SetGoalPriority( "ROUTE_newtankpath_*.*", 0.00);
                //SetAvailableMapGoals( TEAM.ALLIES, false, "ROUTE_newtankpath_*.*" );
        	SetGoalPriority( "ESCORT_tank", 0.0, TEAM.ALLIES );
            SetAvailableMapGoals( TEAM.ALLIES, false, "ESCORT_tank" );
            SetAvailableMapGoals( TEAM.ALLIES, false, "BUILD_tank" );
        SetAvailableMapGoals( TEAM.AXIS, false, "AIRSTRIKE_barrier2axis_1" );//NEW
        SetAvailableMapGoals( TEAM.AXIS, false, "AIRSTRIKE_pastbarrier2axis_1" );//NEW
    SetAvailableMapGoals( TEAM.ALLIES, false, "CALLARTILLERY_bank2spawn" );     
        SetAvailableMapGoals( TEAM.AXIS, false, "CALLARTILLERY_bank2spawn" );
    SetAvailableMapGoals( TEAM.AXIS, false, "ARTILLERY_D_bank2spawn_.*" );
            SetAvailableMapGoals( TEAM.AXIS, true, "CALLARTILLERY_bank2b1" );
    SetAvailableMapGoals( TEAM.AXIS, true, "ARTILLERY_D_bank2b1_.*" );        
        
        
		// Axis goals
		SetAvailableMapGoals( TEAM.AXIS, false, {
			"MOUNTMG42_mg42_bridge",
			"REPAIRMG42_mg42_bridge",
			"MOUNT_tank_axis",
            "AIRSTRIKE_bBarrier2_1",
            "AIRSTRIKE_bBarrier2_2",
		});
        SetGoalPriority( "DEFEND_Bank_7", 0.90, TEAM.AXIS );
        SetGoalPriority( "DEFEND_Bank_Roam4", 0.90, TEAM.AXIS );
        SetGoalPriority( "TRIPMINE_Bank.*", 0.90, TEAM.AXIS );
        SetGoalPriority( "DEFEND_Bank_[89]", 0.90, TEAM.AXIS );
        Map.BankDoorsDestroyed = true;
        SetAvailableMapGoals( TEAM.AXIS, true, "DEFEND_Bank_Roam4" );
        SetAvailableMapGoals( TEAM.AXIS, true, "TRIPMINE_Bank.*" );
        SetAvailableMapGoals( TEAM.AXIS, true, "DEFEND_Bank_[89]" );
        SetAvailableMapGoals( TEAM.AXIS, true, "MOUNTMG42_mg42_bank" );
        SetAvailableMapGoals( TEAM.AXIS, true, "BUILD_Truck_Barrier_2" );        
        SetAvailableMapGoals( TEAM.AXIS, true, "BUILD_Truck_Barrier_1" );
        //SetGoalPriority( "BUILD_Truck_Barrier_2", 0.97, TEAM.AXIS );
        //SetGoalPriority( "BUILD_Truck_Barrier_1", 0.98, TEAM.AXIS );        
		// let allies use south stairs again
		Wp.SetWaypointFlag( "southstairs1", "axis", false );
		Wp.SetWaypointFlag( "southstairs3", "axis", false );

		// intrusion warning region triggers
		Map.iw1 = OnTriggerRegion( AABB(1480.742,-2466.167,-403.870,1605.773,-2403.699,-235.466), RegionTrigger.IntrusionWarning );
		Map.iw2 = OnTriggerRegion( AABB(1470.405,-2041.986,-359.106,1696.767,-1951.906,-206.108), RegionTrigger.IntrusionWarning );
		Map.iw3 = OnTriggerRegion( AABB(1854.647,-2344.672,-406.225,1942.472,-2162.907,-187.716), RegionTrigger.IntrusionWarning );

		Util.MapDebugPrint( "^6blow_doors" );
	},

	allies_taking_gold = function( trigger )//GOLD IS ALL CAPTURED?
	{
        		Util.ChangeSpawn( TEAM.ALLIES, 3, 4 );
		// Allied goals
		SetAvailableMapGoals( TEAM.ALLIES, true, {
			"REPAIRMG42_mg42_allied",
			"ESCORT_truck",
			"MOUNTMG42_mg42_allied",
			"ATTACK_Truck_Barrier1_.*",
			"PLANT_Truck_Barrier_1",
			"PLANT_Truck_Barrier_2",
		});
        SetAvailableMapGoals( TEAM.AXIS, true, "BUILD_Truck_Barrier_1" );
        SetAvailableMapGoals( TEAM.AXIS, true, "BUILD_Truck_Barrier_2" );
        SetAvailableMapGoals( TEAM.ALLIES, false, "BUILD_Tank" );       		
		SetAvailableMapGoals( TEAM.ALLIES, false, {
			"ATTACK_Bank_.*",
			"MOUNTMG42_mg42_bank",
		});
		SetGoalPriority( "BUILD_Truck", 0.9, TEAM.ALLIES );
        //SetGoalPriority( "DEFEND_Truck_Barrier1_.*", 0.79, TEAM.AXIS );
		// Axis goals
		SetAvailableMapGoals( TEAM.AXIS, true, {
			"MOUNTMG42_mg42_allied",
			"DEFEND_Truck_Barrier1_.*",
		});
		SetAvailableMapGoals( TEAM.AXIS, false, {
			"DEFEND_Bank_.*",
			"TRIPMINE_Bank.*",
			"MOUNTMG42_mg42_bank",
			"REPAIRMG42_mg42_bank",
			"PLANTMINE_rBank.*",
			"CALLARTILLERY_rBank1",
			"ARTILLERY_S_rBank1",
		});
             SetAvailableMapGoals( TEAM.ALLIES, false, "CALLARTILLERY_bank2b1" );    
        SetAvailableMapGoals( TEAM.AXIS, true, "CALLARTILLERY_bank2b1" );
    SetAvailableMapGoals( TEAM.AXIS, true, "ARTILLERY_D_bank2b1_.*" );
    
    SetAvailableMapGoals( TEAM.ALLIES, false, "CALLARTILLERY_bank2spawn" );     
        SetAvailableMapGoals( TEAM.AXIS, false, "CALLARTILLERY_bank2spawn" );
    SetAvailableMapGoals( TEAM.AXIS, false, "ARTILLERY_D_bank2spawn_.*" );
    
                        SetAvailableMapGoals( TEAM.AXIS, false, "DEFEND_Bank*.*" );
                        //SetGoalPriority( "DEFEND_Truck_Barrier1*.*", 0.99, TEAM.AXIS );
                                //SetGoalPriority( "DEFEND_Truck_Barrier2*.*", 0.98, TEAM.AXIS );
            SetAvailableMapGoals( TEAM.AXIS, true, "DEFEND_Truck_Barrier2*.*" );
            SetAvailableMapGoals( TEAM.AXIS, true, "DEFEND_Truck_Barrier1*.*" );
            //SetGoalPriority( "DEFEND_Truck_Barrier2*.*", 1.9, TEAM.AXIS );
             SetAvailableMapGoals( TEAM.ALLIES, false, "FLAG_gold_crate" );
              SetAvailableMapGoals( TEAM.ALLIES, false, "CAPPOINT_Gold_Dropoff" );
              SetAvailableMapGoals( TEAM.ALLIES, false, "ATTACK_Bank_.*" );
		DeleteTriggerRegion( Map.iw1 );
		DeleteTriggerRegion( Map.iw2 );
		DeleteTriggerRegion( Map.iw3 );
        Util.BotChat( 0, "say", "^5ALL GOLD HAS BEEN SECURED - STOP THE TRUCK NOW!!!!", 2 );
		Util.MapDebugPrint( "^6allies_taking_gold" );
	},

	truck_past_barrier1 = function( trigger )
	{
		Util.ChangeSpawn( TEAM.ALLIES, 3 );
                            SetGoalPriority( "BUILD_Truck_Barrier_2", 1.9, TEAM.AXIS );
