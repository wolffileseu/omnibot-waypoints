		PLANT_Allied_bunker_backdoor =
		{
		},
		PLANT_Allied_Basement_Access =
		{
		},
		PLANT_Allied_Wall =
		{
		},
		FLAG_axis_gold_crate =
		{
		},
		FLAG_allies_gold_crate =
		{
		},
	};
	Util.Routes(MapRoutes);
};
