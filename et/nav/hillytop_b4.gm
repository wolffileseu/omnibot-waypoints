global OnMapLoad = function()
{
	if ( TestMapOn )
		{ Util.AutoTestMap(); }

	// Register callback functions
	OnTrigger( "Allied MG nest constructed!", Map.Allied_MG_Built );
	OnTrigger( "Axis MG nest constructed!", Map.Axis_MG_Built );
	OnTrigger( "MISSING_STRING", Map.Command_Post_Built );
	OnTrigger( "Planted at the MISSING_STRING.", Map.Allied_Basement_Access_Planted );
	OnTrigger( "Planted at the MISSING_STRING.", Map.Allied_MG_Planted );
	OnTrigger( "Planted at the MISSING_STRING.", Map.Allied_Wall_Planted );
	OnTrigger( "Planted at the MISSING_STRING.", Map.Allied_bunker_backdoor_Planted );
	OnTrigger( "Planted at the MISSING_STRING.", Map.Axis_Basement_Access_Planted );
	OnTrigger( "Planted at the MISSING_STRING.", Map.Axis_Bunker_Backdoor_Planted );
	OnTrigger( "Planted at the MISSING_STRING.", Map.Axis_MG_Planted );
	OnTrigger( "Planted at the MISSING_STRING.", Map.Axis_Wall_Planted );
	OnTrigger( "Planted at the MISSING_STRING.", Map.Command_Post_Planted );
	OnTrigger( "Defused at the MISSING_STRING.", Map.Allied_Basement_Access_Defused );
	OnTrigger( "Defused at the MISSING_STRING.", Map.Allied_MG_Defused );
	OnTrigger( "Defused at the MISSING_STRING.", Map.Allied_Wall_Defused );
	OnTrigger( "Defused at the MISSING_STRING.", Map.Allied_bunker_backdoor_Defused );
	OnTrigger( "Defused at the MISSING_STRING.", Map.Axis_Basement_Access_Defused );
	OnTrigger( "Defused at the MISSING_STRING.", Map.Axis_Bunker_Backdoor_Defused );
	OnTrigger( "Defused at the MISSING_STRING.", Map.Axis_MG_Defused );
	OnTrigger( "Defused at the MISSING_STRING.", Map.Axis_Wall_Defused );
	OnTrigger( "Defused at the MISSING_STRING.", Map.Command_Post_Defused );
	OnTrigger( "Axis forces has breached through the basement walkway!", Map.Allied_Basement_Access_Destroyed );
	OnTrigger( "Axis team has destroyed the Allied MG nest!", Map.Allied_MG_Destroyed );
	OnTrigger( "Axis forces has broken into the Allied bunker!", Map.Allied_Wall_Destroyed );
	OnTrigger( "Axis forces has broken into the Allied bunker!", Map.Allied_Wall_New_Destroyed );
	OnTrigger( "Axis forces has breached the backdoor wall!", Map.Allied_bunker_backdoor_Destroyed );
	OnTrigger( "Allied forces has breached through the basement walkway!", Map.Axis_Basement_Access_Destroyed );
	OnTrigger( "Allied forces has breached the backdoor wall", Map.Axis_Bunker_Backdoor_Destroyed );
	OnTrigger( "Allied team has destroyed the Axis MG nest!", Map.Axis_MG_Destroyed );
	OnTrigger( "Allied forces has broken into the Axis bunker!", Map.Axis_Wall_Destroyed );
	OnTrigger( "Allied forces has broken into the Axis bunker!", Map.Axis_Wall_New_Destroyed );
	OnTrigger( "MISSING_STRING", Map.Command_Post_Destroyed );
	OnTrigger( "MISSING_STRING", Map.allies_gold_crate_Taken );
	OnTrigger( "MISSING_STRING", Map.axis_gold_crate_Taken );
	OnTrigger( "MISSING_STRING", Map.allies_gold_crate_Returned );
	OnTrigger( "MISSING_STRING", Map.axis_gold_crate_Returned );
	OnTrigger( "MISSING_STRING", Map.allies_gold_crate_Secured );
	OnTrigger( "MISSING_STRING", Map.axis_gold_crate_Secured );
	
	SetAvailableMapGoals( TEAM.AXIS, false, "MOUNTMG42_273" );
	SetAvailableMapGoals( TEAM.AXIS, false, "REPAIRMG42_273" );
	SetAvailableMapGoals( TEAM.ALLIES, false, "MOUNTMG42_273" );
	SetAvailableMapGoals( TEAM.ALLIES, false, "REPAIRMG42_273" );

	//~Util.DisableGoal( ".*", true ); // all but routes
	//~SetAvailableMapGoals( TEAM.AXIS, true, "ATTACK_.*" );
	//~SetAvailableMapGoals( TEAM.ALLIES, true, "ATTACK_.*" );

	// Max users per goal
	//Util.SetMaxUsers( 1, "DEFEND_.*" );
	//Util.SetMaxUsers( 1, "GRENADE_.*" );
	//Util.SetMaxUsers( 1, "MOUNTMG42_.*" );

	// Camp times
	SetMapGoalProperties( "MOUNTMG42_.*", {MinCampTime=15, MaxCampTime=90} );
	SetMapGoalProperties( "MOBILEMG42_.*", {MinCampTime=10, MaxCampTime=60} );


	Util.MapDebugPrint( "Omni-bot map script for " + GetMapName() + " executed." );
};

global OnBotJoin = function( bot )
{
	bot.TargetBreakableDist = 90.0;
	// Only set MaxViewDistance on maps with limited sight (e.g. fog)
	//~bot.MaxViewDistance = 2400;
};

