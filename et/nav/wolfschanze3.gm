			//Util.MapDebugPrint("^utunnelexit Soldier enter");
 		},
 		OnExit = function(ent)
 		{
                        if(GetEntTeam(ent) == TEAM.ALLIES )
            {
                if (GetEntFlags( ent, ENTFLAG.CARRYINGGOAL))
                {
                    b = Util.GetBotByName(GetEntName(ent));
                    if (b)
                    {
                        b.SayTeam("^2I stole Train Parts Number");                         
                    }
                foreach (id and bot in BotTable)
                {
                    if ( bot.GetTeam() == TEAM.AXIS )
                    {
                        bot.SayTeam("^2Do not Allow The Allies To Invade!");
                        break;
                    }
                }
                }
            }
            SetAvailableMapGoals( TEAM.AXIS, false, "DEFEND_dynowall_1" );  
    SetAvailableMapGoals( TEAM.AXIS, true, "DEFEND_dynowall_2" );//key to defense
    SetAvailableMapGoals( TEAM.AXIS, false, "DEFEND_dynowall_3" ); //key to defense 
            SetAvailableMapGoals( TEAM.AXIS, true, "DEFEND_ramppath_1" ); 
    SetAvailableMapGoals( TEAM.AXIS, false, "DEFEND_ramppath_2" );
    SetAvailableMapGoals( TEAM.AXIS, false, "DEFEND_ramppath_3" );
        //todo defend mineramp dynowall mountmg42bridgeguns
		Util.MapDebugPrint(GetEntTeam(ent) + "^utunnelexit TRIGGER Exit" );  		        
	},
    },

