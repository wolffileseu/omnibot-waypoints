    gatestop = function( trigger )//door status trigger - use for door with trigger string and use with path through switch navigation
	{  
    Map.gatestatusCounter += 1;

		if ( Map.gatestatusCounter == 0 || Map.gatestatusCounter >> 1 )//closed
		{ 
            Map.gatestatusCounter = 0;//gateisclosed
            Map.gateClosed = true;
            SetAvailableMapGoals( TEAM.ALLIES, true, "SWITCH_traingate" );
            SetAvailableMapGoals( TEAM.AXIS, false, "SWITCH_traingate" );
            Util.MapDebugPrint( "^elabdoor_1 TUCKER switch ALLIES" );			
			//Util.MapDebugPrint( "^eOPENING CELEBRATE !!!!POW XLABS DOOR 1 IS OPENING CELEBRATE !!!! OPENING" );
			    Util.MapDebugPrint( "^eIS CLOSING CLOSING CLOSING = allies switch" );  //correct on what gate is doing
                Util.BotChat( 1, "say", "^6Bot Files Created By ^1C^2Y^3B^6E^5R^04^1W^2O^3L^6F ^3GATE IS CLOSING", 1 );          
		}
		else if (Map.gatestatusCounter == 1) //open
		{ 
            Map.gateClosed = false;
            SetAvailableMapGoals( TEAM.ALLIES, false, "SWITCH_traingate" );
            SetAvailableMapGoals( TEAM.AXIS, true, "SWITCH_traingate" );
            SetGoalPriority( "SWITCH_traingate", 3.99, TEAM.AXIS );
			    //Util.MapDebugPrint( "^1XLABS DOOR 1 IS CLOSING CLOSING CELEBRATE !!!!CLOSING" );
			Util.MapDebugPrint( "^eOPENING CELEBRATE !!!! OPENING CELEBRATE !!!! OPENING = axis switch" );    //correct on what gate is doing
            Util.BotChat( 1, "say", "^6Bot Files Created By ^1C^2Y^3B^6E^5R^04^1W^2O^3L^6F ^3GATE IS OPENING", 1 );                	
			    Util.MapDebugPrint( "^13labdoor_1 switch enabled" );//being used
               
		}
            else
            {
            Util.MapDebugPrint( "^1STILL ALL FUCKED UP !!!!!" );//being used  
            }
	},

