global OnMapLoad = function()
{
	// Register callback functions
                      
	OnTrigger( "Allied Team have built the Ruin MG42 nest!!", Map.Allied_MG42_Construction_Built );
	OnTrigger( "MISSING_STRING", Map.Allied_MG42_Construction_1_Built );
    OnTrigger( "Axis have destroyed the Ruin MG42 Nest!!", Map.Allied_MG42_Construction_Destroyed );
	OnTrigger( "MISSING_STRING", Map.Allied_MG42_Construction_1_Destroyed );
	OnTrigger( "Allies have destroyed the left bridge-MG42!!", Map.Axis_MG42_Construction_Destroyed );
	OnTrigger( "Allies have destroyed the right bridge-MG42!!", Map.Axis_MG42_Construction_1_Destroyed );
	OnTrigger( "Axis Team have built the right bridge-MG42!!", Map.Axis_MG42_Construction_Built );
	OnTrigger( "Axis Team have built the left bridge-MG42!!", Map.Axis_MG42_Construction_1_Built );   
