global OnMapLoad = function()
{
	// Various syntax coloration tests
	Blackboard.MakeKey();
	Wp.IsWaypointViewOn();
	ETUtil.BuildVehiclePath();
	Util.FixMoverPos();
	Util.ExcludeClass();
	Util.EnableGoal();
	TEAM;
	TEAM.AXIS;
	AXIS;
	System.NewLine;
	Zero;
	ZoomButton;

	b = AABB();
	v = b.CenterPoint();

	Map.Test();

	Util.MapDebugPrint( "", true );
};

